// ================== MODAL: EXTEND ==================
function openExtend(id) {
    const rec = BONUSTIME_CACHE[id];
    if (!rec) return;

    const dlg = document.getElementById("btExtendModal");
    const plansBox = document.getElementById("btExtendPlans");
    const includeLotto = !!rec.LOTTO_ENABLED;

    document.getElementById("btExtendId").value = id;
    document.getElementById("btExtendIncludeLotto").value =
    includeLotto ? "1" : "0";
    document.getElementById("btExtendTenantLabel").textContent =
    `Service: ${rec.tenantId || "-"}`;

    const plans = includeLotto ? PLANS_LOTTO : PLANS_NORMAL;
    plansBox.innerHTML = "";

    plans.forEach((p, idx) => {
    const row = document.createElement("label");
    row.className = "bt-plan";

    row.innerHTML = `
        <div class="bt-plan-main">
        <div class="bt-plan-label">
            <input type="radio" name="btPlan" value="${p.days}" ${
        idx === 0 ? "checked" : ""
    }>
            ${p.label}
        </div>
        <div class="bt-plan-discount">ส่วนลด ${p.discount}</div>
        </div>
        <div class="bt-plan-price">฿${p.price.toLocaleString()}</div>
    `;

    plansBox.appendChild(row);
    });

    updateExtendSummary(); // สรุปครั้งแรก
    dlg.showModal();
}

function updateExtendSummary() {
    const radios = document.querySelectorAll("input[name='btPlan']");
    let selected = null;
    const includeLotto =
    document.getElementById("btExtendIncludeLotto").value === "1";
    const planSet = includeLotto ? PLANS_LOTTO : PLANS_NORMAL;

    radios.forEach((r) => {
    if (r.checked) {
        const days = Number(r.value);
        selected = planSet.find((p) => p.days === days);
    }
    });

    const sumEl = document.getElementById("btExtendSummary");
    const noteEl = document.getElementById("btExtendNote");

    if (!selected) {
    sumEl.textContent = "ยังไม่ได้เลือกแพ็กเกจ";
    noteEl.textContent = "";
    return;
    }

    sumEl.textContent = `${selected.label} — ฿${selected.price.toLocaleString()}`;
    noteEl.textContent = `ส่วนลด ${selected.discount}`;
}

document.addEventListener("change", (ev) => {
    if (ev.target && ev.target.name === "btPlan") {
    updateExtendSummary();
    }
});

async function submitBonustimeExtend() {
    const id = document.getElementById("btExtendId").value;
    const includeLotto =
    document.getElementById("btExtendIncludeLotto").value === "1";
    const plans = includeLotto ? PLANS_LOTTO : PLANS_NORMAL;

    const checked = document.querySelector("input[name='btPlan']:checked");
    if (!checked) {
        btNotify(
            'warn',
            'กรุณาเลือกแพ็กเกจ',
            'กรุณาเลือกแพ็กเกจที่ต้องการต่ออายุ'
        );
        return;
    }

    const days = Number(checked.value);
    const plan = plans.find((p) => p.days === days);

    const payload = {
    days: plan.days,
    includeLotto,
    };

    try {
    const res = await fetch(`/bonustime/${id}/extend`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
    });
    const data = await res.json();

    if (data.ok) {
        const msg = data.plan && data.plan.price
            ? `ต่ออายุการใช้งานสำเร็จ — แพ็กเกจ ${data.plan.label} ราคา ฿${data.plan.price.toLocaleString()}`
            : 'ต่ออายุการใช้งานสำเร็จ';

        btNotify('success', 'ต่ออายุสำเร็จ', msg);
        document.getElementById("btExtendModal").close();
        loadBonustimeHistory();
    } else {
        btNotify('error', 'ต่ออายุไม่สำเร็จ', data.message || 'ไม่สามารถต่ออายุได้');
    }
    } catch (err) {
    console.error(err);
        btNotify('error', 'ต่ออายุไม่สำเร็จ', 'เกิดข้อผิดพลาดในการต่ออายุ');
    }
}

async function upgradeLotto(id) {
  const rec = BONUSTIME_CACHE[id];
  if (!rec) return;

  if (rec.LOTTO_ENABLED) {
    btNotify('info', 'อัปเกรดไม่ได้', 'แพ็กเกจนี้เปิดใช้งานหวยอยู่แล้ว');
    return;
  }

  const price = 1000;
  const msg = `คุณต้องการอัปเกรดแพ็กเกจนี้ให้รองรับหวยในราคา ฿${price.toLocaleString()} ใช่หรือไม่?`;

  const ok = await btConfirm(msg);
  if (!ok) return;

  try {
    const res = await fetch(`/bonustime/${id}/upgrade-lotto`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ price }), // ฝั่ง server จะไม่เชื่อ price ฝั่ง client อยู่แล้ว
    });

    const data = await res.json();

    if (!data.ok) {
      btNotify('error', 'อัปเกรดไม่สำเร็จ', data.message || 'ไม่สามารถอัปเกรดแพ็กเกจนี้ได้');
      return;
    }

    btNotify(
      'success',
      'อัปเกรดสำเร็จ',
      'ระบบได้เปิดใช้งานหวยให้แพ็กเกจนี้แล้ว'
    );

    // reload history เพื่อให้ปุ่มอัปเกรดหาย และสถานะ LOTTO_ENABLED เป็น 'เปิด'
    loadBonustimeHistory();
  } catch (err) {
    console.error(err);
    btNotify(
      'error',
      'อัปเกรดไม่สำเร็จ',
      'เกิดข้อผิดพลาดในการอัปเกรดแพ็กเกจ'
    );
  }
}

