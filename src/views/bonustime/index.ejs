// RAILWAY
let currentDeploymentId = null;
let logInterval = null;

async function openServerMonitor(tenantId) {
    const modal = document.getElementById('railwayMonitorModal');
    const logBox = document.getElementById('logContainer');
    document.getElementById('monitorTitle').textContent = `Report: ${tenantId}`;
    
    modal.showModal();
    logBox.innerHTML = "กำลังดึงข้อมูล Service...";

    try {
        const res = await fetch(`/railway/service-info/${tenantId}`); 
        const info = await res.json();

        if (info.deploymentId) {
            currentDeploymentId = info.deploymentId;
            fetchLogs();
            // สั่ง Refresh Log ทุก 5 วินาที
            if(logInterval) clearInterval(logInterval);
            logInterval = setInterval(fetchLogs, 5000);
        } else {
            logBox.innerHTML = "ไม่พบข้อมูลการ Deploy ของเซิร์ฟเวอร์นี้";
        }
    } catch (err) {
        logBox.innerHTML = "เกิดข้อผิดพลาดในการเชื่อมต่อ Railway API";
    }
}

async function fetchLogs() {
    if (!currentDeploymentId) return;
    try {
        // ต้องเปลี่ยน Path ให้ตรงกับที่ประกาศใน bonustime.js
        const res = await fetch(`/railway/logs/deploy/${currentDeploymentId}`);
        const data = await res.json();
        const logs = data.logs; // ใน backend คุณส่งกลับเป็น { ok: true, logs: [...] }
        
        const logBox = document.getElementById('logContainer');
        logBox.innerHTML = logs.map(l => `
            <div style="margin-bottom: 4px;">
                <span style="color: #6b7280;">[${new Date(l.timestamp).toLocaleTimeString()}]</span> 
                <span>${l.message}</span>
            </div>
        `).join('') || "ไม่มี Log ในขณะนี้";
        
        logBox.scrollTop = logBox.scrollHeight;
    } catch (e) { console.error(e); }
}

async function confirmRestartServer(tenantId) {
    if(!confirm(`ยืนยันการ Restart Service: ${tenantId}?`)) return;

    try {
        const infoRes = await fetch(`/railway/service-info/${tenantId}`);
        const info = await infoRes.json();
        if(!info.serviceId) return alert("ไม่พบข้อมูล Service ID");

        // เปลี่ยน Path ตรงนี้ด้วย
        const res = await fetch('/railway/restart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ 
                serviceId: info.serviceId, 
                environmentId: info.environmentId 
            })
        });

        const result = await res.json();
        if(res.ok) {
            alert("สั่ง Restart เรียบร้อย! กรุณารอระบบ Rebuild ประมาณ 1-2 นาที");
        } else {
            alert("Error: " + result.error);
        }
    } catch (err) {
        alert("เชื่อมต่อล้มเหลว: " + err.message);
    }
}

function switchLogTab(type) {
    const tabs = document.querySelectorAll('#railwayMonitorModal .bt-tab');
    tabs.forEach(t => t.classList.remove('active'));
    
    // ไฮไลท์แท็บที่เลือก
    event.currentTarget.classList.add('active');

    const logBox = document.getElementById('logContainer');
    if (type === 'deploy') {
        logBox.innerHTML = "กำลังโหลด Deploy Logs...";
        fetchLogs(); // เรียกฟังก์ชันเดิมที่เราเขียนไว้
    } else {
        logBox.innerHTML = "HTTP Logs ยังไม่รองรับในขณะนี้";
    }
}

// ล้าง Interval เมื่อปิด Modal
document.getElementById('railwayMonitorModal').addEventListener('close', () => {
    clearInterval(logInterval);
});
</script>

