<script>
(function(){
  const KEY = 'bt_notice_suppress_until_v1'; // localStorage key
  const modal = document.getElementById('btNoticeModal');
  const chk = document.getElementById('btNoticeDontShow');
  const btnClose = document.getElementById('btNoticeClose');

  function shouldShow(){
    try {
      const v = localStorage.getItem(KEY);
      if (!v) return true;
      const ts = Number(v);
      if (!Number.isFinite(ts)) return true;
      return Date.now() > ts; // show if now past expiry
    } catch(e){
      return true;
    }
  }

  function setSuppressFor1Day(){
    const until = Date.now() + 1 * 24 * 60 * 60 * 1000;
    try { localStorage.setItem(KEY, String(until)); } catch(e){ /* ignore */ }
  }

  // show modal on DOM ready if needed
  document.addEventListener('DOMContentLoaded', ()=>{
    try {
      if (shouldShow()) {
        // wait a tick so dialog styles/backdrop applied nicely
        setTimeout(()=> {
          if (!modal.open) modal.showModal();
        }, 120);
      }
    } catch(e){}
  });

  btnClose?.addEventListener('click', ()=>{
    if (chk && chk.checked) setSuppressFor1Day();
    try { if (modal.open) modal.close(); } catch(e){}
  });

  // allow Escape/cancel to close as well but don't set suppression
  modal?.addEventListener('cancel', (ev)=> {
    ev.preventDefault();
    try { modal.close(); } catch(e){}
  });

  // 👇 เพิ่มบล็อกนี้
  const helpLink = document.getElementById("btNoticeHelpLink");
  helpLink?.addEventListener("click", () => {
    // ถ้าเช็ก "ไม่แสดงอีกในวันนี้" ก็ให้จำไว้เหมือนกดปุ่มปิด
    if (chk && chk.checked) setSuppressFor1Day();

    // ปิด modal ทันที
    try {
      if (modal.open) modal.close();
    } catch (e) {}

    // สลับไปแท็บ "ช่วยเหลือ"
    const helpTabBtn = document.querySelector('.bt-tab[data-tab="helpers"]');
    if (helpTabBtn) {
      helpTabBtn.click();
    }
  });
})();
</script>

<script>
// ================== GLOBAL NOTIFY HELPER ==================
function btNotify(variant, title, text) {
  // 1) ถ้ามีฟังก์ชัน notify ที่คุณประกาศใน layout
  if (typeof window.notify === 'function') {
    return window.notify({ variant, title, text });
  }
  // 2) ถ้ามีตัว wrapper แบบที่คุณแปะให้ดู (notify ใน scope ปัจจุบัน)
  if (typeof notify === 'function') {
    return notify({ variant, title, text });
  }
  // 3) ถ้ามี showMsg (dialog) ก็ใช้ได้
  if (typeof window.showMsg === 'function') {
    return window.showMsg({ variant, title, text });
  }
  // 4) fallback สุดท้าย — alert ธรรมดา
  alert((title ? title + '\n' : '') + (text || ''));
}

let PENDING_EXTEND_TENANT = null;

// ================== CONFIRM HELPER (ใช้ uiConfirm ถ้ามี) ==================
async function btConfirm(message) {
  // ถ้ามี uiConfirm (การ์ดสวย ๆ) ให้ใช้
  if (window.uiConfirm) {
    return await window.uiConfirm({
      variant: "success",
      title: "ยืนยันอัปเกรดแพ็กเกจ",
      sub: message,
      okText: "อัปเกรดเลย",
      cancelText: "ยกเลิก",
      focus: "cancel",
    });
  }

  // ถ้าไม่มี uiConfirm (เช่น หน้าโหลดไม่ครบ) ใช้ confirm เดิม
  if (window.originalConfirm) {
    return window.originalConfirm(message);
  }
  return window.confirm(message);
}

// ================== CACHE + PLAN CONFIG ==================
const BONUSTIME_CACHE = {};

const PLANS_NORMAL = [ // สล็อต+บาคาร่า
    { days: 30,  price: 1500,  label: "1 เดือน",   discount: "0%" },
    { days: 90,  price: 4050,  label: "3 เดือน",  discount: "-10%" },
    { days: 180, price: 7200,  label: "6 เดือน",  discount: "-20%" },
    { days: 365, price: 12600, label: "12 เดือน", discount: "-30%" },
    { days: 730, price: 21600, label: "24 เดือน", discount: "-40%" },
];

const PLANS_LOTTO = [ // สล็อต+บาคาร่า+หวย
    { days: 30,  price: 2000,  label: "1 เดือน",   discount: "0%" },
    { days: 90,  price: 5400,  label: "3 เดือน",  discount: "-10%" },
    { days: 180, price: 9600,  label: "6 เดือน",  discount: "-20%" },
    { days: 365, price: 16800, label: "12 เดือน", discount: "-30%" },
    { days: 730, price: 28800, label: "24 เดือน", discount: "-40%" },
];

const UPGRADE_LOTTO_PRICE = 1000;

// ================== TABS ==================
const tabButtons = document.querySelectorAll(".bt-tab");
const panes = {
  order:   document.getElementById("tab-order"),
  history: document.getElementById("tab-history"),
  helpers: document.getElementById("helpers"),
};

if (tabButtons.length) {
  tabButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      // toggle active ปุ่ม
      tabButtons.forEach((x) => x.classList.remove("active"));
      btn.classList.add("active");

      // toggle pane ทั้งหมด
      Object.values(panes).forEach((pane) => {
        if (pane) pane.classList.remove("show");
      });

      const name = btn.dataset.tab;
      if (panes[name]) panes[name].classList.add("show");
    });
  });
}

// ================== HELPERS: วันหมดอายุ ==================
function calcExpiredDate(start, days) {
    if (!start || !days) return null;
    const [d, m, y] = start.split("/").map((v) => parseInt(v));
    if (!d || !m || !y) return null;
    const startDate = new Date(y - 543, m - 1, d);
    return new Date(startDate.getTime() + days * 24 * 60 * 60 * 1000);
}

function calcRemainDays(expiry) {
    if (!expiry) return 0;
    const now = new Date();
    const diff = expiry - now;
    return Math.max(0, Math.ceil(diff / (1000 * 60 * 60 * 24)));
}

// ================== CountDown นับถอยหลัง ==================
let BT_COUNTDOWN_TIMER = null;

function formatRemainFull(msDiff) {
  if (msDiff <= 0) return null;

  const totalSec = Math.floor(msDiff / 1000);
  const days = Math.floor(totalSec / 86400);
  const hours = Math.floor((totalSec % 86400) / 3600);
  const mins = Math.floor((totalSec % 3600) / 60);

  if (days > 0) {
    return `อีก ${days} วัน ${hours} ชม. ${mins} นาที`;
  }
  if (hours > 0) {
    return `อีก ${hours} ชม. ${mins} นาที`;
  }
  return `อีก ${mins} นาที`;
}

function applyCountdownColor(el, daysLeft) {
  el.classList.remove(
    "bt-countdown-pill--safe",
    "bt-countdown-pill--warn15",
    "bt-countdown-pill--warn7",
    "bt-countdown-pill--warn3"
  );

  if (daysLeft < 3) {
    el.classList.add("bt-countdown-pill--warn3");
  } else if (daysLeft < 7) {
    el.classList.add("bt-countdown-pill--warn7");
  } else if (daysLeft < 15) {
    el.classList.add("bt-countdown-pill--warn15");
  } else {
    el.classList.add("bt-countdown-pill--safe");
  }
}

function initBonustimeCountdowns() {
  const nodes = document.querySelectorAll(".bt-countdown-pill[data-expiry]");
  if (!nodes.length) {
    if (BT_COUNTDOWN_TIMER) {
      clearInterval(BT_COUNTDOWN_TIMER);
      BT_COUNTDOWN_TIMER = null;
    }
    return;
  }

  function tick() {
    const now = Date.now();
    nodes.forEach((el) => {
      const iso = el.dataset.expiry;
      if (!iso) return;
      const exp = new Date(iso).getTime();
      const diff = exp - now;

      if (diff <= 0) {
        // หมดอายุแล้ว ไม่ต้องแสดง countdown
        el.remove();
        return;
      }

      const label = formatRemainFull(diff);
      if (!label) return;

      el.textContent = label;

      // แปลงเป็นวันเพื่อเลือกสี
      const daysLeft = Math.ceil(diff / (1000 * 60 * 60 * 24));
      applyCountdownColor(el, daysLeft);
    });
  }

  // อัปเดตทันที 1 รอบ
  tick();

  if (BT_COUNTDOWN_TIMER) clearInterval(BT_COUNTDOWN_TIMER);
  BT_COUNTDOWN_TIMER = setInterval(tick, 30000);
}

// ================== LOAD HISTORY ==================
// อ่านค่า ?extend= จาก URL ไว้ก่อน (เช่น /bonustime?extend=Server1)
(function readExtendFromQuery() {
  try {
    const params = new URLSearchParams(window.location.search);
    const ext = params.get("extend");
    if (ext) {
      PENDING_EXTEND_TENANT = String(ext).trim();
    }
  } catch (e) {
    console.warn("cannot parse extend query", e);
  }
})();

async function loadBonustimeHistory() {
    const box = document.getElementById("bonustimeHistory");
    if (!box) return;

    box.innerHTML = `<p class="muted">กำลังโหลดข้อมูล…</p>`;

    try {
    const res = await fetch("/bonustime/history");
    const data = await res.json();

    if (!data.ok || !Array.isArray(data.records) || !data.records.length) {
        box.innerHTML = `<p class="muted">ไม่มีประวัติการสั่งซื้อ</p>`;
        return;
    }

    box.innerHTML = "";
    data.records.forEach((rec) => {
        BONUSTIME_CACHE[rec._id] = rec;

        let statusText = "";
        let expiryDate = null;
        let remainDays = null;
        
        if (rec.LICENSE_DISABLED === true) {
          statusText = "ไม่มีวันหมดอายุ";
        } else {
          expiryDate = calcExpiredDate(
            rec.LICENSE_START_DATE,
            rec.LICENSE_DURATION_DAYS
          );
          if (expiryDate) {
            const now = new Date();
            const diff = expiryDate - now;
            remainDays = Math.ceil(diff / (1000 * 60 * 60 * 24));
          }

          if (!expiryDate || (remainDays !== null && remainDays <= 0)) {
            statusText = "หมดอายุแล้ว";
          } else {
            statusText = `เหลืออีก ${remainDays} วัน`;
          }
        }

        const lottoText = rec.LOTTO_ENABLED ? "เปิด" : "ปิด";
        // ถ้ายังไม่ได้เปิดหวย ให้เตรียมปุ่มอัปเกรดเพิ่ม
        const upgradeBtnHtml = !rec.LOTTO_ENABLED
          ? `<button class="bt-btn warn" onclick="upgradeLotto('${rec._id}')">
               อัปเกรดเพิ่มหวย +฿1,000
             </button>`
          : "";

        // ถ้า LICENSE_DISABLED เป็น true หรือไม่มีวันหมดอายุ -> ไม่แสดงปุ่มต่ออายุ
        const canExtend = rec.LICENSE_DISABLED !== true;
        const extendBtnHtml = canExtend
          ? `<button class="bt-btn primary" onclick="openExtend('${rec._id}')">
               ต่ออายุการใช้งาน
             </button>`
          : "";
        
        const updatedataAllowed = true;
        const updatedataBtnHtml = updatedataAllowed
            ? `
              <button class="bt-btn updatedata" onclick="openEdit('${rec._id}')">
                แก้ไขข้อมูล
              </button>
            `
            : "";

        // ถ้ายังไม่หมดอายุและมี expiryDate ให้สร้าง countdown pill
        const countdownHtml =
          expiryDate && remainDays > 0
            ? `<div class="bt-countdown-pill" data-expiry="${expiryDate.toISOString()}"></div>`
            : "";

        const el = document.createElement("section");
        el.className = "bonustime-card";

        el.innerHTML = `
        <div class="collapse-head">
            <div class="tenant-block">
              <div class="tenant">${rec.NAME || "-"}</div>
              <div class="tenant-hint muted small">กดขายเพื่อดูรายละเอียด Service</div>
            </div>
            <div class="bt-status-wrap">
              <div class="status-pill">${statusText}</div>
              ${countdownHtml}
            </div>
        </div>

        <div class="collapse-body">
            <div class="bt-grid">
            <div class="bt-label">Service</div>
            <div class="bt-value ellipsis" title="${rec.tenantId || ""}">
                ${rec.tenantId || "-"}
            </div>

            <div class="bt-label">Serial Key</div>
            <div class="bt-value ellipsis" title="${rec.serial_key || ""}">
                ${rec.serial_key || "-"}
            </div>

            <div class="bt-label">CHANNEL_ACCESS_TOKEN</div>
            <div class="bt-value ellipsis" title="${rec.CHANNEL_ACCESS_TOKEN || ""}">
                ${rec.CHANNEL_ACCESS_TOKEN || "-"}
            </div>

            <div class="bt-label">CHANNEL_SECRET</div>
            <div class="bt-value ellipsis" title="${rec.CHANNEL_SECRET || ""}">
                ${rec.CHANNEL_SECRET || "-"}
            </div>

            <div class="bt-label">โลโก้เว็บ</div>
            <div class="bt-value ellipsis" title="${rec.LOGO || ""}">
                ${rec.LOGO || "-"}
            </div>

            <div class="bt-label">ลิงก์เข้าสู่ระบบ</div>
            <div class="bt-value ellipsis" title="${rec.LOGIN_URL || ""}">
                ${rec.LOGIN_URL || "-"}
            </div>

            <div class="bt-label">ลิงก์สมัครสมาชิก</div>
            <div class="bt-value ellipsis" title="${rec.SIGNUP_URL || ""}">
                ${rec.SIGNUP_URL || "-"}
            </div>

            <div class="bt-label">ลิงก์ไลน์ติดต่อ</div>
            <div class="bt-value ellipsis" title="${rec.LINE_ADMIN || ""}">
                ${rec.LINE_ADMIN || "-"}
            </div>

            <div class="bt-label">เปิดใช้งานหวย</div>
            <div class="bt-value">${lottoText}</div>

            <div class="bt-label">เริ่มใช้งาน</div>
            <div class="bt-value">${rec.LICENSE_START_DATE || "-"}</div>

            <div class="bt-label">จำนวนวัน</div>
            <div class="bt-value">${rec.LICENSE_DURATION_DAYS ?? "-"}</div>

            <div class="bt-label">ลิงก์เชื่อมต่อ</div>
            <div class="bt-value link-row">
            <span class="link-text" title="${rec.LINK || ""}">
                ${rec.LINK || "-"}
            </span>
            ${
                rec.LINK
                ? `<button
                    type="button"
                    class="copy-link-btn"
                    data-link="${rec.LINK}"
                    onclick="copyLink(this)">
                    คัดลอก
                    </button>`
                : ""
            }
            </div>
            </div>

             <div class="bt-actions">
                ${extendBtnHtml}
                ${updatedataBtnHtml}
                ${upgradeBtnHtml}
                <button class="bt-btn primary" onclick="openServerMonitor('${rec.tenantId}')" style="background: linear-gradient(135deg, #6366f1, #a855f7); color: white !important;">
                    <i class="fa-solid fa-server"></i> ดูรายงาน Server
                </button>
                <button class="bt-btn warn" onclick="confirmRestartServer('${rec.tenantId}')">
                    <i class="fa-solid fa-rotate"></i> Restart
                </button>
            </div>
        </div>
        `;

        el.querySelector(".collapse-head").addEventListener("click", () => {
        el.classList.toggle("open");
        });

        box.appendChild(el);
    });

    initBonustimeCountdowns();

    // <<< เพิ่มบล็อกนี้หลังจากเติมการ์ดเสร็จ >>>
    if (PENDING_EXTEND_TENANT) {
      const targetId = Object.keys(BONUSTIME_CACHE).find((id) => {
        const r = BONUSTIME_CACHE[id];
        if (!r) return false;

        // เทียบได้ทั้ง tenantId และ _id เผื่ออนาคตเปลี่ยนใจใช้แบบอื่น
        return (
          (r.tenantId && String(r.tenantId) === PENDING_EXTEND_TENANT) ||
          String(id) === PENDING_EXTEND_TENANT
        );
      });

      if (targetId) {
        // สลับไปแท็บประวัติ
        const historyTab = document.querySelector('.bt-tab[data-tab="history"]');
        if (historyTab) historyTab.click();

        // เปิด Modal ต่ออายุ
        openExtend(targetId);
      }

      // เคลียร์ไม่ให้ยิงซ้ำใน reload ถัดไป
      PENDING_EXTEND_TENANT = null;
    }
    // <<< จบส่วนเพิ่ม >>>

    } catch (err) {
    console.error(err);
    box.innerHTML = `<p class="muted">โหลดข้อมูลไม่สำเร็จ</p>`;
    btNotify('error', 'โหลดประวัติไม่สำเร็จ', 'กรุณาลองใหม่อีกครั้ง');
    }
}

function copyLink(btn) {
  const url = btn.dataset.link || "";
  if (!url) return;

  navigator.clipboard?.writeText(url)
    .then(() => btNotify('success', 'คัดลอกลิงก์แล้ว', url))
    .catch(() => btNotify('error', 'คัดลอกไม่สำเร็จ', 'กรุณาลองใหม่อีกครั้ง'));
}

async function loadBonustimeProducts() {
  const normalCard = document.getElementById("pkg-normal");
  const lottoCard = document.getElementById("pkg-lotto");
  const normalCountEl = document.getElementById("pkg-normal-count");
  const lottoCountEl = document.getElementById("pkg-lotto-count");
  const normalBtn = document.getElementById("pkg-normal-btn");
  const lottoBtn = document.getElementById("pkg-lotto-btn");

  if (!normalCard || !lottoCard) return;

  normalCountEl.textContent = "กำลังโหลด…";
  lottoCountEl.textContent = "กำลังโหลด…";

  try {
    const res = await fetch("/bonustime/products");
    const data = await res.json();

    if (!data.ok) {
      normalCountEl.textContent = "โหลดไม่สำเร็จ";
      lottoCountEl.textContent = "โหลดไม่สำเร็จ";
      return;
    }

    const normalCount = data.packages?.normal?.count || 0;
    const lottoCount = data.packages?.lotto?.count || 0;

    // ปรับ UI แพ็กเกจ 1
    if (normalCount > 0) {
      normalCountEl.textContent = `คงเหลือ ${normalCount} รายการ`;
      normalCard.classList.remove("disabled");
      normalBtn.disabled = false;
    } else {
      normalCountEl.textContent = "สินค้าหมด";
      normalCard.classList.add("disabled");
      normalBtn.disabled = true;
    }

    // ปรับ UI แพ็กเกจ 2
    if (lottoCount > 0) {
      lottoCountEl.textContent = `คงเหลือ ${lottoCount} รายการ`;
      lottoCard.classList.remove("disabled");
      lottoBtn.disabled = false;
    } else {
      lottoCountEl.textContent = "สินค้าหมด";
      lottoCard.classList.add("disabled");
      lottoBtn.disabled = true;
    }
  } catch (err) {
    console.error(err);
    normalCountEl.textContent = "โหลดไม่สำเร็จ";
    lottoCountEl.textContent = "โหลดไม่สำเร็จ";
    btNotify('error', 'โหลดข้อมูลสินค้าไม่สำเร็จ', 'กรุณารีโหลดหน้าแล้วลองใหม่');
  }
}
// ================== SUBMIT ORDER ==================
async function submitBonustimeOrder() {
  const id = document.getElementById("btOrderId").value;
  const type = document.getElementById("btOrderType").value || "normal";

  const payload = {
    bonustimeId: id,
    packageType: type,
    NAME: document.getElementById("btOrderName").value.trim(),
    CHANNEL_ACCESS_TOKEN: document.getElementById("btOrderAccessToken").value.trim(),
    CHANNEL_SECRET: document.getElementById("btOrderSecret").value.trim(),
    LOGO: document.getElementById("btOrderLogo").value.trim(),
    LOGIN_URL: document.getElementById("btOrderLogin").value.trim(),
    SIGNUP_URL: document.getElementById("btOrderSignup").value.trim(),
    LINE_ADMIN: document.getElementById("btOrderLineAdmin").value.trim(),
  };

  // เช็กฟิลด์ว่างคร่าว ๆ
  if (!payload.CHANNEL_ACCESS_TOKEN || !payload.CHANNEL_SECRET || !payload.NAME) {
    btNotify(
        'warn',
        'กรุณากรอกข้อมูลให้ครบ',
        'กรุณากรอก CHANNEL_ACCESS_TOKEN และ CHANNEL_SECRET ให้ครบ'
    );
    return;
  }

  try {
    const res = await fetch("/bonustime/order", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });

    const data = await res.json();

    if (!data.ok) {
        btNotify(
            'error',
            'สั่งซื้อไม่สำเร็จ',
            data.message || 'เกิดข้อผิดพลาด โปรดลองใหม่'
        );
        console.warn('order error (ok=false):', data);
        return;
    }

    // สำเร็จ
    const label = data.plan?.label || "แพ็กเกจ Bonustime";
    const price = data.plan?.price
        ? `ราคา ฿${data.plan.price.toLocaleString()}`
        : "";
    btNotify(
        'success',
        'สั่งซื้อสำเร็จ',
        `${label} ${price}`
    );

    document.getElementById("btOrderModal").close();

    // รีโหลดสินค้า + ประวัติ
    loadBonustimeProducts();
    loadBonustimeHistory();

    // สลับไปแท็บ "ประวัติการสั่งซื้อ"
    const historyTab = document.querySelector('.bt-tab[data-tab="history"]');
    if (historyTab) historyTab.click();
  } catch (err) {
    console.error(err);
    btNotify(
        'error',
        'สั่งซื้อไม่สำเร็จ',
        'เกิดข้อผิดพลาดในการสั่งซื้อ โปรดลองใหม่อีกครั้ง'
    );
  }
}

// ================== TOGGLE PACKAGE DETAILS ==================
(function () {
  const cards = document.querySelectorAll(".bt-package");
  if (!cards.length) return;

  cards.forEach((card) => {
    card.addEventListener("click", (ev) => {
      // ถ้ากดปุ่มสั่งซื้อ ไม่ต้องเปิด/ปิดรายละเอียด
      if (ev.target.closest(".bt-btn")) return;

      const isOpen = card.classList.contains("open");

      // ปิดทุกการ์ดก่อน
      cards.forEach((c) => c.classList.remove("open"));

      // ถ้าการ์ดที่คลิกเดิม "ยังไม่เปิด" ให้เปิด
      // ถ้าเดิมเปิดอยู่แล้ว จะกลายเป็นปิด (ไม่ต้อง add open)
      if (!isOpen) {
        card.classList.add("open");
      }
    });
  });
})();

// ================== CHECK & SEND EXPIRY MAIL ==================
async function checkBonustimeExpiryMail() {
  try {
    const res = await fetch("/bonustime/check-expiry-mail", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "X-Requested-With": "XMLHttpRequest",
      },
    });

    const data = await res.json();

    if (!data.ok) {
      // ไม่ต้อง notify แรง เพราะ user อาจยังไม่มีอีเมล / serial ก็ได้
      console.warn("check-expiry-mail not ok:", data);
      return;
    }

    if (typeof data.sent === "number" && data.sent > 0) {
      btNotify(
        "success",
        "ส่งอีเมลแจ้งเตือนแล้ว",
        `ระบบได้ส่งอีเมลแจ้งเตือนการหมดอายุให้กับ Service ที่ใกล้หมดอายุ ${data.sent} รายการ`
      );
    }
  } catch (err) {
    console.error("checkBonustimeExpiryMail error", err);
    // เงียบไว้ก็ได้ จะได้ไม่รบกวน user
  }
}

