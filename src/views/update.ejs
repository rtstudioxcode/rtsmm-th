<% const PAGE_TITLE = title || "อัปเดตบริการ"; %>

<section class="page-head">
  <div class="page-title">
    <h1><%= PAGE_TITLE %></h1>
    <small class="muted">หน้าหลัก → <%= PAGE_TITLE %></small>
  </div>

  <div class="right-actions">
    <button id="btnRefresh" class="btn">รีเฟรช</button>
  </div>
</section>

<section class="card" id="updatesCard">
  <h3 class="title">รายการอัปเดต (วันล่าสุด)</h3>

  <!-- Desktop table -->
  <div class="upd-desktop">
    <div class="table-wrap">
      <table class="upd-table zebra">
        <thead>
          <tr>
            <th style="width:90px">ID</th>
            <th>ชื่อ</th>
            <th style="width:420px">สิ่งที่ได้รับการอัปเดต</th>
            <th style="width:180px">วันที่</th>
          </tr>
        </thead>
        <tbody id="updTbody"><!-- filled by JS --></tbody>
      </table>
    </div>
  </div>

  <!-- Mobile cards -->
  <div class="upd-mobile" id="upCards"><!-- filled by JS --></div>

  <div id="foot" class="muted" style="margin-top:10px;"></div>
</section>

<style>
:root{
  --surface: var(--elevated-bg, #141518);
  --border:  var(--elevated-border, #24262b);
  --muted:   var(--text-muted, #a7b0bb);
  --success: var(--success, #10b981);
  --danger:  var(--danger,  #ef4444);
  --accent:  var(--accent,  #2a84ff);
  --warning: var(--warn,    #f59e0b);
  --tbl-row:       #13161b;
  --tbl-row-alt:   #181c22;
  --tbl-hover:     #212633;
  --tbl-head-bg:   color-mix(in oklab,var(--surface) 92%, transparent);
}
html[data-theme="light"]{
  --surface:#fff; --border:#e5e7eb; --muted:#64748b;
  --tbl-row:#ffffff; --tbl-row-alt:#f3f4f6; --tbl-hover:#eef2f7;
  --tbl-head-bg:#f6f7fb;
}

/* ====== Table (Desktop) ====== */
.upd-table{ width:100%; border-collapse:separate; border-spacing:0; font-size:14px; }
.upd-table thead th{
  text-align:left; font-weight:400;
  padding:10px 12px; position:sticky; top:0;
  background:var(--tbl-head-bg);
  border-bottom:1px solid var(--border);
  z-index:2;
}
.upd-table td{ padding:12px; border-bottom:1px solid var(--border); vertical-align:top; transition:background .15s ease; }
.upd-table.zebra tbody tr:nth-child(odd)  td { background: var(--tbl-row); }
.upd-table.zebra tbody tr:nth-child(even) td { background: var(--tbl-row-alt); }
.upd-table.zebra tbody tr:hover td { background: var(--tbl-hover); }
.upd-table.zebra tbody tr:hover td:first-child { box-shadow: inset 3px 0 0 0 var(--accent); }

.id-mono{ font-family:ui-monospace,Menlo,Consolas,monospace; opacity:.9; }

/* ป้ายผลลัพธ์ */
.pill{ display:inline-flex; align-items:center; gap:.4rem; padding:6px 10px; border-radius:999px; font-weight:400; border:1px solid transparent; white-space:nowrap; }
.pill.ok{ background:color-mix(in oklab,var(--success) 35%, transparent); color:#0b2; }
.pill.danger{ background:color-mix(in oklab,var(--danger) 35%, transparent); }
.pill.info{ background:color-mix(in oklab,var(--accent) 22%, transparent); color:#fff; border-color:var(--accent) }
.pill.warn{ background:color-mix(in oklab,var(--warning) 35%, transparent); color:#222; }
.pill.neutral{ background:color-mix(in oklab,#94a3b8 30%, transparent); color:#111; }

.chip{
  display:inline-flex; align-items:center; gap:.35rem;
  padding:.25rem .5rem; font-size:12px; border-radius:999px;
  background:color-mix(in oklab,var(--accent) 18%, transparent);
  border:1px solid color-mix(in oklab,var(--accent) 40%, transparent);
  color:#fff; font-weight:400;
}

/* ไอคอนเล็กข้าง ID */
.dot{ width:8px; height:8px; border-radius:50%; display:inline-block; background:color-mix(in oklab,#9ca3af 75%, transparent); margin-right:8px; }

/* ====== Mobile cards ====== */
.upd-mobile{ display:none; }
@media (max-width: 900px){
  .upd-desktop{ display:none; }
  .upd-mobile{ display:grid; gap:10px; }
}

.u-card{
  border:1px solid var(--border); border-radius:12px;
  background:var(--surface); overflow:hidden; cursor:pointer;
  transition:box-shadow .15s ease, transform .06s ease;
  content-visibility:auto; contain-intrinsic-size:160px 320px;
}
.u-card:hover{ box-shadow:0 10px 24px rgba(0,0,0,.25); }
.u-card:active{ transform:translateY(1px) }

.u-head{
  display:grid; grid-template-columns: 1fr auto; gap:8px;
  padding:12px 14px; border-bottom:1px dashed var(--border);
}
.u-id{ font-family:ui-monospace,Menlo,Consolas,monospace; font-weight:400; }
.u-name{ font-weight:400; line-height:1.35; }
.u-meta{ color:var(--muted); font-size:12px; margin-top:4px; }

.u-body{ display:none; padding:12px 14px; }
.u-card.open .u-body{ display:block; }
.u-row{ display:grid; grid-template-columns:120px 1fr; gap:10px; padding:6px 0; border-bottom:1px dotted var(--border) }
.u-row:last-child{ border-bottom:0 }
.u-label{ color:var(--muted); font-weight:400; font-size:13px }

.name-badge{
  font-size:12px; font-weight:400; letter-spacing:.1px;
  color:color-mix(in oklab,var(--accent) 90%, #fff);
  margin-left:.5rem;
}

.svc-ico{
  width:22px;
  height:22px;
  object-fit:contain;
  border-radius:6px;
}
</style>

