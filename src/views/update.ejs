<% const PAGE_TITLE = title || "อัปเดตรายการบริการ"; %>

<section class="page-head">
  <div class="page-title">
    <h1><%= PAGE_TITLE %></h1>
    <small class="muted">หน้าหลัก → <%= PAGE_TITLE %></small>
  </div>
</section>

<section class="card" id="updatesCard">
  <h3 class="title">รายการอัปเดต (วันล่าสุด)</h3>

  <!-- Desktop table -->
  <div class="upd-desktop">
    <div class="table-wrap">
      <table class="upd-table">
        <thead>
          <tr>
            <th style="width:90px">ID</th>
            <th>ชื่อ</th>
            <th style="width:420px">สิ่งที่ได้รับการอัปเดต</th>
            <th style="width:180px">วันที่</th>
          </tr>
        </thead>
        <tbody id="updTbody">
          <!-- filled by JS -->
        </tbody>
      </table>
    </div>
  </div>

  <!-- Mobile cards -->
  <div class="upd-mobile" id="upCards">
    <!-- filled by JS -->
  </div>

  <div id="foot" class="muted" style="margin-top:10px;"></div>
</section>

<style>
  /* ====== Table (Desktop) ====== */
  .upd-table{ width:100%; border-collapse:collapse; font-size:14px; }
  .upd-table thead th{
    text-align:left; font-weight:700;
    padding:10px 12px; position:sticky; top:0;
    background:color-mix(in oklab,var(--surface) 92%, transparent);
    border-bottom:1px solid var(--border);
    z-index:1;
  }
  .upd-table td{ padding:12px; border-bottom:1px solid var(--border); vertical-align:top; }
  .id-mono{ font-family:ui-monospace,Menlo,Consolas,monospace; opacity:.9; }

  /* ป้ายผลลัพธ์ */
  .pill{ display:inline-flex; align-items:center; gap:.4rem; padding:6px 10px; border-radius:999px; font-weight:800; border:1px solid transparent; white-space:nowrap; }
  .pill.ok{ background:color-mix(in oklab,var(--success) 35%, transparent); color:#123; }
  .pill.danger{ background:color-mix(in oklab,var(--danger) 35%, transparent); }
  .pill.info{ background:color-mix(in oklab,var(--accent) 22%, transparent); color:#fff; border-color:var(--accent) }
  .pill.warn{ background:color-mix(in oklab,var(--warning) 35%, transparent); color:#222; }

  /* ไอคอนเล็กข้าง ID */
  .dot{ width:8px; height:8px; border-radius:50%; display:inline-block; background:color-mix(in oklab,#9ca3af 75%, transparent); margin-right:8px; }

  /* ====== Mobile cards ====== */
  .upd-mobile{ display:none; }
  @media (max-width: 900px){
    .upd-desktop{ display:none; }
    .upd-mobile{ display:grid; gap:10px; }
  }

  .u-card{
    border:1px solid var(--border); border-radius:12px;
    background:var(--surface); overflow:hidden; cursor:pointer;
    transition:box-shadow .15s ease, transform .06s ease;
    content-visibility: auto; contain-intrinsic-size: 160px 320px;
  }
  .u-card:active{ transform:translateY(1px) }

  .u-head{
    display:grid; grid-template-columns: 1fr auto; gap:8px;
    padding:12px 14px; border-bottom:1px dashed var(--border);
  }
  .u-id{ font-family:ui-monospace,Menlo,Consolas,monospace; font-weight:800; }
  .u-name{ font-weight:700; line-height:1.35; }
  .u-meta{ color:var(--muted); font-size:12px; margin-top:4px; }

  .u-body{ display:none; padding:12px 14px; }
  .u-card.open .u-body{ display:block; }
  .u-row{ display:grid; grid-template-columns:120px 1fr; gap:10px; padding:6px 0; border-bottom:1px dotted var(--border) }
  .u-row:last-child{ border-bottom:0 }
  .u-label{ color:var(--muted); font-weight:700; font-size:13px }

  /* คำว่า UPDATED ... ในชื่อ */
  .name-badge{
    font-size:12px; font-weight:900; letter-spacing:.1px;
    color:color-mix(in oklab,var(--accent) 90%, #fff);
    margin-left:.5rem;
  }
</style>

<script>
/* ========= helpers ========= */
const $ = s => document.querySelector(s);
const fmtDate = (d) => new Date(d).toLocaleDateString();
const fmtTime = (d) => new Date(d).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});

/* map ป้าย */
function buildPill(it){
  // diff: 'new' | 'open' | 'close' | 'removed' (ตามที่ routes/changes.js สร้าง)
  const isCat = it.target === 'category';
  if (it.diff === 'open')   return `<span class="pill ok">${isCat?'หมวดหมู่ - ':''}✔ เปิดใช้งาน</span>`;
  if (it.diff === 'close')  return `<span class="pill danger">${isCat?'หมวดหมู่ - ':''}✖ ปิดใช้งาน</span>`;
  if (it.diff === 'new')    return `<span class="pill info">ใหม่</span>`;
  if (it.diff === 'removed')return `<span class="pill warn">นำออก</span>`;
  // เผื่ออนาคต (เช่น ปรับราคา/เพดาน)
  return `<span class="pill info">${it.diff}</span>`;
}

/* ========= render desktop table ========= */
function renderTable(items){
  const tbody = $('#updTbody');
  const rows = items.map(it => {
    const id = (it.target === 'service') ? (it.providerServiceId || '') : (it.serviceGroupId || '');
    const name = (it.target === 'service') ? (it.serviceName || '(ไม่ทราบชื่อ)') : (it.categoryName || '(ไม่ทราบหมวด)');
    const pill = buildPill(it);
    return `
      <tr>
        <td class="id-mono"><span class="dot"></span>${id}</td>
        <td>
          <div style="font-weight:700">${name}
            ${it.target==='service' ? `<span class="name-badge">UPDATED ${fmtDate(it.ts)}</span>` : ``}
          </div>
          ${it.platform ? `<div class="muted" style="margin-top:2px">${it.platform}</div>` : ``}
        </td>
        <td>${pill}</td>
        <td class="muted">${fmtDate(it.ts)}, ${fmtTime(it.ts)}</td>
      </tr>
    `;
  }).join('');
  tbody.innerHTML = rows || `<tr><td colspan="4" class="muted">ไม่มีรายการของวันล่าสุด</td></tr>`;
}

/* ========= render mobile cards ========= */
function renderCards(items){
  const root = $('#upCards');
  root.innerHTML = items.map(it => {
    const id = (it.target === 'service') ? (it.providerServiceId || '') : (it.serviceGroupId || '');
    const name = (it.target === 'service') ? (it.serviceName || '(ไม่ทราบชื่อ)') : (it.categoryName || '(ไม่ทราบหมวด)');
    const pill = buildPill(it);
    return `
      <div class="u-card" data-key="${it._id || ''}">
        <div class="u-head">
          <div>
            <div class="u-id">#${id}</div>
            <div class="u-name">${name}
              ${it.target==='service' ? `<span class="name-badge">UPDATED ${fmtDate(it.ts)}</span>` : ``}
            </div>
            ${it.platform ? `<div class="u-meta">${it.platform}</div>` : ``}
          </div>
          <div style="align-self:center">${pill}</div>
        </div>
        <div class="u-body">
          <div class="u-row">
            <div class="u-label">สิ่งที่อัปเดต</div>
            <div>${pill}</div>
          </div>
          <div class="u-row">
            <div class="u-label">วันที่</div>
            <div>${fmtDate(it.ts)} ${fmtTime(it.ts)}</div>
          </div>
        </div>
      </div>
    `;
  }).join('');

  // กด “ตรงไหนก็ขยาย”
  root.addEventListener('click', e => {
    const card = e.target.closest('.u-card');
    if (!card) return;
    card.classList.toggle('open');
  }, { passive:true });
}

/* ========= load only latest day ========= */
async function loadLatest(){
  $('#foot').textContent = 'กำลังโหลด…';
  const res = await fetch('/api/changes?latest=1&limit=800');
  const data = await res.json();
  if (!data?.ok) {
    $('#foot').textContent = 'โหลดไม่สำเร็จ';
    return;
  }
  const items = Array.isArray(data.items) ? data.items : [];
  renderTable(items);
  renderCards(items);
  $('#foot').textContent = items.length ? '' : 'ไม่มีรายการของวันล่าสุด';
}

/* boot */
loadLatest();
</script>
