<!-- register.ejs -->
<% const title = "สมัครสมาชิก"; %>

<section class="auth-card">
  <div class="auth-head">
    <div class="auth-title">สมัครสมาชิก</div>
    <div class="auth-sub">สร้างบัญชีใหม่ของคุณ</div>
  </div>

  <% if (typeof error === 'string' && error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>

  <form id="registerForm" class="auth-form stack" action="/register" method="post" novalidate>
    <input type="hidden" name="next" value="<%= next %>">

    <!-- ชื่อผู้ใช้ -->
    <label class="f-field">
      <span class="f-label">ชื่อผู้ใช้</span>
      <input class="f-input" name="username" required autocomplete="username" placeholder="เช่น rtssm-th">
      <small class="f-hint">ใช้อักษร a–z, 0–9 และขีดกลางได้</small>
    </label>

    <!-- อีเมล -->
    <label class="f-field">
      <span class="f-label">อีเมล</span>
      <input class="f-input" type="email" name="email" required placeholder="you@email.com" autocomplete="email">
      <small class="f-hint">ใช้สำหรับยืนยันตัวตนและกู้รหัสผ่าน</small>
    </label>

    <!-- ชื่อจริง -->
    <label class="f-field">
      <span class="f-label">ชื่อ–นามสกุล</span>
      <span class="muted">(ชื่อ–นามสกุล ต้องตรงกับบัญชีที่ผูกด้วยไม่งั้นเวลาเติมเงินเครดิตจะไม่เข้าออโต้)</span>
      <input class="f-input" name="name" required autocomplete="name" placeholder="ชื่อจริง นามสกุล">
    </label>

    <!-- รหัสผ่าน + สวิตช์ แสดง/ซ่อน -->
    <label class="f-field">
      <span class="f-label">รหัสผ่าน</span>
      <div class="f-password">
        <input class="f-input" type="password" name="password" required autocomplete="new-password" minlength="6" placeholder="อย่างน้อย 6 ตัวอักษร" id="pwd">
        <button type="button" class="pwd-toggle" id="togglePwd" aria-pressed="false" aria-controls="pwd">
          <span class="knob" aria-hidden="true"></span>
          <span class="txt"><b>ซ่อน</b>รหัส</span>
        </button>
      </div>
    </label>

    <!-- ===== บัญชีธนาคาร/วอลเล็ท (บังคับกรอกอย่างน้อย 1, สูงสุด 2) ===== -->
    <div class="bank-accounts">
      <div class="f-label" style="margin-top:6px">บัญชีของฉัน (ธนาคารไทย/TrueMoney Wallet)</div>

      <template id="tplBankRow">
        <div class="bank-row" data-index="">
          <div class="bank-grid">
            <label class="f-field">
              <span class="muted" style="color: #cea32b;">ต้องเพิ่มอย่างน้อย 1 บัญชี (ต้องใช้สำหรับการฝากเงิน)</span>
              <select name="accountCode" class="f-input sel-bank" required>
                <option value="">— เลือกธนาคาร/วอลเล็ท —</option>
                <!-- รายชื่อจาก server (render) -->
                <% const BANKS = [
                  {code:'bbl',label:'ธนาคารกรุงเทพ'},
                  {code:'kbank',label:'ธนาคารกสิกรไทย'},
                  {code:'ktb',label:'ธนาคารกรุงไทย'},
                  {code:'bay',label:'ธนาคารกรุงศรีอยุธยา'},
                  {code:'scb',label:'ธนาคารไทยพาณิชย์'},
                  {code:'ttb',label:'ทหารไทยธนชาต (TTB)'},
                  {code:'cimbt',label:'ธนาคารซีไอเอ็มบีไทย'},
                  {code:'uobt',label:'ธนาคารยูโอบี'},
                  {code:'gsb',label:'ธนาคารออมสิน'},
                  {code:'baac',label:'ธ.เพื่อการเกษตรและสหกรณ์การเกษตร'},
                  {code:'kkp',label:'ธนาคารเกียรตินาคินภัทร'},
                  {code:'tw',label:'TrueMoney Wallet'}
                ]; %>
                <% BANKS.forEach(b=>{ %>
                  <option value="<%= b.code %>"><%= b.label %></option>
                <% }) %>
              </select>
              <small class="f-hint">แนะนำให้เพิ่ม True Wallet ไว้ 1 บัญชี</small>
            </label>

            <label class="f-field">
              <span class="f-label">เลขบัญชี / เบอร์วอลเล็ท</span>
              <input class="f-input in-number" name="accountNumber" placeholder="ตัวเลขเท่านั้น" inputmode="numeric" required>
              <small class="f-hint hint-number">ธนาคาร: 10-15 หลัก • TrueWallet: มือถือ 10 หลัก</small>
            </label>
          </div>

          <label class="f-field" style="margin-top:10px">
            <span class="f-label">ชื่อบัญชี</span>
            <span class="muted">(ข้อมูลบัญชีที่ผูก ต้องตรงกับชื่อ-นามสกุลด้วยไม่งั้นเวลาเติมเงินเครดิตจะไม่เข้าออโต้)</span>
            <input class="f-input" name="accountName" placeholder="ชื่อ–นามสกุลตามบัญชี" required>
          </label>

          <div class="flex" style="display:flex;gap:10px;justify-content:flex-end;margin-top:6px">
            <button class="pill" type="button" data-action="remove" aria-label="ลบบัญชีนี้">ลบรายการ</button>
          </div>

          <hr style="border:0;border-top:1px solid var(--border);margin:12px 0">
        </div>
      </template>

      <div id="bankList"></div>
      <div style="display:flex;gap:10px;justify-content:flex-end">
        <button class="pill" type="button" id="btnAddBank">+ เพิ่มบัญชีอีก 1 รายการ</button>
      </div>
    </div>

    <button class="block btn primary" type="submit" id="btnRegister">สมัคร</button>
    <div class="auth-foot">มีบัญชีอยู่แล้ว? <a href="/login">เข้าสู่ระบบ</a></div>
  </form>
</section>

<!-- Dialog แจ้งข้อความแบบการ์ด (HEAD แยกสีชัดเจน) -->
<dialog id="msgDialog" class="toast-modal" data-variant="info">
  <div class="toast-card" role="alertdialog" aria-labelledby="msgTitle" aria-describedby="msgText">
    
    <!-- แถบหัว (แยกส่วนจากตัวเนื้อหา) -->
    <div class="toast-headbar">
      <div class="toast-badge" id="msgBadge" aria-hidden="true">?</div>
      <div class="toast-headtxt">
        <h3 class="toast-title" id="msgTitle">หัวข้อ</h3>
        <!-- (ถ้าอยากซ่อนบรรทัดย่อยใต้หัวข้อ ก็ลบทิ้งได้) -->
      </div>
    </div>

    <!-- เนื้อหาข้อความ -->
    <div class="toast-body">
      <p class="toast-desc" id="msgText">รายละเอียดข้อความ</p>
    </div>

    <!-- ปุ่ม -->
    <div class="toast-actions">
      <button class="pill ghost" id="msgCancel" hidden>ยกเลิก</button>
      <button class="pill primary" id="msgClose">ตกลง</button>
    </div>
  </div>
</dialog>

<!-- Register Notice Modal -->
<dialog id="registerNoticeModal" class="toast-modal" aria-labelledby="regNoticeTitle" aria-describedby="regNoticeText">
  <div class="toast-card" role="alertdialog">
    <div class="toast-headbar" style="--th-bg: linear-gradient(135deg,#8b5cf6,#6d5dfc);">
      <div class="toast-badge" aria-hidden="true">⚠️</div>
      <div class="toast-headtxt">
        <h3 class="toast-title" id="regNoticeTitle">แจ้งเตือน</h3>
        <div class="muted" style="font-weight:600;font-size:13px">โปรดอ่านข้อมูลต่อไปนี้ก่อนสมัครสมาชิก</div>
      </div>
    </div>

    <div class="toast-body">
      <ul style="margin:0 0 0 18px; padding:10px 0; color:var(--t-muted); line-height:1.5">
        <li>ข้อมูลที่ใช้ต้องเป็นข้อมูลจริงตามกฏหมาย</li>
        <li>อีเมลต้องสามารถยืนยันได้จริง</li>
        <li>ชื่อ-นามสกุลต้องใช้ตามบัตรประชาชน</li>
        <li>บัญชีธนาคาร / TrueMoney Wallet ต้องเพิ่มอย่างน้อย 1 บัญชี (แนะนำ Wallet จะเร็วกว่า)</li>
        <li>ข้อมูลบัญชีต้องตรงกับชื่อนามสกุลเท่านั้น</li>
      </ul>

      <p style="margin-top:8px;color:var(--t-red-1);font-weight:700">
        คำเตือน: กรอกข้อมูลให้ครบตามความเป็นจริง เพราะมีผลทางกฎหมาย ระบบเติมเงินอัตโนมัติต้องการข้อมูลจริงในการเติมเครดิต
      </p>

      <label style="display:flex; gap:10px; align-items:center; margin-top:12px; color:var(--t-muted)">
        <input id="regNoticeDontShow" type="checkbox" style="width:18px; height:18px;"/>
        <span>ไม่แสดงอีก 7 วัน</span>
      </label>
    </div>

    <div class="toast-actions" style="padding-top:8px;">
      <button class="pill" id="regNoticeCloseCancel" hidden>ยกเลิก</button>
      <button class="pill primary" id="regNoticeClose">ปิดและยอมรับ</button>
    </div>
  </div>
</dialog>

<!-- Dialog OTP -->
<dialog id="otpDialog" class="rt-modal">
  <div class="rt-card" style="min-width:360px">
    <h3 class="rt-title">ยืนยันอีเมล</h3>
    <p class="rt-desc" id="otpHelp">เราได้ส่งรหัส 6 หลักไปที่อีเมลของคุณแล้ว</p>

    <label class="f-field">
      <span class="f-label">รหัส OTP</span>
      <input id="otpCode" class="f-input" inputmode="numeric" pattern="[0-9]*" maxlength="6" placeholder="______" style="letter-spacing:6px;text-align:center;font-weight:800">
    </label>

    <div class="muted" style="margin:6px 0 12px">
      <span id="otpTimer">ส่งใหม่ได้ใน 60s</span>
      • <button id="btnResend" class="link" disabled type="button">ส่งใหม่</button>
    </div>

    <div class="rt-actions" style="gap:8px">
      <button class="btn" id="btnCancelOtp" type="button">ยกเลิก</button>
      <button class="btn primary" id="btnVerifyOtp" type="button">ยืนยัน</button>
    </div>
  </div>
</dialog>

<style>
/* =========================================
   1) THEME TOKENS (Dark/Light)
   ใช้ทั้งหน้า: พื้นหลัง การ์ด ตัวอักษร ขอบ เงา
   ========================================= */
:root[data-theme="dark"]{
  --bg:#0b0e14; --card:#0f1117; --text:#e5e7eb; --muted:#9aa4b2; --border:#1f2937;
  --accent:#6d5dfc; --accent-2:#8b5cf6;
  --backdrop:rgba(0,0,0,.55); --shadow:0 24px 80px rgba(0,0,0,.55); --input-bg:#0b0e14;

  /* toast palette */
  --t-surface:#11141a; --t-surface-2:#151924; --t-text:#f4f6fb; --t-muted:#b6bfca;
  --t-border:#202938; --t-shadow:0 24px 80px rgba(0,0,0,.55); --t-backdrop:rgba(0,0,0,.55);
  --t-vlt-1:#a78bfa; --t-vlt-2:#8b5cf6; --t-grn-1:#34d399; --t-grn-2:#10b981;
  --t-warm-1:#f59e0b; --t-warm-2:#fbbf24; --t-red-1:#ef4444; --t-red-2:#fb7185;
}
:root[data-theme="light"]{
  --bg:#ffffff; --card:#ffffff; --text:#0f172a; --muted:#667085; --border:#e5e7eb;
  --accent:#6d5dfc; --accent-2:#9b8cff;
  --backdrop:rgba(2,8,23,.35); --shadow:0 30px 80px rgba(2,8,23,.15); --input-bg:#f9fafb;

  /* toast palette */
  --t-surface:#ffffff; --t-surface-2:#fffaf3; --t-text:#0f172a; --t-muted:#667085;
  --t-border:#efe7de; --t-shadow:0 24px 80px rgba(2,8,23,.12); --t-backdrop:rgba(2,8,23,.25);
  --t-vlt-1:#7c3aed; --t-vlt-2:#a78bfa; --t-grn-1:#10b981; --t-grn-2:#34d399;
  --t-warm-1:#f59e0b; --t-warm-2:#fbbf24; --t-red-1:#ef4444; --t-red-2:#fb7185;
}

/* =========================================
   2) AUTH LAYOUT + FORM
   ========================================= */
.auth-card{ padding-inline:clamp(16px,4vw,28px); }
.auth-card .auth-head{ margin:0 auto 18px; text-align:center; max-width:1100px; }
.auth-card .auth-form.stack{
  display:flex; flex-direction:column; gap:16px;
  width:calc(100% - clamp(16px,4vw,28px)*2); max-width:1100px; margin:0 auto;
}

/* fields */
.f-field{ display:flex; flex-direction:column; gap:6px; width:100% }
.f-label{ font-weight:800; color:var(--text); line-height:1.2 }
.f-hint{ color:var(--muted); font-size:12px; }
.f-input{
  width:100%; background:var(--input-bg); border:1px solid var(--border); color:var(--text);
  border-radius:14px; padding:14px 16px; outline:none; transition:border .15s, box-shadow .15s;
}
.f-input:focus{ border-color:var(--accent); box-shadow:0 0 0 3px color-mix(in srgb, var(--accent) 25%, transparent) }

/* password toggle (modern pill) */
.f-password{ position:relative; display:flex; align-items:center; }
.pwd-toggle{
  --sw:44px; --sh:28px;
  position:absolute; right:8px; height:var(--sh); min-width:calc(var(--sw) + 68px);
  padding:2px 10px 2px calc(var(--sw) + 10px);
  border-radius:999px; border:1px solid var(--border);
  background: color-mix(in srgb, var(--card) 92%, transparent); color:var(--text);
  font-weight:800; cursor:pointer; display:flex; align-items:center; gap:10px;
  transition: background .15s, border-color .15s;
}
.pwd-toggle .txt{ font-size:12px; opacity:.9 }
.pwd-toggle .txt b{ font-weight:900 }
.pwd-toggle .knob{
  position:absolute; left:6px; top:50%; transform:translateY(-50%);
  width:var(--sw); height:var(--sh); border-radius:999px;
  background:linear-gradient(180deg,var(--accent),var(--accent));
  box-shadow:0 6px 16px color-mix(in srgb, var(--accent) 35%, transparent);
}
.pwd-toggle[aria-pressed="true"]{ background:color-mix(in srgb, var(--accent) 14%, var(--card)); border-color:transparent }

/* buttons */
.btn{ border:1px solid transparent; border-radius:14px; padding:12px 16px; font-weight:800; }
.btn.primary{ background:linear-gradient(180deg,var(--accent),var(--accent)); color:#fff }
.btn.block{ width:100% }

/* =========================================
   3) <dialog> RESET / BACKDROP
   ========================================= */
dialog{ border:0; outline:0; padding:0; background:transparent; }
dialog::backdrop{ background:var(--backdrop); backdrop-filter: blur(8px) }

/* =========================================
   4) TOAST DIALOG (msgDialog)
   โครงสร้างที่ใช้: .toast-modal > .toast-card
                      ├─ .toast-headbar (badge + title)
                      ├─ .toast-body (.toast-desc)
                      └─ .toast-actions (ปุ่ม)
   ========================================= */

/* ตัว dialog */
.toast-modal{ border:0; outline:0; padding:0; background:transparent; }
.toast-modal::backdrop{ background:var(--t-backdrop); backdrop-filter: blur(10px) saturate(120%); }

/* สีหัวตามชนิดข้อความ */
.toast-modal[data-variant="info"]    { --th-bg: linear-gradient(135deg,#8b5cf6,#6d5dfc); }
.toast-modal[data-variant="success"] { --th-bg: linear-gradient(135deg,#22c55e,#16a34a); }
.toast-modal[data-variant="warn"]    { --th-bg: linear-gradient(135deg,#f59e0b,#f97316); }
.toast-modal[data-variant="error"]   { --th-bg: linear-gradient(135deg,#ef4444,#fb7185); }

/* การ์ด */
.toast-card{
  width: clamp(360px, 92vw, 520px);
  border-radius: 26px; overflow: hidden;
  border: 1px solid var(--t-border);
  box-shadow: var(--t-shadow); background: var(--t-surface);
  display:flex; flex-direction:column;
}

/* headbar */
.toast-headbar{
  display:flex; align-items:center; gap:12px;
  padding:14px 18px; color:#fff; background: var(--th-bg);
  border-bottom: 1px solid color-mix(in srgb, #000 10%, transparent);
}
.toast-badge{
  width:40px; height:40px; flex:0 0 40px; display:grid; place-items:center;
  border-radius:14px; font-weight:900; font-size:20px;
  background: color-mix(in srgb, #ffffff 22%, transparent);
  box-shadow: 0 8px 18px rgba(0,0,0,.18) inset;
}
.toast-title{ margin:0; font-size:18px; font-weight:950; letter-spacing:.2px; color:#fff }

/* body */
.toast-body{ padding:16px 18px 8px; min-height:72px; }
.toast-desc{ margin:0; color:var(--t-muted); font-size:15px; line-height:1.65; word-wrap:break-word }

/* actions */
.toast-actions{
  display:flex; justify-content:flex-end; gap:10px;
  padding:12px 18px 18px;
  background: linear-gradient(180deg, var(--t-surface), color-mix(in srgb,var(--t-surface) 85%, transparent));
}
.pill{
  --ring: var(--t-vlt-2);
  border-radius:999px; padding:11px 18px; font-weight:900;
  border:1px solid var(--t-border); cursor:pointer;
  background: color-mix(in srgb, var(--t-surface-2) 96%, transparent); color: var(--t-text);
  transition: transform .07s ease, box-shadow .14s ease, background .14s ease;
}
.pill:hover{ transform: translateY(-1px); }
.pill:focus-visible{ outline:none; box-shadow:0 0 0 4px color-mix(in srgb, var(--ring) 26%, transparent); }
.pill.primary{
  background: linear-gradient(180deg, var(--t-vlt-2), var(--t-vlt-1)); color:#fff; border-color:transparent;
  box-shadow: 0 10px 22px color-mix(in srgb, var(--t-vlt-2) 35%, transparent);
}

/* motion เล็กน้อย */
@media (prefers-reduced-motion:no-preference){
  .toast-card{ animation: toast-pop .18s ease-out both; }
}
@keyframes toast-pop{
  from{ transform: translateY(8px) scale(.985); opacity: 0 }
  to  { transform: translateY(0)   scale(1);     opacity: 1 }
}

/* =========================================
   5) OTP DIALOG (otpDialog)
   ========================================= */
.rt-card{
  background:var(--card); color:var(--text);
  border:1px solid var(--border); border-radius:18px;
  padding:20px; box-shadow:var(--shadow)
}
.rt-title{ margin:0 0 6px; font-size:20px; font-weight:900 }
.rt-desc{ margin:0 0 12px; color:var(--muted) }
.rt-actions{ display:flex; justify-content:flex-end; gap:8px }
.link{ background:none; border:0; color:var(--accent); cursor:pointer }
.muted{ color:var(--muted) }
/* ===== Bank Accounts: make fields full-width ===== */
.bank-accounts { width: 100%; }

.bank-grid{
  display: grid;
  grid-template-columns: 1fr;  /* ทำให้ทุกช่องยาวเต็มเหมือนฟิลด์อื่น */
  gap: 10px;
}

/* ถ้าอนาคตอยากให้หน้าจอกว้างมาก ๆ เป็น 2 คอลัมน์ ค่อยเปิดใช้อันนี้ได้
@media (min-width: 1024px){
  .bank-grid{ grid-template-columns: 1fr 1fr; }
}
*/

.bank-accounts .f-field { width: 100%; }
.bank-accounts .f-input,
.bank-accounts select.f-input,
.bank-accounts input.f-input{ width: 100%; }

/* ปุ่มลบ/เพิ่ม — ให้ชิดขวาและไม่ดันความกว้างฟอร์ม */
.bank-accounts .flex { width: 100%; }

#registerNoticeModal .toast-body ul { margin-left: 1rem; }
</style>

<script>
  // Flash message จาก server (ถ้ามี)
  window.__flash = <%- JSON.stringify(flash || null) %>;
  document.addEventListener('DOMContentLoaded', () => {
    if (window.__flash) {
      if (window.notify && typeof window.notify.push === 'function') {
        window.notify.push(window.__flash);
      } else if (typeof window.notify === 'function') {
        window.notify(window.__flash);
      } else {
        const f = window.__flash;
        alert((f.title ? f.title + '\n' : '') + (f.text || ''));
      }
      window.__flash = null;
    }
  });
</script>
<script>
  (function(){
    const KEY = 'register_notice_suppress_until_v1'; // localStorage key
    const modal = document.getElementById('registerNoticeModal');
    const chk = document.getElementById('regNoticeDontShow');
    const btnClose = document.getElementById('regNoticeClose');

    function shouldShow(){
      try {
        const v = localStorage.getItem(KEY);
        if (!v) return true;
        const ts = Number(v);
        if (!Number.isFinite(ts)) return true;
        return Date.now() > ts; // show if now past expiry
      } catch(e){
        return true;
      }
    }

    function setSuppressFor7Days(){
      const until = Date.now() + 7 * 24 * 60 * 60 * 1000;
      try { localStorage.setItem(KEY, String(until)); } catch(e){ /* ignore */ }
    }

    // show modal on DOM ready if needed
    document.addEventListener('DOMContentLoaded', ()=>{
      try {
        if (shouldShow()) {
          // wait a tick so dialog styles/backdrop applied nicely
          setTimeout(()=> {
            if (!modal.open) modal.showModal();
          }, 120);
        }
      } catch(e){}
    });

    btnClose?.addEventListener('click', ()=>{
      if (chk && chk.checked) setSuppressFor7Days();
      try { if (modal.open) modal.close(); } catch(e){}
    });

    // allow Escape/cancel to close as well but don't set suppression
    modal?.addEventListener('cancel', (ev)=> {
      ev.preventDefault();
      try { modal.close(); } catch(e){}
    });
  })();
</script>

<script type="module">
// ✅ Module-scoped notify: ไม่ชนกับ window.notify
const notify = ({ variant='info', title='ข้อความ', text='', timeout } = {}) => {
  if (window.notify && typeof window.notify.push === 'function') {
    window.notify.push({ variant, title, text, timeout });
  } else if (typeof window.notify === 'function') {
    // เผื่อหน้าเก่ายังเป็นแบบฟังก์ชัน
    window.notify({ variant, title, text, timeout });
  } else {
    alert((title ? title + '\n' : '') + (text || ''));
  }
};
/* ======================
   Helpers & DOM refs
   ====================== */
const $  = (s, p=document)=>p.querySelector(s);
const $$ = (s, p=document)=>[...p.querySelectorAll(s)];

const form       = $('#registerForm');
const btnRegister= $('#btnRegister');
const bankList   = $('#bankList');
const btnAddBank = $('#btnAddBank');
const tplBankRow = $('#tplBankRow');

/* ============== Toast/Dialog (msgDialog) ============== */
const msgDlg    = $('#msgDialog');
const msgBadge  = $('#msgBadge');
const msgTitle  = $('#msgTitle');
const msgText   = $('#msgText');
const msgClose  = $('#msgClose');
const msgCancel = $('#msgCancel');

function showMsg({
  variant = 'info', // 'info'|'success'|'warn'|'error'
  icon,
  title = 'ข้อความ',
  text  = '',
  okText = 'ตกลง',
  cancelText,
  onOk, onCancel
} = {}) {
  const iconMap = { info:'❔', success:'✅', warn:'⚠️', error:'✖' };
  msgDlg.setAttribute('data-variant', variant);
  msgBadge.textContent = icon || iconMap[variant] || '❔';
  msgTitle.textContent = title;
  msgText.textContent  = text;
  msgClose.textContent = okText;
  if (cancelText) { msgCancel.hidden = false; msgCancel.textContent = cancelText; }
  else            { msgCancel.hidden = true; }

  msgClose.onclick  = ()=>{ msgDlg.close(); onOk?.(); };
  msgCancel.onclick = ()=>{ msgDlg.close(); onCancel?.(); };
  if (!msgDlg.open) msgDlg.showModal();
}
msgDlg?.addEventListener('cancel', e=>{ e.preventDefault(); msgDlg.close(); });

/* ============== Flash จาก server (ถ้ามี) ============== */
const __flash = (typeof window.__flash !== 'undefined' ? window.__flash : null);
if (__flash) {
  showMsg(__flash);
  window.__flash = null;
}

/* ============== Toggle password ============== */
const pwd = $('#pwd');
const togglePwd = $('#togglePwd');
togglePwd?.addEventListener('click', ()=>{
  const show = pwd.type === 'password';
  pwd.type = show ? 'text' : 'password';
  togglePwd.setAttribute('aria-pressed', String(show));
  togglePwd.querySelector('.txt').innerHTML = show ? '<b>แสดง</b>รหัส' : '<b>ซ่อน</b>รหัส';
});

/* =======================================================
   บัญชีของฉัน (บังคับ >=1 และ <=2) + Validation ฝั่ง client
   ======================================================= */
function validateAccount(a){
  const code   = (a.accountCode||'').trim();
  const digits = (a.accountNumber||'').replace(/[^\d]/g,'');
  if (!code)            return { ok:false, msg:'เลือกธนาคาร/วอลเล็ท' };
  if (!a.accountName)   return { ok:false, msg:'กรอกชื่อบัญชี' };
  if (code === 'tw') {
    if (!/^0\d{9}$/.test(digits)) return { ok:false, msg:'True Wallet ต้องเป็นเบอร์ 10 หลักขึ้นต้น 0' };
  } else {
    if (!/^\d{10,15}$/.test(digits)) return { ok:false, msg:'เลขบัญชีต้องเป็นตัวเลข 9–12 หลัก' };
  }
  return { ok:true };
}

function getAccountsFromDom(){
  return $$('.bank-row', bankList).map(r=>({
    accountCode: r.querySelector('.sel-bank')?.value || '',
    accountNumber: r.querySelector('.in-number')?.value || '',
    accountName: r.querySelector('[name="accountName"]')?.value || ''
  })).filter(a => a.accountCode || a.accountNumber || a.accountName); // ตัดแถวว่าง
}

function attachRowBehaviors(row){
  row.querySelector('.in-number')?.addEventListener('input', e=>{
    e.target.value = e.target.value.replace(/[^\d]/g,'').slice(0,12);
    updateSubmitState();
  });
  row.querySelector('.sel-bank')?.addEventListener('change', updateSubmitState);
  row.querySelector('[name="accountName"]')?.addEventListener('input', updateSubmitState);
  row.querySelector('[data-action="remove"]')?.addEventListener('click', ()=>{
    row.remove(); updateSubmitState();
  });
}

function addRow(prefill={}){
  const frag = tplBankRow.content.cloneNode(true);
  const row  = frag.querySelector('.bank-row');
  if (!row) return;

  if (prefill.accountCode)   row.querySelector('.sel-bank').value = prefill.accountCode;
  if (prefill.accountNumber) row.querySelector('.in-number').value = prefill.accountNumber;
  if (prefill.accountName)   row.querySelector('[name="accountName"]').value = prefill.accountName;

  attachRowBehaviors(row);
  bankList.appendChild(frag);
  updateSubmitState();
}

function updateSubmitState(){
  const rows = $$('.bank-row', bankList);
  btnAddBank.disabled = rows.length >= 2; // สูงสุด 2 แถว

  const accs = getAccountsFromDom();
  let ok = accs.length >= 1 && accs.length <= 2;
  if (ok) ok = accs.every(a => validateAccount(a).ok);

  btnRegister.disabled = !ok;
}

btnAddBank?.addEventListener('click', ()=> addRow());
if (bankList.childElementCount === 0) addRow(); // เริ่มด้วย 1 แถว

/* =======================================================
   สมัครสมาชิก: ส่งฟอร์ม -> /register
   (รองรับสองกรณี: needOtp=true | verify-link)
   ======================================================= */
let nextUrl = '/';

form.addEventListener('submit', async (e)=>{
  e.preventDefault();
  updateSubmitState();
  if (btnRegister.disabled) {
    notify({ variant:'warn', title:'กรอกข้อมูลไม่ครบ', text:'โปรดเพิ่มบัญชีอย่างน้อย 1 รายการ และกรอกให้ถูกต้อง' });
    return;
  }

  btnRegister.disabled = true;

  // เก็บค่าฟอร์มพื้นฐาน
  const fd = new FormData(form);
  nextUrl = fd.get('next') || '/';
  // เก็บ accounts จาก DOM แล้ว append เป็น array fields
  const accs = getAccountsFromDom();
  // สร้าง payload เป็น URLSearchParams เองเพื่อควบคุม array
  const payload = new URLSearchParams();
  ['username','email','name','password','next'].forEach(k=>{
    const v = fd.get(k);
    if (v!=null) payload.append(k, v);
  });
  accs.forEach(a=>{
    payload.append('accountCode',   (a.accountCode||'').trim());
    payload.append('accountNumber', (a.accountNumber||'').replace(/[^\d]/g,''));
    payload.append('accountName',   (a.accountName||'').trim());
  });

  try {
    const res = await fetch('/register', {
      method: 'POST',
      headers: { 'Accept':'application/json', 'Content-Type':'application/x-www-form-urlencoded' },
      body: payload
    });
    let data = {};
    try { data = await res.json(); } catch {}

    if (!res.ok || !data?.ok) {
      notify({ variant:'error', title:'สมัครสมาชิกไม่สำเร็จ', text: data?.message || 'กรุณาตรวจสอบข้อมูล' });
      return;
    }

    // ถ้าเซิร์ฟเวอร์ตอบแบบ OTP
    if (data.needOtp) {
      openOtp(data.email, data.ttl || 300, 60);
      return;
    }

    // ถ้าเป็น verify-link (อีเมลยืนยัน)
    notify({ variant:'success', title:'ส่งอีเมลยืนยันแล้ว', text:'โปรดตรวจกล่องจดหมายของคุณ แล้วคลิกลิงก์เพื่อเปิดใช้งานบัญชี' });
  } catch (err) {
    console.error(err);
    notify({ variant:'error', title:'เครือข่ายมีปัญหา', text:'โปรดลองใหม่อีกครั้ง' });
  } finally {
    btnRegister.disabled = false;
  }
});

/* =======================================================
   OTP Flow (optional – ใช้ก็ต่อเมื่อ server ตอบ needOtp:true)
   ======================================================= */
const otpDlg   = $('#otpDialog');
const otpCode  = $('#otpCode');
const btnOtpOK = $('#btnVerifyOtp');
const btnOtpCancel = $('#btnCancelOtp');
const btnResend= $('#btnResend');
const otpTimer = $('#otpTimer');
const otpHelp  = $('#otpHelp');
let pendingEmail = '';
let timerId = null;

function openOtp(email, ttl=300, cooldown=60){
  pendingEmail = email;
  otpHelp.textContent = `เราได้ส่งรหัส 6 หลักไปที่ ${email}`;
  otpCode.value = '';
  btnResend.disabled = true;
  startTimer(cooldown);
  if (!otpDlg.open) otpDlg.showModal();
  otpCode.focus();
}
function closeOtp(){
  clearInterval(timerId); timerId=null;
  if (otpDlg.open) otpDlg.close();
}
function startTimer(sec){
  clearInterval(timerId);
  let left = sec;
  otpTimer.textContent = `ส่งใหม่ได้ใน ${left}s`;
  timerId = setInterval(()=>{
    left--;
    if (left<=0){ clearInterval(timerId); timerId=null; otpTimer.textContent='ส่งใหม่ได้ตอนนี้'; btnResend.disabled=false; }
    else { otpTimer.textContent = `ส่งใหม่ได้ใน ${left}s`; }
  },1000);
}

btnOtpOK?.addEventListener('click', async ()=>{
  const code = (otpCode.value||'').trim();
  if (!/^\d{6}$/.test(code)) {
    notify({ variant:'warn', title:'รหัสไม่ครบ', text: 'กรอกรหัส OTP 6 หลักให้ถูกต้อง' });
    return;
  }
  try {
    const verifyRes = await fetch('/otp/verify', {
      method: 'POST',
      headers: { 'Content-Type':'application/x-www-form-urlencoded', 'Accept':'application/json' },
      body: new URLSearchParams({ email: pendingEmail, code })
    });
    const vr = await verifyRes.json().catch(()=> ({}));
    if (!verifyRes.ok || !vr?.ok) {
      notify({ variant:'error', title:'ยืนยันไม่สำเร็จ', text: vr?.error || 'รหัสไม่ถูกต้อง' });
      return;
    }
    const finRes = await fetch('/register/finalize', {
      method: 'POST',
      headers: { 'Content-Type':'application/x-www-form-urlencoded', 'Accept':'application/json' },
      body: new URLSearchParams({ next: nextUrl })
    });
    const fr = await finRes.json().catch(()=> ({}));
    if (!finRes.ok || !fr?.ok) {
      notify({ variant:'error', title:'สร้างบัญชีไม่ได้', text: fr?.message || 'โปรดลองใหม่' });
      return;
    }
    closeOtp();
    notify({ variant:'success', title:'สมัครสำเร็จ!', text:'ล็อกอินสำเร็จ' });
    setTimeout(()=> location.assign(fr.redirect || nextUrl || '/'), 500);
  } catch(e){
    console.error(e);
    notify({ variant:'error', title:'เครือข่ายมีปัญหา', text:'โปรดลองใหม่อีกครั้ง' });
  }
});

btnResend?.addEventListener('click', async ()=>{
  btnResend.disabled = true;
  try {
    const rs = await fetch('/otp/send', {
      method: 'POST',
      headers: { 'Content-Type':'application/x-www-form-urlencoded', 'Accept':'application/json' },
      body: new URLSearchParams({ email: pendingEmail })
    });
    const data = await rs.json().catch(()=> ({}));
    if (!rs.ok || !data?.ok) {
      notify({ variant:'error', title:'ส่งรหัสไม่สำเร็จ', text: data?.error || 'โปรดลองใหม่' });
      btnResend.disabled = false;
      return;
    }
    startTimer(60);
    notify({ variant:'success', title:'ส่งรหัสใหม่แล้ว', text:'โปรดตรวจที่อีเมลของคุณ' });
  } catch(e){
    console.error(e);
    notify({ variant:'error', title:'ส่งรหัสไม่สำเร็จ', text: data?.error || 'โปรดลองใหม่' });
    btnResend.disabled = false;
  }
});

btnOtpCancel?.addEventListener('click', closeOtp);
otpCode?.addEventListener('input', ()=> { otpCode.value = otpCode.value.replace(/[^\d]/g,'').slice(0,6); });
otpCode?.addEventListener('keydown', (e)=>{ if (e.key === 'Enter') btnOtpOK?.click(); });
</script>