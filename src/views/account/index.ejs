      if (j.user?.avatarUrl) img.src = j.user.avatarUrl;
      if (j.user?.email && !j.user?.emailVerified) document.getElementById('otpArea')?.removeAttribute('hidden');
      ok('อัปโหลดรูปโปรไฟล์แล้ว');
    } catch {
      fail('อัปโหลดไม่สำเร็จ', 'เครือข่ายมีปัญหา');
    } finally {
      btnAvatar.disabled = false;
      input.value = '';
    }
  });

  // ===== Change password =====
  $('#formPassword')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.currentTarget;
    const btn  = form.querySelector('button[type=submit]');
    btn.disabled = true;

    const fd   = new FormData(form);
    const body = Object.fromEntries(fd.entries());
    if ((body.newPassword || '') !== (body.newPassword2 || '')) {
      fail('เปลี่ยนรหัสไม่สำเร็จ', '⚠️รหัสผ่านใหม่ทั้งสองช่องไม่ตรงกัน');
      btn.disabled = false; return;
    }

    try {
      const r = await fetch('/account/password', {
        method: 'POST',
        headers: { 'Content-Type':'application/json' },
        body: JSON.stringify(body)
      });
      let j = null; try { j = await r.json(); } catch {}

      if (r.ok && j?.ok) {
        form.reset();
        ok('เปลี่ยนรหัสผ่านเรียบร้อย', { onClose: () => window.location.replace('/account') });
        setTimeout(() => { try{ window.location.replace('/account'); }catch{} }, 300);
        return;
      }
      const msg = j?.error || (r.status >= 500 ? 'เซิร์ฟเวอร์มีปัญหา' : '⚠️ดำเนินการไม่สำเร็จเครือข่ายมีปัญหา');
      fail('เปลี่ยนรหัสไม่สำเร็จ', msg);
    } catch {
      fail('เปลี่ยนรหัสผ่านไม่สำเร็จ', '⚠️เครือข่ายมีปัญหา');
    } finally {
      btn.disabled = false;
    }
  });

  // ===== OTP =====
  const btnSendOtp   = $('#btnSendOtp');
  const otpCodeInput = $('#otpCode');

  const show = (variant, title, text, icon) =>
    window.showMsg?.({ variant, title, text, icon });

  function getEmail() {
    const dataEmail = btnSendOtp?.dataset.email?.trim().toLowerCase();
    if (dataEmail) return dataEmail;
    const field = $('input[name="email"]');
    return (field?.value || '').trim().toLowerCase();
  }

  function startCooldown(seconds) {
    if (!btnSendOtp || !Number.isFinite(seconds) || seconds <= 0) return;
    const original = btnSendOtp.textContent;
    btnSendOtp.disabled = true;
    let left = Math.ceil(seconds);
    btnSendOtp.textContent = `ส่งใหม่ได้ใน ${left}s`;
    const t = setInterval(() => {
      left -= 1;
      if (left <= 0) {
        clearInterval(t);
        btnSendOtp.disabled = false;
        btnSendOtp.textContent = original || 'ส่งรหัสยืนยัน';
        return;
      }
      btnSendOtp.textContent = `ส่งใหม่ได้ใน ${left}s`;
    }, 1000);
  }

  btnSendOtp?.addEventListener('click', async () => {
    const email = getEmail();
    if (!email) { show('warn', 'กรอกอีเมลก่อน', 'โปรดกรอกอีเมลที่ใช้สมัคร', '⚠️'); return; }

    btnSendOtp.disabled = true;
    try {
      const r = await fetch('/otp/send', {
        method: 'POST',
        headers: { 'Content-Type':'application/json' },
        body: JSON.stringify({ email, channel: 'email' })
      });

      if (r.status === 429) {
        const j = await r.json().catch(()=>({}));
        const m = /\s(\d+)s\s/.exec(j?.error || '');
        const waitSec = m ? Number(m[1]) : 60;
        show('warn', 'ขอรหัสถี่เกินไป', j?.error || 'โปรดรอสักครู่ก่อนขอใหม่', '⏳');
        startCooldown(waitSec);
        return;
      }

      const j = await r.json().catch(()=>({}));
      if (!r.ok || !j?.ok) { show('error', 'ส่งรหัสไม่สำเร็จ', j?.error || 'โปรดลองใหม่อีกครั้ง', '✖'); return; }

      document.getElementById('otpArea')?.removeAttribute('hidden');
      otpCodeInput?.focus();

      const ttlSec = Number(j.ttl || 300);
      const ttlMin = Math.max(1, Math.round(ttlSec/60));
      show('success', 'ส่งรหัสแล้ว', `เราได้ส่งรหัสไปยังอีเมลของคุณ (ใช้ได้ประมาณ ${ttlMin} นาที)`, '✅');
      startCooldown(30);
    } catch {
      show('error', 'เครือข่ายมีปัญหา', 'โปรดลองใหม่อีกครั้ง', '✖');
    } finally {
      if (!btnSendOtp.hasAttribute('disabled')) btnSendOtp.disabled = false;
    }
  });

  const verifyBtn = document.getElementById('btnVerifyOtp');
  verifyBtn?.addEventListener('click', async () => {
    const code = (document.getElementById('otpCode')?.value || '').trim();
    if (code.length < 4) return warn('รหัสไม่ครบ', 'กรุณากรอกรหัสให้ครบ');
    verifyBtn.disabled = true;
    try{
      const r = await fetch('/account/email/verify', {
        method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ code })
      });
      const j = await r.json();
      if (!j.ok) { verifyBtn.disabled = false; return fail('ยืนยันไม่สำเร็จ', j.error || ''); }
      ok('ยืนยันอีเมลเรียบร้อย');
      window.location.reload();
    } catch {
      verifyBtn.disabled = false;
      fail('ยืนยันไม่สำเร็จ', 'เครือข่ายมีปัญหา');
    }
  });

  // ===== Redeem Points =====
  const btnRedeem = document.getElementById('btnRedeemPoints');
  if (btnRedeem) {
    btnRedeem.addEventListener('click', async () => {
      if (btnRedeem.disabled) return;
      btnRedeem.disabled = true;
      const oldLabel = btnRedeem.textContent;
      btnRedeem.textContent = 'กำลังแลก…';

      try {
        const r = await fetch('/account/points/redeem', { method: 'POST' });
        const j = await r.json();

        if (!r.ok || !j?.ok) { fail('แลกแต้มไม่สำเร็จ', j?.error || 'โปรดลองใหม่'); return; }

        const pointsNum = Number(j.remainPoints || 0);
        const pointsEl = document.querySelector('[data-id="points-num"]');
        if (pointsEl) pointsEl.innerHTML = `${pointsNum.toLocaleString(undefined,{ maximumFractionDigits: 2})} คะแนน`;
        const rateEl = document.querySelector('[data-id="point-rate"]');
        if (rateEl) rateEl.textContent = `฿${(j.rate || 0).toLocaleString()} / 1 แต้ม`;
        const valEl = document.querySelector('[data-id="point-value"]');
        if (valEl) valEl.textContent = `≈ ฿${(j.pointValueTHB || 0).toLocaleString(undefined,{ maximumFractionDigits: 2 })}`;

        const prEl = document.querySelector('[data-id="points-redeemed"]');
        if (prEl && typeof j.pointsRedeemed === 'number') {
          prEl.textContent = `฿${j.pointsRedeemed.toLocaleString(undefined,{ minimumFractionDigits:2 })}`;
        }

        if (pointsNum < 100) {
          btnRedeem.classList.remove('primary');
          btnRedeem.setAttribute('disabled', 'disabled');
        }

        const added = Number(j.addedBalance || 0);
        ok(`แลก ${j.redeemed} แต้ม เป็น ฿${added.toLocaleString(undefined,{ maximumFractionDigits: 2 })} แล้ว`, {
          onClose: () => window.location.replace('/account')
        });
        setTimeout(() => { try { window.location.replace('/account'); } catch {} }, 300);
      } catch {
        fail('แลกแต้มไม่สำเร็จ', 'เครือข่ายมีปัญหา');
      } finally {
        btnRedeem.textContent = oldLabel;
        if (!btnRedeem.hasAttribute('disabled')) btnRedeem.disabled = false;
      }
    });
  }

  // ===== Levels renderer (2 cols) =====
  const track = document.getElementById('levelsTrack');
  const pages = [];
  const _levels = window.__LEVELS__ || [];
  for (let i=0;i<_levels.length;i+=2) pages.push(_levels.slice(i,i+2));
  let page = 0;

  function render() {
    track.innerHTML = '';
    const pickPercent = s => {
      const m = (s || '').match(/-?\d+(?:\.\d+)?%/);
      return m ? m[0] : (s || '—');
    };
    (pages[page] || []).forEach(lv => {
      const perks = lv.perks || [];
      const bonusTxt    = perks.find(p => p.includes('โบนัสเติมเงิน')) || '';
      const discountTxt = perks.find(p => p.includes('ส่วนลดทุกคำสั่งซื้อ')) || '';
      const bonusVal    = pickPercent(bonusTxt);
      const discountVal = pickPercent(discountTxt);

      track.insertAdjacentHTML('beforeend', `
        <div class="prof-card" style="padding:14px">
          <div class="kv" style="margin-bottom:8px">
            <div><strong>${lv.name}</strong></div>
            <div><span class="badge balance">ใช้จ่าย &gt; ฿${(lv.need||0).toLocaleString()}</span></div>
          </div>
          <div class="kv"><div>อัตราการแลกเปลี่ยน ↔ (Point × Rate)</div><div><span class="badge balance">${lv.rate}</span></div></div>
          <div class="kv"><div>โบนัสเติมเงิน</div><div><span class="badge warn">${bonusVal}</span></div></div>
          <div class="kv"><div>ส่วนลดทุกคำสั่งซื้อ</div><div><span class="badge warn">${discountVal}</span></div></div>
          ${perks.filter(p => !p.includes('โบนัสเติมเงิน') && !p.includes('ส่วนลดทุกคำสั่งซื้อ'))
                 .map(p => `<div class="muted" style="margin:6px 0">• ${p}</div>`).join('')}
        </div>
      `);
    });
  }
  render();
  document.getElementById('lvPrev')?.addEventListener('click', () => { page = (page-1+pages.length)%pages.length; render(); });
  document.getElementById('lvNext')?.addEventListener('click', () => { page = (page+1)%pages.length; render(); });
})();
</script>

<script>
(() => {
  const $  = s => document.querySelector(s);
  const fmt = n => Number(n||0).toLocaleString(undefined,{maximumFractionDigits:2});
  // fallback สำหรับ ok/fail ถ้าไม่มีตัวช่วย
  const ok  = window.ok  || (msg => alert(msg));
  const fail= window.fail|| (msg => alert(msg));
  const btn = document.getElementById('btnCreateAff');
  if (!btn) return;

  btn.addEventListener('click', async (e) => {
    e.preventDefault();
    if (btn.disabled) return;
    const old = btn.textContent;
    btn.disabled = true; btn.textContent = 'กำลังสร้าง…';

    try {
      const r = await fetch('/account/affiliate/create-link', { method:'POST' });
      const j = await r.json();
      if (!r.ok || !j?.ok || !j?.link) {
        fail(j?.error || 'สร้างลิงก์ไม่สำเร็จ');
        return;
      }

      // สลับ UI มาโชว์ลิงก์ทันที
      const create = document.getElementById('aff-create-area');
      const area   = document.getElementById('aff-link-area');
      const out    = document.getElementById('aff-link');
      if (create && area && out) {
        create.hidden = true;
        area.hidden   = false;
        out.textContent = j.link; // เช่น https://rtsmm-th.com/aff?=KEY
      }

      ok('สร้างลิงก์แนะนำเรียบร้อย');
    } catch {
      fail('เครือข่ายมีปัญหา โปรดลองใหม่');
    } finally {
      btn.disabled = false; btn.textContent = old;
    }
  });

  let lastStats = null; // เก็บไว้ใช้เปิดโมดัลโดยไม่ต้อง fetch ซ้ำ

  async function loadStats(){
    try{
      const r = await fetch('/account/affiliate/stats');
      const j = await r.json();
      if (!r.ok || !j?.ok) throw new Error('fail');
      lastStats = j;

      // % เรต (ป้องกัน NaN และปัดเศษ)
      const rawRate = Number(j?.summary?.ratePct);
      const rate = Number.isFinite(rawRate) ? Math.min(40, Math.max(5, Math.round(rawRate))) : 5;
      $('#aff-rate-title')  && ($('#aff-rate-title').textContent   = rate);
      $('#aff-rate-inline') && ($('#aff-rate-inline').textContent  = rate);
      $('#aff-rate-inline-2')&&($('#aff-rate-inline-2').textContent= rate);

      $('#aff-refcount') && ($('#aff-refcount').textContent = j.summary.referredCount || 0);
      $('#aff-orders')   && ($('#aff-orders').textContent   = j.summary.orders || 0);
      $('#aff-spent')    && ($('#aff-spent').textContent    = fmt(j.summary.spentTHB || 0));
      $('#aff-earn')     && ($('#aff-earn').textContent     = fmt(j.summary.earningsTHB || 0));

      // ยอดถอนได้ + ปุ่ม
      const wd = Number(j.summary.withdrawableTHB || 0);
      $('#aff-withdrawable') && ($('#aff-withdrawable').textContent = fmt(wd));
      const btn = $('#btnAffWithdraw');
      if (btn) btn.disabled = !(wd > 0.0001);

      // หลอดเลื่อนระดับ
      const t = j.tier || {};
      const cont = $('.aff-progress');
      const fill = $('#aff-tier-fill');
      const note = $('#aff-tier-note');

      const atMax = !!(t.atMax || rate >= 40);
      cont && cont.classList.toggle('max', atMax);

      if (atMax){
        fill && (fill.style.width = '100%');
        note && (note.textContent = 'ระดับของคุณถึงระดับสูงสุดแล้ว');
      } else if (t){
        const p = Math.max(0, Math.min(100, Number(t.progressPct || 0)));
        fill && (fill.style.width = p + '%');
        if (note && t.next) note.textContent = `ระดับถัดไป: ${t.next.rate}%`;
      }
    } catch { /* เงียบไว้: SSR ควรมีค่าเริ่ม */ }
  }

  function openTierModal(payload){
    const next = payload?.tier?.next;
    const refs = payload?.summary?.referredCount || 0;
    const earn = payload?.summary?.earningsTHB   || 0;

    let html;
    if (!next) {
      html = `<div class="modal"><div class="modal-body">
        <h3>ระดับสูงสุดแล้ว</h3>
        <p class="muted">คุณได้รับ 40% และไม่ต้องทำเงื่อนไขเพิ่มเติม</p>
        <div style="text-align:right;margin-top:12px"><button class="btn" id="tierClose">ปิด</button></div>
      </div></div>`;
    } else {
      const needRefs = Math.max(0, next.refs - refs);
      const needEarn = Math.max(0, next.earn - earn);
      html = `<div class="modal"><div class="modal-body">
        <h3>ระดับถัดไป ${next.rate}%</h3>
        <ul>
          <li>แนะนำเพิ่มอีก <b>${needRefs}</b> คน (เป้าหมาย ${next.refs})</li>
          <li>ยอดรายได้รวมถึง <b>฿${next.earn.toLocaleString()}</b>
              <small class="muted">(ขาดอีก ฿${needEarn.toLocaleString()})</small></li>
        </ul>
        <div style="text-align:right;margin-top:12px"><button class="btn" id="tierClose">ปิด</button></div>
      </div></div>`;
    }
    const wrap = document.createElement('div');
    wrap.className = 'modal-wrap';
    wrap.innerHTML = html;
    document.body.appendChild(wrap);
    wrap.addEventListener('click', e=>{
      if (e.target.id==='tierClose' || e.target===wrap) wrap.remove();
    });
  }

  // เปิดโมดัลจากข้อมูลล่าสุด ถ้าไม่มีค่อย fetch
  $('#aff-tier-pill')?.addEventListener('click', async ()=>{
    if (lastStats) return openTierModal(lastStats);
    try{
      const r = await fetch('/account/affiliate/stats');
      const j = await r.json();
      if (r.ok && j?.ok) openTierModal(j);
    }catch{}
  });

  // ถอนรายได้
  $('#btnAffWithdraw')?.addEventListener('click', async ()=>{
    const btn = $('#btnAffWithdraw');
    if (!btn || btn.disabled) return;
    const old = btn.textContent;
    btn.disabled = true; btn.textContent = 'กำลังถอน...';
    try{
      const r = await fetch('/account/affiliate/withdraw', { method:'POST' });
      const j = await r.json();
      if (!r.ok || !j?.ok){
        fail(j?.error || 'ถอนรายได้ไม่สำเร็จ');
        btn.disabled = false; btn.textContent = old;
        return;
      }
      ok(`เพิ่มยอดกระเป๋าแล้ว ฿${(j.addedBalance||0).toLocaleString(undefined,{maximumFractionDigits:2})}`);
      await loadStats();
    } catch {
      fail('เครือข่ายมีปัญหา โปรดลองใหม่');
    } finally {
      btn.textContent = old;
    }
  });

  loadStats();
})();

(() => {
  const titleEl = document.getElementById('acctPageTitle');
  const tabs    = document.querySelectorAll('.tabs .tab');

  // อัปเดต H1 + document.title ตามแท็บที่ active
  function updateTitle() {
    const active = document.querySelector('.tabs .tab.active');
    const label  = (active?.textContent || 'ตั้งค่าข้อมูลส่วนตัว').trim();
    if (titleEl) titleEl.textContent = label;
    // (ออปชัน) อัปเดต title ของแท็บเบราว์เซอร์ให้เข้ากัน
    document.title = `${label} — RTSMM-TH`;
  }

  // ผูก event กับทุกแท็บ (ถ้าโค้ดเปลี่ยนแท็บของคุณมีอยู่แล้ว แทรกแค่ updateTitle() หลังจากสลับคลาส)
  tabs.forEach(btn => {
    btn.addEventListener('click', () => {
      // ถ้ามีโค้ดสลับแท็บเดิมอยู่แล้ว ไม่ต้องทำส่วน remove/add นี้ซ้ำ
      document.querySelectorAll('.tabs .tab').forEach(b => {
        b.classList.toggle('active', b === btn);
        b.setAttribute('aria-selected', b === btn ? 'true' : 'false');
        b.setAttribute('tabindex', b === btn ? '0' : '-1');
      });
      updateTitle();
    });
  });

  // รองรับเปิดด้วยแฮช เช่น /account#tab-affiliate
  window.addEventListener('hashchange', updateTitle);

  // ตั้งค่าครั้งแรกเมื่อโหลดหน้า
  updateTitle();
})();

// สลับโชว์ลิงก์ถ้ามีคีย์อยู่แล้ว + ใช้ https:
