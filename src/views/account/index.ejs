<!-- /account/index.ejs -->
<section class="page account-v3">
  <h1 class="page-title" style="align-items: center; text-align: center;" >ตั้งค่าข้อมูลส่วนตัว</h1>

  <div class="acc-wrap">
    <!-- = LEFT: Summary = -->
    <aside class="acc-side">
      <div class="prof-card">
        <div class="prof-avatar">
          <img
            id="avatarPreview"
            src="<%= userDoc.avatarUrl %>?v=<%= (me && me.avatarVer) || Date.now() %>"
            loading="lazy"
            decoding="async"
            onerror="this.onerror=null;this.src='/static/assets/logo/rtsmmgif2.gif';"
            alt="avatar">
        </div>

        <!-- ปุ่มเลือกไฟล์ + input ซ่อน -->
        <div style="display:flex;justify-content:center;gap:8px;">
          <button type="button" id="btnChangeAvatar" class="btn-line">เปลี่ยนรูปโปรไฟล์</button>
          <input
            id="avatarInput"
            name="avatar"
            type="file"
            hidden
            accept="image/png,image/jpeg,image/webp,image/gif">
        </div>

        <div class="prof-name"><%= userDoc.name || (me?.username || '') %></div>
        <div class="prof-mail">
          <%= userDoc.email || '-' %>
          <% if (userDoc.email) { %>
            <% if (userDoc.emailVerified) { %>
              <span class="badge ok">ยืนยันแล้ว</span>
            <% } else { %>
              <span class="badge warn">ยังไม่ยืนยัน</span>
            <% } %>
          <% } %>
        </div>

        <div class="kv">
          <div>ระดับบัญชี</div>
          <div><span class="badge warn"><%= userDoc.levelName || `เลเวล ${userDoc.level || '1'}` %></span></div>
        </div>
        <div class="kv">
          <div>ยอดคงเหลือ</div>
          <div><span class="badge balance"><%= balanceText %></span></div>
        </div>

        <!-- ✅ อัปเดตข้อความรองรับไฟล์ -->
        <div class="muted sm" style="margin-top:8px">ไฟล์ที่รองรับ: png, jpg, jpeg, webp, gif (สูงสุด 10MB)</div>
      </div>

      <div class="prof-card" style="margin-top:14px">
        <div class="kv"><div>ยืนยันตัวตน KYC</div><div><a class="badge danger">ยังไม่เปิดใช้งาน</a></div></div>
        <div class="kv"><div>ช่วยเหลือ</div><div><a class="badge ok" href="https://line.me/R/ti/p/@507vkplq" target="_blank" rel="noopener">Line Official</a></div></div>
      </div>
    </aside>

    <!-- = RIGHT: Tabs = -->
    <div class="acc-main">
      <div class="tabs">
        <button class="tab active" data-tab="tab-general">การตั้งค่าทั่วไป</button>
        <button class="tab" data-tab="tab-points">ข้อมูลระดับบัญชี</button>
        <!-- <button class="tab" data-tab="tab-notify">การแจ้งเตือน</button> -->
      </div>

      <!-- GENERAL -->
      <div class="tabpane show" id="tab-general">
        <form id="formProfile" class="card" enctype="multipart/form-data">
          <div class="card-header"><div class="title">ข้อมูลส่วนตัว</div></div>
          <div class="form-grid">
            <label>ชื่อ - นามสกุล
              <input name="name" type="text" value="<%= userDoc.name || '' %>" <%= userDoc.name ? 'disabled' : '' %> placeholder="ระบุชื่อ-นามสกุล">
              <% if (userDoc.name) { %><small class="muted sm">ตั้งแล้ว หากต้องการเปลี่ยนให้ติดต่อผู้ดูแล</small><% } %>
            </label>

            <label>Username
              <div class="static-input" aria-readonly="true"><%= me?.username || '-' %></div>
            </label>

            <label>Email Address
              <div class="email-row">
                <input name="email" type="email"
                      value="<%= userDoc.email || '' %>"
                      <%= userDoc.email ? 'disabled' : '' %>
                      placeholder="name@example.com">
                <% if (userDoc.email) { %>
                  <% if (userDoc.emailVerified) { %>
                    <button type="button" class="badge2 ok" disabled>ยืนยันแล้ว</button>
                  <% } else { %>
                    <button id="btnSendOtp" type="button" class="btn" data-email="<%= userDoc.email %>">
                      ส่งรหัสยืนยัน
                    </button>
                  <% } %>
                <% } %>
              </div>
            </label>

            <% if (userDoc.email && !userDoc.emailVerified) { %>
              <!-- ซ่อนจนกว่าจะกด "ส่งรหัสยืนยัน" สำเร็จ -->
              <div id="otpArea" class="otp-row" hidden>
                <input id="otpCode" type="text" inputmode="numeric" maxlength="6" placeholder="กรอกรหัส 6 หลัก">
                <button id="btnVerifyOtp" type="button" class="btn primary">ยืนยัน</button>
              </div>
            <% } %>

            <label>Timezone
              <div class="static-input" aria-readonly="true">(GMT+7:00) Asia/Bangkok (Indochina Time)</div>
            </label>

            <label>สกุลเงิน
              <div class="static-input" aria-readonly="true"><%= me?.currency || 'THB' %></div>
            </label>
          </div>

          <div class="card-actions">
            <button class="btn primary" type="submit">บันทึกข้อมูล</button>
          </div>
        </form>

        <!-- บัญชีของฉัน -->
        <div class="card" style="margin-top:14px">
          <div class="card-header">
            <div class="title">บัญชีของฉัน</div>
            <div class="actions">
              <span class="pill">สูงสุด 2 บัญชี</span>
              <button id="btnAddBank" type="button" class="btn primary"
                      <% if (Array.isArray(bankAccounts) && bankAccounts.length >= 2) { %>disabled<% } %>>
                เพิ่มบัญชี
              </button>
            </div>
          </div>

          <div class="bank-list" id="bankListView">
            <% if (Array.isArray(bankAccounts) && bankAccounts.length) { %>
              <% bankAccounts.forEach(function(a, idx){ %>
                <div class="bank-item" data-code="<%= a.code %>" data-number="<%= a.number %>">
                  <div class="bank-meta">
                    <div class="bank-name">
                      <span class="badge <%= a.code === 'TRUEWALLET' ? 'warn' : 'balance' %>"><%= a.label %></span>
                    </div>
                    <div class="bank-no"><%= a.numberMasked %></div>
                    <div class="bank-owner muted">ชื่อบัญชี: <%= a.name || '-' %></div>
                  </div>
                </div>
                <% if (idx !== bankAccounts.length - 1) { %><div class="bank-sep"></div><% } %>
              <% }) %>
            <% } else { %>
              <div class="bank-empty muted" id="bankEmptyMsg">
                ยังไม่มีข้อมูลบัญชี — หากต้องการแก้ไข/เพิ่ม โปรดติดต่อผู้ดูแลระบบ
              </div>
            <% } %>
          </div>
        </div>

        <form id="formPassword" class="card">
          <div class="card-header"><div class="title">เปลี่ยนรหัสผ่าน</div></div>
          <div class="form-grid">
            <label>รหัสผ่านเดิม
              <div class="pw-field">
                <input name="currentPassword" type="password" required>
                <button type="button" class="pw-toggle" aria-label="แสดง/ซ่อนรหัสผ่าน" aria-pressed="false" title="แสดง/ซ่อน"></button>
              </div>
            </label>

            <label>รหัสผ่านใหม่
              <div class="pw-field">
                <input name="newPassword" type="password" minlength="6" required>
                <button type="button" class="pw-toggle" aria-label="แสดง/ซ่อนรหัสผ่าน" aria-pressed="false" title="แสดง/ซ่อน"></button>
              </div>
            </label>

            <label>ยืนยันรหัสผ่านใหม่
              <div class="pw-field">
                <input name="newPassword2" type="password" minlength="6" required>
                <button type="button" class="pw-toggle" aria-label="แสดง/ซ่อนรหัสผ่าน" aria-pressed="false" title="แสดง/ซ่อน"></button>
              </div>
              <small id="pwMismatchMsg" class="muted sm" style="color: var(--danger); display:none;">
                รหัสผ่านใหม่ไม่ตรงกัน
              </small>
            </label>
          </div>
          <div class="card-actions">
            <button class="btn primary" type="submit">เปลี่ยนรหัสผ่าน</button>
          </div>
        </form>
      </div>

      

      <!-- =========== Tab: Points และ Level(แทนที่บล็อกเดิมทั้งหมด) =========== -->
      <div class="card" style="margin-bottom:14px">
        <div class="card-header">
          <div class="title">คะแนนสะสม (Points)</div>
          <span class="pill lvl">
            <%= userDoc.levelName ? userDoc.levelName : ('เลเวล ' + (userDoc.level || '1')) %>
          </span>
        </div>

        <div class="form-grid">
          <div class="score-wrap">
            <div>
              <div class="bignum" data-id="points-num">
                <%
                  var __points = (agg && typeof agg.points === 'number') ? agg.points : 0;
                %>
                <%= __points.toLocaleString(undefined,{maximumFractionDigits:2}) %> คะแนน
              </div>
              <div class="muted" style="color: #31d810;">ใช้จ่ายครบ ฿50 | ได้รับ 0.5 Point</div>
              <!-- <div class="muted" style="color: #e2bc0f;">แต้มสะสมจะรีเซ็ตทุกวันที่ 1 ของทุกเดือน</div>
              <div class="muted" style="color: #e2bc0f;">ให้แลกก่อนจะรีเซ็ตไม่งั้นแต้มจะหายทั้งหมด</div> -->
            </div>

            <div>
              <div class="kv" style="margin-bottom:8px">
                <div>เรทแลกเป็นเงิน</div>
                <%
                  var __rate = (agg && typeof agg.pointRateTHB === 'number') ? agg.pointRateTHB : 0;
                %>
                <div><span class="badge balance" data-id="point-rate">฿<%= __rate.toLocaleString() %> / 1 แต้ม</span></div>
              </div>
              <div class="kv">
                <div>มูลค่าแลกได้ (หากแลกทั้งหมด)</div>
                <%
                  var __val = (agg && typeof agg.pointValueTHB === 'number') ? agg.pointValueTHB : 0;
                %>
                <div><span class="badge balance" data-id="point-value">≈ ฿<%= __val.toLocaleString(undefined,{maximumFractionDigits:2}) %></span></div>
              </div>

              <div class="kv" style="color: #dbad16;">
                <div>⚠️ คำเตือน: เมื่อแลกแต้มเป็นเงินระดับบัญชีของคุณจะลดลงตามไปด้วย</div>
              </div>

              <div class="card-actions" style="text-align:right;padding:12px 0 0">
                <% 
                  var __canRedeem = (__points >= 100);
                  var __needLeft  = Math.max(0, 100 - __points); 
                %>
                <button
                  id="btnRedeemPoints"
                  class="btn <%= __canRedeem ? 'primary' : '' %>"
                  <% if (!__canRedeem) { %>
                    disabled aria-disabled="true"
                    title="ต้องมีอย่างน้อย 100 แต้ม (ขาดอีก <%= __needLeft.toLocaleString() %> แต้ม)"
                  <% } %>
                >
                  แลกแต้มเป็นเงิน (ขั้นต่ำ 100 แต้ม)
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="tabpane" id="tab-points">
        <div class="card">
            <div class="card-header">
            <div class="title">ยอดใช้จ่ายสะสม</div>
            <span class="pill lvl"><%= userDoc.levelName || `เลเวล ${userDoc.level || '1'}` %></span>
            </div>

            <%
              // ✅ ประกาศก่อนใช้งานเสมอ
              const __spent = (typeof agg !== 'undefined' && agg && typeof agg.totalSpent === 'number') ? agg.totalSpent : 0;
              const __level = Number(userDoc.level || 1);
              const __need  = [0, ...((levels||[]).map(l => Number(l.need||0)))];
              const __nextMax = __need[__level + 1] || __need.at(-1) || 1;
              const __pctRaw  = (__spent / __nextMax) * 100;
              const __pct     = Math.max(0, Math.min(100, +__pctRaw.toFixed(2)));

              // ✅ ถ้าจะโชว์ breakdown ให้ประกาศตัวแปรของมัน “หลังจาก” __spent แล้ว
              const __raw      = (agg && typeof agg.totalSpentRaw === 'number') ? agg.totalSpentRaw
                                  : (typeof userDoc.totalSpentRaw === 'number' ? userDoc.totalSpentRaw : 0);
              const __redeemed = (agg && typeof agg.redeemedSpent === 'number') ? agg.redeemedSpent
                                  : (typeof userDoc.redeemedSpent === 'number' ? userDoc.redeemedSpent : 0);
            %>

            <div class="form-grid">
              <div class="score-wrap">
                <div>
                  <div class="bignum">฿<%= __spent.toFixed(2) %></div>
                  <div class="subcap">ใช้จ่ายไปแล้ว</div>
                  <!-- (ออปชัน) breakdown -->
                  <div class="subcap" style="margin-top:6px">
                    ยอดดิบทั้งหมด: ฿<%= __raw.toLocaleString(undefined,{maximumFractionDigits:2}) %>
                    · แลกไปแล้ว: ฿<%= __redeemed.toLocaleString(undefined,{maximumFractionDigits:2}) %>
                    · ใช้คำนวณเลเวล: ฿<%= __spent.toLocaleString(undefined,{maximumFractionDigits:2}) %>
                  </div>
                </div>
                <div>
                  <div class="prog"><div class="fill" style="width:<%= __pct %>%"></div></div>
                  <div class="subcap" style="margin-top:6px">
                    เป้าหมายเลเวลถัดไป: ฿<%= (__nextMax || 0).toLocaleString() %> (<%= __pct %>%)
                  </div>
                </div>
              </div>
            </div>
        </div>

        <!-- ระดับบัญชี (แสดงทีละ 2 การ์ด) -->
        <div class="card">
            <div class="card-header"><div class="title">ข้อมูลระดับบัญชี</div></div>

            <div id="levelsTrack"><!-- เติมด้วย JS เดิม --></div>

            <div class="level-nav">
            <button class="btn" id="lvPrev" aria-label="ก่อนหน้า">‹</button>
            <button class="btn primary" id="lvNext" aria-label="ถัดไป">›</button>
            </div>
        </div>
      </div>

      <!-- NOTIFY -->
      <div class="tabpane" id="tab-notify">
        <div class="card">
          <div class="card-header"><div class="title">การแจ้งเตือน</div></div>
          <div class="form-grid"><p class="muted">จะเพิ่มภายหลัง</p></div>
        </div>
      </div>
    </div>
  </div>
</section>

<dialog id="bankModal" class="rt-modal">
  <div class="rt-card" style="min-width:380px">
    <h3 class="rt-title">เพิ่มบัญชีของฉัน</h3>

    <form id="bankForm" class="form-grid" style="padding:0;margin-top:8px">
      <label>ผู้ให้บริการ
        <select name="accountCode" class="fsel" required>
          <option value="">— เลือกธนาคาร/วอลเล็ท —</option>
          <option value="bbl">ธนาคารกรุงเทพ</option>
          <option value="kbank">ธนาคารกสิกรไทย</option>
          <option value="ktb">ธนาคารกรุงไทย</option>
          <option value="bay">ธนาคารกรุงศรีอยุธยา</option>
          <option value="scb">ธนาคารไทยพาณิชย์</option>
          <option value="tmb">ทหารไทยธนชาต (TTB)</option>
          <option value="cimb">ธนาคารซีไอเอ็มบีไทย</option>
          <option value="uob">ธนาคารยูโอบี</option>
          <option value="gsb">ธนาคารออมสิน</option>
          <option value="baac">ธ.เพื่อการเกษตรและสหกรณ์การเกษตร</option>
          <option value="kkb">ธนาคารเกียรตินาคินภัทร</option>
          <option value="lhfg">ธนาคารแลนด์ แอนด์ เฮ้าส์</option>
          <option value="icbc">ธนาคารไอซีบีซี (ไทย)</option>
          <option value="tisco">ธนาคารทิสโก้</option>
          <option value="tw">TrueMoney Wallet</option>
        </select>
      </label>

      <label>เลขบัญชี / เบอร์วอลเล็ท
        <input name="accountNumber" type="text" inputmode="numeric" placeholder="ตัวเลขเท่านั้น" required>
        <small class="muted sm">ธนาคาร 9–12 หลัก • TrueWallet มือถือ 10 หลักขึ้นต้น 0</small>
      </label>

      <label>ชื่อบัญชี
        <input name="accountName" type="text" placeholder="ชื่อ–นามสกุลตามบัญชี" required>
      </label>

      <div class="rt-actions" style="margin-top:6px">
        <button type="button" class="btn" id="bankCancel">ยกเลิก</button>
        <button type="submit" class="btn primary" id="bankSave">บันทึก</button>
      </div>
    </form>
  </div>
</dialog>

<style>
/* ===== Theme tokens (sync กับ layout.ejs: html[data-theme]) ===== */
:root{
  --bg:#0b0c0f;
  --surface:#121318;
  --surface-2:#171922;
  --line:#22252d;
  --text:#eaf0f8;
  --muted:#9aa6b2;
  --accent:#2b8cff;
  --accent-2:#5da3ff;
  --danger:#f11212e3;
  --success:#10b981;
  --balance:#10a0b9;
  --warn:#f59e0b;
  --shadow:0 10px 30px rgba(0,0,0,.35);
}
html[data-theme="light"]{
  --bg:#f6f8fb;
  --surface:#ffffff;
  --surface-2:#ffffff;
  --line:#e7edf5;
  --text:#111827;
  --danger:#f11212e3;
  --muted:#667085;
  --accent:#2563eb;
  --accent-2:#5b8cff;
  --shadow:0 12px 28px rgba(16,24,40,.08);
}

/* ===== Layout base ===== */
.page-title{margin:8px 0 18px;color:var(--text);font-weight:800;letter-spacing:.2px}
.page-title.center{display:block;text-align:center}

.acc-wrap{display:grid;grid-template-columns:300px 1fr;gap:22px}
@media (max-width:980px){.acc-wrap{grid-template-columns:1fr}}

/* ===== Sidebar summary ===== */
.acc-side .prof-card{
  background:linear-gradient(180deg,var(--surface),var(--surface-2));
  border:1px solid var(--line);
  border-radius:16px; padding:18px 16px; box-shadow:var(--shadow)
}
.prof-avatar{display:flex;justify-content:center;margin:4px 0 12px}
.prof-avatar img{
  width:108px;height:108px;object-fit:cover;border-radius:999px;
  box-shadow:0 6px 16px rgba(0,0,0,.28); border:3px solid rgba(255,255,255,.06)
}
.prof-name{font-weight:800;margin:.25rem 0 .35rem;font-size:1.05rem}
.prof-mail{color:var(--muted);font-size:.92rem;margin-bottom:.6rem;word-break:break-all}

.kv{display:flex;justify-content:space-between;gap:10px;margin:10px 0}
.pill{
  display:inline-flex;align-items:center;gap:6px;
  background:color-mix(in oklab,var(--accent) 10%, transparent);
  border:1px solid color-mix(in oklab,var(--accent) 25%, var(--line));
  color:var(--text); padding:6px 10px; border-radius:999px; font-weight:600
}
.pill.lvl{background:color-mix(in oklab,#f1c40f 16%, transparent);border-color:#f1c40f33;color:#f1c40f}

.badge{
  font-size:.78rem;padding:2px 8px;border-radius:999px;border:1px solid transparent
}
.badge.danger{background:color-mix(in oklab,var(--danger) 18%, transparent);border-color:#ff02027c;color:var(--danger)}
.badge.balance{background:color-mix(in oklab,var(--balance) 18%, transparent);border-color:#10b3b955;color:var(--balance)}
.badge.ok{background:color-mix(in oklab,var(--success) 18%, transparent);border-color:#10b98155;color:var(--success)}
.badge.warn{background:color-mix(in oklab,var(--warn) 18%, transparent);border-color:#f59e0b55;color:var(--warn)}

.badge2{
  font-family: Prompt; font-size:.98rem;padding:6px 10px;border-radius:999px;border:1px solid transparent
}
.badge2.ok{background:color-mix(in oklab,var(--success) 18%, transparent);border-color:#10b98155;color:var(--success)}

.muted{color:var(--muted)} .muted.sm{font-size:.84rem}

/* ===== Tabs ===== */
.tabs{display:flex;gap:10px;margin-bottom:12px;flex-wrap:wrap}
.tab{
  background:var(--surface);border:1px solid var(--line);
  border-radius:12px;padding:10px 14px;cursor:pointer;
  color:var(--text);font-weight:600;transition:all .15s ease
}
.tab:hover{border-color:color-mix(in oklab,var(--accent) 35%, var(--line))}
.tab.active{
  background:linear-gradient(180deg,var(--accent),var(--accent));
  border-color:color-mix(in oklab,var(--accent) 80%,#000 20%);
  color:#fff; box-shadow:0 6px 20px color-mix(in oklab,var(--accent) 30%, transparent)
}
.tabpane{display:none} .tabpane.show{display:block}

/* ===== Cards / Forms (ส่วน general เดิมใช้ต่อได้) ===== */
.card{
  background:linear-gradient(180deg,var(--surface),var(--surface-2));
  border:1px solid var(--line); border-radius:16px; box-shadow:var(--shadow)
}
.card-header{
  display:flex;justify-content:space-between;align-items:center;
  padding:16px 18px;border-bottom:1px solid var(--line)
}
.card .title{font-weight:800}
.card-actions{padding:14px 18px;border-top:1px solid var(--line);text-align:right}

.form-grid{display:grid;grid-template-columns:1fr;gap:14px;padding:16px 18px}
.form-grid.two{grid-template-columns:repeat(auto-fit,minmax(260px,1fr))}
label{display:flex;flex-direction:column;gap:6px;color:var(--text)}
input[type=text],input[type=email],input[type=password]{
  background:color-mix(in oklab,var(--surface) 70%, #000 30%);
  border:1px solid var(--line);border-radius:12px;padding:11px 12px;color:var(--text)
}
input:disabled{opacity:.75;cursor:not-allowed}
.email-row{display:flex;gap:8px;align-items:center}
.otp-row{display:flex;gap:8px;align-items:center}

/* ===== Buttons ===== */
.btn{
  border-radius:12px;border:1px solid var(--line);
  padding:10px 12px;cursor:pointer;background:var(--surface);color:var(--text);font-weight:600
}
.btn.primary{
  background:linear-gradient(180deg,var(--accent),var(--accent));
  color:#fff;border-color:color-mix(in oklab,var(--accent) 80%,#000 20%)
}
.btn.ghost{background:transparent;color:var(--success)}
.btn-line{
  display:inline-flex;align-items:center;gap:8px;border:1px dashed var(--line);
  padding:7px 11px;border-radius:10px;cursor:pointer
}
/* ปุ่มปิดการใช้งานให้ดู “ปิด” ชัดเจน และกันคลิก */
.btn[disabled],
.btn:disabled,
[aria-disabled="true"].btn {
  opacity: .5;
  cursor: not-allowed;
  pointer-events: none;
  box-shadow: none;
  filter: grayscale(.2);
}

/* ===== Progress (tab-points) ===== */
.score-wrap{display:grid;grid-template-columns:260px 1fr;gap:18px}
@media (max-width:720px){.score-wrap{grid-template-columns:1fr}}
.bignum{font-size:2rem;font-weight:900;letter-spacing:.2px}
.subcap{color:var(--muted);margin-top:4px}

.prog{height:12px;border-radius:999px;background:color-mix(in oklab,#94a3b8 20%, transparent);overflow:hidden}
.prog .fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent-2))}

/* ===== Levels (2 cols “carousel” area) ===== */
#levelsTrack{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px;padding:14px 18px}
@media (max-width:880px){#levelsTrack{grid-template-columns:1fr}}
.level{
  background:var(--surface);border:1px solid var(--line);border-radius:14px;padding:14px 14px
}
.level .head{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
.chip{
  display:inline-flex;align-items:center;gap:6px;padding:6px 10px;border-radius:999px;
  background:color-mix(in oklab,var(--accent) 12%, transparent);
  border:1px solid color-mix(in oklab,var(--accent) 28%, var(--line)); font-weight:700
}
.rate{background:#0b1220;color:#fff;border:1px solid rgba(255, 255, 255, .15);border-radius:8px;padding:4px 8px;font-size:.85rem}
html[data-theme="light"] .rate{background:#0f172a}
.level ul{margin:8px 0 0 0;padding:0 0 0 18px;color:var(--text)}
.level ul li{margin:.42rem 0}

.level-nav{display:flex;justify-content:center;gap:10px;padding:8px 0 16px}
.level-nav .btn{min-width:44px}

/* --- Static (read-only) display field --- */
.static-input{
  display:flex; align-items:center; min-height:22px;
  padding:4px 12px;
  border:1px solid var(--line);
  border-radius:12px;
  background:color-mix(in oklab, var(--surface) 70%, #000 30%);
  color:var(--text);
  font-weight:300;
  letter-spacing:.2px;
}
html[data-theme="light"] .static-input{
  background:color-mix(in oklab, #f2f4f8 60%, var(--surface) 40%);
}

.prog .fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent-2)); min-width: 2px}
.prof-mail{
  display: flex;
  align-items: center;
  gap: 8px;
}
.prof-mail .badge{
  margin-left: auto; /* ดัน badge ไปชิดขวา */
}
/* บังคับซ่อนทุก element ที่ติด hidden */
[hidden] { display: none !important; }

/* เฉพาะ otp-row ก็กันไว้ด้วย */
.otp-row[hidden] { display: none !important; }

.pw-field { position: relative; }
.pw-field input { width: 100%; padding-right: 40px; }

.pw-toggle{
  position:absolute; right:8px; top:50%; transform:translateY(-50%);
  width:34px; height:34px; display:grid; place-items:center;
  background:transparent; border:0; cursor:pointer; opacity:.7;
}
.pw-toggle:hover{ opacity:1; }
.pw-toggle svg{ width:18px; height:18px; }
/* ===== Bank account list ===== */
.bank-list{ padding: 12px 16px; }
.bank-item{
  display:flex; align-items:flex-start; gap:12px;
  padding: 8px 2px;
}
.bank-meta{ display:flex; flex-direction:column; gap:4px; }
.bank-name{ font-weight:800; color:var(--text); }
.bank-no{ font-size:1.05rem; font-weight:900; letter-spacing:.2px; }
.bank-owner{ font-size:.92rem; }
.bank-sep{ height:1px; background:var(--line); margin:8px 0; opacity:.8; }
.bank-empty{ padding:8px 2px; }

.card-header .actions{display:flex;align-items:center;gap:8px}
dialog.rt-modal{border:0;background:transparent;padding:0}
dialog.rt-modal::backdrop{background:rgba(0,0,0,.5);backdrop-filter:blur(6px)}
.rt-card{background:var(--surface);color:var(--text);border:1px solid var(--line);
  border-radius:16px;padding:16px;box-shadow:var(--shadow)}
.rt-title{margin:0 0 6px;font-weight:900;font-size:18px}
.fsel{background:color-mix(in oklab,var(--surface) 70%, #000 30%);
  border:1px solid var(--line);border-radius:12px;padding:10px 12px;color:var(--text)}
</style>

<script>
(() => {
  // ====== Eye icons (ขาว-ดำ เรียบ ๆ)
  const ICON_EYE = `
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path fill="currentColor" d="M12 5c-5.5 0-9.5 4.5-10.7 6 1.2 1.5 5.2 6 10.7 6s9.5-4.5 10.7-6C21.5 9.5 17.5 5 12 5zm0 10a4 4 0 1 1 0-8 4 4 0 0 1 0 8z"/>
    </svg>`;
  const ICON_EYE_OFF = `
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path fill="currentColor" d="M2.8 1.4 1.4 2.8l3.1 3.1C2.8 7.3 1.5 8.9 1.3 9.2l-.3.4.3.4C2.5 11.5 6.5 16 12 16c1.7 0 3.2-.4 4.6-1.1l3.6 3.6 1.4-1.4L2.8 1.4zM12 14c-3.9 0-7.2-3-8.8-4.8C4.2 7.8 7.2 5 12 5c2 0 3.8.6 5.4 1.7l-2 2A4 4 0 0 0 10.7 8l-2 2A4 4 0 0 0 12 14z"/>
    </svg>`;

  // ติดไอคอนเริ่มต้นให้ปุ่มทุกตัว
  document.querySelectorAll('.pw-toggle').forEach(btn => { btn.innerHTML = ICON_EYE; });

  // toggle แสดง/ซ่อนรหัสผ่าน
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('.pw-toggle');
    if (!btn) return;
    const input = btn.previousElementSibling; // input อยู่ก่อนปุ่ม
    if (!input) return;
    const show = input.type === 'password';
    input.type = show ? 'text' : 'password';
    btn.setAttribute('aria-pressed', show ? 'true' : 'false');
    btn.innerHTML = show ? ICON_EYE_OFF : ICON_EYE;
  });

  // ====== ตรวจรหัสผ่านแบบเรียลไทม์ + คุมปุ่ม submit
  const form = document.getElementById('formPassword');
  const btnSubmit = form?.querySelector('button[type="submit"]');
  const cur = form?.querySelector('input[name="currentPassword"]');
  const pw1 = form?.querySelector('input[name="newPassword"]');
  const pw2 = form?.querySelector('input[name="newPassword2"]');
  const msg = document.getElementById('pwMismatchMsg');
  const MIN = 6;

  function validate() {
    const v0 = (cur?.value || '').trim();
    const v1 = (pw1?.value || '').trim();
    const v2 = (pw2?.value || '').trim();

    const tooShort = v1.length > 0 && v1.length < MIN;
    const mismatch = v2.length > 0 && v1 !== v2;

    // แสดง/ซ่อนข้อความเตือน
    msg.style.display = mismatch ? '' : 'none';

    const ok = v0.length >= 1 && v1.length >= MIN && v2.length >= MIN && !mismatch && !tooShort;
    if (btnSubmit) btnSubmit.disabled = !ok;
  }

  ['input','blur'].forEach(ev => {
    cur?.addEventListener(ev, validate);
    pw1?.addEventListener(ev, validate);
    pw2?.addEventListener(ev, validate);
  });
  form?.addEventListener('submit', (e) => {
    validate();
    if (btnSubmit?.disabled) e.preventDefault();
  });

  // เริ่มต้นปิดปุ่มไว้ก่อน
  validate();
})();
</script>

<script>
(() => {
  const $ = s => document.querySelector(s);
  const pick = id => document.getElementById(id);

  // helper เรียก modal แบบย่อ (ถ้า showMsg ไม่มี ให้ fallback เป็น alert)
  const toast = (variant, title, text) => {
    if (window.showMsg) window.showMsg({ variant, title, text });
    else alert(`${title}\n${text || ''}`);
  };

  // เปลี่ยน ok() ให้ตั้งหัวข้อ "สำเร็จ" เสมอ แล้วเอา argument เป็นรายละเอียด
  const ok   = (detail='ดำเนินการเรียบร้อย') => toast('success', 'สำเร็จ', detail);
  const warn = (title, text='')  => toast('warn',   title, text);
  const fail = (title, text='')  => toast('error',  title, text);
  const info = (title, text='')  => toast('info',   title, text);

  // ===== Data for levels (ใช้ของเซิร์ฟเวอร์ถ้ามี ไม่งั้นใช้ mock) =====
  window.__LEVELS__ = <%- JSON.stringify(levels || []) %>;
  if (!Array.isArray(window.__LEVELS__) || !window.__LEVELS__.length) {
    window.__LEVELS__ = [
      { name:'เลเวล 1',  need:0,       rate:'฿0.05', perks:['โบนัสเติมเงิน 0%','ส่วนลดทุกคำสั่งซื้อ 0%','ช่วยเหลือผ่านตั๋ว','ช่วยเหลือผ่าน Line Official Account'] },
      { name:'เลเวล 2',  need:5000,    rate:'฿0.1',  perks:['โบนัสเติมเงิน 0%','ส่วนลดทุกคำสั่งซื้อ 0%','ช่วยเหลือผ่านตั๋ว','ช่วยเหลือผ่าน Line Official Account'] },
      { name:'เลเวล 3',  need:10000,   rate:'฿0.15', perks:['โบนัสเติมเงิน 0%','ส่วนลดทุกคำสั่งซื้อ 0%','ช่วยเหลือผ่านตั๋ว','ช่วยเหลือผ่าน Line Official Account'] },
      { name:'เลเวล 4',  need:30000,   rate:'฿0.2',  perks:['โบนัสเติมเงิน 0%','ส่วนลดทุกคำสั่งซื้อ 0%','ช่วยเหลือผ่านตั๋ว','ให้ความสำคัญการช่วยเหลือ'] },
      { name:'เลเวล 5',  need:50000,   rate:'฿0.25', perks:['โบนัสเติมเงิน 0%','ส่วนลดทุกคำสั่งซื้อ 0%','ช่วยเหลือผ่านตั๋ว','ให้ความสำคัญการช่วยเหลือ'] },
      { name:'Retail',   need:80000,   rate:'฿0.3',  perks:['โบนัสเติมเงิน 0%','ส่วนลดทุกคำสั่งซื้อ 0%','ช่วยเหลือผ่านตั๋ว','ให้ความสำคัญการช่วยเหลือ'] },
      { name:'Wholesale',need:175000,  rate:'฿0.5',  perks:['โบนัสเติมเงิน 0%','ส่วนลดทุกคำสั่งซื้อ 0%','ช่วยเหลือผ่านตั๋ว','ให้ความสำคัญการช่วยเหลือ'] },
      { name:'Reseller', need:700000,  rate:'฿0.8',  perks:['โบนัสเติมเงิน 0%','ส่วนลดทุกคำสั่งซื้อ 0%','ช่วยเหลือผ่านตั๋ว','ให้ความสำคัญการช่วยเหลือสูง'] },
      { name:'VIP',      need:1000000, rate:'฿1',    perks:['โบนัสเติมเงิน 0%','ส่วนลดทุกคำสั่งซื้อ 0%','ช่วยเหลือผ่านตั๋ว','ให้ความสำคัญการช่วยเหลือสูง'] },
      { name:'Legendary',need:5000000, rate:'฿15',   perks:['โบนัสเติมเงิน 0%','ส่วนลดทุกคำสั่งซื้อ 0%','ช่วยเหลือผ่านตั๋ว','ให้ความสำคัญการช่วยเหลือสูงสุด'] }
    ];
  }

  // Tabs
  document.querySelectorAll('.tabs .tab').forEach(btn=>{
    btn.addEventListener('click', ()=>{
      document.querySelectorAll('.tabs .tab').forEach(b=>b.classList.remove('active'));
      document.querySelectorAll('.tabpane').forEach(p=>p.classList.remove('show'));
      btn.classList.add('active');
      document.getElementById(btn.dataset.tab)?.classList.add('show');
    });
  });

  const btnAvatar = pick('btnChangeAvatar');
  const input = pick('avatarInput');
  const img = pick('avatarPreview');

  // เคล็ดลับ: อนุญาต GIF, เช็คขนาดก่อนอัปโหลด
  const MAX_MB = 10;
  const ACCEPT = /image\/(png|jpe?g|webp|gif)/i;

  let tmpUrl = null;

  // กดปุ่ม → เปิด file chooser
  btnAvatar?.addEventListener('click', () => input?.click());

  // เลือกไฟล์ → พรีวิวทันที + อัปโหลดอัตโนมัติ
  input?.addEventListener('change', async (e) => {
    const f = e.currentTarget.files?.[0];
    if (!f) return;

    // validate เบื้องต้น
    if (!ACCEPT.test(f.type)) {
      return (window.showMsg
        ? showMsg({ variant:'warn', title:'ไฟล์ไม่รองรับ', text:'อนุญาตเฉพาะ PNG, JPG, WEBP และ GIF' })
        : alert('ไฟล์ไม่รองรับ (PNG/JPG/WEBP/GIF เท่านั้น)'));
    }
    if (f.size > MAX_MB * 1024 * 1024) {
      return (window.showMsg
        ? showMsg({ variant:'warn', title:'ไฟล์ใหญ่เกินไป', text:`ขนาดสูงสุด ${MAX_MB}MB` })
        : alert(`ไฟล์ใหญ่เกินไป (สูงสุด ${MAX_MB}MB)`));
    }

    // พรีวิวทันที (GIF แสดงอนิเมชันได้)
    if (tmpUrl) URL.revokeObjectURL(tmpUrl);
    tmpUrl = URL.createObjectURL(f);
    img.src = tmpUrl;

    // ปิดปุ่มกันกดซ้ำช่วงอัปโหลด
    btnAvatar.disabled = true;

    // อัปโหลดไป /account/profile (multipart/form-data)
    const fd = new FormData();
    fd.append('avatar', f);

    try {
      const r = await fetch('/account/profile', { method: 'POST', body: fd });
      // ถ้าเซิร์ฟเวอร์ส่ง JSON (ตามโค้ดของคุณ) ให้ parse
      let j = null;
      try { j = await r.json(); } catch {}

      if (!r.ok || !j?.ok) {
        // ย้อนรูปพรีวิวถ้าอยากทำ (ข้ามได้)
        (window.showMsg
          ? showMsg({ variant:'error', title:'อัปโหลดไม่สำเร็จ', text: j?.error || '' })
          : alert('อัปโหลดไม่สำเร็จ'));
        return;
      }

      // ใช้ URL กันแคชที่เซิร์ฟเวอร์ส่งกลับมา เพื่อให้เห็นผลทันที
      if (j.user?.avatarUrl) img.src = j.user.avatarUrl;

      // ถ้ายังไม่ได้ยืนยันอีเมล โชว์ช่อง OTP
      if (j.user?.email && !j.user?.emailVerified) {
        document.getElementById('otpArea')?.removeAttribute('hidden');
      }

      // แจ้งสำเร็จ (ไม่ต้องรีเฟรชก็ได้)
      (window.showMsg
        ? showMsg({ variant:'success', title:'สำเร็จ', text:'อัปโหลดรูปโปรไฟล์แล้ว' })
        : alert('อัปโหลดสำเร็จ'));

      // ถ้าต้องการ sync ส่วนอื่น ๆ บนหน้าแบบชัวร์ ๆ:
      // setTimeout(()=> location.replace('/account'), 400);

    } catch (err) {
      (window.showMsg
        ? showMsg({ variant:'error', title:'เครือข่ายมีปัญหา', text:'โปรดลองใหม่อีกครั้ง' })
        : alert('อัปโหลดไม่สำเร็จ: เครือข่ายมีปัญหา'));
    } finally {
      btnAvatar.disabled = false;
      // reset input ให้เลือกไฟล์เดิมซ้ำได้
      input.value = '';
    }
  });

  // Change password
  $('#formPassword')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const form = e.currentTarget;
    const btn  = form.querySelector('button[type=submit]');
    btn.disabled = true;

    const fd   = new FormData(form);
    const body = Object.fromEntries(fd.entries());

    // เช็คก่อนยิง API
    if ((body.newPassword || '') !== (body.newPassword2 || '')) {
      fail('เปลี่ยนรหัสไม่สำเร็จ', '⚠️รหัสผ่านใหม่ทั้งสองช่องไม่ตรงกัน');
      btn.disabled = false;
      return;
    }

    try {
      const r = await fetch('/account/password', {
        method: 'POST',
        headers: { 'Content-Type':'application/json' },
        body: JSON.stringify(body)
      });

      let j = null;
      try { j = await r.json(); } catch {}

      if (r.ok && j?.ok) {
        form.reset();

        // ✅ แสดงผลลัพธ์ แล้ว redirect เมื่อปิดโมดอล (ถ้ามี onClose)
        if (window.showMsg) {
          window.showMsg({
            variant: 'success',
            title: 'สำเร็จ',
            text: 'เปลี่ยนรหัสผ่านเรียบร้อย',
            onClose: () => window.location.replace('/account')
          });
          // safety net: ไม่ว่าปุ่มจะกดหรือไม่ ให้เปลี่ยนหน้าใน 2 วิ
          setTimeout(() => { try{ window.location.replace('/account'); }catch{} }, 300);
        } else {
          alert('เปลี่ยนรหัสผ่านเรียบร้อย');
          window.location.replace('/account');
        }
        return;
      }

      const msg = j?.error || (r.status >= 500 ? 'เซิร์ฟเวอร์มีปัญหา' : '⚠️ดำเนินการไม่สำเร็จเครือข่ายมีปัญหา');
      fail('เปลี่ยนรหัสไม่สำเร็จ', msg);

    } catch {
      fail('เปลี่ยนรหัสผ่านไม่สำเร็จ', '⚠️เครือข่ายมีปัญหา');
    } finally {
      btn.disabled = false;
    }
  });

  // OTP: request
  const btnSendOtp   = $('#btnSendOtp');
  const otpArea      = $('#otpArea');
  const otpCodeInput = $('#otpCode');

  // helper: dialog
  const show = (variant, title, text, icon) =>
    window.showMsg?.({ variant, title, text, icon });

  // helper: ดึงอีเมลจาก data-attr หรือ input[name="email"]
  function getEmail() {
    const dataEmail = btnSendOtp?.dataset.email?.trim().toLowerCase();
    if (dataEmail) return dataEmail;
    const field = $('input[name="email"]');
    return (field?.value || '').trim().toLowerCase();
  }

  // helper: เคานท์ดาวน์ตอนโดนคูลดาวน์
  function startCooldown(seconds) {
    if (!btnSendOtp || !Number.isFinite(seconds) || seconds <= 0) return;
    const original = btnSendOtp.textContent;
    btnSendOtp.disabled = true;

    let left = Math.ceil(seconds);
    btnSendOtp.textContent = `ส่งใหม่ได้ใน ${left}s`;

    const t = setInterval(() => {
      left -= 1;
      if (left <= 0) {
        clearInterval(t);
        btnSendOtp.disabled = false;
        btnSendOtp.textContent = original || 'ส่งรหัสยืนยัน';
        return;
      }
      btnSendOtp.textContent = `ส่งใหม่ได้ใน ${left}s`;
    }, 1000);
  }

  // ===== OTP: request =====
  btnSendOtp?.addEventListener('click', async () => {
    const email = getEmail();
    if (!email) {
      show('warn', 'กรอกอีเมลก่อน', 'โปรดกรอกอีเมลที่ใช้สมัคร', '⚠️');
      return;
    }

    btnSendOtp.disabled = true;
    try {
      const r = await fetch('/otp/send', {
        method: 'POST',
        headers: { 'Content-Type':'application/json' },
        body: JSON.stringify({ email, channel: 'email' })
      });

      // แยก handling สถานะ 429 (คูลดาวน์) ก่อน
      if (r.status === 429) {
        const j = await r.json().catch(()=>({}));
        // พยายามดึงจำนวนวินาทีจากข้อความ error เช่น "โปรดรอ 42s ก่อนขอรหัสใหม่"
        const m = /\s(\d+)s\s/.exec(j?.error || '');
        const waitSec = m ? Number(m[1]) : 60;
        show('warn', 'ขอรหัสถี่เกินไป', j?.error || 'โปรดรอสักครู่ก่อนขอใหม่', '⏳');
        startCooldown(waitSec);
        return;
      }

      const j = await r.json().catch(()=>({}));

      if (!r.ok || !j?.ok) {
        show('error', 'ส่งรหัสไม่สำเร็จ', j?.error || 'โปรดลองใหม่อีกครั้ง', '✖');
        return;
      }

      // สำเร็จ → โชว์ช่อง OTP + โฟกัส + แจ้งเตือน
      const otpArea = document.getElementById('otpArea');
      if (otpArea) otpArea.hidden = false;
      otpCodeInput?.focus();

      const ttlSec = Number(j.ttl || 300);
      const ttlMin = Math.max(1, Math.round(ttlSec/60));
      show('success', 'ส่งรหัสแล้ว', `เราได้ส่งรหัสไปยังอีเมลของคุณ (ใช้ได้ประมาณ ${ttlMin} นาที)`, '✅');

      // ออปชัน: ใส่คูลดาวน์เบา ๆ เพื่อกันเผลอกดซ้ำทันที (เช่น 30s)
      startCooldown(30);
    } catch (e) {
      show('error', 'เครือข่ายมีปัญหา', 'โปรดลองใหม่อีกครั้ง', '✖');
    } finally {
      // ถ้าติดคูลดาวน์อยู่จะยัง disabled ตาม startCooldown
      if (!btnSendOtp.hasAttribute('disabled')) btnSendOtp.disabled = false;
    }
  });

  // OTP: verify
  const verifyBtn = document.getElementById('btnVerifyOtp');
  verifyBtn?.addEventListener('click', async () => {
    const code = (document.getElementById('otpCode')?.value || '').trim();
    if (code.length < 4) return warn('รหัสไม่ครบ', 'กรุณากรอกรหัสให้ครบ');
    verifyBtn.disabled = true;
    try{
      const r = await fetch('/account/email/verify', {
        method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ code })
      });
      const j = await r.json();
      if (!j.ok) { verifyBtn.disabled = false; return fail('ยืนยันไม่สำเร็จ', j.error || ''); }
      ok('ยืนยันอีเมลเรียบร้อย');
      window.location.reload();
    } catch {
      verifyBtn.disabled = false;
      fail('ยืนยันไม่สำเร็จ', 'เครือข่ายมีปัญหา');
    }
  });

  // ===== Redeem Points =====
  const btn = document.getElementById('btnRedeemPoints');
  if (!btn) return;

  btn.addEventListener('click', async () => {
    if (btn.disabled) return;
    btn.disabled = true;

    // ใส่สถานะโหลดนิดหน่อย
    const oldLabel = btn.textContent;
    btn.textContent = 'กำลังแลก…';

    try {
      const r = await fetch('/account/points/redeem', { method: 'POST' });
      const j = await r.json();

      if (!r.ok || !j?.ok) {
        fail('แลกแต้มไม่สำเร็จ', j?.error || 'โปรดลองใหม่');
        return;
      }

      // ====== อัปเดต UI ทันที (ไม่ต้องรีเฟรช) ======
      // 1) คะแนนคงเหลือ
      const pointsNum = Number(j.remainPoints || 0);
      const pointsEl = document.querySelector('[data-id="points-num"]');
      if (pointsEl) {
        pointsEl.innerHTML = `${pointsNum.toLocaleString(undefined,{ maximumFractionDigits: 2})} คะแนน`;
      }

      // 2) เรท/มูลค่าแลกได้ (ถ้าในหน้าใส่ตำแหน่ง badge เหล่านี้ไว้แล้ว)
      const rateEl = document.querySelector('[data-id="point-rate"]'); // <span data-id="point-rate">
      if (rateEl) rateEl.textContent = `฿${(j.rate || 0).toLocaleString()} / 1 แต้ม`;

      const valEl = document.querySelector('[data-id="point-value"]'); // <span data-id="point-value">
      if (valEl) valEl.textContent = `≈ ฿${(j.pointValueTHB || 0).toLocaleString(undefined,{ maximumFractionDigits: 2 })}`;

      // 3) ปุ่มแลก (ถ้าคะแนน < 100 ให้ปิด)
      if (pointsNum < 100) {
        btn.classList.remove('primary');
        btn.setAttribute('disabled', 'disabled');
      }

      // 4) แจ้งผลลัพธ์
      const added = Number(j.addedBalance || 0);
      if (window.showMsg) {
        window.showMsg({
          variant: 'success',
          title: 'สำเร็จ',
          text: `แลก ${j.redeemed} แต้ม เป็น ฿${added.toLocaleString(undefined,{ maximumFractionDigits: 2 })} แล้ว`,
          // ถ้าอยากรีเฟรชให้แน่ใจว่าส่วนอื่น ๆ ตรงกันก็ปล่อย redirect นี้ไว้ได้
          onClose: () => window.location.replace('/account')
        });
        // safety net เผื่อผู้ใช้ไม่ปิด modal
        setTimeout(() => { try { window.location.replace('/account'); } catch {} }, 300);
      } else {
        alert(`แลกสำเร็จ: ${j.redeemed} แต้ม → ฿${added.toLocaleString(undefined,{ maximumFractionDigits: 2 })}`);
        window.location.replace('/account');
      }
    } catch {
      fail('แลกแต้มไม่สำเร็จ', 'เครือข่ายมีปัญหา');
    } finally {
      // คืนปุ่มถ้าไม่ได้ redirect ทันที
      btn.textContent = oldLabel;
      // อย่าปลดล็อกถ้าคะแนนต่ำกว่า 100 แล้ว—ปล่อยให้ disabled ต่อไป
      if (!btn.hasAttribute('disabled')) btn.disabled = false;
    }
  });

  // Levels renderer (2 columns slide)
  const track = document.getElementById('levelsTrack');
  const pages = [];
  const _levels = window.__LEVELS__ || [];
  for (let i=0;i<_levels.length;i+=2) pages.push(_levels.slice(i,i+2));
  let page = 0;

  function render() {
    track.innerHTML = '';
    const pickPercent = s => {
      const m = (s || '').match(/-?\d+(?:\.\d+)?%/);
      return m ? m[0] : (s || '—');
    };

    (pages[page] || []).forEach(lv => {
      const perks = lv.perks || [];
      const bonusTxt    = perks.find(p => p.includes('โบนัสเติมเงิน')) || '';
      const discountTxt = perks.find(p => p.includes('ส่วนลดทุกคำสั่งซื้อ')) || '';
      const bonusVal    = pickPercent(bonusTxt);
      const discountVal = pickPercent(discountTxt);

      track.insertAdjacentHTML('beforeend', `
        <div class="prof-card" style="padding:14px">
          <div class="kv" style="margin-bottom:8px">
            <div><strong>${lv.name}</strong></div>
            <div><span class="badge balance">ใช้จ่าย &gt; ฿${(lv.need||0).toLocaleString()}</span></div>
          </div>
          <div class="kv"><div>อัตราการแลกเปลี่ยน ↔ (Point × Rate)</div><div><span class="badge balance">${lv.rate}</span></div></div>
          <div class="kv"><div>โบนัสเติมเงิน</div><div><span class="badge warn">${bonusVal}</span></div></div>
          <div class="kv"><div>ส่วนลดทุกคำสั่งซื้อ</div><div><span class="badge warn">${discountVal}</span></div></div>
          ${perks.filter(p => !p.includes('โบนัสเติมเงิน') && !p.includes('ส่วนลดทุกคำสั่งซื้อ'))
                 .map(p => `<div class="muted" style="margin:6px 0">• ${p}</div>`).join('')}
        </div>
      `);
    });
  }
  const btnOpen = document.getElementById('btnAddBank');
  const modal   = document.getElementById('bankModal');
  const form    = document.getElementById('bankForm');
  const btnCancel = document.getElementById('bankCancel');
  const btnSave   = document.getElementById('bankSave');
  const listView  = document.getElementById('bankListView');
  const emptyMsg  = document.getElementById('bankEmptyMsg');

  const BANK_LABELS = {
    bbl: 'ธนาคารกรุงเทพ',
    kbank: 'ธนาคารกสิกรไทย',
    ktb: 'ธนาคารกรุงไทย',
    bay: 'ธนาคารกรุงศรีอยุธยา',
    scb: 'ธนาคารไทยพาณิชย์',
    tmb: 'ทหารไทยธนชาต (TTB)',
    cimb: 'ธนาคารซีไอเอ็มบีไทย',
    uob: 'ธนาคารยูโอบี',
    gsb: 'ธนาคารออมสิน',
    baac: 'ธ.เพื่อการเกษตรและสหกรณ์การเกษตร',
    kkb: 'ธนาคารเกียรตินาคินภัทร',
    lhfg: 'ธนาคารแลนด์ แอนด์ เฮ้าส์',
    icbc: 'ธนาคารไอซีบีซี (ไทย)',
    tisco: 'ธนาคารทิสโก้',
    tw: 'TrueMoney Wallet'
  };

  function maskNumber(code, raw) {
    const digits = (raw || '').replace(/[^\d]/g,'');
    if (code === 'TRUEWALLET') {
      return /^0\d{9}$/.test(digits) ? `${digits.slice(0,3)}-${digits.slice(3,6)}-${digits.slice(6)}` : raw;
    }
    if (digits.length >= 9) {
      const a=digits.slice(0,3), b=digits.slice(3,4), c=digits.slice(4,-1), d=digits.slice(-1);
      return `${a}-${b}-${c}-${d}`;
    }
    return raw;
  }

  btnOpen?.addEventListener('click', () => {
    if (!modal.open) modal.showModal();
    form.reset();
    form.accountCode.focus();
  });
  btnCancel?.addEventListener('click', () => modal.close());
  modal?.addEventListener('cancel', e => { e.preventDefault(); modal.close(); });

  form?.accountNumber?.addEventListener('input', e => {
    e.target.value = e.target.value.replace(/[^\d]/g,'').slice(0,12);
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btnSave.disabled = true;

    const code = (form.accountCode.value || '').trim();
    const number = (form.accountNumber.value || '').trim();
    const name = (form.accountName.value || '').trim();

    // client-validate
    const digits = number.replace(/[^\d]/g,'');
    if (!code) { window.showMsg?.({variant:'warn',title:'กรุณาเลือกผู้ให้บริการ'}); btnSave.disabled=false; return; }
    if (!name) { window.showMsg?.({variant:'warn',title:'กรุณากรอกชื่อบัญชี'}); btnSave.disabled=false; return; }
    if (code === 'TRUEWALLET') {
      if (!/^0\d{9}$/.test(digits)) { window.showMsg?.({variant:'warn',title:'เบอร์วอลเล็ทไม่ถูกต้อง',text:'ต้องขึ้นต้น 0 และยาว 10 หลัก'}); btnSave.disabled=false; return; }
    } else {
      if (!/^\d{10,15}$/.test(digits)) { window.showMsg?.({variant:'warn',title:'เลขบัญชีไม่ถูกต้อง',text:'ต้องเป็นตัวเลข 9–12 หลัก'}); btnSave.disabled=false; return; }
    }

    try {
      const r = await fetch('/account/bank/add', {
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ accountCode:code, accountNumber:digits, accountName:name })
      });
      const j = await r.json().catch(()=>({}));
      if (!r.ok || !j?.ok) {
        window.showMsg?.({variant:'error',title:'เพิ่มบัญชีไม่สำเร็จ',text:j?.error||'โปรดลองใหม่'});
        btnSave.disabled=false; return;
      }

      // อัปเดต UI
      modal.close();
      const itemHtml = `
        <div class="bank-item" data-code="${code}" data-number="${digits}">
          <div class="bank-meta">
            <div class="bank-name"><span class="badge ${code==='TRUEWALLET'?'warn':'balance'}">${BANK_LABELS[code]||code}</span></div>
            <div class="bank-no">${maskNumber(code, digits)}</div>
            <div class="bank-owner muted">ชื่อบัญชี: ${name || '-'}</div>
          </div>
        </div>`;
      // ลบข้อความว่าง + คั่นเส้นถ้ามีรายการอยู่ก่อน
      emptyMsg?.remove();
      if (listView?.lastElementChild && listView.lastElementChild.classList.contains('bank-item')) {
        listView.insertAdjacentHTML('beforeend','<div class="bank-sep"></div>');
      }
      listView?.insertAdjacentHTML('beforeend', itemHtml);

      window.showMsg?.({variant:'success',title:'สำเร็จ',text:'เพิ่มบัญชีแล้ว'});
      // ปิดปุ่มถ้าครบ 2
      const count = listView.querySelectorAll('.bank-item').length;
      if (count >= 2) btnOpen.disabled = true;

    } catch {
      window.showMsg?.({variant:'error',title:'เครือข่ายมีปัญหา',text:'โปรดลองใหม่อีกครั้ง'});
    } finally {
      btnSave.disabled = false;
    }
  });
  render();
  document.getElementById('lvPrev')?.addEventListener('click', () => { page = (page-1+pages.length)%pages.length; render(); });
  document.getElementById('lvNext')?.addEventListener('click', () => { page = (page+1)%pages.length; render(); });
})();
</script>


