  <!-- Bridge: sync data-theme -> CSS variables (เหมือน index.ejs) -->
  <script>
    (() => {
      const html = document.documentElement;

      const PALETTE_LIGHT = Object.assign({
        primary:'#16a34a', accent:'#7c3aed', dark:'#0e314c', muted:'#6084a4',
        surface:'#f7fafd', surface2:'#ffffff',
        gradient:'linear-gradient(135deg,#22c55e 0%, #06b6d4 100%)'
      }, (window.THEME_LIGHT||{}));

      const PALETTE_DARK = Object.assign({
        primary:'#22d3ee', accent:'#a78bfa', dark:'#e6edf3', muted:'#9fb6c6',
        surface:'#0b1620', surface2:'#0f1e2b',
        gradient:'linear-gradient(135deg,#06b6d4 0%, #14b8a6 100%)'
      }, (window.THEME_DARK||{}));

      function setVars(p){
        const s = html.style;
        s.setProperty('--theme-primary',   p.primary);
        s.setProperty('--theme-accent',    p.accent);
        s.setProperty('--theme-dark',      p.dark);
        s.setProperty('--theme-muted',     p.muted);
        s.setProperty('--theme-surface',   p.surface);
        s.setProperty('--theme-surface-2', p.surface2);
        s.setProperty('--theme-gradient',  p.gradient);
        html.setAttribute('data-bs-theme', html.getAttribute('data-theme')==='dark'?'dark':'light');
      }
      function apply(){ setVars(html.getAttribute('data-theme')==='dark' ? PALETTE_DARK : PALETTE_LIGHT); }
      apply();
      window.addEventListener('themechange', apply);

      window.ThemeBridge = {
        setLight(v){ Object.assign(PALETTE_LIGHT, v||{}); apply(); },
        setDark(v){  Object.assign(PALETTE_DARK,  v||{}); apply(); }
      };
    })();
  </script>

