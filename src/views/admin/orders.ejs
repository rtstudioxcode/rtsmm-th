<% const pageTitle = "Admin | รายการการสั่งออเดอร์ทั้งหมด"; %>
<% bodyClass = 'orders-wide'; %>
<%
function decideDisplaySSR(o){
  const qty = Number(o.quantity)||0;
  const st  = String(o.status||'').toLowerCase();

  if (st === 'canceled') {
    return { label: 'ยกเลิก', donePct: 0, showPct: false, isDone: false };
  }

  if (st === 'canceling') {
    return { label: 'กำลังยกเลิก…', donePct: 0, showPct: false, isDone: false };
  }
  
  if (st === 'partial') {
    return { label: 'คืนบางส่วน', donePct: 0, showPct: false, isDone: false };
  }

  const isWaiting =
    st === 'processing' &&
    (o.progress == null) &&
    ((typeof o.remains === 'number' ? o.remains >= qty : true) || o.currentCount == null);

  if (isWaiting) return { label: 'รอดำเนินการ', donePct: 0, showPct: false, isDone: false };

  let donePct = 0;
  if (typeof o.progress === 'number') {
    donePct = Math.max(0, Math.min(100, o.progress));
  } else if (typeof o.remains === 'number' && qty > 0) {
    donePct = Math.max(0, Math.min(100, (1 - Math.max(0, o.remains)/qty) * 100));
  } else if (typeof o.startCount === 'number' && typeof o.currentCount === 'number' && qty > 0) {
    donePct = Math.max(0, Math.min(100, ((o.currentCount - o.startCount)/qty) * 100));
  }
  const isDone = (st === 'completed') || donePct >= 99.995;

  return isDone
    ? { label: 'เสร็จสิ้น', donePct: 100, showPct: false, isDone: true }
    : { label: `ดำเนินการ ~ ${donePct.toFixed(2)}%`, donePct, showPct: true, isDone: false };
}
%>

<section class="orders-history page-head">
  <div class="page-title">
    <h1><%= pageTitle %></h1>
    <small class="muted">หน้าผู้ดูแลระบบ → <%= pageTitle %></small>
  </div>

  <!-- <div class="right-actions">
    <button id="btnSync" class="btn primary">
      <span style="font-size:14px;">🔄</span> อัปเดตสถานะล่าสุด
    </button>
  </div> -->
</section>

<% if (typeof syncError === 'string' && syncError) { %>
  <div class="orders-history alert error">⚠️ <%= syncError %></div>
<% } else { %>
  <div class="orders-history alert info">
    ℹ️ ระบบจะอัปเดตสถานะอัตโนมัติทุก ~1–2 นาที (ถ้าเหลือแต่คำสั่ง “กำลังยกเลิก…” ระบบจะเช็คทุก 5 นาที)
  </div>
<% } %>

<!-- แท็บตัวกรองสถานะ -->
<div class="orders-history tabs chips" id="statusTabs">
  <% const st = (status||'all').toLowerCase(); %>
  <button class="chip <%= st==='all'?'active':'' %>" data-st="all">ทั้งหมด</button>
  <button class="chip <%= st==='processing'?'active':'' %>" data-st="processing">รอดำเนินการ</button>
  <button class="chip <%= st==='inprogress'?'active':'' %>" data-st="inprogress">กำลังทำ</button>
  <button class="chip <%= st==='completed'?'active':'' %>" data-st="completed">เสร็จสิ้น</button>
  <button class="chip <%= st==='partial'?'active':'' %>" data-st="partial">ส่วนบางส่วน</button>
  <button class="chip <%= st==='canceled'?'active':'' %>" data-st="canceled">ยกเลิก</button>
</div>

<!-- ฟิลเตอร์ -->
<form class="orders-history filters card" method="get">
  <div class="row wrap">
    <div class="inline">
      <label class="muted">ช่วงเวลา</label>
      <input class="input" type="date" name="from" value="<%= from || '' %>" />
      <span class="muted">–</span>
      <input class="input" type="date" name="to"   value="<%= to || '' %>" />
    </div>

    <div class="inline">
      <label class="muted">ค้นหาแบบละเอียด</label>
      <div class="searchbox">
        <span aria-hidden="true">🔎</span>
        <input class="input" name="q" id="q" placeholder="ค้นหา ID/ลิงก์/บริการ/ผู้ใช้…" value="<%= q||'' %>">
        <button class="btn">ค้นหา</button>
      </div>
    </div>

    <div class="inline grow">
      <label class="muted">ค้นหาเร็ว</label>
      <input class="input" id="quick" placeholder="พิมพ์เพื่อกรองทันที…">
    </div>
  </div>
</form>

<!-- ตารางออเดอร์ (เดสก์ท็อป) -->
<div class="orders-history table-wrap card order-desktop">
  <table class="table order-table" id="orderTable">
    <thead>
      <tr>
        <th style="width:62px">ID</th>
        <th style="width:170px">วันที่</th>
        <th style="width:220px">ผู้ใช้</th> <!-- เพิ่มคอลัมน์ผู้ใช้ -->
        <th>บริการ / ลิงก์</th>
        <th style="width:140px">ค่าใช้จ่าย</th>
        <th style="width:110px">ปริมาณ</th>
        <th style="width:160px">สถานะ</th>
      </tr>
    </thead>
    <tbody>
      <% (list || []).forEach(o => { %>
        <tr data-status="<%= (o.status||'').toLowerCase() %>" data-order-id="<%= o._id %>">
          <td>
            <a class="mono" href="/orders/<%= o._id %>" title="DB _id: <%= o._id %>">
              <%= o.providerOrderId || '-' %>
            </a>
          </td>
          <td class="mono"><%= new Date(o.createdAt).toLocaleString() %></td>

          <!-- ผู้ใช้ -->
          <td class="usercell">
            <div class="u">
              <img class="uav" src="<%= o.user?.avatarUrl || '/static/assets/img/user-blue.png' %>" alt="">
              <div class="umeta">
                <div class="uname">
                  <b><%= o.user?.username || '—' %></b>
                  <% if (o.user?.role) { %>
                    <span class="badge role"><%= o.user.role %></span>
                  <% } %>
                </div>
                <div class="uemail muted"><%= o.user?.email || '—' %></div>
              </div>
            </div>
          </td>

          <td>
            <div class="svc">
              <div class="svc-name">
                <span class="badge soft">#<%= o.service?.providerServiceId || o.providerServiceId || '-' %></span>
                <b><%= o.service?.name || o.serviceName || '-' %></b>
                <% if (o.meta?.country) { %><span class="badge flag"><%= o.meta.country %></span><% } %>
                <% if (o.meta?.speed)   { %><span class="badge blue"><%= o.meta.speed %></span><% } %>
              </div>
              <div class="link ellipsis">
                <span class="muted" aria-hidden="true">🔗</span>
                <a href="<%= o.link %>" target="_blank" rel="noopener"><%= o.link %></a>
              </div>
            </div>
          </td>

          <td class="mono">
            <%
              const costNum = Number(o.estCost ?? o.cost ?? (((o.quantity||0)/1000) * (o.service?.rate||0)));
              const costText = Number.isFinite(costNum)
                ? costNum.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })
                : '0.00';
              const cur = o.currency || o.service?.currency || 'THB';
            %>
            <%= costText %> <%= cur %>
          </td>

          <td class="mono"><%= o.quantity %></td>

          <td class="st-cell">
            <% const dd = decideDisplaySSR(o); %>
            <% const stLower = String(o.status||'').toLowerCase(); %>
            <% const canCancel  = !!(o.uiFlags && o.uiFlags.canCancel); %>
            <% const isDone     = !!(o.uiFlags && o.uiFlags.isDone); %>
            <% const canRepeat  = isDone && !!(o.service && o.service._id); %>

            <div class="st-block">
              <!-- pill สถานะยาว -->
              <div
                class="pill long <%= dd.isDone
                  ? 'ok'
                  : (stLower==='canceled' ? 'danger'
                    : (stLower==='canceling' ? 'warn'
                      : (stLower==='partial' ? 'warn' : ''))) %>"
                data-pct="<%= dd.donePct %>">

                <i class="bar" style="width:<%= (stLower==='canceling')
                  ? '0'
                  : (dd.isDone ? '100' : dd.donePct) %>%"></i>

                <span class="label">
                  <% const isPartialRefund =
                      (stLower==='canceled' && Number(o.refundAmount||0)>0 && o.refundType==='partial'); %>
                  <% if (isPartialRefund) { %>
                    <span class="badge warn" style="margin-right:8px">คืนบางส่วน</span>
                  <% } %>

                  <% if (stLower === 'canceling') { %>
                    <!-- ⬅️ กำลังสั่งยกเลิก -->
                    กำลังสั่งยกเลิก…
                  <% } else if (dd.showPct) { %>
                    ดำเนินการ ~ <span class="pct"><%= dd.donePct.toFixed(2) %>%</span>
                  <% } else { %>
                    <%= dd.label %>
                  <% } %>
                </span>
              </div>

              <div class="st-actions under">
                <% if (o.uiFlags?.canCancel) { %>
                  <button
                    type="button"
                    class="xbtn xbtn-sync btn-cancel"
                    title="ยกเลิกออเดอร์นี้"
                    onclick="startCancel('<%= o._id %>')">
                    <img src="/static/assets/emoji/cancel.png" alt="" class="icon" />
                  </button>
                <% } %>

                <% if (!(dd.isDone || stLower === 'canceled' || stLower === 'partial' || stLower === 'canceling')) { %>
                  <button type="button" class="xbtn xbtn-sync btn-refresh" data-id="<%= o._id %>" title="อัปเดตสถานะออเดอร์" aria-label="อัปเดตสถานะออเดอร์">
                    <img src="/static/assets/emoji/updatestatus.png" alt="" class="icon" />
                  </button>
                <% } %>

                <% const isPartialRefundCanceled = (stLower === 'canceled' && Number(o.refundAmount||0)>0 && o.refundType==='partial'); %>
                <% const canRepeatStrict = ((stLower === 'completed') || (stLower === 'partial') || isPartialRefundCanceled) && !!(o.service && o.service._id); %>
                <% if (canRepeatStrict) { %>
                  <button type="button" class="xbtn xbtn-primary btn-repeat" data-id="<%= o._id %>" title="สั่งซ้ำรายการนี้" aria-label="สั่งซ้ำรายการนี้">
                    <img src="/static/assets/emoji/repeat.png" alt="" class="icon" />
                  </button>
                <% } %>

                <button type="button" class="xbtn xbtn-info open-order" data-id="<%= o._id %>" title="รายละเอียด" aria-label="รายละเอียด">
                  <img src="/static/assets/emoji/detail.png" alt="" class="icon" />
                </button>
              </div>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <% if (!(list||[]).length) { %>
    <div class="empty muted">ยังไม่มีออเดอร์ในช่วงนี้</div>
  <% } %>
</div>

<!-- การ์ดออเดอร์ (มือถือ) -->
