            </div>
          </label>
          <label class="ot-item"><input type="radio" name="otime" disabled><div>เวลาที่เซิร์ฟเวอร์อัปเดต<div class="ottime" id="om-updatedAt">-</div></div></label>
          <label class="ot-item"><input type="radio" name="otime" disabled><div>เวลาที่คำสั่งซื้อเข้ามา<div class="ottime" id="om-createdAt">-</div></div></label>
        </div>
      </section>

      <section class="omodal-sec">
        <h4>รายละเอียดคำสั่งซื้อ</h4>
        <div class="ometa">
          <div class="muted">ลิงก์</div>
          <div class="olink"><a id="om-link" href="#" target="_blank" rel="noopener">-</a></div>

          <div class="muted">ปริมาณ</div>
