        </div>

        <div class="o-row"><div class="o-label">ปริมาณ</div><div class="o-val mono"><%= o.quantity %></div></div>

        <div class="o-row">
          <div class="o-label">สถานะ</div>
          <div class="o-val">
            <% const mdd = decideDisplaySSR(o); %>
            <%
              const canCancel = !!(o.uiFlags && o.uiFlags.canCancel);
              const isDone    = !!(o.uiFlags && o.uiFlags.isDone);
              const canRepeat = isDone && !!(o.service && o.service._id);
            %>
            <% const stLower = String(o.status||'').toLowerCase(); %>

            <div class="st-stack">
              <span
                class="pill progress <%= mdd.isDone
                  ? 'ok'
                  : (stLower==='canceled' ? 'danger'
                    : (stLower==='canceling' ? 'warn'
                      : (stLower==='partial' ? 'warn' : ''))) %>"
                data-pct="<%= (stLower==='canceling') ? 0 : mdd.donePct %>">

                <% const isPartialRefund = (
                    stLower === 'canceled' &&
                    Number(o.refundAmount || 0) > 0 &&
                    o.refundType === 'partial'
                  ); %>

                <% if (isPartialRefund) { %>
                  <span class="badge warn" style="margin-right:8px">คืนบางส่วน</span>
                <% } %>

                <% if (stLower === 'canceling') { %>
                  กำลังสั่งยกเลิก…
                <% } else if (mdd.showPct) { %>
                  ดำเนินการ ~ <span class="pct" data-pct="<%= mdd.donePct %>"><%= mdd.donePct.toFixed(2) %>%</span>
                <% } else { %>
                  <%= mdd.label %>
                <% } %>
              </span>

              <div class="st-actions">
                <% if (o.uiFlags?.canCancel) { %>
                  <button
                    type="button"
