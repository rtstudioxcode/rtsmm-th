      </header>

      <div class="o-body">
        <!-- ผู้ใช้ -->
        <div class="o-row">
          <div class="o-label">ผู้ใช้</div>
          <div class="o-val">
            <div class="u">
              <img class="uav" src="<%= o.user?.avatarUrl || '/static/assets/img/user-blue.png' %>" alt="">
              <div class="umeta">
                <div class="uname">
                  <b><%= o.user?.username || '—' %></b>
