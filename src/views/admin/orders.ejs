            <div class="oprog" style="margin-bottom:6px">
              <span class="opct" id="om-left-pct">0.00%</span>
              <div class="opbar"><i id="om-bar" style="width:0%"></i></div>
            </div>
            <div class="mono muted">
              เหลือ <span id="om-left-abs">0</span> จากทั้งหมด <span id="om-qty-abs">0</span>
            </div>
          </div>
        </div>
      </section>
    </div>

    <footer class="omodal-foot">
      <button class="btn-ghost" data-close="1">ปิด</button>
      <button id="om-refresh" class="btn-ghost">รีเฟรชสถานะ</button>
    </footer>
  </div>
</div>

<script>
/* ==== ส่งข้อมูลออเดอร์มาไว้ฝั่ง client (เฉพาะที่ต้องใช้ใน modal) ==== */
window.__ORDERS__ = <%- JSON.stringify((list||[]).map(o => ({
  _id: o._id,
  providerOrderId: o.providerOrderId,
  link: o.link,
  quantity: o.quantity,
  startCount: o.startCount ?? null,
  currentCount: o.currentCount ?? null,
  remains: o.remains ?? null,
  progress: o.progress ?? null,
  status: o.status,
  createdAt: o.createdAt,
  updatedAt: o.updatedAt ?? o.createdAt,
  currency: (o.currency || o.service?.currency || 'THB'),
  estCost: (o.estCost ?? o.cost ?? (((o.quantity||0)/1000) * (o.service?.rate||0))),
  serviceId: (o.service && o.service._id) || null, 
  svcProviderServiceId: (o.service && o.service.providerServiceId) || (o.providerServiceId || null),
  providerServiceId: o.providerServiceId || null,
  refundAmount: (o.refundAmount ?? 0),
  refundType: (o.refundType || null)
}))) %>;

(function(){
  const $ = (s,r=document)=>r.querySelector(s);

  // utils
  const fmtDate = x => {
    if(!x) return '-';
    try{ return new Date(x).toLocaleString(); }catch{ return '-'; }
  };
  const fmtMoney = (n,cur='THB') =>
    (Number(n)||0).toLocaleString(undefined,{minimumFractionDigits:3, maximumFractionDigits:3}) + ' ' + cur;

  function clamp01(x){ return Math.max(0, Math.min(1, x)); }

  // คำนวณเปอร์เซ็นต์ ทำ/เหลือ (ใช้ใน modal)
  function calcPercents(o){
    const qty = Number(o.quantity)||0;
    if (qty <= 0){
      const progress = (typeof o.progress === 'number') ? clamp01(o.progress/100) : 0;
      return { donePct: progress*100, leftPct: (1-progress)*100, leftAbs: null };
    }
    if (typeof o.remains === 'number') {
      const r = Math.max(0, o.remains);
      const leftPct = clamp01(r/qty)*100;
      const donePct = 100 - leftPct;
      return { donePct, leftPct, leftAbs: r };
    }
    if (typeof o.progress === 'number'){
      const donePct = clamp01(o.progress/100)*100;
      const leftPct = 100 - donePct;
      const leftAbs = Math.round((leftPct/100)*qty);
      return { donePct, leftPct, leftAbs };
    }
    if (typeof o.startCount === 'number' && typeof o.currentCount === 'number'){
      const gained = Math.max(0, o.currentCount - o.startCount);
      const donePct = clamp01(gained/qty)*100;
      const leftPct = 100 - donePct;
      const leftAbs = Math.max(0, qty - gained);
      return { donePct, leftPct, leftAbs };
    }
    const st = String(o.status||'').toLowerCase();
    if (st === 'partial') {
      return { label: 'คืนบางส่วน', donePct: 0, showPct: false, isDone: false };
    }
    if (st === 'completed') return { donePct:100, leftPct:0, leftAbs:0 };
    if (st === 'processing') return { donePct:0, leftPct:100, leftAbs:qty };
    return { donePct:0, leftPct:100, leftAbs:qty };
  }

  // ===== Modal =====
  const wrap = $('#orderModal');
  const title = $('#om-title'), cost = $('#om-cost'), link = $('#om-link');
  const qty = $('#om-qty'), start = $('#om-start'), current = $('#om-current');
  const leftAbsEl = $('#om-left-abs'), qtyAbsEl = $('#om-qty-abs');
  const leftPctEl = $('#om-left-pct'), bar = $('#om-bar');
  const createdAt = $('#om-createdAt'), updatedAt = $('#om-updatedAt');
  const btnRefresh = $('#om-refresh');

  let currentId = null;

  // ===== Render =====
  function render(o){
    currentId = o._id;
    title.textContent = '#' + (o.providerOrderId || '-');
    cost.textContent  = fmtMoney(o.estCost, o.currency);
    link.href = o.link; link.textContent = o.link;

    qty.textContent     = Number(o.quantity)||0;
    start.textContent   = (o.startCount ?? '-');
    current.textContent = (o.currentCount ?? '-');

    createdAt.textContent = fmtDate(o.createdAt);
    updatedAt.textContent = fmtDate(o.updatedAt);

    // ==== สรุปเปอร์เซ็นต์ ====
    const { donePct, leftPct, leftAbs } = calcPercents(o);
    leftPctEl.textContent = leftPct.toFixed(2) + '%';
    bar.style.width = donePct + '%';
    qtyAbsEl.textContent  = Number(o.quantity)||0;
    leftAbsEl.textContent = (leftAbs==null ? '—' : leftAbs);

    // ==== Refund display ====
    const refund = Number(o.refundAmount||0);
    const refLabel = document.getElementById('om-refund-label');
    const refVal   = document.getElementById('om-refund');
    if (refund > 0) {
      refLabel.style.display = '';
      refVal.style.display = '';
      refVal.textContent = fmtMoney(refund, o.currency) + (o.refundType==='partial' ? ' (คืนบางส่วน)' : ' (คืนเต็ม)');
    } else {
      refLabel.style.display = 'none';
      refVal.style.display = 'none';
    }

    // ==== ไทม์ไลน์: จุดสุดท้าย (แข็งแรง + ครอบคลุมสถานะ) ====
    const stRaw = String(o.status || '').toLowerCase();
    const isPartialRefundCanceled =
      stRaw === 'canceled' && o.refundType === 'partial' && Number(o.refundAmount || 0) > 0;

    // เลือก label + class ตามสถานะ
    function decideFinalTimeline(status) {
      switch (status) {
        case 'completed':
          return { label: 'เวลาที่คำสั่งซื้อเสร็จสิ้น', cls: 'ot-final--success' };
        case 'partial':
          return { label: 'เวลาที่เซิร์ฟเวอร์ยืนยัน (คืนบางส่วน)', cls: 'ot-final--partial' };
        case 'canceled':
          if (isPartialRefundCanceled) {
            return { label: 'เวลาที่คำสั่งซื้อยกเลิก (คืนเงินบางส่วน)', cls: 'ot-final--partial' };
          }
          return { label: 'เวลาที่เซิร์ฟเวอร์ยกเลิก / คำสั่งซื้อผิดพลาด', cls: 'ot-final--canceled' };
        case 'canceling':
          return { label: 'สถานะล่าสุด (กำลังยกเลิก)', cls: 'ot-final--progress' };
        case 'processing':
        case 'inprogress':
        default:
          return { label: 'สถานะล่าสุด (กำลังดำเนินการ)', cls: 'ot-final--progress' };
      }
    }

    const finalWrap  = document.querySelector('.ot-item--final');
    const finalLabel = document.getElementById('om-final-label');
    const finalTime  = document.getElementById('om-final-time');

    // อัปเดตเฉพาะเมื่อ element มีจริง (กัน null)
    if (finalWrap && finalLabel && finalTime) {
      // เคลียร์คลาสเก่า
      finalWrap.classList.remove(
        'ot-final--success',
        'ot-final--canceled',
        'ot-final--partial',
        'ot-final--progress'
      );

      // คำนวณค่าที่จะแสดง
      const { label, cls } = decideFinalTimeline(stRaw);
      finalLabel.textContent = label;
      finalTime.textContent  = fmtDate(o.updatedAt || o.createdAt);
      if (cls) finalWrap.classList.add(cls);
    }

    // ===== ควบคุมปุ่มรีเฟรชในโมดัล ตามสถานะ =====
    const showRefresh = shouldShowModalRefresh(o);
    if (btnRefresh) {
      btnRefresh.style.display = showRefresh ? '' : 'none';
      btnRefresh.disabled = !showRefresh;
    }
  }
  // ===== END =====

  function openModal(o){
    render(o);
    // ย้ำอีกชั้นเผื่ออนาคตมีการเปลี่ยนแปลงลำดับ render
    const showRefresh = shouldShowModalRefresh(o);
    if (btnRefresh) {
      btnRefresh.style.display = showRefresh ? '' : 'none';
      btnRefresh.disabled = !showRefresh;
    }

    wrap.classList.add('show');
    wrap.setAttribute('aria-hidden','false');
    document.documentElement.style.overflow = 'hidden';
  }
  function closeModal(){
    wrap.classList.remove('show');
    wrap.setAttribute('aria-hidden','true');
    document.documentElement.style.overflow = '';
    currentId = null;
  }

  document.addEventListener('click', e=>{
    const btn = e.target.closest('.open-order'); if(!btn) return;
    e.preventDefault();
    const row = btn.closest('[data-order-id]');
    const id  = row?.dataset?.orderId;
    const o   = (window.__ORDERS__||[]).find(x=>x._id===id);
    if (o) openModal(o);
  });

  function shouldShowModalRefresh(o){
    const st = String(o?.status || '').toLowerCase();
    // ไม่ให้รีเฟรชเมื่อกำลังยกเลิก / เสร็จแล้ว / คืนบางส่วน / ยกเลิกแล้ว
    return !(st === 'canceling' || st === 'completed' || st === 'partial' || st === 'canceled');
  }

  if (btnRefresh) btnRefresh.addEventListener('click', async ()=>{
    if (btnRefresh.disabled || btnRefresh.style.display === 'none') return;
    if (!currentId) return;

    btnRefresh.disabled = true;
    btnRefresh.setAttribute('aria-busy','true');
    const keep = btnRefresh.textContent;
    btnRefresh.textContent = 'กำลังรีเฟรช…';

    try {
      const res = await fetch(`/api/orders/${currentId}/refresh`, { method:'POST' });
      const data = await res.json();

      const arr = window.__ORDERS__||[];
      const idx = arr.findIndex(x=>x._id===currentId);
      if (idx>-1){
        const o = arr[idx];
        o.status        = data.status ?? o.status;
        if (typeof data.progress === 'number')      o.progress = data.progress;
        if (typeof data.remains  === 'number')      o.remains  = data.remains;
        if (typeof data.start_count === 'number')   o.startCount   = data.start_count;
        if (typeof data.current_count === 'number') o.currentCount = data.current_count;
        if (typeof data.refundAmount === 'number')  o.refundAmount = data.refundAmount;
        if (typeof data.refundType === 'string')    o.refundType   = data.refundType;
        o.updatedAt = data.updatedAt ?? new Date().toISOString();

        render(o); // จะจัดการโชว์/ซ่อนปุ่มให้เอง
      }
    } catch {
      // เงียบไว้หรือจะแจ้งเตือนก็ได้
    } finally {
      btnRefresh.textContent = keep;
      btnRefresh.removeAttribute('aria-busy');

      const arr = window.__ORDERS__||[];
      const idx = arr.findIndex(x=>x._id===currentId);
      const o = idx>-1 ? arr[idx] : null;
      const showRefresh = shouldShowModalRefresh(o);
      btnRefresh.style.display = showRefresh ? '' : 'none';
      btnRefresh.disabled = !showRefresh;
    }
  });

  wrap.addEventListener('click', e=>{
    if (e.target.dataset.close) closeModal();
  });
  document.addEventListener('keydown', e=>{
    if(e.key==='Escape' && wrap.classList.contains('show')) closeModal();
  });

  /* ===== UI helpers (ใช้ทั้ง Desktop & Mobile) ===== */

  // อัปเดต DOM ทั้งฝั่งตารางและการ์ดให้ตรงกับ payload ล่าสุด
  window.applyOrderPatch = function(payload){
    // sync cache
    const arr = window.__ORDERS__ || [];
    const idx = arr.findIndex(x => x._id === payload._id);
    if (idx > -1) {
      Object.assign(arr[idx], {
        status: payload.status ?? arr[idx].status,
        progress: payload.progress ?? arr[idx].progress,
        remains: payload.remains ?? arr[idx].remains,
        startCount: payload.startCount ?? arr[idx].startCount,
        currentCount: payload.currentCount ?? arr[idx].currentCount,
        updatedAt: payload.updatedAt ?? arr[idx].updatedAt,
        refundAmount: (payload.refundAmount ?? arr[idx].refundAmount),
        refundType: (payload.refundType ?? arr[idx].refundType)
      });
    }

    const displayPayload = {
      status: payload.status,
      progress: payload.progress,
      remains: payload.remains,
      startCount: payload.startCount,
      currentCount: payload.currentCount,
      quantity: (payload.quantity != null ? payload.quantity :
                 (idx > -1 ? arr[idx].quantity : 0)),
      refundAmount: payload.refundAmount,
      refundType: payload.refundType
    };

    const newSt = String(displayPayload.status || '').toLowerCase();
    const isPartialRefundCanceled = (newSt === 'canceled') &&
      (Number(displayPayload.refundAmount||0) > 0) &&
      (displayPayload.refundType === 'partial');

    // Desktop row
    const tr = document.querySelector(`tr[data-order-id="${payload._id}"]`);
    if (tr) {
      tr.dataset.status = newSt;
      renderProgressPill(tr, displayPayload);

      // toggle buttons
      tr.querySelectorAll('.btn-cancel').forEach(b => {
        b.style.display = (newSt === 'processing') ? '' : 'none';
        if (newSt === 'canceling') b.style.display = 'none'; // ⬅️ ซ่อนทันที
      });
      tr.querySelectorAll('.btn-refresh').forEach(b => {
        b.style.display = (newSt === 'completed' || newSt === 'canceled' || newSt === 'partial' || newSt === 'canceling') ? 'none' : '';
      });
      tr.querySelectorAll('.btn-repeat').forEach(b => {
        b.style.display = ((newSt === 'completed') || (newSt === 'partial') || isPartialRefundCanceled) ? '' : 'none';
      });
    }

    // Mobile card
    const card = document.querySelector(`.o-card[data-order-id="${payload._id}"]`);
    if (card) {
      card.dataset.status = newSt;
      renderProgressPill(card, displayPayload);

      card.querySelectorAll('.btn-cancel').forEach(b => {
        b.style.display = (newSt === 'processing') ? '' : 'none';
        if (newSt === 'canceling') b.style.display = 'none'; // ⬅️ ซ่อนทันที
      });
      card.querySelectorAll('.btn-refresh').forEach(b => {
        b.style.display = (newSt === 'completed' || newSt === 'canceled' || newSt === 'partial' || newSt === 'canceling') ? 'none' : '';
      });
      card.querySelectorAll('.btn-repeat').forEach(b => {
        b.style.display = ((newSt === 'completed') || (newSt === 'partial') || isPartialRefundCanceled) ? '' : 'none';
      });
    }
  };

  // รองรับทั้ง .pill.long (ใหม่) และ .pill.progress (เดิม)
  window.renderProgressPill = function(container, payload){
    const pillLong = container?.querySelector?.('.pill.long') || container?.querySelector?.('.pill.progress');
    if (!pillLong) return;

    const dd = (window.decideDisplay ? window.decideDisplay(payload) : null) ||
              { label:'รอดำเนินการ', donePct:0, showPct:false, isDone:false };

    const stLower       = String(payload.status||'').toLowerCase();
    const isCanceled    = stLower === 'canceled';
    const isPartial     = stLower === 'partial';
    const isCanceling   = stLower === 'canceling';
    const isPartialRefund = (isCanceled && Number(payload.refundAmount||0) > 0 && payload.refundType === 'partial');

    pillLong.classList.toggle('ok', !!dd.isDone);
    pillLong.classList.toggle('danger', isCanceled);
    pillLong.classList.toggle('warn', isPartial || isCanceling);

    // โครงสร้างใหม่: มี .bar + .label
    const barEl = pillLong.querySelector('.bar');
    const lblEl = pillLong.querySelector('.label');
    if (barEl && lblEl) {
      // ถ้า canceling แถบความคืบหน้าให้ 0%
      const widthPct = isCanceling ? 0 : (dd.isDone ? 100 : Math.max(0, Math.min(100, dd.donePct)));
      barEl.style.width = widthPct + '%';

      // ถ้า canceling แสดงข้อความเฉพาะ
      const mainLabel = isCanceling
        ? 'กำลังสั่งยกเลิก…'
        : (dd.showPct ? `ดำเนินการ ~ <span class="pct">${Number(dd.donePct||0).toFixed(2)}%</span>` : dd.label);

      lblEl.innerHTML = isPartialRefund
        ? `<span class="badge warn" style="margin-right:8px">คืนบางส่วน</span>${mainLabel}`
        : mainLabel;
      return;
    }

    // fallback: pill เดิม (ไม่มี .bar/.label)
    if (isCanceling) {
      pillLong.textContent = 'กำลังสั่งยกเลิก…';
    } else {
      pillLong.innerHTML = dd.showPct
        ? `ดำเนินการ ~ <span class="pct" data-pct="${dd.donePct}">${Number(dd.donePct||0).toFixed(2)}%</span>`
        : dd.label;
    }
  };
})();
</script>

<script>
(() => {
  const $  = (s,r=document)=>r.querySelector(s);
  const $$ = (s,r=document)=>Array.from(r.querySelectorAll(s));

  /* ===========================
 * Auto Refresh-All (Smart Poller)
 * - ปกติ: adaptive 1–2 นาที
 * - ถ้ามีแต่ canceling: "เป๊ะ" ทุก 5 นาที (ไม่เร็วกว่านี้)
 * =========================== */
  const AutoRefresh = (() => {
    const MIN_INTERVAL       = 60_000;    // 1 นาที
    const MAX_INTERVAL       = 120_000;   // 2 นาที
    const CANCELING_INTERVAL = 420_000;   // 7 นาที
    const ERR_BACKOFF        = 2.0;

    let interval = MIN_INTERVAL;
    let timer = null;
    let running = false;

    // บันทึกเวลาที่รีเฟรชรอบ canceling ล่าสุด (มิลลิวินาที)
    let lastCancelingRun = 0;

    // งานกำลังทำ (ไม่นับ canceling)
    const isVisible = el => !!(el && el.offsetParent !== null);
    const hasActiveNonCanceling = () => {
      const nodes = document.querySelectorAll(
        '#orderTable tbody tr[data-status="processing"], ' +
        '#orderTable tbody tr[data-status="inprogress"], ' +
        '.o-card[data-status="processing"], ' +
        '.o-card[data-status="inprogress"]'
      );
      return Array.from(nodes).some(isVisible);
    };

    // มี canceling ไหม
    const hasAnyCanceling = () => !!document.querySelector(
      '#orderTable tbody tr[data-status="canceling"], ' +
      '.o-card[data-status="canceling"]'
    );

    // มีแต่ canceling ล้วน ๆ
    const hasOnlyCanceling = () => hasAnyCanceling() && !hasActiveNonCanceling();

    const schedule = (ms) => {
      clearTimeout(timer);
      timer = setTimeout(tick, Math.max(0, ms));
    };

    const doRefresh = async (nextMs, { markCancelingRun = false } = {}) => {
      if (running) {
        // ถ้ารอบก่อนยังไม่จบ ให้เลื่อนไป "อย่างน้อย" ตาม nextMs (กันโดน 5 วินาทีแซงสิทธิ์)
        schedule(Math.max(nextMs, 5_000));
        return;
      }
      running = true;
      try {
        const btnSync = document.querySelector('#btnSync');
        await refreshAll(btnSync || undefined);
        if (markCancelingRun) lastCancelingRun = Date.now();
        schedule(nextMs);
      } catch (e) {
        console.error('auto refresh failed:', e);
        const backoff = Math.min(MAX_INTERVAL, Math.floor((nextMs || MIN_INTERVAL) * ERR_BACKOFF));
        schedule(backoff);
      } finally {
        running = false;
      }
    };

    const tick = async () => {
      if (document.hidden) { schedule(MIN_INTERVAL); return; }

      if (hasActiveNonCanceling()) {
        // โหมดปกติ: adaptive
        interval = Math.max(MIN_INTERVAL, Math.floor(interval * 0.9));
        await doRefresh(interval);
        return;
      }

      if (hasOnlyCanceling()) {
        // โหมด canceling ล้วน: เคารพ 5 นาที "เป๊ะ"
        const now = Date.now();
        const dueIn = (lastCancelingRun + CANCELING_INTERVAL) - now;
        if (dueIn > 0) {
          schedule(dueIn);   // ยังไม่ถึงกำหนด → รอส่วนต่างที่เหลือจริงๆ
          return;
        }
        await doRefresh(CANCELING_INTERVAL, { markCancelingRun: true });
        return;
      }

      // ไม่มีงานใด ๆ
      schedule(MIN_INTERVAL);
    };

    // กลับมาโฟกัส:
    // - ถ้ามีงานปกติ → ยิงทันที
    // - ถ้ามีแต่ canceling → ยิงทันที "เฉพาะ" เมื่อถึงกำหนด (ครบ 5 นาทีแล้วเท่านั้น)
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) return;
      if (hasActiveNonCanceling()) {
        interval = MIN_INTERVAL;
        clearTimeout(timer);
        tick();
      } else if (hasOnlyCanceling()) {
        const now = Date.now();
        if (!lastCancelingRun) lastCancelingRun = now;   // ถ้ายังไม่เคยตั้ง ให้เริ่มนับจากตอนนี้
        const dueIn = (lastCancelingRun + CANCELING_INTERVAL) - now;
        if (dueIn <= 0) {
          clearTimeout(timer);
          tick();                                        // ถึงเวลาแล้วค่อยยิง
        } else {
          schedule(dueIn);                               // ยังไม่ถึง → รอส่วนต่างจริงๆ
        }
      }
    });

    // เริ่มต้น: ถ้ามีงาน (normal/canceling) → เริ่มใน 3 วิ
    window.addEventListener('load', () => {
      if (hasActiveNonCanceling()) {
        schedule(3_000);
      } else if (hasOnlyCanceling()) {
        lastCancelingRun = Date.now();        // ← เริ่มจับเวลา 5 นาทีตั้งแต่ตอนนี้
        schedule(CANCELING_INTERVAL);         //    ไม่ยิงทันที
      }
    });

    // ผู้ใช้กดเอง → รีเซ็ตนาฬิกาเฉพาะโหมดปกติ
    const manual = document.querySelector('#btnSync');
    manual?.addEventListener('click', () => {
      // ถ้ามีแต่ canceling ให้ยึด 5 นาทีเหมือนเดิม (ไม่รีเซ็ตให้ไวขึ้น)
      if (hasOnlyCanceling()) return;
      interval = MIN_INTERVAL;
      schedule(interval);
    });

    return { start: () => schedule(1_000), stop: () => clearTimeout(timer) };
  })();


  /* === decideDisplay (ฝั่ง client) === */
  window.decideDisplay = function(o){
    const qty = Number(o.quantity)||0;
    const st  = String(o.status||'').toLowerCase();
    
    if (st === 'canceling') {
      return { label: 'กำลังสั่งยกเลิก…', donePct: 0, showPct: false, isDone: false };
    }

    if (st === 'canceled') {
      return { label: 'ยกเลิก', donePct: 0, showPct: false, isDone: false };
    }

    if (st === 'partial') {
      return { label: 'คืนบางส่วน', donePct: 0, showPct: false, isDone: false };
    }

    const isWaiting =
      st === 'processing' &&
      (o.progress == null) &&
      ((typeof o.remains === 'number' ? o.remains >= qty : true) || o.currentCount == null);

    if (isWaiting) return { label: 'รอดำเนินการ', donePct: 0, showPct: false, isDone: false };

    let donePct = 0;
    if (typeof o.progress === 'number') {
      donePct = Math.max(0, Math.min(100, o.progress));
    } else if (typeof o.remains === 'number' && qty > 0) {
      donePct = Math.max(0, Math.min(100, (1 - Math.max(0, o.remains)/qty) * 100));
    } else if (typeof o.startCount === 'number' && typeof o.currentCount === 'number' && qty > 0) {
      donePct = Math.max(0, Math.min(100, ((o.currentCount - o.startCount)/qty) * 100));
    }
    const isDone = (st === 'completed') || donePct >= 99.995;

    return isDone
      ? { label: 'เสร็จสิ้น', donePct: 100, showPct: false, isDone: true }
      : { label: `ดำเนินการ ~ ${donePct.toFixed(2)}%`, donePct, showPct: true, isDone: false };
  };

  /* ---------- สั่งซ้ำ (Repeat) ---------- */
  async function repeatOrder(btn){
    const id = btn?.dataset?.id;
    if (!id) return;

    const cache = (window.__ORDERS__||[]).find(x => x._id === id);
    if (!cache) { alert('ไม่พบบันทึกออเดอร์'); return; }

    if (!confirm('ต้องการสั่งซ้ำรายการนี้อีกครั้งใช่ไหม?')) return;

    btn.disabled = true; const keep = btn.textContent; btn.textContent = '…';

    try{
      const childProvId = cache.providerServiceId; 
      const parentProvId = cache.svcProviderServiceId;

      let body;
      if (childProvId && String(childProvId) !== String(parentProvId)) {
        body = {
          groupId: cache.serviceId,
          providerServiceId: childProvId, 
          link: cache.link,
          quantity: cache.quantity
        };
      } else {
        body = {
          serviceId: cache.serviceId,
          link: cache.link,
          quantity: cache.quantity
        };
      }

      const res = await fetch('/orders', {
        method:'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify(body)
      });
      const data = await res.json();
      if (!data?.ok) throw new Error(data?.error || 'repeat failed');

      alert('สั่งซ้ำสำเร็จ! หมายเลขใหม่: ' + (data.providerOrderId || data.orderId || '—'));
    }catch(e){
      console.error(e);
      alert('สั่งซ้ำไม่สำเร็จ: ' + (e.message||''));
    }finally{
      btn.textContent = keep; btn.disabled = false;
    }
  }

  document.addEventListener('click', e=>{
    const b = e.target.closest('.btn-repeat'); 
    if (!b) return;
    e.preventDefault();
    repeatOrder(b);
  });

  /* ---------- ปุ่ม/ยูทิล ---------- */
  function setBusy(btns, on=true){
    btns.forEach(b => {
      if(!b) return;
      if(on){
        b.disabled = true;
        b.dataset.keep = b.textContent;
        b.textContent = '…';
      }else{
        b.disabled = false;
        if(b.dataset.keep){ b.textContent = b.dataset.keep; delete b.dataset.keep; }
      }
    });
  }

  // * ---------- รีเฟรชเฉพาะออเดอร์เดียว ---------- *//
  function setBtnBusy(btn, on = true) {
    if (!btn) return;
    if (on) {
      btn.disabled = true;
      if (!btn.dataset.keepHtml) btn.dataset.keepHtml = btn.innerHTML;
      btn.setAttribute('aria-busy', 'true');
      btn.classList.add('is-loading');
    } else {
      btn.disabled = false;
      btn.removeAttribute('aria-busy');
      btn.classList.remove('is-loading');
      if (btn.dataset.keepHtml) {
        btn.innerHTML = btn.dataset.keepHtml;
        delete btn.dataset.keepHtml;
      }
    }
  }

  async function refreshOneOrder(orderId, triggerBtn) {
    if (!orderId) return;
    setBtnBusy(triggerBtn, true);
    try {
      const res = await fetch(`/api/orders/${orderId}/refresh`, { method: 'POST' });
      const data = await res.json();

      // สร้าง patch แล้วอัปเดต DOM ผ่าน applyOrderPatch
      const patch = {
        _id: orderId,
        status:        data.status,
        progress:      data.progress,
        remains:       data.remains,
        startCount:    data.start_count,
        currentCount:  data.current_count,
        updatedAt:     data.updatedAt || new Date().toISOString(),
        refundAmount:  data.refundAmount,
        refundType:    data.refundType
      };
      window.applyOrderPatch?.(patch);

      // อัปเดต cache modal (__ORDERS__) ถ้ามี
      const arr = window.__ORDERS__ || [];
      const idx = arr.findIndex(x => x._id === orderId);
      if (idx > -1) {
        const o = arr[idx];
        o.status        = (patch.status        ?? o.status);
        o.progress      = (typeof patch.progress      === 'number') ? patch.progress      : o.progress;
        o.remains       = (typeof patch.remains       === 'number') ? patch.remains       : o.remains;
        o.startCount    = (typeof patch.startCount    === 'number') ? patch.startCount    : o.startCount;
        o.currentCount  = (typeof patch.currentCount  === 'number') ? patch.currentCount  : o.currentCount;
        o.updatedAt     = patch.updatedAt || o.updatedAt;
        if (typeof patch.refundAmount === 'number') o.refundAmount = patch.refundAmount;
        if (typeof patch.refundType   === 'string') o.refundType   = patch.refundType;
      }
    } catch (e) {
      console.error('refresh one failed:', e);
    } finally {
      setBtnBusy(triggerBtn, false);
    }
  }

  /* ---------- เปลี่ยน handler ปุ่มรีเฟรชใต้สถานะให้รีเฟรชเฉพาะออเดอร์ ---------- */
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('.btn-refresh');
    if (!btn) return;
    e.preventDefault();

    // ไม่ให้กดในสถานะที่ห้าม (ตามเงื่อนไข EJS ที่ซ่อนไว้อยู่แล้ว เผื่อ DOM เปลี่ยน)
    const rowOrCard = btn.closest('[data-order-id]');
    const st = (rowOrCard?.dataset?.status || '').toLowerCase();
    if (st === 'canceling' || st === 'completed' || st === 'partial' || st === 'canceled') return;

    const id = btn.dataset.id || rowOrCard?.dataset?.orderId;
    refreshOneOrder(id, btn);
  });

  async function refreshAll(triggerBtn){
    const btnSync = document.querySelector('#btnSync');

    // ไม่อ้าง rowBtns แล้ว เพราะรีเฟรชทีละออเดอร์แยกต่างหาก
    const targets = [triggerBtn, btnSync].filter(Boolean);
    const uniqTargets = [...new Set(targets)];

    setBusyTargets(uniqTargets, true);
    try{
      const res = await fetch('/api/orders/refresh-all', { method: 'POST' });
      const data = await res.json();
      if (!data?.ok) throw new Error(data?.error || 'refresh failed');

      (data.changes || []).forEach(patch => {
        // ── ข้ามออเดอร์ที่กำลังยกเลิก ───────────────────────────
        const st = String(patch?.status || '').toLowerCase();
        if (st === 'canceling') return;

        // เผื่อกรณี server ไม่คืน status แต่ฝั่ง DOM เป็น canceling อยู่แล้ว → ข้ามเช่นกัน
        const rowOrCard = document.querySelector(`[data-order-id="${patch._id}"]`)
                      || document.querySelector(`.o-card[data-order-id="${patch._id}"]`);
        const domSt = (rowOrCard?.dataset?.status || '').toLowerCase();
        if (domSt === 'canceling') return;

        window.applyOrderPatch?.(patch);
      });
    } catch(e){
      console.error(e);
    } finally{
      setBusy(uniqTargets, false);
    }
  }

  /* ---------- ค้นหาเร็ว ---------- */
  $('#quick')?.addEventListener('input', e=>{
    const q = e.target.value.trim().toLowerCase();
    $$('#orderTable tbody tr').forEach(tr=>{
      const text = tr.innerText.toLowerCase();
      tr.style.display = text.includes(q) ? '' : 'none';
    });
    $$('#orderCards .o-card').forEach(card=>{
      const text = card.innerText.toLowerCase();
      card.style.display = text.includes(q) ? '' : 'none';
    });
  });

  /* ---------- ตัวกรองสถานะ ---------- */
  $('#statusTabs')?.addEventListener('click', e=>{
    const b = e.target.closest('.chip'); if(!b) return;
    $('#statusTabs').querySelectorAll('.chip').forEach(x=>x.classList.remove('active'));
    b.classList.add('active');
    const st = b.dataset.st;
    const ok = el => (st==='all') || (el.dataset.status===st);
    $$('#orderTable tbody tr').forEach(tr=>tr.style.display = ok(tr) ? '' : 'none');
    $$('#orderCards .o-card').forEach(c=>c.style.display = ok(c) ? '' : 'none');
  });

  /* ---------- คัดลอกลิงก์ ---------- */
  document.addEventListener('click', e=>{
    const btn = e.target.closest('.btn-copy'); if(!btn) return;
    navigator.clipboard.writeText(btn.dataset.copy||'').then(()=>{
      const old = btn.textContent; btn.textContent='✅';
      setTimeout(()=>btn.textContent=old,900);
    });
  });

  /* ---------- ปุ่มซิงก์ ---------- */
  $('#btnSync')?.addEventListener('click', (e)=>{
    e.preventDefault();
    refreshAll(e.currentTarget);
  });
  // document.addEventListener('click', (e)=>{
  //   const b = e.target.closest('.btn-refresh'); if(!b) return;
  //   e.preventDefault();
  //   refreshAll(b);
  // });

  /* ---------- mobile card toggle ---------- */
  $('#orderCards')?.addEventListener('click', (e) => {
    const card = e.target.closest('.o-card'); if (!card) return;
    if (e.target.closest('a') || e.target.closest('button') || e.target.closest('.btn-copy') || e.target.closest('.btn-refresh')) return;
    card.classList.toggle('open');
    const t = card.querySelector('.o-toggle');
    if (t) t.textContent = card.classList.contains('open') ? '−' : '＋';
  });

  /* ---------- maps ---------- */
  window.pillClass = window.pillClass || (s => {
    s = String(s||'').toLowerCase();
    if (s==='processing') return 'warn';
    if (s==='inprogress') return 'blue';
    if (s==='completed')  return 'ok';
    if (s==='partial')    return 'violet';
    if (s==='canceled')   return 'danger';
    return '';
  });
  window.thStatus = window.thStatus || (s => ({
    processing: 'รอดำเนินการ',
    inprogress: 'กำลังทำ',
    completed:  'เสร็จสิ้น',
    partial:    'บางส่วน',
    canceled:   'ยกเลิก',
  }[String(s||'').toLowerCase()] || s));

  function updateEmptyMsg(){
    const anyVisible = !!document.querySelector('#orderTable tbody tr:not([style*="display: none"])');
    let msg = document.getElementById('adm-empty');
    if (!msg) {
      msg = document.createElement('div');
      msg.id = 'adm-empty'; msg.className='empty muted'; msg.textContent='ไม่พบออเดอร์ตามเงื่อนไข';
      document.querySelector('.order-desktop').appendChild(msg);
    }
    msg.style.display = anyVisible ? 'none' : '';
  }
  document.getElementById('quick')?.addEventListener('input', updateEmptyMsg);
  document.getElementById('statusTabs')?.addEventListener('click', e=>{ if(e.target.closest('.chip')) setTimeout(updateEmptyMsg,0); });
})();

/* helpers */
async function postJSON(url, body) {
  const r = await fetch(url, {
    method: 'POST',
    headers: { 'Content-Type':'application/json' },
    body: body ? JSON.stringify(body) : null
  });
  let j = null; try { j = await r.json(); } catch {}
  if (!r.ok) {
    const msg = (j && j.error) ? j.error : ('HTTP ' + r.status);
    const err = new Error(msg); err.status = r.status; err.payload = j; throw err;
  }
  return j || {};
}

function setPillCanceling(orderId) {
  const row  = document.querySelector(`[data-order-id="${orderId}"]`);
  const card = document.querySelector(`.o-card[data-order-id="${orderId}"]`);
  const pill = row?.querySelector('.pill.long, .pill.progress') || card?.querySelector('.pill.long, .pill.progress');

  // อัปเดต data-status เป็น canceling (ให้ตัวกรองและไอคอนรู้)
  if (row)  row.dataset.status  = 'canceling';
  if (card) card.dataset.status = 'canceling';

  // ซ่อนปุ่มยกเลิก (กันสับสนว่าเป็นสถานะ)
  row?.querySelectorAll('.btn-cancel').forEach(b => b.style.display = 'none');
  card?.querySelectorAll('.btn-cancel').forEach(b => b.style.display = 'none');

  // ปรับ pill ให้เป็นกำลังยกเลิก
  if (pill) {
    pill.classList.remove('ok','danger','violet','blue');
    pill.classList.add('warn');
    const bar   = pill.querySelector('.bar');   if (bar)   bar.style.width = '0%';
    const label = pill.querySelector('.label'); if (label) label.textContent = 'กำลังสั่งยกเลิก…';
    // fallback โครงสร้างเก่า
    if (!label) pill.textContent = 'กำลังสั่งยกเลิก…';
  }
}

async function pollCancel(orderId, { timeoutMs=120000, intervalMs=3000 } = {}) {
  const t0 = Date.now();
  while (Date.now() - t0 < timeoutMs) {
    try {
      const j = await postJSON(`/orders/${orderId}/cancel/refresh`);
      // provider คอนเฟิร์มยกเลิกแล้ว → updated=true (ฝั่ง server จะคืนเงิน/อัปเดตสถานะให้เรียบร้อย)
      if (j?.updated) { location.reload(); return; }
    } catch (e) {
      // เงียบไว้—อาจ 429/5xx ชั่วคราว
    }
    await new Promise(s => setTimeout(s, intervalMs));
  }
  // ยังไม่คอนเฟิร์มในเวลา timeout → ปล่อยให้ refresh-all ซิงก์ต่อเอง
  if (window.showMsg) showMsg({ variant:'info', title:'กำลังรอยืนยัน', text:'ระบบจะอัปเดตให้อัตโนมัติเมื่อยกเลิกสำเร็จ' });
}

async function startCancel(orderId, _providerOrderId_unused) {
  const btn = document.querySelector(`tr[data-order-id="${orderId}"] .btn-cancel`)
          || document.querySelector(`.o-card[data-order-id="${orderId}"] .btn-cancel`)
          || document.querySelector(`[data-order-id="${orderId}"] .btn.small.danger`)
          || document.querySelector(`button[onclick*="${orderId}"]`);
  if (btn) btn.disabled = true;

  try {
    await postJSON(`/orders/${orderId}/cancel`);
    setPillCanceling(orderId);
    // await pollCancel(orderId);
  } catch (e) {
    if (window.showMsg) showMsg({ variant:'error', title:'ยกเลิกไม่สำเร็จ', text: e.message || 'โปรดลองใหม่' });
    else alert('ยกเลิกไม่สำเร็จ: ' + (e.message || 'โปรดลองใหม่'));
    if (btn) btn.disabled = false;
  }
}

</script>
