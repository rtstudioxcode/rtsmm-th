<!-- admin/otp-report.ejs -->
<% const COUNTDOWN = (typeof COUNTDOWN_ENABLED !== 'undefined') ? COUNTDOWN_ENABLED : true; %>
<%
// ===== Helpers: ธงประเทศ
const CT2CODE = {52:'th',187:'us',16:'gb',6:'id',10:'vn',5:'mm',1:'ua',19:'ng',62:'tr',3:'cn',4:'ph',24:'kh',25:'la',7:'my',21:'eg'};
const FLAGIMG = (id) => `/static/assets/otp24/${CT2CODE[id] || 'xx'}.png`;
const USERNAME = (user) => {
  if (!user) return '-';
  if (typeof user === 'object') return user.username || user._id || '-';
  // ถ้าเป็น id string และมี userMap ถูกส่งมา ก็ลอง map; ไม่งั้นแสดง id
  return (typeof userMap !== 'undefined' && userMap && userMap[String(user)]) || String(user) || '-';
};
%>

<section class="page container otp24 admin-otp-report">
  <div class="tabs">
    <button class="tab active" data-target="orders" style="width:100%;">ประวัติสั่งซื้อ OTP (ทั้งหมด)</button>
    <button class="tab" data-target="summary" style="width:100%;">สรุปยอดขาย OTP (รายเดือน)</button>
  </div>

  <!-- ============ TAB 1: ประวัติสั่งซื้อ OTP (ADMIN) ============ -->
  <section id="section-orders" class="tabpane show">
    <!-- Controls: per-page + pager + ค้นหา -->
    <div class="orders-controls" id="ordersControlsDesktop">
      <div class="left">
        แสดง
        <select id="perPageSelect">
          <option value="10">10</option>
          <option value="20" selected>20</option>
          <option value="50">50</option>
          <option value="100">100</option>
        </select>
        รายการ/หน้า
      </div>
      <div class="left">
        <input id="searchBox" class="input" placeholder="ค้นหา: orderId / username / app / เบอร์ / OTP">
      </div>
      <div class="right pager">
        <button class="pg-btn" data-act="first">«</button>
        <button class="pg-btn" data-act="prev">‹</button>
        <span id="pageInfo">หน้า 1/1</span>
        <button class="pg-btn" data-act="next">›</button>
        <button class="pg-btn" data-act="last">»</button>
      </div>
    </div>

    <div class="orders-wrap">
      <table class="tbl" id="ordersTable">
        <thead>
        <tr>
          <th>เลขออเดอร์</th>
          <th>ผู้ใช้</th>
          <th>แอป</th>
          <th>เบอร์</th>
          <th>OTP / เวลา</th>
          <th class="center">ราคาขาย</th>
          <th class="center">ต้นทุน</th>
          <th class="center">กำไร</th>
          <th class="right">สถานะ</th>
        </tr>
        </thead>
        <tbody id="ordersBody">
        <% (orders||[]).forEach(o => {
          const st = String(o.status||'processing').toLowerCase();

          // ===== คำนวณเวลาหมดอายุแบบ fallback =====
          const expISO = (() => {
            try {
              if (o.expiresAt) return new Date(o.expiresAt).toISOString();
              const base = new Date(o.createdAt).getTime();
              if (!Number.isFinite(base)) return '';
              const ttlMs =
                (o.timeoutMs && Number(o.timeoutMs)) ||
                (o.timeoutSec && Number(o.timeoutSec)*1000) ||
                20*60*1000; // ดีฟอลต์ 20 นาที
              return new Date(base + ttlMs).toISOString();
            } catch { return ''; }
          })();

          // ===== คำนวณราคา/กำไร (ประกาศครั้งเดียวพอ) =====
          const sale   = Number(o.salePrice||0);
          const cost   = Number(o.providerPrice||0);
          const profit = sale - cost;

          // ===== ฟอร์แมตเบอร์ =====
          const phoneStr = (() => {
            if (!o.phone) return '-';
            const ct = Number(o.countryId || 0);
            let s = String(o.phone).trim();

            if (ct === 52){
              if (/^\+?66\d{8,9}$/.test(s)) return s.replace(/^\+?66/,'0');
              if (/^0\d{8,9}$/.test(s))     return s;
              return s;
            }

            s = s.replace(/\s|-/g,'');
            if (s.startsWith('00')) s = s.slice(2);
            if (s.startsWith('+'))  return '+' + s.slice(1).replace(/[^\d]/g,'');
            return '+' + s.replace(/[^\d]/g,'');
          })();
        %>
          <tr data-orderid="<%= o.orderId %>" data-ct="<%= Number(o.countryId||0) %>" data-expires="<%= expISO %>">
            <td class="mono"><%= o.orderId || '-' %></td>
            <td class="mono"><%= USERNAME(o.user) %></td>
            <td>
              <span class="badge app"><%= o.appName || '—' %></span>
            </td>
            <td class="mono">
              <span class="flag"><img src="<%= FLAGIMG(Number(o.countryId||0)) %>" alt=""></span>
              <span class="v"><%= phoneStr %></span>
              <% if (o.phone) { %>
                <button class="copy" data-copy="<%= phoneStr %>" aria-label="คัดลอกเบอร์">
                  <img src="/static/assets/otp24/copy.png" alt="">
                </button>
              <% } %>
            </td>

            <td>
              <% if (o.otp) { %>
                <div class="otp">OTP : <b><%= o.otp %></b>
                  <button class="copy" data-copy="<%= o.otp %>" aria-label="คัดลอก OTP">
                    <img src="/static/assets/otp24/copy.png" alt="">
                  </button>
                </div>
              <% } else { %>
                <div class="otp none">OTP : <span class="muted">ไม่พบข้อความ</span></div>
              <% } %>
              <div class="ts"><%= new Date(o.createdAt).toISOString().replace('T',' ').slice(0,19) %></div>
            </td>

            <td class="center">฿ <%= sale.toFixed(2) %></td>
            <td class="center muted">฿ <%= cost.toFixed(2) %></td>
            <td class="center <%= profit>=0?'text-success':'text-danger' %>">฿ <%= profit.toFixed(2) %></td>

            <td class="right">
              <span class="pill <%= st %>">
                <%= st==='success'   ? 'สำเร็จ'
                : st==='refunded'  ? 'คืนเครดิต'
                : st==='timeout'   ? 'คืนเครดิต'
                : st==='failed'    ? 'คืนเครดิต'
                : 'กำลังรอ OTP' %>
              </span>
              <% if (COUNTDOWN && st==='processing') { %>
                <div class="countdown" data-expires="<%= expISO %>">
                  เหลือเวลาอีก —:— นาที หากไม่ได้รับ OTP ระบบจะคืนเงินอัตโนมัติ
                </div>
              <% } %>
            </td>
          </tr>
        <% }) %>
        </tbody>
      </table>
    </div>

    <!-- ===== Mobile list (แสดงเฉพาะมือถือ) ===== -->
    <div id="mOrders" class="m-orders">
    <% (orders||[]).forEach(o => {
    const st = String(o.status||'processing').toLowerCase();
    const sale = Number(o.salePrice||0);
    const cost = Number(o.providerPrice||0);
    const profit = sale - cost;
    const phoneStr = o.phone
        ? (Number(o.countryId)===52 ? String(o.phone).replace(/^\+?66/,'0') : String(o.phone))
        : '-';
    const createdStr = new Date(o.createdAt).toISOString().replace('T',' ').slice(0,19);
    %>
    <div class="m-item collapsed"
        data-orderid="<%= o.orderId %>"
        data-ct="<%= Number(o.countryId||0) %>">
        <!-- หัวการ์ด: แตะตรงไหนก็พับ/กาง -->
        <div class="m-head">
            <div class="row1">
                <div class="oid mono"><%= o.orderId %></div>
                <div class="when mono"><%= createdStr %></div>
                <button class="toggle" type="button" aria-label="toggle">+</button>
            </div>
            <div class="row2">
                <div class="phone mono">
                    เบอร์: <span class="v"><%= phoneStr %></span>
                    <% if (o.phone) { %>
                    <button class="copy" data-copy="<%= phoneStr %>" aria-label="คัดลอกเบอร์">
                        <img src="/static/assets/otp24/copy.png" alt="">
                    </button>
                    <% } %>
                </div>

                <% if (o.otp) { %>
                <div class="otp">OTP: <b class="v"><%= o.otp %></b>
                    <button class="copy" data-copy="<%= o.otp %>" aria-label="คัดลอก OTP">
                    <img src="/static/assets/otp24/copy.png" alt="">
                    </button>
                </div>
                <% } else { %>
                <div class="otp none">OTP: <span class="muted v">ไม่พบข้อความ</span></div>
                <% } %>
            </div>
        </div>

        <!-- เนื้อหาเมื่อกาง -->
        <div class="m-body">
        <div class="pair"><span>ผู้ใช้</span> <span class="mono"><%= USERNAME(o.user) %></span></div>
        <div class="pair"><span>แอป</span> <span class="badge app"><%= o.appName||'—' %></span></div>
        <div class="pair"><span>ประเทศ</span>
            <span class="flag"><img src="<%= FLAGIMG(Number(o.countryId||0)) %>" alt=""></span>
        </div>
        <div class="pair"><span>ราคาขาย</span> <span class="mono">฿ <%= sale.toFixed(2) %></span></div>
        <div class="pair"><span>ต้นทุน</span>   <span class="mono muted">฿ <%= cost.toFixed(2) %></span></div>
        <div class="pair"><span>กำไร</span>
            <span class="mono <%= profit>=0?'text-success':'text-danger' %>">฿ <%= profit.toFixed(2) %></span>
        </div>
        <div class="pair">
            <span>สถานะ</span>
            <span>
            <span class="pill <%= st %>">
                <%= st==='success' ? 'สำเร็จ'
                : st==='refunded' ? 'คืนเครดิต'
                : st==='timeout'  ? 'คืนเครดิต'
                : st==='failed'   ? 'คืนเครดิต' : 'กำลังรอ OTP' %>
            </span>
            <% if (COUNTDOWN && st==='processing') { %>
                <div class="countdown" data-expires="<%= o.expiresAt ? new Date(o.expiresAt).toISOString() : '' %>">
                เหลือเวลาอีก —:— นาที
                </div>
            <% } %>
            </span>
        </div>
        </div>
    </div>
    <% }) %>
    </div>

    <!-- Mobile controls -->
    <div class="orders-controls mobile-only" id="ordersControlsMobile">
      <div class="left">
        แสดง
        <select id="perPageSelectMobile">
          <option value="10">10</option>
          <option value="20" selected>20</option>
          <option value="50">50</option>
          <option value="100">100</option>
        </select>
        รายการ/หน้า
      </div>
      <div class="right pager">
        <button class="pg-btn" data-act="first">«</button>
        <button class="pg-btn" data-act="prev">‹</button>
        <span id="pageInfoMobile">หน้า 1/1</span>
        <button class="pg-btn" data-act="next">›</button>
        <button class="pg-btn" data-act="last">»</button>
      </div>
    </div>
  </section>

  <!-- ============ TAB 2: สรุปยอดขาย OTP (รายเดือน / เฉพาะ success) ============ -->
  <section id="section-summary" class="tabpane">
    <section class="page-head">
      <div class="page-title">
        <h1>สรุปยอดขาย OTP รายเดือน</h1>
        <small class="muted">หน้าผู้ดูแล → รายงาน → OTP</small>
      </div>
    </section>

    <!-- การ์ดสรุป -->
    <div class="grid cards summary-cards">
      <section class="card2">
        <div class="card-head row-head">
          <h3>ยอดต้นทุนรวม</h3><span class="metric-badge soft">ทั้งเดือน</span>
        </div>
        <div class="big muted">฿<%= Number(monthTotals?.cost||0).toLocaleString(undefined,{minimumFractionDigits:2}) %></div>
      </section>
      <section class="card2">
        <div class="card-head row-head">
          <h3>ยอดขายรวม</h3><span class="metric-badge soft">ทั้งเดือน</span>
        </div>
        <div class="big accent">฿<%= Number(monthTotals?.sale||0).toLocaleString(undefined,{minimumFractionDigits:2}) %></div>
      </section>
      <section class="card2">
        <div class="card-head row-head">
          <h3>ออเดอร์ที่สำเร็จ</h3><span class="metric-badge soft">ทั้งเดือน</span>
        </div>
        <div class="big info"><%= Number(monthTotals?.count||0).toLocaleString() %> รายการ</div>
      </section>
      <section class="card2">
        <div class="card-head row-head">
          <h3>กำไรรวม</h3><span class="metric-badge soft">ทั้งเดือน</span>
        </div>
        <div class="big <%= (monthTotals?.profit||0)>=0?'success':'danger' %>">
          ฿<%= Number(monthTotals?.profit||0).toLocaleString(undefined,{minimumFractionDigits:2}) %>
        </div>
      </section>
    </div>

    <!-- ตัวเลือกเดือน (ยกมาจากหน้าเดิม + ปรับ) -->
    <div class="month-toolbar" role="group" aria-label="เลือกเดือน">
      <button class="btn ghost" id="btnPrev" type="button">◀︎</button>
      <label class="month-ctrl">
        <input id="monthInput" type="text" value="<%= monthStr %>" readonly aria-label="เลือกเดือน" />
        <button class="icon-btn" id="btnOpenPicker" type="button" aria-label="เปิดตัวเลือกเดือน">📅</button>
      </label>
      <button class="btn ghost" id="btnNext" type="button">▶︎</button>
      <button class="btn" id="btnThisMonth" type="button">เดือนนี้</button>
    </div>

    <!-- Popup: Month Picker -->
    <div id="monthPicker" class="mp-popup" hidden>
      <div class="mp-card" role="dialog" aria-modal="true" aria-label="เลือกเดือน">
        <div class="mp-head">
          <button class="mp-nav" id="mpPrevYear">‹</button>
          <div class="mp-year" id="mpYear">2025</div>
          <button class="mp-nav" id="mpNextYear">›</button>
        </div>
        <div class="mp-grid" id="mpGrid" role="grid" aria-label="รายชื่อเดือน"></div>
        <div class="mp-actions">
          <button class="btn ghost" id="mpClear">ล้าง</button>
          <div class="spacer"></div>
          <button class="btn ghost" id="mpThisMonth">เดือนนี้</button>
          <button class="btn primary" id="mpOK">ตกลง</button>
        </div>
      </div>
    </div>

    <% const [yy, mm] = (monthStr||'').split('-').map(Number);
       const MONTHS_TH = ['มกราคม','กุมภาพันธ์','มีนาคม','เมษายน','พฤษภาคม','มิถุนายน','กรกฎาคม','สิงหาคม','กันยายน','ตุลาคม','พฤศจิกายน','ธันวาคม'];
       const headMonthLabel = `${MONTHS_TH[(mm||1)-1]} ${yy}`;
    %>

    <section class="card">
      <div class="table-wrap">
        <table class="tbl zebra">
          <thead>
            <tr class="tbl-head-month">
              <th style="color:#f3a71a; text-align:center;" colspan="5"><%= headMonthLabel %></th>
            </tr>
            <tr>
              <th style="text-align:start; width:141px">วันที่</th>
              <th class="center">ต้นทุน</th>
              <th class="center">ยอดขาย</th>
              <th class="center">ออเดอร์สำเร็จ</th>
              <th class="center">กำไร</th>
            </tr>
          </thead>
          <tbody>
            <% 
                // เตรียม map หาแถวตามวันได้เร็ว
                const rowsByDay = Object.fromEntries((rows||[]).map(r => [String(r.day), r]));
                const daysInMonth = new Date(yy, mm, 0).getDate(); // mm เป็นเลขเดือน 1-12 อยู่แล้ว
                for (let i = 1; i <= daysInMonth; i++) {
                const dayKey = `${yy}-${String(mm).padStart(2,'0')}-${String(i).padStart(2,'0')}`;
                const r = rowsByDay[dayKey] || { day: dayKey, cost: 0, sale: 0, count: 0, profit: 0 };
            %>
                <tr>
                <td style="text-align:start;"><%= r.day %></td>
                <td class="center muted"><%= Number(r.cost||0).toLocaleString(undefined,{minimumFractionDigits:2, maximumFractionDigits:2}) %></td>
                <td class="center" style="color:#43cf43;"><%= Number(r.sale||0).toLocaleString(undefined,{minimumFractionDigits:2, maximumFractionDigits:2}) %></td>
                <td class="center" style="color:#0ea9e6;"><%= Number(r.count||0).toLocaleString() %></td>
                <td class="center <%= (r.profit||0)>=0?'text-success':'text-danger' %>">
                    <%= Number(r.profit||0).toLocaleString(undefined,{minimumFractionDigits:2, maximumFractionDigits:2}) %>
                </td>
                </tr>
            <% } %>
            </tbody>
        </table>
      </div>
    </section>
  </section>
</section>

<script>
const COUNTDOWN_ENABLED = <%= COUNTDOWN ? 'true' : 'false' %>;

const PHONE_COL_INDEX  = 3;
const OTP_COL_INDEX    = 4;
const STATUS_COL_INDEX = 8;

// ───────── Tabs ─────────
document.querySelectorAll('.tab').forEach(t=>{
  t.addEventListener('click', ()=>{
    document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));
    document.querySelectorAll('.tabpane').forEach(x=>x.classList.remove('show'));
    t.classList.add('active');
    document.getElementById('section-'+t.dataset.target).classList.add('show');
  });
});

// ───────── Admin Orders: pagination + search ─────────
let ORDERS_PER_PAGE = Number(localStorage.getItem('OTP24_ADMIN_PER_PAGE')) || 20;
let currentPage = 1;

const $rows   = () => Array.from(document.querySelectorAll('#ordersBody tr'))
  .filter(tr => tr.style.display !== 'none' || true); // always included; filtering handled separately
const $info   = document.getElementById('pageInfo');
const $infoM  = document.getElementById('pageInfoMobile');
const $sel    = document.getElementById('perPageSelect');
const $selM   = document.getElementById('perPageSelectMobile');
const $ctrlD  = document.getElementById('ordersControlsDesktop');
const $ctrlM  = document.getElementById('ordersControlsMobile');
const $search = document.getElementById('searchBox');

let filterText = '';

function totalItems(){ return $rows().filter(matchFilter).length; }
function totalPages(){ return Math.max(1, Math.ceil(totalItems() / ORDERS_PER_PAGE)); }
function clampPage(n){ return Math.min(Math.max(1, n), totalPages()); }

function matchFilter(tr){
  if (!filterText) return true;
  const t = filterText;
  const cells = Array.from(tr.children).map(td => td.textContent?.toLowerCase() || '');
  return cells.some(v => v.includes(t));
}

function applyPagination(){
  const rows = $rows();
  const items = rows.filter(matchFilter);

  const pages = totalPages();
  currentPage = clampPage(currentPage);
  const start = (currentPage-1) * ORDERS_PER_PAGE;
  const end   = start + ORDERS_PER_PAGE;

  rows.forEach(el => { el.style.display = 'none'; });
  items.forEach((el, i) => {
    if (i >= start && i < end) el.style.display = '';
  });

  if ($info)  $info.textContent  = `หน้า ${currentPage}/${pages}`;
  if ($infoM) $infoM.textContent = `หน้า ${currentPage}/${pages}`;

  const setBtns = (root) => {
    if (!root) return;
    root.querySelector('[data-act="first"]')?.toggleAttribute('disabled', currentPage<=1);
    root.querySelector('[data-act="prev"]') ?.toggleAttribute('disabled', currentPage<=1);
    root.querySelector('[data-act="next"]') ?.toggleAttribute('disabled', currentPage>=pages);
    root.querySelector('[data-act="last"]') ?.toggleAttribute('disabled', currentPage>=pages);
  };
  setBtns($ctrlD); setBtns($ctrlM);
}

function bindPerPage(selectEl){
  if (!selectEl) return;
  Array.from(selectEl.options).forEach(opt => { opt.selected = Number(opt.value) === ORDERS_PER_PAGE; });
  selectEl.addEventListener('change', () => {
    ORDERS_PER_PAGE = Number(selectEl.value) || 20;
    localStorage.setItem('OTP24_ADMIN_PER_PAGE', ORDERS_PER_PAGE);
    currentPage = 1;
    applyPagination();
  });
}
bindPerPage($sel); bindPerPage($selM);

function bindPager(ctrlRoot){
  if (!ctrlRoot) return;
  ctrlRoot.addEventListener('click', (e) => {
    const btn = e.target.closest('.pg-btn'); if (!btn) return;
    const act = btn.dataset.act;
    if (act==='first') currentPage = 1;
    else if (act==='prev') currentPage = clampPage(currentPage-1);
    else if (act==='next') currentPage = clampPage(currentPage+1);
    else if (act==='last') currentPage = totalPages();
    applyPagination();
  });
}
bindPager($ctrlD); bindPager($ctrlM);

// ค้นหา
$search?.addEventListener('input', ()=>{
  filterText = ($search.value || '').trim().toLowerCase();
  currentPage = 1;
  applyPagination();
});

// เริ่มต้น
applyPagination();

// copy OTP icon feedback
function setCopyIcon(btn, ok){
  const img = btn.querySelector('img');
  if (!img) return;
  img.src = ok ? '/static/assets/otp24/copy-success.png' : '/static/assets/otp24/copy.png';
}
document.addEventListener('click', (e) => {
  const btn = e.target.closest('.copy');
  if (!btn) return;
  navigator.clipboard.writeText(btn.dataset.copy||'')
    .then(()=>{ setCopyIcon(btn,true); setTimeout(()=>setCopyIcon(btn,false),900); })
    .catch(()=> setCopyIcon(btn,false));
});

// ───────── Month Picker (อัปเดต) ─────────
(function(){
  const MONTH_NAMES_TH = ['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'];
  const input   = document.getElementById('monthInput');
  const btnOpen = document.getElementById('btnOpenPicker');
  const popup   = document.getElementById('monthPicker');
  const yearEl  = document.getElementById('mpYear');
  const grid    = document.getElementById('mpGrid');
  const btnPrevY= document.getElementById('mpPrevYear');
  const btnNextY= document.getElementById('mpNextYear');
  const btnOK   = document.getElementById('mpOK');
  const btnClear= document.getElementById('mpClear');
  const btnThis = document.getElementById('mpThisMonth');
  const btnPrev = document.getElementById('btnPrev');
  const btnNext = document.getElementById('btnNext');
  const btnThisMonth = document.getElementById('btnThisMonth');

  const now = new Date();
  let selYear  = now.getFullYear();
  let selMonth = now.getMonth();
  let tempYear = selYear, tempMonth = selMonth;

  const monthStrInit = (input?.value || '').slice(0,7);
  if (monthStrInit){
    const [yy,mm] = monthStrInit.split('-').map(n=>+n);
    if (yy && mm){ selYear = yy; selMonth = mm-1; tempYear=yy; tempMonth=mm-1; }
  }

  function toYYYYMM(y,m){ return `${y}-${String(m+1).padStart(2,'0')}`; }

  // ===== เก็บ/คงแท็บเดิม =====
  const TAB_KEY = 'OTP24_LAST_TAB';
  document.querySelectorAll('.tab').forEach(t=>{
    t.addEventListener('click', ()=> localStorage.setItem(TAB_KEY, t.dataset.target || 'orders'));
  });

  function currentTab(){
    return localStorage.getItem(TAB_KEY)
      || document.querySelector('.tab.active')?.dataset.target
      || 'summary';
  }

  // ===== go(): เปลี่ยนเดือนโดยคงแท็บเดิม =====
  function go(monthStr){
    const u = new URL(location.href);
    const tab = currentTab();
    u.searchParams.set('month', monthStr);
    u.searchParams.set('tab', tab); // ใส่พารามิเตอร์
    u.hash = `#${tab}`;             // เผื่อฝั่งอื่นอ่านจาก hash
    location.href = u.toString();
  }

  // ===== สร้าง Grid เดือน =====
  function renderGrid(){
    if (!yearEl || !grid) return;
    yearEl.textContent = String(tempYear);
    grid.innerHTML = '';
    for (let m=0;m<12;m++){
      const b = document.createElement('button');
      b.type='button';
      b.className = 'mp-m'
        + (m===tempMonth && tempYear===selYear ? ' active' : '')
        + (m===now.getMonth() && tempYear===now.getFullYear() ? ' current' : '');
      b.textContent = MONTH_NAMES_TH[m];
      b.setAttribute('role','gridcell');
      b.addEventListener('click', ()=>{
        tempMonth = m;
        [...grid.children].forEach(c=>c.classList.remove('active'));
        b.classList.add('active');
        positionPicker(); // ขนาดการ์ดอาจเปลี่ยนเล็กน้อย — จัดตำแหน่งซ้ำ
      });
      grid.appendChild(b);
    }
  }

  // ===== จัดตำแหน่งป็อปอัพไว้ใต้ .month-ctrl เสมอ =====
  function positionPicker(){
    if (!popup) return;
    const anchor = document.querySelector('.month-toolbar .month-ctrl') || document.querySelector('.month-toolbar');
    const card = popup.querySelector('.mp-card');
    if (!anchor || !card){ return; }

    popup.classList.add('anchor');      // ใช้โหมด anchor
    popup.classList.remove('center');

    const r = anchor.getBoundingClientRect();
    const vpW = window.innerWidth, vpH = window.innerHeight;

    // ค่าเริ่มต้น: วางใต้ anchor 8px
    let top  = Math.min(r.bottom + 8, vpH - 12);
    let left = Math.max(12, Math.min(r.left, vpW - card.offsetWidth - 12));

    // ถ้าล้นขวา ให้เลื่อนไปชิดขวาของ anchor
    if (left + card.offsetWidth > vpW - 12) left = Math.max(12, r.right - card.offsetWidth);

    // ถ้าพื้นที่ด้านล่างไม่พอ แต่ด้านบนพอ ให้สลับไปวางเหนือ
    const needH = card.offsetHeight + 12;
    if (vpH - r.bottom < needH && r.top > needH){
      top = Math.max(12, r.top - needH);
    }

    Object.assign(card.style, { top: `${top}px`, left: `${left}px` });
  }

  function openPicker(){
    tempYear = selYear; tempMonth = selMonth;
    renderGrid();
    popup?.removeAttribute('hidden');
    popup?.setAttribute('aria-hidden','false');
    positionPicker();
    setTimeout(()=> grid?.querySelector('.mp-m.active')?.focus(),0);

    window.addEventListener('resize', positionPicker, { passive:true });
    window.addEventListener('scroll', positionPicker, { passive:true });
  }
  function closePicker(){
    popup?.setAttribute('hidden','');
    popup?.setAttribute('aria-hidden','true');
    window.removeEventListener('resize', positionPicker);
    window.removeEventListener('scroll', positionPicker);
  }

  // คลิกนอกการ์ดเพื่อปิด (เฉพาะ anchor mode)
  popup?.addEventListener('click', (e)=>{
    if (e.target === popup) closePicker();
  });

  // ปุ่มเลื่อนเดือน (ซ้าย/ขวา/เดือนนี้)
  btnPrev?.addEventListener('click', ()=>{
    const d = new Date(selYear, selMonth-1, 1);
    go(toYYYYMM(d.getFullYear(), d.getMonth()));
  });
  btnNext?.addEventListener('click', ()=>{
    const d = new Date(selYear, selMonth+1, 1);
    go(toYYYYMM(d.getFullYear(), d.getMonth()));
  });
  btnThisMonth?.addEventListener('click', ()=> go(toYYYYMM(now.getFullYear(), now.getMonth())));

  // เปิด/ปิด + เดินปี
  btnOpen?.addEventListener('click', openPicker);
  input?.addEventListener('click', openPicker);
  btnPrevY?.addEventListener('click', ()=>{ tempYear--; renderGrid(); positionPicker(); });
  btnNextY?.addEventListener('click', ()=>{ tempYear++; renderGrid(); positionPicker(); });
  btnThis?.addEventListener('click', ()=>{ tempYear = now.getFullYear(); tempMonth = now.getMonth(); renderGrid(); positionPicker(); });

  btnOK?.addEventListener('click', ()=>{
    selYear = tempYear; selMonth = tempMonth;
    input.value = toYYYYMM(selYear, selMonth);
    closePicker();
    go(input.value);
  });
  btnClear?.addEventListener('click', ()=>{
    input.value = '';
    closePicker();
    go(toYYYYMM(now.getFullYear(), now.getMonth()));
  });

  // ===== คืนค่าแท็บเดิมหลังโหลดหน้า =====
  window.addEventListener('DOMContentLoaded', ()=>{
    const params = new URLSearchParams(location.search);
    const fromUrl = params.get('tab') || (location.hash||'').replace('#','');
    const last = fromUrl || localStorage.getItem(TAB_KEY);
    if (last){
      document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));
      document.querySelectorAll('.tabpane').forEach(x=>x.classList.remove('show'));
      document.querySelector(`.tab[data-target="${last}"]`)?.classList.add('active');
      document.getElementById(`section-${last}`)?.classList.add('show');
    }
  });
})();

function mmss(ms){
  if (!Number.isFinite(ms) || ms < 0) ms = 0;
  const s = Math.floor(ms/1000);
  const m = String(Math.floor(s/60)).padStart(2,'0');
  const ss = String(s%60).padStart(2,'0');
  return `${m}:${ss}`;
}
function tickCountdowns(){
  const now = Date.now();
  const upd = (el) => {
    const exp = Date.parse(el.dataset.expires || el.getAttribute('data-expires') || '');
    if (!Number.isFinite(exp)) return;
    const left = exp - now;
    el.textContent = left>0 ? `เหลือเวลาอีก ${mmss(left)} นาที` : 'ระบบกำลังคืนเครดิต';
    el.classList.toggle('warn', left>0 && left<=3*60*1000);
    el.classList.toggle('danger', left>0 && left<=60*1000);
  };
  document.querySelectorAll('#ordersBody .countdown').forEach(upd);
  document.querySelectorAll('#mOrders .countdown').forEach(upd);
  // ปรับหมายเลขในตาราง Desktop ให้ถูกต้องตามประเทศ
  document.querySelectorAll('#ordersBody tr').forEach(tr => {
    const ct = Number(tr.dataset.ct || 0);
    const box = tr.children?.[PHONE_COL_INDEX];
    const mono = box?.querySelector('.mono .v') || box?.querySelector('.mono');
    if (mono){
      const formatted = displayPhoneByCountry(mono.textContent.trim(), ct);
      mono.textContent = formatted;
      const btn = box.querySelector('.copy');
      if (btn) btn.dataset.copy = formatted;
    }
  });

  // ปรับหมายเลขในลิสต์มือถือให้ถูกต้องเหมือนกัน
  document.querySelectorAll('#mOrders .m-item').forEach(card => {
    const ct = Number(card.dataset.ct || 0);
    const el = card.querySelector('.row2 .phone .v');
    if (el){
      const formatted = displayPhoneByCountry(el.textContent.trim(), ct);
      el.textContent = formatted;
      const btn = card.querySelector('.row2 .phone .copy');
      if (btn) btn.dataset.copy = formatted;
    }
  });
}
</script>

<script>
// ── helper: แสดงเบอร์ตามประเทศ (ไทย 52 → 0XXXXXXXX)
function displayPhoneByCountry(rawPhone, countryId){
  if (!rawPhone) return '-';
  let s = String(rawPhone).trim();

  // ── ไทย: countryId = 52 → 0XXXXXXXX
  if (Number(countryId) === 52){
    if (/^\+?66\d{8,9}$/.test(s)) return s.replace(/^\+?66/, '0'); // +66... → 0...
    if (/^0\d{8,9}$/.test(s))     return s;                         // 0XXXXXXXX → ใช้เดิม
    return s; // เคสพิเศษอื่น ๆ ของไทย
  }

  // ── ประเทศอื่น: บังคับให้ขึ้นต้นด้วย "+"
  s = s.replace(/\s|-/g, '');          // ตัดช่องว่าง/ขีด
  if (s.startsWith('00')) s = s.slice(2); // 00XXXXXXXX → +XXXXXXXX
  if (s.startsWith('+'))  s = '+' + s.slice(1).replace(/[^\d]/g,''); // ทำให้เหลือ +digits
  else                    s = '+' + s.replace(/[^\d]/g,'');           // เติม + ถ้าไม่มี
  return s;
}

// แตะตรงไหนบนการ์ดก็พับ/กาง (กันปุ่ม/ลิงก์ไม่ให้พับ)
document.getElementById('mOrders')?.addEventListener('click', (e) => {
  const item = e.target.closest('.m-item');
  if (!item) return;
  // กันปุ่ม copy
  if (e.target.closest('.copy')) return;
  item.classList.toggle('collapsed');
  const btn = item.querySelector('.toggle');
  if (btn) btn.textContent = item.classList.contains('collapsed') ? '+' : '−';
});

// copy OTP พร้อมไอคอน feedback (ใช้ setCopyIcon เดิม)
document.addEventListener('click', (e) => {
  const btn = e.target.closest('.copy');
  if (!btn) return;

  navigator.clipboard.writeText(btn.dataset.copy || '').then(() => {
    setCopyIcon(btn, true);
    // กลับเป็นไอคอนปกติใน 900ms
    setTimeout(() => setCopyIcon(btn, false), 900);
  }).catch(() => {
    // ถ้า copy ไม่ได้ อย่าค้างไอคอน success
    setCopyIcon(btn, false);
  });
});

// ====== รวม pagination เดสก์ท็อป + มือถือ ======
const $cards = () => Array.from(document.querySelectorAll('#mOrders .m-item'));

function totalItems(){
  const isMobile = window.matchMedia('(max-width: 640px)').matches;
  const rows = isMobile ? $cards() : $rows();
  return rows.filter(el => elMatchesFilter(el)).length;
}
function elMatchesFilter(el){
  if (!filterText) return true;
  const t = filterText;
  const text = (el.textContent || '').toLowerCase();
  return text.includes(t);
}

function applyPagination(){
  const isMobile = window.matchMedia('(max-width: 640px)').matches;
  const items = (isMobile ? $cards() : $rows());

  const filtered = items.filter(el => elMatchesFilter(el));
  const pages = Math.max(1, Math.ceil(filtered.length / ORDERS_PER_PAGE));
  currentPage = Math.min(Math.max(1, currentPage), pages);
  const start = (currentPage-1) * ORDERS_PER_PAGE;
  const end   = start + ORDERS_PER_PAGE;

  items.forEach(el => { el.style.display = 'none'; });
  filtered.forEach((el,i) => { if (i>=start && i<end) el.style.display = ''; });

  if (!isMobile && $info)  $info.textContent  = `หน้า ${currentPage}/${pages}`;
  if ( isMobile && $infoM) $infoM.textContent = `หน้า ${currentPage}/${pages}`;

  const setBtns = (root) => {
    if (!root) return;
    root.querySelector('[data-act="first"]')?.toggleAttribute('disabled', currentPage<=1);
    root.querySelector('[data-act="prev"]') ?.toggleAttribute('disabled', currentPage<=1);
    root.querySelector('[data-act="next"]') ?.toggleAttribute('disabled', currentPage>=pages);
    root.querySelector('[data-act="last"]') ?.toggleAttribute('disabled', currentPage>=pages);
  };
  setBtns($ctrlD); setBtns($ctrlM);
}

// ค้นหา: ใช้กับทั้ง table & mobile
$search?.addEventListener('input', ()=>{
  filterText = ($search.value || '').trim().toLowerCase();
  currentPage = 1;
  applyPagination();
});

// ปรับเมื่อ resize (สลับโหมด)
let _resizeTimer = null;
window.addEventListener('resize', () => {
  clearTimeout(_resizeTimer);
  _resizeTimer = setTimeout(applyPagination, 150);
});

// เริ่มต้น
applyPagination();
</script>

<script>
/* ====== ค่าพื้นฐานให้ตรง otp24 ====== */
let ORD_AUTO_TIMER = null;
const POLL_DONE = new Set(['success','timeout','failed','refunded']);
const pollers   = new Map();  
let countdownTimer = null;

/* มีแถวกำลังรออยู่ไหม */
function hasProcessingRows(){
  return !!document.querySelector('#ordersBody .pill.processing');
}

/* แปลงเบอร์ตามประเทศ (เหมือน otp24) */
function displayPhoneByCountry(rawPhone, countryId){
  if (!rawPhone) return '-';
  let s = String(rawPhone).trim();

  // ไทย: countryId = 52  →  0XXXXXXXX
  if (Number(countryId) === 52) {
    if (/^\+?66\d{8,9}$/.test(s)) return s.replace(/^\+?66/, '0');
    if (/^0\d{8,9}$/.test(s)) return s;
    return s;
  }

  // ประเทศอื่น: แสดง "ตัวเลขล้วน" ไม่มีเครื่องหมาย +
  if (s.startsWith('+')) s = s.slice(1);
  if (s.startsWith('00')) s = s.slice(2);
  return s.replace(/[^\d]/g, '');
}

/* นับถอยหลังใต้สถานะ */
function mmss(ms){
  if (!Number.isFinite(ms) || ms < 0) ms = 0;
  const s = Math.floor(ms/1000);
  return `${String(Math.floor(s/60)).padStart(2,'0')}:${String(s%60).padStart(2,'0')}`;
}
function tickCountdowns(){
  const now = Date.now();
  const upd = (el) => {
    const exp = Date.parse(el.dataset.expires || el.getAttribute('data-expires') || '');
    if (!Number.isFinite(exp)) return;
    const left = exp - now;
    el.textContent = left>0 ? `เหลือเวลาอีก ${mmss(left)} นาที` : 'ระบบกำลังคืนเครดิต';
    el.classList.toggle('warn',   left>0 && left<=3*60*1000);
    el.classList.toggle('danger', left>0 && left<=60*1000);
  };
  document.querySelectorAll('#ordersBody .countdown').forEach(upd);
  document.querySelectorAll('#mOrders .countdown').forEach(upd);
}

/* อัปเดต DOM จาก patch เดียวกับ otp24 */
function applyOrderPatch(p){
  // p: { orderId, status, otp, phone, message }
  const tr = document.querySelector(`tr[data-orderid="${p.orderId}"]`);
  if (!tr) return;

  if (p.expiresAt){
    tr.dataset.expires = p.expiresAt;
    const cd = tr.querySelector('.countdown');
    if (cd) cd.dataset.expires = p.expiresAt;
  }

  // อัปเดตเบอร์ (ถ้ามี)
  if (Object.prototype.hasOwnProperty.call(p,'phone')) {
    const cell = tr.children[2];
    const ct = Number(tr.dataset.ct || 0);
    const formatted = displayPhoneByCountry(p.phone || '-', ct);

    // desktop
    const mono = cell.querySelector('.mono .v') || cell.querySelector('.mono');
    if (mono) mono.textContent = formatted;
    let btn = cell.querySelector('.copy');
    if (!btn && p.phone){
      btn = document.createElement('button');
      btn.className = 'copy';
      btn.setAttribute('aria-label','คัดลอกเบอร์');
      btn.innerHTML = `<img src="/static/assets/otp24/copy.png" alt="">`;
      (cell.querySelector('.mono') || cell).appendChild(btn);
    }
    if (btn) btn.dataset.copy = formatted;

    // mobile
    const m = document.querySelector(`.m-orders .m-item[data-orderid="${p.orderId}"]`);
    if (m){
      const v = m.querySelector('.row2 .phone .v');
      if (v) v.textContent = formatted;
      let mBtn = m.querySelector('.row2 .phone .copy');
      if (!mBtn && p.phone){
        mBtn = document.createElement('button');
        mBtn.className = 'copy';
        mBtn.setAttribute('aria-label','คัดลอกเบอร์');
        mBtn.innerHTML = `<img src="/static/assets/otp24/copy.png" alt="">`;
        v?.after(mBtn);
      }
      if (mBtn) mBtn.dataset.copy = formatted;
    }
  }

  // อัปเดต OTP block
  const cell = tr.children[3]; // คอลัมน์ OTP/เวลา
  if (p.otp){
    // มี OTP แล้ว
    let otpDiv = cell.querySelector('.otp');
    if (!otpDiv){
      otpDiv = document.createElement('div');
      otpDiv.className = 'otp';
      cell.prepend(otpDiv);
    }
    otpDiv.innerHTML = `OTP : <b>${p.otp}</b>
        <button class="copy" data-copy="${p.otp}" aria-label="คัดลอก OTP">
            <img src="/static/assets/otp24/copy.png" alt="">
        </button>`;
  } else {
    // ยังไม่มี OTP → “ไม่พบข้อความ”
    let otpDiv = cell.querySelector('.otp');
    if (!otpDiv){
      otpDiv = document.createElement('div');
      otpDiv.className = 'otp none';
      cell.prepend(otpDiv);
    }
    otpDiv.classList.add('none');
    otpDiv.innerHTML = `OTP : <span class="muted">ไม่พบข้อความ</span>`;
  }

  // อัปเดต Pill สถานะ + ข้อความ
  if (p.status){
    const pill = tr.querySelector('.pill');
    const status = String(p.status).toLowerCase();
    pill.className = `pill ${status}`;
    pill.textContent =
      status==='success'   ? 'สำเร็จ' :
      status==='refunded'  ? 'คืนเครดิต' :
      status==='timeout'   ? 'คืนเครดิต' :
      status==='failed'    ? 'คืนเครดิต' :
                             'กำลังรอ OTP';
  }

  // จัดการ countdown ใต้ pill
  const status = String(p.status||'').toLowerCase();
  let cd = tr.querySelector('.countdown');

  if (status === 'processing') {
    if (!cd) {
      cd = document.createElement('div');
      cd.className = 'countdown';
      // ถ้าเซิร์ฟเวอร์ส่ง expiresAt มาใน patch ก็ใส่ด้วย (ถ้ายังไม่มี ให้ใช้ data-expires เดิม)
      // นี่คือ display only; ถ้าไม่มี ก็ไม่เป็นไร tick จะข้าม
      cd.dataset.expires = tr.getAttribute('data-expires') || '';
      tr.children[5].appendChild(cd); // คอลัมน์สถานะ
    }
  } else {
    cd?.remove();
  }

  // ถ้าออเดอร์นี้ success → ตัด countdown ทิ้ง และถ้าไม่เหลือ processing เลย ให้หยุด auto-refresh ทันที
  if (status === 'success') {
    // ตัด countdown ของแถวนี้ทิ้ง
    tr.querySelector('.countdown')?.remove();
    tr.removeAttribute('data-expires');

    // มือถือด้วย
    const mCard = document.querySelector(`.m-orders .m-item[data-orderid="${p.orderId}"]`);
    mCard?.querySelector('.countdown')?.remove();
    mCard?.removeAttribute('data-expires');

    // ถ้าไม่เหลืองานสถานะ processing แล้ว → หยุดลูปทันที (ไม่ต้องรอรอบถัดไป)
    if (!hasProcessingRows()) stopOrdersAutoRefresh();
  }
}

function getProcessingOrderIds() {
  const ids = new Set();

  // Desktop table rows
  document.querySelectorAll('#ordersBody tr[data-orderid]').forEach(tr => {
    const pill = tr.querySelector('.pill');
    const st = (pill?.className || '').toLowerCase();
    if (st.includes('processing')) {
      ids.add(tr.getAttribute('data-orderid'));
    }
  });

  // Mobile cards
  document.querySelectorAll('#mOrders .m-item[data-orderid]').forEach(card => {
    const pill = card.querySelector('.pill');
    const st = (pill?.className || '').toLowerCase();
    if (st.includes('processing')) {
      ids.add(card.getAttribute('data-orderid'));
    }
  });

  return Array.from(ids).filter(Boolean);
}

/* ดึง patch ทั้งหน้า แล้วอัปเดตทุกแถว */
async function refreshProcessingOrdersOnce() {
  try {
    const ids = getProcessingOrderIds();
    if (!ids.length) {
      stopOrdersAutoRefresh?.();
      return;
    }

    const results = await Promise.allSettled(
      ids.map(async (orderId) => {
        const res = await fetch(`/otp24/orders/${encodeURIComponent(orderId)}/refresh`, { method: 'POST' });
        const j = await res.json().catch(() => ({}));
        if (res.ok && j?.ok && j?.patch) applyOrderPatch?.(j.patch);
        return j;
      })
    );

    // หลังอัปเดตทุกรายการแล้ว — ถ้าไม่เหลือ processing เลยให้หยุด
    if (!hasProcessingRows?.()) stopOrdersAutoRefresh?.();
  } catch {
    // เงียบไว้ตามสไตล์เดิม
  }
}

/* ลูปออโต้เหมือน otp24 */
function startOrderPolling(orderId){
  if (!orderId || pollers.has(orderId)) return;

  // ป้องกันกระพริบ DOM เมื่อได้ OTP แล้ว
  let lastOtp = null;
  let lastStatus = null;

  const updateOtpCell = (tr, patch) => {
    const cell = tr.children[3];
    const nowText = new Date().toISOString().replace('T',' ').slice(0,19);

    if (patch.otp && patch.otp !== lastOtp) {
      lastOtp = patch.otp;
      cell.innerHTML = `
        <div class="otp">OTP : <b>${patch.otp}</b>
          <button class="copy" data-copy="${patch.otp}" aria-label="คัดลอก OTP">
            <img src="/static/assets/otp24/copy.png" alt="" />
          </button>
        </div>
        <div class="ts">${nowText}</div>`;
      // ไฮไลต์ครั้งเดียวตอนเพิ่งได้รหัส
      cell.classList.remove('flash');
      void cell.offsetWidth; // reflow
      cell.classList.add('flash');
    } else if (!patch.otp && lastOtp == null) {
      cell.innerHTML = `
        <div class="otp muted">OTP : <b>ไม่พบข้อความ</b></div>
        <div class="ts">${nowText}</div>`;
    }
  };

  const updateStatusPill = (tr, patch) => {
    const pill = tr.querySelector('.pill');
    if (!pill) return;
    const st = String(patch.status || '').toLowerCase();
    if (st === lastStatus) return;
    lastStatus = st;

    pill.className = `pill ${st}`;
    pill.textContent =
      st==='success'    ? 'สำเร็จ' :
      st==='processing' ? 'กำลังรอ OTP' :
      st==='timeout'    ? 'คืนเครดิต' :
      st==='failed'     ? 'คืนเครดิต' :
      st==='refunded'   ? 'คืนเครดิต' : 'คืนเครดิต';
  };

  const updatePhoneCells = (tr, patch) => {
    if (!patch.phone) return;

    const ct = Number(tr.dataset.ct || 0);
    const formatted = displayPhoneByCountry(patch.phone, ct);

    // desktop cell
    const cell = tr.children[2];
    const mono = cell.querySelector('.mono .v') || cell.querySelector('.mono');
    if (mono) mono.textContent = formatted;

    let btn = cell.querySelector('.copy');
    if (!btn){
      btn = document.createElement('button');
      btn.className = 'copy';
      btn.setAttribute('aria-label','คัดลอกเบอร์');
      btn.innerHTML = `<img src="/static/assets/otp24/copy.png" alt="">`;
      (cell.querySelector('.mono') || cell).appendChild(btn);
    }
    btn.dataset.copy = formatted;

    // mobile card
    const mCard = document.querySelector(`.m-orders .m-item[data-orderid="${orderId}"]`);
    if (mCard){
      const el = mCard.querySelector('.row2 .phone .v');
      if (el) el.textContent = formatted;
      let mBtn = mCard.querySelector('.row2 .phone .copy');
      if (!mBtn){
        mBtn = document.createElement('button');
        mBtn.className = 'copy';
        mBtn.setAttribute('aria-label','คัดลอกเบอร์');
        mBtn.innerHTML = `<img src="/static/assets/otp24/copy.png" alt="">`;
        el?.after(mBtn);
      }
      mBtn.dataset.copy = formatted;
    }
  };

  const stopThisPolling = () => {
    clearInterval(pollers.get(orderId));
    pollers.delete(orderId);
    const tr = document.querySelector(`tr[data-orderid="${CSS.escape(orderId)}"]`);
    tr?.querySelector('.countdown')?.remove();
    const mCard = document.querySelector(`.m-orders .m-item[data-orderid="${orderId}"]`);
    mCard?.querySelector('.countdown')?.remove();
    if (!hasProcessingRows()) stopOrdersAutoRefresh();
  };

  const tick = async () => {
    try{
      const r = await fetch(`/otp24/orders/${encodeURIComponent(orderId)}/refresh`, { method:'POST' });
      const j = await r.json();
      if (!j?.ok) return;

      const { patch } = j;
      const tr = document.querySelector(`tr[data-orderid="${CSS.escape(orderId)}"]`);
      if (!tr || !patch) return;

      // 1) อัปเดต OTP ทันทีที่มี
      updateOtpCell(tr, patch);

      // 2) อัปเดตสถานะ
      updateStatusPill(tr, patch);

      // 3) อัปเดตเบอร์ถ้ายังไม่เคยโชว์
      updatePhoneCells(tr, patch);

      // 4) หยุดเมื่อ success (ตามสเปคใหม่)
      const st = String(patch.status||'').toLowerCase();
      if (POLL_DONE.has(st)) stopThisPolling();

    }catch{
      // เงียบ ๆ ไป ไม่ให้ user สะดุด
    }
  };

  // เริ่มยิงทันที แล้วค่อยทุก 1 วินาที
  tick();
  const id = setInterval(tick, 1000);
  pollers.set(orderId, id);
}

function startOrdersAutoRefresh(){
  stopOrdersAutoRefresh();
  ORD_AUTO_TIMER = setInterval(async () => {
    await refreshProcessingOrdersOnce();
    tickCountdowns();   // ← เรียกทุก ๆ วิ
  }, 1000);
}

function stopOrdersAutoRefresh(){
  if (ORD_AUTO_TIMER){ clearInterval(ORD_AUTO_TIMER); ORD_AUTO_TIMER = null; }
}

/* เริ่มทำงานให้เหมือนหน้า otp24 */
tickCountdowns();
setInterval(tickCountdowns, 1000);

// เปิดแท็บ "ประวัติ" แล้วค่อยเริ่มลูป
document.querySelector('.tab[data-target="orders"]')
  ?.addEventListener('click', () => {
    startOrdersAutoRefresh();
  });

// เปิดหน้ามาแล้วพบว่ามี processing → เริ่มเลย
if (hasProcessingRows()) startOrdersAutoRefresh();

/* หยุด/เริ่มตาม visibility (ประหยัดโหลด) */
document.addEventListener('visibilitychange', () => {
  if (document.hidden) stopOrdersAutoRefresh();
  else if (document.querySelector('#section-orders').classList.contains('show')) {
    startOrdersAutoRefresh();
  }
});

/* copy OTP ไอคอนแบบ otp24 */
function setCopyIcon(btn, success){
  const img = btn.querySelector('img');
  if (!img) return;
  img.src = success ? '/static/assets/otp24/copy-success.png' : '/static/assets/otp24/copy.png';
}
document.addEventListener('click', (e) => {
  const btn = e.target.closest('.copy');
  if (!btn) return;
  navigator.clipboard.writeText(btn.dataset.copy || '').then(() => {
    setCopyIcon(btn, true);
    setTimeout(() => setCopyIcon(btn, false), 900);
  }).catch(() => setCopyIcon(btn, false));
});

if (COUNTDOWN_ENABLED) {
  tickCountdowns();
  setInterval(tickCountdowns, 1000);
}
</script>

