<section class="page-head">
  <div class="page-title">
    <h1><%= typeof title !== 'undefined' && title ? title : 'สรุปยอดขายรายเดือน' %></h1>
    <small class="muted">หน้าผู้ดูแล → รายงาน → สรุปยอดขายรายเดือน</small>
  </div>
</section>

<div class="month-toolbar" role="group" aria-label="เลือกเดือน">
  <button class="btn ghost" id="btnPrev" type="button" aria-label="เดือนก่อนหน้า">◀︎</button>
  <label class="month-ctrl">
    <input id="monthInput" type="text" value="<%= monthStr %>" readonly aria-label="เลือกเดือน" />
    <button class="icon-btn" id="btnOpenPicker" type="button" aria-label="เปิดตัวเลือกเดือน">📅</button>
  </label>
  <button class="btn ghost" id="btnNext" type="button" aria-label="เดือนถัดไป">▶︎</button>
  <button class="btn" id="btnThisMonth" type="button">เดือนนี้</button>
</div>

<!-- Popup: Month Picker -->
<div id="monthPicker" class="mp-popup" hidden>
  <div class="mp-card" role="dialog" aria-modal="true" aria-label="เลือกเดือน">
    <div class="mp-head">
      <button class="mp-nav" id="mpPrevYear" aria-label="ปีก่อนหน้า">‹</button>
      <div class="mp-year" id="mpYear">2025</div>
      <button class="mp-nav" id="mpNextYear" aria-label="ปีถัดไป">›</button>
    </div>
    <div class="mp-grid" id="mpGrid" role="grid" aria-label="รายชื่อเดือน">
      <!-- เติมด้วยสคริปต์ -->
    </div>
    <div class="mp-actions">
      <button class="btn ghost" id="mpClear">ล้าง</button>
      <div class="spacer"></div>
      <button class="btn ghost" id="mpThisMonth">เดือนนี้</button>
      <button class="btn primary" id="mpOK">ตกลง</button>
    </div>
  </div>
</div>

<%
// monthStr รูปแบบ 'YYYY-MM'
const [yy, mm] = (monthStr || '').split('-').map(Number);
const MONTHS_TH = ['มกราคม','กุมภาพันธ์','มีนาคม','เมษายน','พฤษภาคม','มิถุนายน','กรกฎาคม','สิงหาคม','กันยายน','ตุลาคม','พฤศจิกายน','ธันวาคม'];
const headMonthLabel = `${MONTHS_TH[(mm||1)-1]} ${yy}`; // ถ้าอยากเป็น พ.ศ. ใช้ (yy+543)
%>

<section class="card">
  <div class="table-wrap">
    <table class="tbl zebra">
      <thead>
        <tr class="tbl-head-month">
          <th style="color: #f3a71a; text-align: center;" colspan="5"><%= headMonthLabel %></th>
        </tr>
        <tr>
          <th style="text-align: start; width:141px">วันที่</th>
          <th style="text-align: center;">ยอดต้นทุน (฿)</th>
          <th style="text-align: center;">ยอดขาย (฿)</th>
          <th style="text-align: center;">บริการทั้งหมด (รายการ)</th>
          <th style="text-align: center;">กำไร (฿)</th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach(r => { %>
          <tr>
            <td  style="text-align: start;"><%= r.day %></td>
            <td  style="text-align: center;"><%= r.cost.toLocaleString(undefined,{minimumFractionDigits:2, maximumFractionDigits:2}) %></td>
            <td  style="text-align: center;"><%= r.sale.toLocaleString(undefined,{minimumFractionDigits:2, maximumFractionDigits:2}) %></td>
            <td  style="text-align: center;"><%= r.count %></td>
            <td  style="text-align: center;" class="<%= r.profit >= 0 ? 'text-success' : 'text-danger' %>">
              <%= r.profit.toLocaleString(undefined,{minimumFractionDigits:2, maximumFractionDigits:2}) %>
            </td>
          </tr>
        <% }) %>
      </tbody>
      <tfoot>
        <tr>
          <th style="text-align: start;" class="textsummary">ยอดรวมทั้งเดือน</th>
          <th style="text-align: center;" class="textsummary"><%= monthTotals.cost.toLocaleString(undefined,{minimumFractionDigits:2, maximumFractionDigits:2}) %></th>
          <th style="text-align: center;" class="textsummary"><%= monthTotals.sale.toLocaleString(undefined,{minimumFractionDigits:2, maximumFractionDigits:2}) %></th>
          <th style="text-align: center;" class="textsummary"><%= monthTotals.count %></th>
          <th style="text-align: center;"7 class="<%= monthTotals.profit >= 0 ? 'text-success' : 'text-danger' %>">
            <%= monthTotals.profit.toLocaleString(undefined,{minimumFractionDigits:2, maximumFractionDigits:2}) %>
          </th>
        </tr>
      </tfoot>
    </table>
  </div>
</section>

<style>
/* ====== Base (เดสก์ท็อปและรวมของที่ซ้ำ) ====== */
.table-wrap{overflow:auto}
.tbl{width:100%;border-collapse:separate;border-spacing:0;color:var(--tbl-text,inherit)}
.tbl th,.tbl td{padding:10px 12px;border-bottom:1px solid var(--tbl-border,#24262b);transition:background .15s ease,box-shadow .15s ease;text-align:right}
.tbl th:first-child,.tbl td:first-child{text-align:left}
.tbl thead th{background:var(--tbl-head-bg,#111316);color:var(--tbl-head-text,var(--title,#eadfb8));position:sticky;top:0;z-index:5}
.tbl-head-month th{background:var(--tbl-head-bg,#111316);color:var(--tbl-head-text,var(--title,#eadfb8));text-align:center;font-weight:400;padding:12px;border-bottom:1px solid var(--tbl-border,#24262b);position:sticky;top:0;z-index:6}
.tbl.zebra tbody tr:nth-child(odd)  td{background:var(--tbl-row,#13161b)}
.tbl.zebra tbody tr:nth-child(even) td{background:var(--tbl-row-alt,#181c22)}
.tbl.zebra tbody tr:hover td{background:var(--tbl-hover,#212633)}
.tbl.zebra tbody tr:hover td:first-child,
.tbl.zebra tbody tr:focus-within td:first-child{box-shadow:inset 3px 0 0 0 var(--accent,#2a84ff)}
.tbl.zebra tbody tr:focus-within td{background:var(--tbl-hover,#212633)}
.text-success{color:var(--success,#10b981);font-weight:400}
.text-danger{color:var(--danger,#ef4444);font-weight:400}

.page-head{display:flex;align-items:flex-end;justify-content:space-between;gap:12px;margin-bottom:16px}
.month-toolbar{display:flex;align-items:center;gap:10px;background:var(--pick-toolbar-bg,#15171b);border:1px solid var(--tbl-border,#24262b);border-radius:999px;padding:6px 10px;box-shadow:var(--elevated-shadow,0 10px 24px rgba(0,0,0,.25))}
.month-ctrl{display:flex;align-items:center;gap:6px;background:var(--pick-chip-bg,rgba(255,255,255,.06));border:1px solid var(--pick-chip-border,#24262b);border-radius:999px;padding:6px 10px}
.month-ctrl input{background:transparent;border:0;outline:none;color:var(--pick-input,#f2f4f8);font-weight:400;letter-spacing:.3px;min-width:115px;text-align:center;cursor:pointer}
.month-ctrl input:focus-visible{box-shadow:0 0 0 3px var(--pick-toolbar-ring,rgba(42,132,255,.35));border-radius:8px}
.icon-btn{background:transparent;border:0;cursor:pointer;color:var(--pick-icon,#a7b0bb);font-size:16px}
.icon-btn:hover{color:var(--pick-icon-hover,#fff)}

/* Month Picker (popup) */
#monthPicker[hidden]{display:none!important}
.mp-popup{position:fixed;inset:0;display:grid;place-items:start end;padding:72px 16px 16px;background:rgba(0,0,0,.28);z-index:2147483647}
.mp-card{width:260px;background:var(--pick-bg,#121418);border:1px solid var(--pick-border,#262a32);border-radius:14px;box-shadow:var(--pick-shadow,0 18px 60px rgba(0,0,0,.45))}
.mp-head{display:flex;align-items:center;justify-content:center;gap:8px;padding:10px 12px;border-bottom:1px solid var(--tbl-border,#1e2128)}
.mp-year{font-weight:400;color:var(--pick-year,#e5e7eb);letter-spacing:.5px}
.mp-nav{background:transparent;border:1px solid var(--pick-nav-bg,#2a2e37);border-radius:8px;color:var(--pick-nav,#aeb6c4);cursor:pointer;padding:4px 8px}
.mp-nav:hover{background:var(--pick-nav-bg-hover,#1b1f27)}
.mp-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;padding:12px}
.mp-m{display:grid;place-items:center;padding:10px 0;border:1px solid var(--pick-month-bg,#242a33);border-radius:10px;color:var(--pick-month,#cbd5e1);cursor:pointer;font-weight:400;letter-spacing:.3px;transition:background .12s ease,color .12s ease,border-color .12s ease}
.mp-m:hover{background:var(--pick-month-hover,#1b2130);border-color:var(--pick-month-hover,#1b2130)}
.mp-m.active{background:var(--pick-month-active,#2a84ff);color:var(--pick-month-active-text,#fff);border-color:var(--pick-month-active,#2a84ff)}
.mp-m.current{outline:2px dashed var(--pick-month-current,rgba(42,132,255,.6));outline-offset:2px}
.mp-actions{display:flex;align-items:center;gap:8px;padding:10px 12px;border-top:1px solid var(--tbl-border,#1e2128)}
.mp-actions .spacer{flex:1}

/* Light theme tokens (สรุป) */
html[data-theme="light"]{
  --tbl-head-bg:#f6f7fb;--tbl-head-text:#334155;--tbl-row:#fff;--tbl-row-alt:#f3f4f6;--tbl-text:#111827;--tbl-border:#e5e7eb;--tbl-hover:#eef2f7;
  --pick-toolbar-bg:#fff;--pick-chip-bg:#f3f4f6;--pick-chip-border:#e5e7eb;--pick-icon:#64748b;--pick-icon-hover:#111827;--pick-input:#111827;
  --pick-bg:#fff;--pick-border:#e5e7eb;--pick-shadow:0 18px 60px rgba(0,0,0,.12);--pick-year:#0f172a;--pick-nav:#334155;--pick-nav-bg:#e5e7eb;--pick-nav-bg-hover:#dbe2ea;
  --pick-month:#0f172a;--pick-month-bg:#e9eef5;--pick-month-hover:#dde6f2;--pick-month-active:#2a84ff;--pick-month-active-text:#fff;--pick-month-current:rgba(42,132,255,.45)
}

/* ====== Mobile overrides (<=640px) ====== */
@media (max-width: 640px){
  /* ให้หัวข้อชิดขอบ + แถบเครื่องมือกว้างไม่เกินจอ */
  .page-head{ padding-inline: 12px; }

  /* จัด month-toolbar เป็นกริด 4 ช่อง: [ก่อนหน้า][ตัวเลือกเดือนยืด][ถัดไป][เดือนนี้] */
  .month-toolbar{
    width: 100%;
    max-width: min(92vw, 420px);
    margin-inline: auto;
    padding: 6px 8px;
    gap: 6px;
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    border-radius: 14px;
  }

  /* ช่องตัวเลือกเดือนให้หด/ยืดได้ และไม่ดันปุ่มอื่น */
  .month-ctrl{
    min-width: 0;
    padding: 6px 10px;
  }
  .month-ctrl input{
    min-width: 0;
    width: 100%;
    text-overflow: ellipsis;
    white-space: nowrap;
    overflow: hidden;
    font-size: 14px;
  }

  /* ปุ่มต่าง ๆ ให้เล็กลงนิด เพื่อไม่ล้น */
  .month-toolbar .btn,
  .month-toolbar .btn.ghost{
    padding: 6px 10px;
    font-size: 14px;
    min-width: auto;      /* อนุญาตให้หด */
    white-space: nowrap;  /* ไม่หักบรรทัด */
  }

  /* ไอคอนปฏิทินเล็กลงนิด */
  .icon-btn{ font-size: 15px; }
}

/* Popup โหมด: center หรือ anchor ใต้ toolbar */
.mp-popup.center{
  position:fixed; inset:0; display:grid; place-items:center;
  background:rgba(0,0,0,.28); padding:0; z-index:2147483647;
}
.mp-popup.anchor{
  position:fixed; inset:0; display:block;
  background:transparent; pointer-events:none; z-index:2147483647;
}
.mp-popup.anchor .mp-card{
  position:fixed; top:var(--mp-top,0px); left:var(--mp-left,0px);
  width:min(320px,92vw); transform:none; pointer-events:auto;
}
@media (max-width:768px){
  .mp-popup.anchor .mp-card{ width:min(360px,94vw); }
}
/* โหมด anchor: วาง popup ใต้ .month-toolbar เสมอ */
.mp-popup.anchor{
  position:fixed;
  inset:0;
  display:block;
  background:transparent;           /* ไม่ต้องมีฉากมืด */
  pointer-events:none;              /* ให้คลิกผ่านนอกการ์ดได้ */
  z-index:2147483647;
}
.mp-popup.anchor .mp-card{
  position:fixed;
  top:var(--mp-top, 0px);
  left:var(--mp-left, 0px);
  transform:none;
  width:min(420px, 94vw);           /* เดสก์ท็อปกว้างขึ้นหน่อย */
  pointer-events:auto;              /* การ์ดรับคลิก */
  border-radius:14px;
  box-shadow:0 18px 60px rgba(0,0,0,.45);
}

/* ลูกศรชี้เล็ก ๆ (optional) */
.mp-popup.anchor .mp-card::before{
  content:"";
  position:absolute;
  top:-8px;
  left:24px;                        /* จะถูกเลื่อนตาม calc left ที่ JS คำนวณ */
  width:12px; height:12px;
  background:inherit;
  border-left:1px solid var(--pick-border,#262a32);
  border-top:1px solid var(--pick-border,#262a32);
  transform:rotate(45deg);
}

/* มือถือยังคุมขนาดให้พอดี */
@media (max-width: 768px){
  .mp-popup.anchor .mp-card{
    width:min(360px, 94vw);
    box-shadow:0 14px 36px rgba(0,0,0,.40);
  }
}

/* คงสไตล์เดิมของ toolbar */
.month-toolbar{
  display:flex; align-items:center; gap:10px;
  background:var(--pick-toolbar-bg,#15171b);
  border:1px solid var(--tbl-border,#24262b);
  border-radius:999px;
  padding:6px 10px;
  box-shadow:var(--elevated-shadow,0 10px 24px rgba(0,0,0,.25));
}
.month-ctrl{
  display:flex; align-items:center; gap:6px;
  background:var(--pick-chip-bg,rgba(255,255,255,.06));
  border:1px solid var(--pick-chip-border,#24262b);
  border-radius:999px; padding:6px 10px;
}
.month-ctrl input{
  background:transparent; border:0; outline:none;
  color:var(--pick-input,#f2f4f8);
  font-weight:400; letter-spacing:.3px;
  min-width:115px; text-align:center; cursor:pointer;
}
.month-ctrl input:focus-visible{ box-shadow:0 0 0 3px var(--pick-toolbar-ring,rgba(42,132,255,.35)); border-radius:8px; }
.icon-btn{ background:transparent; border:0; cursor:pointer; color:var(--pick-icon,#a7b0bb); font-size:16px; }
.icon-btn:hover{ color:var(--pick-icon-hover,#fff); }

/* มือถือ: ให้กว้างพอดีจอ (เหมือนเดิม) */
@media (max-width: 768px){
  .month-toolbar-row{ padding: 0 12px; }
  .month-toolbar{
    width:100%;
    max-width:min(92vw, 420px);
    margin: 0 auto;
    gap:8px;
  }
}

/* เดสก์ท็อป: จัดกึ่งกลาง section เสมอ */
@media (min-width: 1024px){
  .month-toolbar-row{
    display:grid;            /* ตัวคอนเทนเนอร์กว้างเต็มแถว */
    place-items:center;      /* จัดลูกให้อยู่กลางทั้งแกน X/Y */
    margin-top:10px;
  }
  .month-toolbar{
    width:fit-content;       /* ให้กว้างเท่าที่จำเป็น เพื่อจัดกลางได้สวย */
    margin:0;                /* ไม่ต้องใช้ margin auto แล้ว เพราะแถวจัดให้กลางให้ */
  }
}

/* เดสก์ท็อป: พื้นหลังยาวเต็มแถว แต่ปุ่มอยู่กึ่งกลาง */
@media (min-width:1024px){
  .month-toolbar{
    width: 100%;                 /* พื้นหลังยาวเต็มแถว */
    margin: 10px 0 0;            /* ไม่ต้อง margin auto แล้ว */
    display: flex;
    justify-content: center;     /* จัด “คอนเทนต์” ไปกึ่งกลาง */
    align-items: center;
    gap: 10px;                   /* ระยะห่างปุ่ม ๆ */
  }

  /* ไม่ให้ลูก ๆ ถูกยืดกว้างตาม 100% */
  .month-toolbar > *{
    flex: 0 0 auto;
  }
}
</style>

<script>
(function(){
  const MONTH_NAMES_TH = ['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'];

  const input   = document.getElementById('monthInput');
  const btnOpen = document.getElementById('btnOpenPicker');
  const popup   = document.getElementById('monthPicker');
  const yearEl  = document.getElementById('mpYear');
  const grid    = document.getElementById('mpGrid');
  const btnPrevY= document.getElementById('mpPrevYear');
  const btnNextY= document.getElementById('mpNextYear');
  const btnOK   = document.getElementById('mpOK');
  const btnClear= document.getElementById('mpClear');
  const btnThis = document.getElementById('mpThisMonth');

  const btnPrev = document.getElementById('btnPrev');
  const btnNext = document.getElementById('btnNext');
  const btnThisMonth = document.getElementById('btnThisMonth');

  const toolbarEl = document.querySelector('.month-toolbar');
  const card = popup?.querySelector('.mp-card');

  const now = new Date();
  let selYear  = now.getFullYear();
  let selMonth = now.getMonth(); // 0..11
  let tempYear, tempMonth;

  const monthStrInit = (input?.value || '').slice(0,7);
  if (monthStrInit){
    const [yy,mm] = monthStrInit.split('-').map(n=>+n);
    if (yy && mm){ selYear = yy; selMonth = mm-1; }
  }
  tempYear = selYear; tempMonth = selMonth;

  function toYYYYMM(y,m){ return `${y}-${String(m+1).padStart(2,'0')}`; }
  function go(monthStr){
    const u = new URL(location.href);
    u.searchParams.set('month', monthStr);
    location.href = u.toString();
  }

  // ── Toolbar prev/next/เดือนนี้ ──
  btnPrev?.addEventListener('click', ()=>{
    const d = new Date(selYear, selMonth-1, 1);
    go(toYYYYMM(d.getFullYear(), d.getMonth()));
  });
  btnNext?.addEventListener('click', ()=>{
    const d = new Date(selYear, selMonth+1, 1);
    go(toYYYYMM(d.getFullYear(), d.getMonth()));
  });
  btnThisMonth?.addEventListener('click', ()=>{
    go(toYYYYMM(now.getFullYear(), now.getMonth()));
  });

  // ── วาด grid เดือน ──
  function renderGrid(){
    if (!yearEl || !grid) return;
    yearEl.textContent = String(tempYear);
    grid.innerHTML = '';
    for (let m=0;m<12;m++){
      const b = document.createElement('button');
      b.type='button';
      b.className = 'mp-m'
        + (m===tempMonth && tempYear===selYear ? ' active' : '')
        + (m===now.getMonth() && tempYear===now.getFullYear() ? ' current' : '');
      b.textContent = MONTH_NAMES_TH[m];
      b.setAttribute('role','gridcell');
      b.addEventListener('click', ()=>{
        tempMonth = m;
        [...grid.children].forEach(c=>c.classList.remove('active'));
        b.classList.add('active');
      });
      grid.appendChild(b);
    }
  }

  // ── โหมดจัดวาง: center (เดสก์ท็อป) / anchor (มือถือ) ──
  function chooseMode(){
    return 'anchor'; // เดสก์ท็อปก็วางใต้ toolbar เสมอ
  }
  function clamp(n,min,max){ return Math.max(min, Math.min(max, n)); }
  function positionAnchored(){
    if (!toolbarEl || !popup || !card) return;
    const rect = toolbarEl.getBoundingClientRect();
    const gap  = 8;
    const cardW = Math.min(320, Math.round(window.innerWidth * 0.92));
    let left = rect.left + (rect.width/2) - (cardW/2);
    left = clamp(left, 12, window.innerWidth - cardW - 12);
    let top  = rect.bottom + gap;
    const cardH = card.offsetHeight || 260;
    top = clamp(top, 12, window.innerHeight - cardH - 12);
    card.style.setProperty('--mp-left', `${Math.round(left)}px`);
    card.style.setProperty('--mp-top',  `${Math.round(top)}px`);
  }
  function applyMode(mode){
    popup.classList.remove('center','anchor');
    popup.classList.add(mode);
    if (mode==='anchor') positionAnchored();
  }
  function onRelayout(){
    if (!popup || popup.hasAttribute('hidden')) return;
    if (popup.classList.contains('anchor')) positionAnchored();
  }

  // ── เปิด/ปิด ──
  function openPicker(){
    if (!popup || !popup.hasAttribute('hidden')===false) {/* no-op */}
    if (!popup.hasAttribute('hidden')) return;

    // sync grid state ทุกครั้ง
    tempYear = selYear; tempMonth = selMonth;
    renderGrid();

    applyMode(chooseMode());
    popup.removeAttribute('hidden');
    popup.setAttribute('aria-hidden','false');

    setTimeout(()=> popup.querySelector('.mp-m')?.focus(), 0);
    window.addEventListener('resize', onRelayout, {passive:true});
    window.addEventListener('scroll', onRelayout, {passive:true});
  }
  function closePicker(){
    if (!popup) return;
    popup.setAttribute('hidden','');
    popup.setAttribute('aria-hidden','true');
    popup.classList.remove('center','anchor');
    window.removeEventListener('resize', onRelayout);
    window.removeEventListener('scroll', onRelayout);
  }

  // ปุ่มเปิด
  btnOpen?.addEventListener('click', openPicker);
  input?.addEventListener('click', openPicker);

  // เดินปี
  btnPrevY?.addEventListener('click', ()=>{ tempYear--; renderGrid(); });
  btnNextY?.addEventListener('click', ()=>{ tempYear++; renderGrid(); });

  // ยืนยัน / ล้าง / เดือนนี้
  btnOK?.addEventListener('click', ()=>{
    selYear = tempYear; selMonth = tempMonth;
    input.value = toYYYYMM(selYear, selMonth);
    closePicker();
    go(input.value);
  });
  btnClear?.addEventListener('click', ()=>{
    input.value = '';
    closePicker();
    go(toYYYYMM(now.getFullYear(), now.getMonth()));
  });
  btnThis?.addEventListener('click', ()=>{
    tempYear = now.getFullYear(); tempMonth = now.getMonth();
    renderGrid();
  });

  // ESC ปิด
  window.addEventListener('keydown', (e)=>{
    if (e.key==='Escape' && !popup.hasAttribute('hidden')) closePicker();
  });
  // คลิกฉากทึบ (เฉพาะโหมด center) เพื่อปิด
  popup.addEventListener('click', (e)=>{
    if (popup.classList.contains('center') && e.target === popup) closePicker();
  });

  // เผื่อเรียกจากที่อื่น
  window.__monthPicker__ = { openPicker, closePicker, positionAnchored };
})();
</script>

