            color: "rgba(161,161,170,0.95)",
            callback(value) { return Number(value).toLocaleString(); },
          },
        },
      },
      layout: { padding: { top: 8, right: 12, bottom: 4, left: 6 } },
      animation: { duration: 650, easing: "easeOutCubic" },
