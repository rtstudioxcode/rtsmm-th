<section class="page bonustime container bonustime-admin"
  data-update-endpoint="<%- typeof updateEndpoint !== 'undefined' ? updateEndpoint : '/admin/bonustime/tenant' %>">

  <!-- แถบ Tab แบบเดียวกับหน้า bonustime -->
  <div class="bt-tabbar">
    <button class="bt-tab active" data-tab="orders">
      <span>รายการเช่า Service</span>
    </button>
    <button class="bt-tab" data-tab="summary">
      <span>สรุปยอดขายรายเดือน</span>
    </button>
  </div>

  <!-- TAB 1: รายการเช่า / Serial Key -->
  <section id="tab-orders" class="tabpane show">
    <%
      // ───────────────────────────────────────────────
      // แยก package ล่วงหน้า
      // ───────────────────────────────────────────────
      const pkg1 = [];   // Package 1 = สล็อต+บาคาร่า (LOTTO_ENABLED = false)
      const pkg2 = [];   // Package 2 = สล็อต+บาคาร่า+หวย (LOTTO_ENABLED = true)

      (records || []).forEach(rec => {
        if (rec.LOTTO_ENABLED) pkg2.push(rec);
        else pkg1.push(rec);
      });

      // นับ unsold
      let unsoldTotal = 0;
      let unsoldPkg1 = 0;
      let unsoldPkg2 = 0;

      (records || []).forEach(r => {
        if (!r.serial_key) {
          unsoldTotal++;
          if (r.LOTTO_ENABLED) unsoldPkg2++;
          else unsoldPkg1++;
        }
      });
    %>

    <header class="page-head">
      <div class="bt-head-left">
        <h1>รายการออเดอร์</h1>
      </div>

      <div class="bt-add-wrapper">
        <button id="btnAddTenant" class="bt-add-btn">
          <span class="bt-add-icon">＋</span>
          <span>เพิ่ม Service ใหม่</span>
        </button>
      </div>
    </header>

    <p class="unsold-summary">
      Services ที่เหลือ
      <strong><%= unsoldTotal %></strong> ออเดอร์ ·
      Package 1:
      <strong><%= unsoldPkg1 %> รายการ</strong> |
      Package 2:
      <strong><%= unsoldPkg2 %> รายการ</strong>
    </p>

    <%
      function renderPackage(title, list) {
    %>
      <section class="bt-section">
        <h2 class="bt-section-title">
          <%= title %>
          <span class="count">(<%= list.length %> รายการ)</span>
        </h2>

        <% if (!list.length) { %>
          <div class="card">
            <p class="muted">ไม่มีรายการในหมวดนี้</p>
          </div>
        <% } else { %>

          <div class="bt-admin-list">
            <% list.forEach((rec) => { %>

              <article
                class="bonustime-card admin"
                data-tenant-id="<%= rec.tenantId %>"
                data-serial="<%= rec.serial_key || '' %>">

                <!-- ========== HEADER (กดพับ/ขยาย) ========== -->
                <header class="collapse-head">
                  <div class="tenant">
                    <div class="tenant-name">
                      <%= rec.NAME || rec.name || ('Service: ' + (rec.tenantId || '-')) %>
                    </div>

                    <div class="tenant-meta small muted">
                      Service: <span><%= rec.tenantId || '-' %></span>
                      <% if (rec.serial_key) { %>
                        · Serial: <span><%= rec.serial_key %></span>
                      <% } %>
                      <% if (rec.username) { %>
                        · Owner: <span><%= rec.username %></span>
                      <% } %>
                    </div>
                  </div>

                  <div class="status-right">
                    <% if (rec.serial_key) { %>
                      <div class="status-pill sold">
                        ขายไปแล้ว
                        <% if (rec.licenseDisabled) { %>
                          · ไม่มีวันหมดอายุ
                        <% } else if (rec.expiresAtLabel) { %>
                          · หมดอายุ <%= rec.expiresAtLabel %>
                        <% } %>
                      </div>

                      <% if (!rec.licenseDisabled && rec.expiresAtInput) { %>
                        <div class="expiry-pill" data-expiry="<%= rec.expiresAtInput %>">
                          กำลังคำนวณ…
                        </div>
                      <% } %>

                    <% } else { %>
                      <div class="status-pill free">
                        ยังไม่ขาย
                      </div>
                    <% } %>

                    <button type="button" class="bt-delete-btn" title="ลบ Service นี้">
                      ลบ
                    </button>

                    <div class="collapse-icon" aria-hidden="true">⌃</div>
                  </div>
                </header>

                <!-- ========== BODY (ฟอร์มแก้ไข auto-save) ========== -->
                <div class="collapse-body">
                  <div class="bt-grid">

                    <div class="bt-field">
                      <label>ชื่อ Server (NAME)</label>
                      <input
                        class="bt-edit"
                        data-field="NAME"
                        type="text"
                        value="<%= rec.NAME || '' %>">
                    </div>

                    <div class="bt-field">
                      <label>Service</label>
                      <input type="text" value="<%= rec.tenantId || '' %>" readonly>
                    </div>

                    <div class="bt-field">
                      <label>Serial Key</label>
                      <input
                        class="bt-edit"
                        data-field="serial_key"
                        type="text"
                        value="<%= rec.serial_key || '' %>">
                    </div>

                    <div class="bt-field">
                      <label>เจ้าของ Service</label>
                      <input
                        type="text"
                        value="<%= rec.username || '-' %>"
                        readonly
                        class="owner-readonly">
                    </div>

                    <div class="bt-field">
                      <label>วันหมดอายุ</label>
                      <input
                        class="bt-edit"
                        data-field="expiresAt"
                        type="date"
                        value="<%= rec.licenseDisabled ? '' : (rec.expiresAtInput || '') %>"
                        <%= rec.licenseDisabled ? 'disabled' : '' %> >
                    </div>

                    <div class="bt-field bt-field-wide">
                      <label>ชื่อเจ้าของ</label>
                      <input
                        class="bt-edit"
                        data-field="ownerName"
                        type="text"
                        value="<%= rec.username || '-' %>">
                    </div>

                    <div class="bt-field bt-field-wide full-link-field">
                      <label>ลิงก์เชื่อมต่อ (Webhook)</label>
                      <div class="link-row full-link">
                        <input
                          class="bt-edit"
                          data-field="LINK"
                          type="text"
                          value="<%= rec.LINK || '' %>">
                        <button type="button" class="bt-copy-link" data-link="<%= rec.LINK || '' %>">
                          คัดลอก
                        </button>
                      </div>
                    </div>

                    <div class="bt-field bt-field-wide">
                      <label>โลโก้</label>
                      <input class="bt-edit" data-field="LOGO" type="text" value="<%= rec.LOGO || '' %>">
                    </div>

                    <div class="bt-field">
                      <label>ลิงก์เข้าสู่ระบบ</label>
                      <input class="bt-edit" data-field="LOGIN_URL" type="text" value="<%= rec.LOGIN_URL || '' %>">
                    </div>

                    <div class="bt-field">
                      <label>ลิงก์สมัครสมาชิก</label>
                      <input class="bt-edit" data-field="SIGNUP_URL" type="text" value="<%= rec.SIGNUP_URL || '' %>">
                    </div>

                    <div class="bt-field">
                      <label>ลิงก์ไลน์ติดต่อ</label>
                      <input class="bt-edit" data-field="LINE_ADMIN" type="text" value="<%= rec.LINE_ADMIN || '' %>">
                    </div>

                    <div class="bt-field">
                      <label>หวย</label>
                      <select class="bt-edit" data-field="LOTTO_ENABLED">
                        <option value="true" <%= rec.LOTTO_ENABLED ? 'selected' : '' %>>เปิด</option>
                        <option value="false" <%= !rec.LOTTO_ENABLED ? 'selected' : '' %>>ปิด</option>
                      </select>
                    </div>

                    <div class="bt-field">
                      <label>ระบบวันหมดอายุ</label>
                      <select class="bt-edit" data-field="LICENSE_DISABLED">
                        <option value="false" <%= !rec.LICENSE_DISABLED ? 'selected' : '' %>>เปิด</option>
                        <option value="true" <%= rec.LICENSE_DISABLED ? 'selected' : '' %>>ปิด</option>
                      </select>
                    </div>

                    <div class="bt-field">
                      <label>วันเริ่มต้นใช้งาน</label>
                      <input class="bt-edit" data-field="LICENSE_START_DATE" type="text" value="<%= rec.LICENSE_START_DATE || '' %>">
                    </div>

                    <div class="bt-field">
                      <label>ระยะเวลาใช้งาน (วัน)</label>
                      <input class="bt-edit" data-field="LICENSE_DURATION_DAYS" type="number" value="<%= rec.LICENSE_DURATION_DAYS || 0 %>">
                    </div>

                    <div class="bt-field bt-field-wide">
                      <label>CHANNEL_ACCESS_TOKEN</label>
                      <textarea class="bt-edit" data-field="CHANNEL_ACCESS_TOKEN" rows="2"><%= rec.CHANNEL_ACCESS_TOKEN || '' %></textarea>
                    </div>

                    <div class="bt-field bt-field-wide">
                      <label>CHANNEL_SECRET</label>
                      <input class="bt-edit" data-field="CHANNEL_SECRET" type="text" value="<%= rec.CHANNEL_SECRET || '' %>">
                    </div>

                    <div class="bt-field bt-field-wide">
                      <label>โน้ตภายใน</label>
                      <textarea class="bt-edit" data-field="note" rows="2"><%= rec.note || '' %></textarea>
                    </div>

                  </div>
                  
                  <div class="bt-admin-actions">
                      <button type="button" class="bt-action-btn primary" onclick="openServerMonitor('<%= rec.tenantId %>')">
                          <i class="fa-solid fa-terminal"></i> <span>ดูรายงานเซิฟเวอร์</span>
                      </button>
                      
                      <button type="button" class="bt-action-btn restart" onclick="confirmRestartServer('<%= rec.tenantId %>')">
                          <i class="fa-solid fa-rotate"></i> <span>รีสตาร์ท Server</span>
                      </button>

                      <button type="button" class="bt-action-btn redeploy" onclick="confirmRedeploy('<%= rec.tenantId %>')">
                          <i class="fa-solid fa-cloud-arrow-up"></i> <span>Re-Deploy</span>
                      </button>

                      <div class="bt-flex-spacer"></div>
                  </div>

                </div>
              </article>

            <% }) %>
          </div>
        <% } %>
      </section>
    <%
      } // END function renderPackage
    %>

    <!-- เรียก render ทั้ง 2 group -->
    <%- renderPackage("Package 1 — สล็อต + บาคาร่า", pkg1) %>
    <%- renderPackage("Package 2 — สล็อต + บาคาร่า + หวย", pkg2) %>

  </section>

  <!-- Modal เพิ่มรายการ Bonustime -->
  <dialog id="addTenantModal">
    <form method="dialog" class="modal-form" id="addTenantForm">
      <h2 style="text-align:center;">เพิ่ม Service ใหม่</h2>

      <label>
        Service
        <input name="tenantId" type="text" required placeholder="เช่น RTAUTOBOT-OFFICIAL">
      </label>

      <label>
        หวย
        <select name="lotto" required>
          <option value="true">เปิด</option>
          <option value="false" selected>ปิด</option>
        </select>
      </label>

      <label>
        ลิงก์เชื่อมต่อ (Webhook / Panel)
        <input name="link" type="text" placeholder="https://…/webhook">
      </label>

      <div class="modal-actions">
        <button type="button" class="btn" id="btnAddTenantCancel">ยกเลิก</button>
        <button type="submit" class="btn primary">บันทึก</button>
      </div>
    </form>
  </dialog>

  <!-- Tab 2: Ultra Mode Summary -->
  <section id="tab-summary" class="tabpane ultra-summary">
    <!-- HEADER + MONTH SELECTOR -->
    <header class="ultra-summary-head">
        <div class="ultra-summary-title">
        <h2>สรุปยอด Bonustime รายเดือน</h2>
        <p class="muted small">เลือกเดือนด้านขวาเพื่อดูยอดขายจาก RT AUTOBOT</p>
        </div>

        <div class="ultra-month-select">
        <label for="monthSelect">เลือกเดือน</label>
        <select id="monthSelect">
            <!-- options เติมจาก JS -->
        </select>
        </div>
    </header>

    <!-- SUMMARY CARDS -->
    <div class="ultra-cards">
        <!-- ยอดขายรวม -->
        <section class="ultra-card glass" id="cardTotal">
          <h3>ยอดขายรวมเดือนนี้</h3>
          <div class="ultra-value">
            ฿ <span id="totalRevenue"><%= totalRevenue.toLocaleString() %></span>
          </div>
          <div class="ultra-trend <%= totalRevenue > 0 ? 'up' : 'flat' %>">
            <span class="dot"></span>
            <span class="label" id="labelTotal">
              <%= totalRevenue > 0 ? 'มีรายได้' : 'ยังไม่มีรายการ' %>
            </span>
          </div>
          <canvas class="spark" id="sparkTotal"></canvas>
        </section>

        <!-- Package 1 -->
        <section class="ultra-card glass" id="cardPkg1">
          <h3>Package 1 (สล็อต+บาคาร่า)</h3>
          <div class="ultra-value">
            ฿ <span id="pkg1Revenue"><%= pkg1Revenue.toLocaleString() %></span>
          </div>
          <div class="ultra-trend <%= pkg1Revenue > 0 ? 'up' : 'flat' %>">
            <span class="dot"></span>
            <span class="label" id="labelPkg1">
              <% if (pkg1Count > 0) { %>
                มี <%= pkg1Count %> รายการ
              <% } else { %>
                ยังไม่มีการขาย
              <% } %>
            </span>
          </div>
          <canvas class="spark" id="sparkPkg1"></canvas>
        </section>

        <!-- Package 2 -->
        <section class="ultra-card glass" id="cardPkg2">
          <h3>Package 2 (สล็อต+บาคาร่า+หวย)</h3>
          <div class="ultra-value">
            ฿ <span id="pkg2Revenue"><%= pkg2Revenue.toLocaleString() %></span>
          </div>
          <div class="ultra-trend <%= pkg2Revenue > 0 ? 'up' : 'flat' %>">
            <span class="dot"></span>
            <span class="label" id="labelPkg2">
              <% if (pkg2Count > 0) { %>
                มี <%= pkg2Count %> รายการ
              <% } else { %>
                ยังไม่มีการขาย
              <% } %>
            </span>
          </div>
          <canvas class="spark" id="sparkPkg2"></canvas>
        </section>

        <!-- จำนวนออเดอร์ -->
        <section class="ultra-card glass" id="cardOrders">
          <h3>จำนวนออเดอร์รวม</h3>
          <div class="ultra-value">
            <span id="orderCount"><%= orderCount %></span> ออเดอร์
          </div>
          <div class="ultra-trend <%= orderCount > 0 ? 'up' : 'flat' %>">
            <span class="dot"></span>
            <span class="label" id="labelOrders">
              <% if (orderCount > 0) { %>
                ทั้งหมด <%= orderCount %> รายการ
              <% } else { %>
                ยังไม่มีคำสั่งซื้อ
              <% } %>
            </span>
          </div>
          <canvas class="spark" id="sparkOrders"></canvas>
        </section>
    </div>

    <!-- CHARTS GRID -->
    <div class="ultra-charts-grid">
        <!-- MAIN CHART: DAILY SALES -->
        <section class="ultra-chart glass">
        <div class="ultra-chart-head">
            <h3>ยอดขายรายวัน (รวม)</h3>
        </div>
        <div class="ultra-chart-body">
            <canvas id="chartDaily"></canvas>
        </div>
        </section>

        <!-- SUB CHART: PKG COMPARISON -->
        <section class="ultra-chart glass">
        <div class="ultra-chart-head">
            <h3>ยอดขายแยกตามแพ็กเกจ</h3>
        </div>
        <div class="ultra-chart-body">
            <canvas id="chartPkgCompare"></canvas>
        </div>
        </section>
    </div>

    <!-- TOP 5 DAYS -->
    <section class="ultra-topdays glass">
      <h3>Top 5 วันขายดีที่สุดในเดือนนี้</h3>

      <div id="topDaysList" class="topdays-list">
          <% const topDays = JSON.parse(top5); %>

          <% if (!topDays.length) { %>
              <div class="muted" style="padding: 18px; text-align:center;">
                  ยังไม่มียอดการขายของเดือนนี้
              </div>
          <% } else { %>
              <% topDays.forEach((day, index) => { %>
                  <div class="top-item">
                      <div class="rank"><%= index + 1 %></div>
                      <div class="label">วันที่ <%= day.day %></div>
                      <div class="bar">
                          <div style="width: <%= totalRevenue > 0 ? (day.amount / totalRevenue) * 100 : 0 %>%"></div>
                      </div>
                      <div class="amount">฿ <%= day.amount.toLocaleString() %></div>
                  </div>
              <% }) %>
          <% } %>
      </div>
  </section>
  </section>

  <!-- Monitor Modal สำหรับ Admin (หน้าตาเหมือนฝั่ง User เพื่อความคุ้นเคย) -->
  <dialog id="railwayMonitorModal" class="bt-dialog" style="padding: 0; border: none; background: transparent;">
    <style>
      /* ปรับแต่งภาพรวมให้ Fit จอ */
      #railwayMonitorModal * {
          box-sizing: border-box !important;
      }

      @media (max-width: 768px) {
          #railwayMonitorModal .bt-modal {
              width: 90vw !important;
              max-width: 100vw !important;
              height: 95vh !important;
              max-height: 100vh !important;
              border-radius: 0 !important;
              margin: 0 !important;
          }

          #logContainer {
              height: calc(100vh - 120px) !important;
              width: 100% !important;
              overflow-x: hidden !important;
              border-radius: 0 !important;
          }

          /* --- แก้ไขจุดที่มีปัญหา (เวลาและข้อความ) --- */
          #logContainer > div {
              display: flex !important;           /* บังคับให้อยู่บรรทัดเดียวกัน */
              flex-direction: row !important;      /* เรียงจากซ้ายไปขวา */
              align-items: flex-start !important;  /* ให้เวลาอยู่ชิดบนเสมอ */
              gap: 10px !important;                /* ระยะห่างระหว่างเวลากับข้อความ */
              padding: 4px 10px !important;
              width: 100% !important;
          }

          #logContainer span:first-child {
              flex-shrink: 0 !important;           /* บังคับไม่ให้เวลาโดนบีบจนหาย */
              white-space: nowrap !important;      /* เวลาห้ามขึ้นบรรทัดใหม่ */
              min-width: 65px !important;          /* ล็อคความกว้างช่วงเวลาไว้ */
          }

          #logContainer span:last-child {
              flex: 1 !important;                  /* ให้ข้อความกินพื้นที่ที่เหลือ */
              white-space: pre-wrap !important;    /* ข้อความยาวให้ตัดลงบรรทัดใหม่ */
              word-break: break-all !important;     /* กันล้นขอบจอ */
              display: inline-block !important;    /* กลับมาเป็นบรรทัดเดียวกัน */
          }
          /* -------------------------------------- */
      }
    </style>

    <div class="bt-modal" style="max-width: 900px; width: 95vw; background: #0b0d11; border: 1px solid #2d3139; padding: 0; overflow: hidden; margin: auto;">
      <!-- Head -->
      <div style="display: flex; justify-content: space-between; align-items: center; padding: 16px 20px; border-bottom: 1px solid #1f2937;">
          <div style="display: flex; align-items: center; gap: 10px;">
              <i class="fa-solid fa-terminal" style="color: #6366f1;"></i>
              <h2 id="monitorTitle" style="color: #fff; margin: 0; font-size: 16px; font-weight: 500;">Server Report</h2>
          </div>
          <button onclick="closeMonitorAndRefresh()" style="background: none; border: none; color: #9ca3af; cursor: pointer; font-size: 24px; line-height: 1;">&times;</button>
      </div>

      <!-- Tabs -->
      <div style="background: #0f1116; padding: 0 10px; border-bottom: 1px solid #1f2937;">
          <div class="bt-tabbar" style="margin: 0; border: none;">
              <button class="bt-tab active" id="tab-btn-deploy" onclick="switchLogTab('deploy')">รายงานเซิฟเวอร์</button>
          </div>
      </div>

      <!-- Log Body -->
      <div id="logContainer" style="background: #050505; padding: 10px 0; height: 500px; overflow-y: auto; font-family: 'Fira Code', monospace; font-size: 12px; border-radius: 0 0 18px 18px;">
          <div style="padding: 20px; color: #4b5563;">กำลังดึงข้อมูล...</div>
      </div>
    </div>
  </dialog>

  <!-- UI Confirm Modal (Custom) -->
  <dialog id="btConfirmModal" class="bt-dialog" style="padding: 0; border: none; background: transparent;">
    <style>
      /* Backdrop พื้นหลัง (Blur และมืดลง) */
      #btConfirmModal::backdrop {
        background: rgba(0, 0, 0, 0.75);
        backdrop-filter: blur(5px);
      }

      /* Container หลักของ Confirm Card */
      .confirm-card {
        background: #111318; /* Dark Soft */
        border: 1px solid #2d3139;
        border-radius: 20px;
        width: 90vw;
        max-width: 380px; /* ไม่ใหญ่เกินไป */
        margin: auto;
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6);
        display: flex;
        flex-direction: column;
        position: relative;
      }

      /* ปุ่มปิดมุมขวาบน */
      .confirm-close-btn {
        position: absolute;
        top: 16px;
        right: 16px;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.08);
        color: #9ca3af;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 18px;
        transition: 0.2s;
        z-index: 5;
      }
      .confirm-close-btn:hover { background: rgba(255,255,255,0.08); color: #fff; }

      /* ส่วนเนื้อหาหลัก */
      .confirm-content {
        padding: 32px 24px 24px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      /* ไอคอนวงกลมใหญ่ */
      .confirm-icon-circle {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 36px;
        margin-bottom: 20px;
        border-width: 2px;
        border-style: solid;
      }

      /* หัวข้อและคำอธิบาย */
      .confirm-title-text {
        color: #fff;
        font-size: 18px;
        font-weight: 600;
        margin: 0 0 8px 0;
        font-family: 'Inter', system-ui, sans-serif;
      }
