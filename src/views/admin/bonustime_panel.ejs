          data: dailyData,
          borderColor: "#facc15",
          backgroundColor: bgGradient,
          borderWidth: 2.6,
          fill: true,
          tension: 0.35,
          cubicInterpolationMode: "monotone",
          pointRadius,
          pointHoverRadius: pointRadius ? pointRadius + 1 : 4,
          pointBackgroundColor: "#facc15",
          pointBorderColor: "#020617",
          pointBorderWidth: 1,
          spanGaps: true,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            display: true,
            labels: {
              usePointStyle: true,
              boxWidth: 10,
              color: "rgba(229,229,229,0.9)",
            },
          },
          tooltip: {
            mode: "index",
            intersect: false,
            displayColors: false,
            backgroundColor: "rgba(15,15,23,0.96)",
            borderColor: "#facc15",
            borderWidth: 1,
            padding: 10,
            cornerRadius: 10,
            bodyFont: {
              family: "'Prompt', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
              size: 13,
              weight: "600",
            },
            titleFont: {
              family: "'Prompt', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
              size: 12,
              weight: "500",
            },
            callbacks: {
              label(ctx) {
                const v = Number(ctx.raw || 0);
                return "ยอดรวม: ฿ " + v.toLocaleString();
              },
              title(items) {
                if (!items.length) return "";
                const dayLabel = items[0].label;
                return "วันที่ " + dayLabel;
              },
            },
          },
        },
        interaction: { mode: "index", intersect: false },
        scales: {
          x: {
            grid: { color: "rgba(39,39,42,0.35)", drawBorder: false },
            ticks: { color: "rgba(161,161,170,0.95)", maxTicksLimit: 10 },
          },
          y: {
            beginAtZero: false,
            suggestedMin,
            suggestedMax,
            grid: { color: "rgba(63,63,70,0.55)", drawBorder: false },
            ticks: {
              color: "rgba(161,161,170,0.95)",
              callback(value) { return Number(value).toLocaleString(); },
            },
          },
        },
        layout: { padding: { top: 8, right: 12, bottom: 4, left: 6 } },
        animation: { duration: 650, easing: "easeOutCubic" },
      },
    });
  }

  // -------- PKG COMPARISON --------
  destroyChart("chartPkgCompare");
  const c2 = document.getElementById("chartPkgCompare");
  if (!c2) return;

  const baseLabels =
    Array.isArray(dailyLabels) && dailyLabels.length
      ? dailyLabels
      : (dailyData || []).map((_, i) => i + 1);

  const rawPkg1 = baseLabels.map((_, i) => Number(pkg1Data?.[i] || 0));
  const rawPkg2 = baseLabels.map((_, i) => Number(pkg2Data?.[i] || 0));

  const fLabels = [];
  const fPkg1   = [];
  const fPkg2   = [];
  const fTotal  = [];

  baseLabels.forEach((lbl, i) => {
    const v1 = rawPkg1[i] || 0;
    const v2 = rawPkg2[i] || 0;
    if (v1 !== 0 || v2 !== 0) {
      fLabels.push(lbl);
      fPkg1.push(v1);
      fPkg2.push(v2);
      fTotal.push(v1 + v2);
    }
  });

  const labels    = fLabels.length ? fLabels : baseLabels;
  const safePkg1  = fLabels.length ? fPkg1   : rawPkg1;
  const safePkg2  = fLabels.length ? fPkg2   : rawPkg2;
  const totalData = fLabels.length
    ? fTotal
