// ================== SCRIPT: GRAPH LOGIC ==================
const monthNamesTH = [
  "มกราคม", "กุมภาพันธ์", "มีนาคม", "เมษายน", "พฤษภาคม", "มิถุนายน",
  "กรกฎาคม", "สิงหาคม", "กันยายน", "ตุลาคม", "พฤศจิกายน", "ธันวาคม"
];

const currentDate = new Date();
const currentYearBE = currentDate.getFullYear() + 543;
const currentMonth = currentDate.getMonth() + 1;

// สร้าง select เดือน (ปีเป็น พ.ศ.)
const monthSelect = document.getElementById("monthSelect");
if (monthSelect) {
  monthNamesTH.forEach((month, index) => {
    const option = document.createElement("option");
    const monthValue = `${index + 1}-${currentYearBE}`;
    option.value = monthValue;
    option.textContent = `${month} ${currentYearBE}`;
    if (index + 1 === currentMonth) option.selected = true;
    monthSelect.appendChild(option);
  });
}

// ================== MONTH CHANGE HANDLING ==================
function updateMonthData() {
  const monthSelect = document.getElementById("monthSelect");
  if (!monthSelect) return;

  const selectedMonth = monthSelect.value; // "M-YYYY(BE)"
  const [monthStr, yearBE] = selectedMonth.split("-");
  const month = parseInt(monthStr, 10) || 1;
  const year = (parseInt(yearBE, 10) || (new Date().getFullYear() + 543)) - 543;

  loadMonthData(year, month);
}

document.getElementById("monthSelect")?.addEventListener("change", updateMonthData);

// ================== FUNCTION TO LOAD DATA ==================
async function loadMonthData(year, month) {
  try {
    const monthParam = `${year}-${String(month).padStart(2, "0")}`;

    const res = await fetch(
      `/admin/bonustime/monthly.json?month=${encodeURIComponent(monthParam)}`
    );
    const raw = await res.json().catch(() => ({}));

    if (!res.ok || !raw.ok) {
      console.warn("No data for month", monthParam, raw);
      applyZeroMonth();
      return;
    }

    const daily = Array.isArray(raw.daily) ? raw.daily : [];

    // ====== สร้าง label วันที่จาก daily[].date หรือ daily[].day ======
    const apiDailyLabels = daily
      .map((d, idx) => {
        if (typeof d.day === "number") return String(d.day);
        if (d.date) {
          const dt = new Date(d.date);
          if (!isNaN(dt)) return String(dt.getUTCDate());
        }
        return String(idx + 1);
      });

    const mapped = {
      totalRevenue: Number(raw.totalMonth || 0),
      pkg1Revenue : Number(raw.pkg1Month || 0),
      pkg2Revenue : Number(raw.pkg2Month || 0),
      orderCount  : daily.reduce(
        (sum, d) => sum + Number(d.pkg1 || 0) + Number(d.pkg2 || 0),
        0
      ),
      dailyData   : daily.map(d => Number(d.total || 0)),
      pkg1Data    : daily.map(d => Number(d.pkg1 || 0)),
      pkg2Data    : daily.map(d => Number(d.pkg2 || 0)),
      dailyLabels : apiDailyLabels,
    };

    if (!mapped.dailyData.length) {
      applyZeroMonth();
      return;
    }

    updateCharts(mapped);
    updateSummary(mapped);
  } catch (err) {
    console.error("Error loading month data:", err);
    applyZeroMonth();
  }
}

function applyZeroMonth() {
  const zeroPayload = {
    totalRevenue: 0,
    pkg1Revenue : 0,
    pkg2Revenue : 0,
    orderCount  : 0,
    dailyData   : [0],
    pkg1Data    : [0],
    pkg2Data    : [0],
    dailyLabels : ["1"],
  };
  updateCharts(zeroPayload);
  updateSummary(zeroPayload);
}

// ================== BOOTSTRAP DATA จาก SERVER (EJS) ==================
let dailyLabels = <%- typeof dailyLabels !== 'undefined'
  ? JSON.stringify(dailyLabels)
  : "[]" %>;

let rawDailyData = <%- typeof dailyData !== 'undefined'
  ? JSON.stringify(dailyData)
  : "[]" %>;

let rawPkg1Data = <%- typeof pkg1Data !== 'undefined'
  ? JSON.stringify(pkg1Data)
  : "[]" %>;

let rawPkg2Data = <%- typeof pkg2Data !== 'undefined'
  ? JSON.stringify(pkg2Data)
  : "[]" %>;

let topDaysData = <%- top5 %>;

// ---- helper แปลงเป็น array ตัวเลข ----
function toNumArray(src) {
  if (Array.isArray(src)) return src.map(n => Number(n || 0));
  if (src && typeof src === "object") return Object.values(src).map(n => Number(n || 0));
  return [];
}

let dailyData = toNumArray(rawDailyData);
let pkg1Data  = toNumArray(rawPkg1Data);
let pkg2Data  = toNumArray(rawPkg2Data);

if (!Array.isArray(topDaysData)) {
  topDaysData = topDaysData ? [topDaysData] : [];
}

function ensureAtLeastTwo(arr) {
  if (arr.length === 1) return [arr[0], arr[0]];
  return arr;
}

dailyData = ensureAtLeastTwo(dailyData);
pkg1Data  = ensureAtLeastTwo(pkg1Data);
pkg2Data  = ensureAtLeastTwo(pkg2Data);

console.log("dailyData (boot):", dailyData);
console.log("pkg1Data (boot):", pkg1Data);
console.log("pkg2Data (boot):", pkg2Data);

// ================== FUNCTION TO UPDATE CHARTS ==================
function updateCharts(data) {
  // อัปเดต labels จาก API ถ้ามี
  if (Array.isArray(data.dailyLabels) && data.dailyLabels.length) {
    dailyLabels = data.dailyLabels.slice();
  } else if (!Array.isArray(dailyLabels) || !dailyLabels.length) {
    dailyLabels = (data.dailyData || []).map((_, i) => String(i + 1));
  }

  // อัปเดต datasets
  dailyData = Array.isArray(data.dailyData) ? data.dailyData.slice() : [];
  pkg1Data  = Array.isArray(data.pkg1Data)  ? data.pkg1Data.slice()  : [];
  pkg2Data  = Array.isArray(data.pkg2Data)  ? data.pkg2Data.slice()  : [];

  dailyData = ensureAtLeastTwo(dailyData);
  pkg1Data  = ensureAtLeastTwo(pkg1Data);
  pkg2Data  = ensureAtLeastTwo(pkg2Data);

  if (!dailyData.length) {
    console.warn("No daily data after updateCharts");
    return;
  }

  // spark line
  makeSpark("sparkTotal",  dailyData, "#facc15");
  makeSpark("sparkPkg1",   pkg1Data,  "#38bdf8");
  makeSpark("sparkPkg2",   pkg2Data,  "#fbbf24");
  makeSpark("sparkOrders", dailyData.map(x => x * 0.02), "#a78bfa");

  makeMainCharts();
}

// ================== FUNCTION TO UPDATE SUMMARY ==================
function updateSummary(data) {
  const totalEl = document.getElementById("totalRevenue");
  const pkg1El  = document.getElementById("pkg1Revenue");
  const pkg2El  = document.getElementById("pkg2Revenue");
  const orderEl = document.getElementById("orderCount");

  if (totalEl) totalEl.textContent = Number(data.totalRevenue || 0).toLocaleString();
  if (pkg1El)  pkg1El.textContent  = Number(data.pkg1Revenue || 0).toLocaleString();
  if (pkg2El)  pkg2El.textContent  = Number(data.pkg2Revenue || 0).toLocaleString();
  if (orderEl) orderEl.textContent = Number(data.orderCount  || 0).toLocaleString();
}

// ================== DESTROY CHART HELPER ==================
function destroyChart(chartId) {
  const chartElement = document.getElementById(chartId);
  if (chartElement) {
    const chart = Chart.getChart(chartId);
    if (chart) chart.destroy();
  }
}

// ================== SPARK TOOLTIP ==================
function getOrCreateSparkTooltip(chart) {
  let tooltipEl = chart.canvas.__sparkTooltipEl;
  if (!tooltipEl) {
    tooltipEl = document.createElement("div");
    tooltipEl.className = "spark-tooltip";
    tooltipEl.style.position = "absolute";
    tooltipEl.style.pointerEvents = "none";
    tooltipEl.style.zIndex = 20;
    tooltipEl.style.transform = "translate(-50%, -170%)";
    document.body.appendChild(tooltipEl);
    chart.canvas.__sparkTooltipEl = tooltipEl;
  }
  return tooltipEl;
}

function externalSparkTooltip(context) {
  const { chart, tooltip } = context;
  const tooltipEl = getOrCreateSparkTooltip(chart);

  if (!tooltip || tooltip.opacity === 0 || !tooltip.dataPoints?.length) {
    tooltipEl.style.opacity = 0;
    return;
  }

  const dp = tooltip.dataPoints[0];
  const raw = Number(dp.raw || 0);
  const valueText = "฿ " + raw.toLocaleString();
  const color = dp.dataset.borderColor || "#facc15";

  tooltipEl.innerHTML = valueText;
  tooltipEl.style.opacity = 1;
  tooltipEl.style.background = "rgba(0, 0, 0, 0.9)";
  tooltipEl.style.border = "1px solid " + color;
  tooltipEl.style.borderRadius = "999px";
  tooltipEl.style.padding = "4px 10px";
  tooltipEl.style.color = "#fff";
  tooltipEl.style.fontFamily =
    "'Prompt', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif";
  tooltipEl.style.fontSize = "10px";
  tooltipEl.style.fontWeight = "600";
  tooltipEl.style.whiteSpace = "nowrap";
  tooltipEl.style.boxShadow = "0 0 12px rgba(0,0,0,0.45)";

  const canvasRect = chart.canvas.getBoundingClientRect();
  const left = canvasRect.left + window.pageXOffset + tooltip.caretX;
  const top  = canvasRect.top  + window.pageYOffset + tooltip.caretY;

  tooltipEl.style.left = left + "px";
  tooltipEl.style.top  = top  + "px";
}

// ================== SPARK LINES ==================
function makeSpark(canvasId, data, color) {
  const el = document.getElementById(canvasId);
  if (!el || !Array.isArray(data) || !data.length) return;

  let arr = data.slice();
  if (arr.length === 1) arr = [arr[0], arr[0]];

  if (el.__chart) el.__chart.destroy();

  el.__chart = new Chart(el, {
    type: "line",
    data: {
      labels: arr.map((_, i) => i + 1),
      datasets: [{
        data: arr,
        borderColor: color,
        borderWidth: 1.8,
        fill: false,
        tension: 0.35,
        pointRadius: 0,
        pointHitRadius: 8,
      }],
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          enabled: false,
          external: externalSparkTooltip,
        },
      },
      interaction: { mode: "index", intersect: false },
      scales: {
        x: { display: false, grid: { display: false } },
        y: { display: false, grid: { display: false }, beginAtZero: false },
      },
      layout: { padding: { left: 4, right: 4, top: 4, bottom: 4 } },
    },
  });
}

// ================== MAIN CHARTS ==================
function makeMainCharts() {
  // -------- DAILY LINE --------
  destroyChart("chartDaily");
  const c1 = document.getElementById("chartDaily");
  if (c1 && Array.isArray(dailyData) && dailyData.length) {
    const ctx1 = c1.getContext("2d");

    const labels =
      Array.isArray(dailyLabels) &&
      dailyLabels.length === dailyData.length
        ? dailyLabels
        : dailyData.map((_, i) => i + 1);

    const minVal = Math.min(...dailyData);
    const maxVal = Math.max(...dailyData);
    const range = maxVal - minVal || maxVal || 1;
    const suggestedMin = Math.max(0, minVal - range * 0.3);
    const suggestedMax = maxVal + range * 0.15;

    const bgGradient = ctx1.createLinearGradient(0, 0, 0, c1.height);
    bgGradient.addColorStop(0, "rgba(250,204,21,0.30)");
    bgGradient.addColorStop(0.4, "rgba(250,204,21,0.10)");
    bgGradient.addColorStop(1, "rgba(15,23,42,0)");

    const pointRadius = labels.length > 20 ? 0 : 3;

    new Chart(c1, {
      type: "line",
      data: {
        labels,
        datasets: [{
          label: "ยอดรวม (บาท)",
          data: dailyData,
          borderColor: "#facc15",
          backgroundColor: bgGradient,
          borderWidth: 2.6,
          fill: true,
          tension: 0.35,
          cubicInterpolationMode: "monotone",
          pointRadius,
          pointHoverRadius: pointRadius ? pointRadius + 1 : 4,
          pointBackgroundColor: "#facc15",
          pointBorderColor: "#020617",
          pointBorderWidth: 1,
          spanGaps: true,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            display: true,
            labels: {
              usePointStyle: true,
              boxWidth: 10,
              color: "rgba(229,229,229,0.9)",
            },
          },
          tooltip: {
            mode: "index",
            intersect: false,
            displayColors: false,
            backgroundColor: "rgba(15,15,23,0.96)",
            borderColor: "#facc15",
            borderWidth: 1,
            padding: 10,
            cornerRadius: 10,
            bodyFont: {
              family: "'Prompt', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
              size: 13,
              weight: "600",
            },
            titleFont: {
              family: "'Prompt', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
              size: 12,
              weight: "500",
            },
            callbacks: {
              label(ctx) {
                const v = Number(ctx.raw || 0);
                return "ยอดรวม: ฿ " + v.toLocaleString();
              },
              title(items) {
                if (!items.length) return "";
                const dayLabel = items[0].label;
                return "วันที่ " + dayLabel;
              },
            },
          },
        },
        interaction: { mode: "index", intersect: false },
        scales: {
          x: {
            grid: { color: "rgba(39,39,42,0.35)", drawBorder: false },
            ticks: { color: "rgba(161,161,170,0.95)", maxTicksLimit: 10 },
          },
          y: {
            beginAtZero: false,
            suggestedMin,
            suggestedMax,
            grid: { color: "rgba(63,63,70,0.55)", drawBorder: false },
            ticks: {
              color: "rgba(161,161,170,0.95)",
              callback(value) { return Number(value).toLocaleString(); },
            },
          },
        },
        layout: { padding: { top: 8, right: 12, bottom: 4, left: 6 } },
        animation: { duration: 650, easing: "easeOutCubic" },
      },
    });
  }

  // -------- PKG COMPARISON --------
  destroyChart("chartPkgCompare");
  const c2 = document.getElementById("chartPkgCompare");
  if (!c2) return;

  const baseLabels =
    Array.isArray(dailyLabels) && dailyLabels.length
      ? dailyLabels
      : (dailyData || []).map((_, i) => i + 1);

  const rawPkg1 = baseLabels.map((_, i) => Number(pkg1Data?.[i] || 0));
  const rawPkg2 = baseLabels.map((_, i) => Number(pkg2Data?.[i] || 0));

  const fLabels = [];
  const fPkg1   = [];
  const fPkg2   = [];
  const fTotal  = [];

  baseLabels.forEach((lbl, i) => {
    const v1 = rawPkg1[i] || 0;
    const v2 = rawPkg2[i] || 0;
    if (v1 !== 0 || v2 !== 0) {
      fLabels.push(lbl);
      fPkg1.push(v1);
      fPkg2.push(v2);
      fTotal.push(v1 + v2);
    }
  });

  const labels    = fLabels.length ? fLabels : baseLabels;
  const safePkg1  = fLabels.length ? fPkg1   : rawPkg1;
  const safePkg2  = fLabels.length ? fPkg2   : rawPkg2;
  const totalData = fLabels.length
    ? fTotal
    : labels.map((_, i) => safePkg1[i] + safePkg2[i]);

  const ctx2 = c2.getContext("2d");

  const gradPkg1 = ctx2.createLinearGradient(0, 0, 0, c2.height);
  gradPkg1.addColorStop(0, "rgba(56,189,248,0.95)");
  gradPkg1.addColorStop(1, "rgba(15,23,42,0.10)");

  const gradPkg2 = ctx2.createLinearGradient(0, 0, 0, c2.height);
  gradPkg2.addColorStop(0, "rgba(251,146,60,0.95)");
  gradPkg2.addColorStop(1, "rgba(15,23,42,0.10)");

  new Chart(c2, {
    type: "bar",
    data: {
      labels,
      datasets: [
        {
          type: "bar",
          label: "Package 1",
          data: safePkg1,
          backgroundColor: gradPkg1,
          borderColor: "rgba(56,189,248,1)",
          borderWidth: 1.4,
          borderRadius: 8,
          borderSkipped: false,
          barPercentage: 0.45,
          categoryPercentage: 0.55,
        },
        {
          type: "bar",
          label: "Package 2",
          data: safePkg2,
          backgroundColor: gradPkg2,
          borderColor: "rgba(251,146,60,1)",
          borderWidth: 1.4,
          borderRadius: 8,
          borderSkipped: false,
          barPercentage: 0.45,
          categoryPercentage: 0.55,
        },
        {
          type: "line",
          label: "ยอดรวมต่อวัน",
          data: totalData,
          borderColor: "#facc15",
          backgroundColor: "rgba(250,204,21,0.15)",
          borderWidth: 2.2,
          fill: false,
          tension: 0.35,
          cubicInterpolationMode: "monotone",
          pointRadius: 3,
          pointBackgroundColor: "#facc15",
          pointBorderColor: "#020617",
          pointBorderWidth: 1,
          yAxisID: "y",
        },
      ],
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          display: true,
          labels: { usePointStyle: true, boxWidth: 10, color: "#e5e5e5" },
        },
        tooltip: {
          mode: "index",
          intersect: false,
          backgroundColor: "rgba(15,15,23,0.96)",
          borderColor: "#334155",
          borderWidth: 1,
          padding: 10,
          cornerRadius: 10,
          callbacks: {
            title(ctx) {
              if (!ctx.length) return "";
              const dayLabel = ctx[0].label;
              return "วันที่ " + dayLabel;
            },
            label(ctx) {
              const label = ctx.dataset.label || "";
              const v = Number(ctx.raw || 0);
              return `${label}: ฿ ${v.toLocaleString()}`;
            },
          },
        },
      },
      interaction: { mode: "index", intersect: false },
      scales: {
        x: {
          grid: { color: "rgba(39,39,42,0.45)" },
          ticks: {
            color: "rgba(161,161,170,0.95)",
            autoSkip: false,
            maxRotation: 0,
          },
        },
        y: {
          id: "y",
          beginAtZero: true,
          grid: { color: "rgba(63,63,70,0.55)" },
          ticks: {
            color: "rgba(161,161,170,0.95)",
            callback(value) { return Number(value).toLocaleString(); },
          },
        },
      },
      layout: { padding: { top: 8, right: 12, bottom: 4, left: 6 } },
      animation: { duration: 650, easing: "easeOutCubic" },
    },
  });
}

// ================== TOP 5 DAYS ==================
const list = document.getElementById("topDaysList");
if (list) {
  list.innerHTML = "";
  if (Array.isArray(topDaysData) && topDaysData.length) {
    topDaysData.forEach((d, idx) => {
      const pct = (d.amount / topDaysData[0].amount) * 100;
      list.innerHTML += `
        <div class="top-item">
          <div class="rank">${idx + 1}</div>
          <div class="label">วันที่ ${d.day}</div>
          <div class="bar"><div style="width:${pct}%"></div></div>
          <div class="amount">฿${d.amount.toLocaleString()}</div>
        </div>
      `;
    });
  } else {
    list.innerHTML = `<div class="top-item muted">ยังไม่มีข้อมูลในเดือนนี้</div>`;
  }
}

// ================== INITIAL RENDER (หน้าตอนโหลดครั้งแรก) ==================
if (dailyData.length) {
  makeSpark("sparkTotal",  dailyData, "#facc15");
  makeSpark("sparkPkg1",   pkg1Data,  "#38bdf8");
  makeSpark("sparkPkg2",   pkg2Data,  "#fbbf24");
  makeSpark("sparkOrders", dailyData.map(x => x * 0.02), "#a78bfa");
  makeMainCharts();
}
