// ================== MAIN CHARTS ==================
function makeMainCharts() {
  // --- FIX: บังคับ dailyData ให้เป็นเส้นตรงเมื่อไม่มีข้อมูล ---
  if (!Array.isArray(dailyData) || dailyData.length === 0) {
    dailyData = [0, 0];
    dailyLabels = ["1", "2"];
  }

  if (dailyData.every(v => Number(v) === 0)) {
    dailyData = [0, 0];
    dailyLabels = ["1", "2"];
  }

  if (!Array.isArray(pkg1Data) || pkg1Data.length === 0) {
    pkg1Data = [0, 0];
  }
  if (pkg1Data.every(v => Number(v) === 0)) {
    pkg1Data = [0, 0];
  }

  if (!Array.isArray(pkg2Data) || pkg2Data.length === 0) {
    pkg2Data = [0, 0];
  }
  if (pkg2Data.every(v => Number(v) === 0)) {
    pkg2Data = [0, 0];
  }

  // ❗สำคัญมาก: คำนวณ isFlatDaily ใหม่หลังจากแก้ dailyData แล้ว
  const isFlatDaily = dailyData.every(v => Number(v) === 0);

  // -------- DAILY LINE --------
  destroyChart("chartDaily");
  const c1 = document.getElementById("chartDaily");
  if (c1 && Array.isArray(dailyData) && dailyData.length) {
    const ctx1 = c1.getContext("2d");

    const labels =
      Array.isArray(dailyLabels) &&
      dailyLabels.length === dailyData.length
        ? dailyLabels
        : dailyData.map((_, i) => i + 1);
    let suggestedMin, suggestedMax;

    const minVal = Math.min(...dailyData);
    const maxVal = Math.max(...dailyData);
    const range = maxVal - minVal || maxVal || 1;

    if (isFlatDaily) {
      // ถ้าไม่มีข้อมูลเลย → กราฟเป็นเส้นตรง
      suggestedMin = 0;
      suggestedMax = 1; // ต้องไม่เป็น 0 ทั้งคู่ ไม่งั้น Chart.js ไม่วาด
    } else {
      const minVal = Math.min(...dailyData);
      const maxVal = Math.max(...dailyData);
      const range = maxVal - minVal || maxVal || 1;
      suggestedMin = Math.max(0, minVal - range * 0.3);
      suggestedMax = maxVal + range * 0.15;
    }

    const bgGradient = ctx1.createLinearGradient(0, 0, 0, c1.height);
    bgGradient.addColorStop(0, "rgba(250,204,21,0.30)");
    bgGradient.addColorStop(0.4, "rgba(250,204,21,0.10)");
    bgGradient.addColorStop(1, "rgba(15,23,42,0)");

    const pointRadius = labels.length > 20 ? 0 : 3;

    new Chart(c1, {
      type: "line",
      data: {
        labels,
        datasets: [{
