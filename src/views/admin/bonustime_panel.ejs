// ================== EXPIRY COUNTDOWN BADGES ==================
(function () {
  const pills = document.querySelectorAll(
    ".bonustime-admin .expiry-pill[data-expiry]"
  );
  if (!pills.length) return;

  function updateAll() {
    const now = new Date();

    pills.forEach((el) => {
      const dateStr = (el.dataset.expiry || "").trim();
      if (!dateStr) return;

      // นับถึง 23:59:59 ของวันหมดอายุ
      const end = new Date(dateStr + "T23:59:59");
      if (isNaN(end.getTime())) return;

      const diffMs = end.getTime() - now.getTime();

      if (diffMs <= 0) {
        el.textContent = "หมดอายุแล้ว";
        el.classList.add("expired");
        return;
      }

      const totalMinutes = Math.floor(diffMs / 60000);
      const days = Math.floor(totalMinutes / (60 * 24));
      const hours = Math.floor((totalMinutes - days * 60 * 24) / 60);
      const minutes = totalMinutes % 60;

      let label = "เหลือ ";
      if (days > 0) {
        label += `${days} วัน `;
      }
      label += `${String(hours).padStart(2, "0")} ชม. `;
      label += `${String(minutes).padStart(2, "0")} นาที`;

      el.textContent = label;
      el.classList.remove("expired");
    });
  }

  // อัปเดตตอนโหลด + ทุก 30 วินาที
  updateAll();
  setInterval(updateAll, 30_000);
})();

