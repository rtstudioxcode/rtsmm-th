        desc: `ยืนยันการ Build ใหม่สำหรับ ${tenantId}?\nCode ล่าสุดจะถูกดึงมาติดตั้งและเริ่มทำงานใหม่`,
        icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19L17.5 13M17.5 13L15 15.5M17.5 13L20 15.5"></path><path d="M12 19H6a3 3 0 0 1-1-5.83a6 6 0 1 1 11.83-1.17A3.01 3.01 0 0 1 21 15a3 3 0 0 1-3.5 2.95"></path></svg>`,
        color: "#fb923c", // Orange
        bgColor: "rgba(251, 146, 60, 0.1)",
        btnText: "เริ่ม Re-Deploy",
        onConfirm: async () => {
            try {
                const infoRes = await fetch(`/railway/service-info/${tenantId}`);
                const info = await infoRes.json();
                if(!info.serviceId) throw new Error("ไม่พบข้อมูลรหัสเครื่อง");

                const res = await fetch('/railway/redeploy', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ serviceId: info.serviceId, environmentId: info.environmentId })
                });

                const result = await res.json();
                if(res.ok && result.ok) {
                    if (window.notify) notify.success("กำลังดำเนินการ", "ระบบเริ่มการ Build ใหม่แล้ว");
                    else alert("สั่ง Re-Deploy สำเร็จ!");
                } else {
                    throw new Error(result.error || "สั่ง Redeploy ไม่สำเร็จ");
                }
            } catch (err) {
                if (window.notify) notify.error("ผิดพลาด", err.message);
                else alert("Error: " + err.message);
            }
        }
    });
}

// ล้าง Interval เมื่อปิด Modal
document.getElementById('railwayMonitorModal').addEventListener('close', () => {
    clearInterval(logInterval);
});
</script>

