function renderTop5() {
  const list = document.getElementById("topDaysList");
  if (!list) return;

  list.innerHTML = "";

  // ไม่มีข้อมูลเลย → แสดงข้อความ muted
  if (!Array.isArray(topDaysData) || topDaysData.length === 0) {
    list.innerHTML = `
      <div class="muted" style="
        padding: 20px;
        text-align: center;
        font-size: 14px;
        opacity: 0.85;
      ">
        ยังไม่มียอดการขายของเดือนนี้
      </div>
    `;
    return;
  }

  // มีข้อมูล → แสดง Top 5
  const maxAmt = topDaysData[0].amount || 1;

  topDaysData.forEach((d, idx) => {
    const pct = (d.amount / maxAmt) * 100;

    list.innerHTML += `
      <div class="top-item">
        <div class="rank">${idx + 1}</div>
        <div class="label">วันที่ ${d.day}</div>
        <div class="bar"><div style="width:${pct}%"></div></div>
        <div class="amount">฿${d.amount.toLocaleString()}</div>
      </div>
    `;
  });
}

