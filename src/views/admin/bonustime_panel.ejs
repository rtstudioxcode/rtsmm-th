// ====================== MONTH CHANGE HANDLING ======================
function updateMonthData() {
  const monthSelect = document.getElementById("monthSelect");
  if (!monthSelect) return;

  const val = monthSelect.value; // "M-YYYY(BE)"
  const [mStr, yBE] = val.split("-");
  const m = parseInt(mStr, 10) || 1;
  const y = (parseInt(yBE, 10) || (new Date().getFullYear() + 543)) - 543;

  loadMonthData(y, m);
}

document.getElementById("monthSelect")?.addEventListener("change", updateMonthData);

// ====================== LOAD MONTH DATA ======================
async function loadMonthData(year, month) {
  try {
    const monthParam = `${year}-${String(month).padStart(2, "0")}`;

    const res = await fetch(
      `/admin/bonustime/monthly.json?month=${encodeURIComponent(monthParam)}`
    );
    const raw = await res.json().catch(() => ({}));

    if (!res.ok || !raw.ok) {
      console.warn("No data for month", monthParam, raw);
      applyZeroMonth();
      return;
    }

    const daily = Array.isArray(raw.daily) ? raw.daily : [];

    // ========== UPDATE TOP 5 ==========
    if (Array.isArray(raw.top5)) {
      topDaysData = raw.top5;
    } else {
      topDaysData = [];
    }
    renderTop5();  // ← เพิ่มไว้ที่ท้ายโค้ดด้านล่าง

    // ====== Generate labels ======
    const apiDailyLabels = daily.map((d, idx) => {
      if (typeof d.day === "number") return String(d.day);
      if (d.date) {
        const dt = new Date(d.date);
        if (!isNaN(dt)) return String(dt.getUTCDate());
      }
      return String(idx + 1);
    });

    const mapped = {
      totalRevenue: Number(raw.totalMonth || 0),
      pkg1Revenue : Number(raw.pkg1Month || 0),
      pkg2Revenue : Number(raw.pkg2Month || 0),
      orderCount  : Number(raw.orderCount || 0),
      pkg1Count   : Number(raw.pkg1Count || 0),
      pkg2Count   : Number(raw.pkg2Count || 0),
      dailyData   : daily.map(d => Number(d.total || 0)),
      pkg1Data    : daily.map(d => Number(d.pkg1 || 0)),
      pkg2Data    : daily.map(d => Number(d.pkg2 || 0)),
      dailyLabels : apiDailyLabels,
    };

    updateCharts(mapped);
    updateSummary(mapped);
  } catch (err) {
    console.error("Error loading month data:", err);
    applyZeroMonth();
  }
}

// ====================== ZERO MONTH ======================
function applyZeroMonth() {
  const payload = {
    totalRevenue: 0,
    pkg1Revenue : 0,
    pkg2Revenue : 0,
    orderCount  : 0,
    pkg1Count   : 0,
    pkg2Count   : 0,
    dailyData   : [0],
    pkg1Data    : [0],
    pkg2Data    : [0],
    dailyLabels : ["1"],
  };
  updateCharts(payload);
  updateSummary(payload);
}

// ====================== CHART HANDLING ======================
let dailyLabels = [];
let dailyData = [];
let pkg1Data = [];
let pkg2Data = [];

function ensureAtLeastTwo(arr) {
  if (arr.length === 1) return [arr[0], arr[0]];
  return arr;
}

function updateCharts(data) {
  dailyLabels = data.dailyLabels.slice();
  dailyData = ensureAtLeastTwo(data.dailyData.slice());
  pkg1Data  = ensureAtLeastTwo(data.pkg1Data.slice());
  pkg2Data  = ensureAtLeastTwo(data.pkg2Data.slice());

  // สร้าง sparkline
  makeSpark("sparkTotal",  dailyData, "#facc15");
  makeSpark("sparkPkg1",   pkg1Data,  "#38bdf8");
  makeSpark("sparkPkg2",   pkg2Data,  "#fbbf24");
  makeSpark("sparkOrders", dailyData.map(x => x * 0.02), "#a78bfa");

  makeMainCharts();
}

// ====================== SUMMARY UPDATE ======================
function updateSummary(d) {
  setText("totalRevenue", d.totalRevenue.toLocaleString());
  setText("pkg1Revenue",  d.pkg1Revenue.toLocaleString());
  setText("pkg2Revenue",  d.pkg2Revenue.toLocaleString());
  setText("orderCount",   d.orderCount.toLocaleString());

  // Labels
  setLabel("#cardTotal",  d.totalRevenue > 0 ? `มีทั้งหมด ${d.orderCount} รายการ` : "ยังไม่มีรายการ");
  setLabel("#cardPkg1",   d.pkg1Revenue  > 0 ? `มี ${d.pkg1Count} รายการ` : "ยังไม่มีการขาย");
  setLabel("#cardPkg2",   d.pkg2Revenue  > 0 ? `มี ${d.pkg2Count} รายการ` : "ยังไม่มีการขาย");
  setLabel("#cardOrders", d.orderCount   > 0 ? `ทั้งหมด ${d.orderCount} รายการ` : "ยังไม่มีคำสั่งซื้อ");

  // Trend Active Class
  updateTrendClass("#cardTotal",  d.totalRevenue > 0);
  updateTrendClass("#cardPkg1",   d.pkg1Revenue  > 0);
  updateTrendClass("#cardPkg2",   d.pkg2Revenue  > 0);
  updateTrendClass("#cardOrders", d.orderCount   > 0);
}

