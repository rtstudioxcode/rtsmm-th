          barPercentage: 0.45,
          categoryPercentage: 0.55,
        },
        {
          type: "bar",
          label: "Package 2",
          data: safePkg2,
          backgroundColor: gradPkg2,
          borderColor: "rgba(251,146,60,1)",
          borderWidth: 1.4,
          borderRadius: 8,
          borderSkipped: false,
          barPercentage: 0.45,
          categoryPercentage: 0.55,
        },
        {
          type: "line",
          label: "ยอดรวมต่อวัน",
          data: totalData,
          borderColor: "#facc15",
          backgroundColor: "rgba(250,204,21,0.15)",
          borderWidth: 2.2,
          fill: false,
          tension: 0.35,
          cubicInterpolationMode: "monotone",
          pointRadius: 3,
          pointBackgroundColor: "#facc15",
          pointBorderColor: "#020617",
          pointBorderWidth: 1,
          yAxisID: "y",
        },
      ],
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          display: true,
          labels: { usePointStyle: true, boxWidth: 10, color: "#e5e5e5" },
        },
        tooltip: {
          mode: "index",
          intersect: false,
          backgroundColor: "rgba(15,15,23,0.96)",
          borderColor: "#334155",
          borderWidth: 1,
          padding: 10,
          cornerRadius: 10,
          callbacks: {
            title(ctx) {
              if (!ctx.length) return "";
              const dayLabel = ctx[0].label;
              return "วันที่ " + dayLabel;
            },
            label(ctx) {
              const label = ctx.dataset.label || "";
              const v = Number(ctx.raw || 0);
              return `${label}: ฿ ${v.toLocaleString()}`;
            },
          },
        },
      },
      interaction: { mode: "index", intersect: false },
      scales: {
        x: {
          grid: { color: "rgba(39,39,42,0.45)" },
          ticks: {
            color: "rgba(161,161,170,0.95)",
            autoSkip: false,
            maxRotation: 0,
          },
        },
        y: {
