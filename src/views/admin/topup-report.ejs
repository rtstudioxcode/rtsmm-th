<% const BANK_LABELS = {
  bbl:'ธนาคารกรุงเทพ', kbank:'ธนาคารกสิกรไทย', ktb:'ธนาคารกรุงไทย',
  bay:'ธนาคารกรุงศรีอยุธยา', scb:'ธนาคารไทยพาณิชย์', tmb:'ทหารไทยธนชาต (TTB)',
  cimb:'ธนาคารซีไอเอ็มบีไทย', uob:'ธนาคารยูโอบี', gsb:'ธนาคารออมสิน',
  baac:'ธ.เพื่อการเกษตรและสหกรณ์การเกษตร', kkb:'ธนาคารเกียรตินาคินภัทร',
  lhfg:'ธนาคารแลนด์ แอนด์ เฮ้าส์', icbc:'ธนาคารไอซีบีซี (ไทย)', tisco:'ธนาคารทิสโก้',
  tw:'TrueMoney Wallet'
}; %>

<section class="page-head">
  <div class="page-title">
    <h1>ประวัติการเติมเงินทั้งหมด</h1>
    <small class="muted">หลังบ้าน → รายการเติมเงินทั้งหมด</small>
  </div>
</section>

<!-- สรุปยอดเติมเงินที่สำเร็จทั้งเว็บ -->
<div class="grid cards">
  <% if (typeof sumNoAdmin !== 'undefined' && sumNoAdmin > 0) { %>
    <section class="card">
      <div class="card-head row-head">
        <h3>ยอดเติมรวมทั้งหมด (ไม่รวมแอดมิน)</h3>
        <div class="head-right">
          <span class="metric-badge" style="color:#cc8110; padding:2px 18px;">
            <%= (countNoAdmin || 0).toLocaleString() %> รายการ
          </span>
        </div>
      </div>
      <div class="big" style="color:#35cc10; padding:6px 2px;">
        ฿<%= Number(sumNoAdmin || 0).toLocaleString(undefined, { minimumFractionDigits: 2 }) %>
      </div>
    </section>
  <% } %>
</div>

<div class="grid cards">
  <% if (Array.isArray(methodTotals) && methodTotals.length) { %>
    <% methodTotals.forEach(m => { %>
      <section class="card2">
        <div class="card-head row-head">
          <h3>ยอดเติมรวม <%= m.label %></h3>
          <div class="head-right">
            <span class="metric-badge" style="color:#cc8110; padding:2px 18px;">
              <%= (m.count || 0).toLocaleString() %> รายการ
            </span>
          </div>
        </div>
        <div class="big" style="color:#35cc10; padding:6px 2px;">
          ฿<%= Number(m.sum || 0).toLocaleString(undefined, { minimumFractionDigits: 2 }) %>
        </div>
      </section>
    <% }) %>
  <% } %>
</div>

<!-- ✔️ แถบเลือกเดือน -->
<div class="month-toolbar" role="group" aria-label="เลือกเดือน">
  <button class="btn ghost" id="btnPrev" type="button" aria-label="เดือนก่อนหน้า">◀︎</button>
  <label class="month-ctrl">
    <input id="monthInput" type="text" value="<%= monthStr %>" readonly aria-label="เลือกเดือน" />
    <button class="icon-btn" id="btnOpenPicker" type="button" aria-label="เปิดตัวเลือกเดือน">📅</button>
  </label>
  <button class="btn ghost" id="btnNext" type="button" aria-label="เดือนถัดไป">▶︎</button>
  <button class="btn" id="btnThisMonth" type="button">เดือนนี้</button>
</div>

<!-- Popup: Month Picker -->
<div id="monthPicker" class="mp-popup" hidden>
  <div class="mp-card" role="dialog" aria-modal="true" aria-label="เลือกเดือน">
    <div class="mp-head">
      <button class="mp-nav" id="mpPrevYear" aria-label="ปีก่อนหน้า">‹</button>
      <div class="mp-year" id="mpYear">2025</div>
      <button class="mp-nav" id="mpNextYear" aria-label="ปีถัดไป">›</button>
    </div>
    <div class="mp-grid" id="mpGrid" role="grid" aria-label="รายชื่อเดือน">
      <!-- เติมด้วยสคริปต์ -->
    </div>
    <div class="mp-actions">
      <button class="btn ghost" id="mpClear">ล้าง</button>
      <div class="spacer"></div>
      <button class="btn ghost" id="mpThisMonth">เดือนนี้</button>
      <button class="btn primary" id="mpOK">ตกลง</button>
    </div>
  </div>
</div>

<%
// monthStr รูปแบบ 'YYYY-MM'
const [yy, mm] = (monthStr || '').split('-').map(Number);
const MONTHS_TH = ['มกราคม','กุมภาพันธ์','มีนาคม','เมษายน','พฤษภาคม','มิถุนายน','กรกฎาคม','สิงหาคม','กันยายน','ตุลาคม','พฤศจิกายน','ธันวาคม'];
const headMonthLabel = `${MONTHS_TH[(mm||1)-1]} ${yy}`; // ถ้าอยากเป็น พ.ศ. ใช้ (yy+543)
%>

<div class="history-wrapper card soft">
  <div class="title flex-between" style="align-items:center; gap:10px;">
    <h3 style="margin:0;">ทุกรายการเติมเงิน</h3>
  </div>

  <% if (transactions && transactions.length) { %>

  <!-- ===== Desktop/Table view ===== -->
  <div class="table-wrap desktop-only">
    <table class="history-table">
      <thead>
        <tr>
          <th>วันที่ / เวลา</th>
          <th>รหัสรายการ</th>
          <th>ผู้ใช้</th>
          <th style="text-align:left;">วิธีเติม</th>
          <th>ข้อมูลผู้โอน</th>
          <th style="text-align:right;">จำนวนเงิน</th>
          <th style="text-align:center;">สถานะ</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% transactions.forEach(tx => {
             const method = (tx.method||'').toLowerCase();
             const statusLabel =
                (tx.status === "completed" || tx.status === "completed") ? "สำเร็จ" :
                (tx.status === "pending" || tx.status === "pending") ? "รอดำเนินการ" :
                (tx.status === "reject" || tx.status === "rejected") ? "ถูกปฏิเสธ" :
                tx.status === "failed"    ? "ล้มเหลว" : "ยกเลิก";
        %>
        <tr>
          <td class="muted">
            <%= new Date(tx.createdAt).toLocaleString('th-TH', {
              timeZone: 'Asia/Bangkok', year:'numeric', month:'short', day:'numeric', hour:'2-digit', minute:'2-digit', second:'2-digit'
            }) %>
          </td>
          <td title="<%= tx.transactionId || '' %>"><%= tx.transactionId || '—' %></td>
          <td>
            <div class="user-cell">
                <img
                class="avatar-sm"
                src="<%= (tx.userId?.avatarUrl || '/static/assets/img/user-blue.png') %>?v=<%= tx.userId?.avatarVer || 0 %>"
                alt="<%= tx.userId?.username || tx.username || 'user' %>" width="28" height="28" loading="lazy"/>
                <div class="user-meta">
                    <b class="user-name"><%= (tx.userId?.username || tx.username || '-') %></b>
                    <% if (tx.userId?.email) { %>
                    <span class="user-email muted"><%= tx.userId.email %></span>
                    <% } %>
                </div>
            </div>
          </td>
          <td>
            <% const m = (tx.method || '').toLowerCase(); %>
            <%=
              (m === 'tw' || m === 'truewallet') ? 'True Wallet' :
              (m === 'kbank') ? 'QR Code - Scan' :
              (m === 'admin') ? 'Admin' :
              (m === 'manual') ? 'เติมมือ' :
              (m || '—')
            %>
          </td>
          <td>
            <% if (method === 'truewallet' || method === 'tw') { %>
              <img src="/static/assets/payment/tw.webp" class="bank-logo" />
              <b>TrueWallet</b>
              <div class="muted">เบอร์ผู้โอน: <%= tx.senderNumber || '-' %></div>
            <% } else { %>
              <img src="/static/assets/payment/mobilebanking.png" class="bank-logo" />
              <b><%= BANK_LABELS[tx.senderBank] || 'ไม่ระบุธนาคาร' %></b>
              <div class="muted">เลขท้ายบัญชีผู้โอน: <%= tx.senderLast6 || '-' %></div>
            <% } %>
          </td>
          <td class="amount">฿<%= Number(tx.amount).toLocaleString(undefined,{ minimumFractionDigits: 2 }) %></td>
          <td class="status <%= (tx.status||'').toLowerCase() %>"><%= statusLabel %></td>
          <td>
            <% if ((tx.status||'') === 'pending') { %>
            <button class="btn small success"
              onclick="openManualTopupModal('<%= tx.transactionId %>', <%= tx.amount %>, '<%= (tx.userId?.username || tx.username || '').replace(/'/g, '\\\\' ) %>')">
              เติมให้ผู้ใช้
            </button>
            <button class="btn small danger" onclick="rejectTx('<%= (tx._id || tx.transactionId) %>')">
              ปฏิเสธ
            </button>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- ===== Mobile/Card accordion ===== -->
  <div class="mobile-only tx-accordion-list" style="margin-top:10px;">
    <% transactions.forEach(tx => {
         const method = (tx.method||'').toLowerCase();
         const statusLabel =
           (tx.status === "completed" || tx.status === "completed") ? "สำเร็จ" :
           (tx.status === "pending" || tx.status === "pending") ? "รอดำเนินการ" :
           (tx.status === "reject" || tx.status === "rejected") ? "ถูกปฏิเสธ" :
           tx.status === "failed"    ? "ล้มเหลว" : "ยกเลิก";
    %>
    <div class="tx-accordion" data-open="0">
      <button class="tx-accordion__head" type="button">
        <div class="tx-accordion__title">
          <span class="tx-id" title="<%= tx.transactionId || '' %>"><%= tx.transactionId || '—' %></span>
        </div>
        <div class="tx-accordion__meta">
          <span class="tx-date">
            <%= new Date(tx.createdAt).toLocaleString('th-TH', {
              timeZone: 'Asia/Bangkok', year:'numeric', month:'2-digit', day:'2-digit',
              hour:'2-digit', minute:'2-digit', second:'2-digit'
            }) %>
          </span>
          <span class="tx-toggle"></span>
        </div>
      </button>
      <div class="tx-accordion__body">
        <div class="tx-row">
            <div class="tx-label">ผู้ใช้</div>
            <div class="tx-value">
                <div class="user-cell">
                <img
                    class="avatar-sm"
                    src="<%= (tx.userId?.avatarUrl || '/static/assets/img/user-blue.png') %>?v=<%= tx.userId?.avatarVer || 0 %>"
                    alt="<%= tx.userId?.username || tx.username || 'user' %>" width="28" height="28" loading="lazy"/>
                    <div class="user-meta">
                        <b class="user-name"><%= (tx.userId?.username || tx.username || '-') %></b>
                        <% if (tx.userId?.email) { %>
                        <span class="user-email muted"><%= tx.userId.email %></span>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <div class="tx-row">
          <div class="tx-label">ผู้โอน</div>
          <div class="tx-value">
            <% if (method === 'truewallet' || method === 'tw') { %>
              <img src="/static/assets/payment/tw.webp" class="bank-logo" alt="">
              <b>TrueWallet</b><br>
              <span class="muted">เบอร์ผู้โอน: <%= tx.senderNumber || '-' %></span>
            <% } else { %>
              <img src="/static/assets/payment/mobilebanking.png" class="bank-logo" alt="">
              <b><%= BANK_LABELS[tx.senderBank] || 'ไม่ระบุธนาคาร' %></b><br>
              <span class="muted">เลขท้ายบัญชีผู้โอน: <%= tx.senderLast6 || '-' %></span>
            <% } %>
          </div>
        </div>

        <div class="tx-row">
          <div class="tx-label">วิธีเติม</div>
          <div class="tx-value">
            <% const m = (tx.method || '').toLowerCase(); %>
            <%=
              (m === 'tw' || m === 'truewallet') ? 'True Wallet' :
              (m === 'kbank') ? 'QR Code - Scan' :
              (m === 'admin') ? 'Admin' :
              (m === 'manual') ? 'เติมมือ' :
              (m || '—')
            %>
          </div>
        </div>

        <div class="tx-row">
          <div class="tx-label">จำนวนเงิน</div>
          <div class="tx-value"><b>฿<%= Number(tx.amount).toLocaleString(undefined,{minimumFractionDigits:2}) %></b></div>
        </div>

        <div class="tx-row">
          <div class="tx-label">สถานะ</div>
          <div class="tx-value">
            <span class="pill pill--<%= (tx.status||'').toLowerCase() %>"><%= statusLabel %></span>
          </div>
        </div>

        <div class="tx-actions">
          <% if ((tx.status||'') === 'pending') { %>
          <button class="btn small success" style="width: 100%;"
            onclick="openManualTopupModal('<%= tx.transactionId %>', <%= tx.amount %>, '<%= (tx.userId?.username || tx.username || '').replace(/'/g, '\\\\') %>')">
            เติมให้ผู้ใช้
          </button>
          <button class="btn small danger" style="width: 100%; margin-top: 8px;"
            onclick="rejectTx('<%= (tx._id || tx.transactionId) %>')">
            ปฏิเสธ
          </button>
          <% } %>
        </div>
      </div>
    </div>
    <% }) %>
  </div>

  

  <% } else { %>
    <div class="empty-history" role="status" aria-live="polite">
      <img src="/static/assets/emoji/empty.png" alt="" aria-hidden="true">
      <div class="empty-title">ยังไม่มีรายการเติมเงิน</div>
      <div class="empty-sub">เมื่อมีรายการ ระบบจะแสดงที่นี่โดยอัตโนมัติ</div>
    </div>
  <% } %>
</div>

<!-- Manual Topup Modal -->
<div id="manualTopupModal" class="hidden modal">
  <div class="overlay" data-close="1"></div>
  <div class="dialog" role="dialog" aria-modal="true" aria-labelledby="manualTitle">
    <div class="hdr">
      <div class="title" id="manualTitle">เติมเงินให้ผู้ใช้</div>
      <button class="icon close" id="manualTopupClose" aria-label="ปิด">×</button>
    </div>
    <hr class="sep" />
    <div class="body">
      <form id="manualTopupForm" onsubmit="return submitManualTopup(event)">
        <label>
          ชื่อผู้ใช้ (Username)
          <input type="text" id="manualUsername" list="userList" autocomplete="off" required
                 placeholder="พิมพ์ค้นหา เช่น: ad" class="block input mt-sm"/>
          <datalist id="userList"></datalist>
        </label>

        <label>
          จำนวนเงิน
          <input type="number" id="manualAmount" required class="block input mt-sm"/>
        </label>

        <div class="card soft mt">💡 ระบบจะเพิ่มยอดเงินเข้าบัญชีของผู้ใช้ทันที และบันทึกในระบบ</div>

        <div class="footer d-flex justify-content-center mt">
          <button class="block btn primary" type="submit">ยืนยันเติมเงิน</button>
        </div>
      </form>
      <div id="manualTopupStatus" class="mt"></div>
    </div>
  </div>
</div>

<style>
/* =========================
Table Colors (Dark/Light)
========================= */
:root {
  /* dark */
  --tbl-head-bg:        rgba(255,255,255,.08);
  --tbl-head-text:      var(--text-primary,#f2f4f8);
  --tbl-row-bg:         rgba(255,255,255,.02);
  --tbl-row-alt:        rgba(255,255,255,.06);
  --tbl-border:         #2a2f36;
  --tbl-hover:          rgba(255,255,255,.10);
}
html[data-theme="light"] {
  /* light */
  --tbl-head-bg:   #eef2f6;        /* เข้มขึ้น 1 เชด */
  --tbl-head-text: #0f172a;        /* เทาเข้มอ่านง่าย */
  --tbl-row-bg:    #ffffff;        /* แถวพื้น */
  --tbl-row-alt:   #f7fafc;        /* แถวสลับอ่อนกว่า 1 เชด */
  --tbl-border:    #e5e7eb;        /* เส้นคั่นอ่อน */
  --tbl-hover:     #e9eef5;        /* hover อ่อน */
}

/* โครงตาราง */
.table-wrap{ overflow:auto; -webkit-overflow-scrolling:touch; }
.history-table{
  width:100%;
  border-collapse:separate;         /* ใช้ separate เพื่อให้เส้นคั่นเนียน */
  border-spacing:0;
  margin-top:10px;
  font-size:14px;
  min-width:720px;
  white-space:nowrap;
  background:transparent;
  box-shadow: inset 0 1px 0 var(--tbl-border);
}

.history-table thead th,
.history-table tbody td{
  padding:12px 14px;
  vertical-align:middle;
  border-bottom:1px solid var(--tbl-border);
}

/* หัวตารางเข้ม + sticky */
.history-table thead th{
  position:sticky; top:0; z-index:5;
  text-align:left;
  font-weight:500;
  color:var(--tbl-head-text);
  background:var(--tbl-head-bg);
  backdrop-filter: blur(2px);
}

/* แถวสลับเฉด + hover */
.history-table tbody tr{ background:var(--tbl-row-bg); }
.history-table tbody tr:nth-child(even){ background:var(--tbl-row-alt); }
.history-table tbody tr:hover{ background:var(--tbl-hover); }

/* คอลัมน์พิเศษ */
.history-table .amount{ text-align:right; font-weight:600; }
.history-table .status{ text-align:center; font-weight:500; }

/* โลโก้ธนาคารคมชัด */
.bank-logo{
  width:28px; height:28px; object-fit:contain; vertical-align:middle; margin-right:6px;
  filter: none;
}

/* ปรับเส้นขอบรอบแรก/สุดท้ายให้เนียน */
.history-table thead th:first-child,
.history-table tbody td:first-child { padding-left:16px; }
.history-table thead th:last-child,
.history-table tbody td:last-child  { padding-right:16px; }

/* เสริมมิติแก่กรอบการ์ดตาราง (เบา ๆ) */
.history-wrapper.card.soft{
  border-color: var(--tbl-border);
  box-shadow: var(--elevated-shadow,0 10px 24px rgba(0,0,0,.12));
}
html[data-theme="light"] .history-wrapper.card.soft{
  box-shadow: 0 8px 22px rgba(15, 23, 42, .06);
}

/* Desktop/Mobile switch */
.mobile-only{ display:none !important; }
.desktop-only{ display:block !important; }
@media (max-width:768px){
  .desktop-only{ display:none !important; }
  .mobile-only{ display:block !important; }
}

/* Accordion (มือถือ) */
.tx-accordion-list{ display:grid; gap:10px; }
.tx-accordion{ background:var(--card,#1a1d22); border:1px solid var(--border,#2a2f36); border-radius:12px; overflow:hidden; box-shadow:var(--elevated-shadow,0 10px 24px rgba(0,0,0,.25)); }
.tx-accordion__head{ width:100%; display:grid; grid-template-columns:1fr auto; align-items:center; gap:10px; padding:12px 14px; background:#0f1013; color:var(--text-primary,#f2f4f8); border:0; cursor:pointer; }
.tx-accordion__title{ min-width:0; }
.tx-accordion__title .tx-id{ display:block; overflow:hidden; white-space:nowrap; text-overflow:ellipsis; font-weight:400; letter-spacing:.3px; }
.tx-accordion__meta{ display:inline-grid; grid-auto-flow:column; gap:10px; align-items:center; color:var(--title,#eadfb8); font-weight:400; font-variant-numeric:tabular-nums; white-space:nowrap; }
.tx-accordion__meta .tx-toggle{ width:28px; height:28px; border-radius:8px; display:inline-flex; align-items:center; justify-content:center; border:1px solid var(--border,#2a2f36); background:#17191d; }
.tx-accordion__body{ display:none; padding:12px 14px 14px; background:var(--elevated-bg,#141518); }
.tx-accordion[data-open="1"] .tx-accordion__body{ display:block; }
.tx-accordion[data-open="1"] .tx-accordion__meta .tx-toggle::before{ content:'–'; }
.tx-accordion[data-open="0"] .tx-accordion__meta .tx-toggle::before{ content:'+'; }
.tx-row{ display:grid; grid-template-columns:110px 1fr; gap:10px; padding:8px 0; border-bottom:1px dashed var(--border,#2a2f36); }
.tx-row:last-child{ border-bottom:0; }
.tx-label{ color:var(--muted,#a7b0bb); }
.tx-value{ color:var(--text-primary,#f2f4f8); }
.pill{ display:inline-block; padding:4px 10px; border-radius:999px; font-weight:400; font-size:12px; background:#22262d; border:1px solid #313641; }
.pill--pending{ color:#ffc107; }
.pill--completed{ color:#10b981; }
.pill--failed{ color:#f87171; }
.pill--canceled{ color:#94a3b8; }
.tx-actions{ width:100%; margin-top:12px; display:flex; justify-content:flex-start; }

/* Modal */
.modal.hidden{ display:none; }
.modal{ position:fixed; inset:0; z-index:100; }
.modal .overlay{ position:absolute; inset:0; background:rgba(0,0,0,.55); cursor:pointer; }
.modal .dialog{ position:fixed; top:50%; left:50%; transform:translate(-50%,-50%); max-width:420px; width:calc(100% - 24px); background:var(--card,#1c1f24); border:1px solid var(--border,#2a2f36); border-radius:14px; box-shadow:0 18px 60px rgba(0,0,0,.4); padding:16px 18px 18px; animation:modalFadeIn .25s ease-out; z-index:200; }
.modal .hdr{ display:flex; justify-content:space-between; align-items:center; }
.modal .title{ font-weight:400; font-size:16px; }
.modal .icon.close{ border:0; background:transparent; font-size:22px; color:var(--text,#fff); cursor:pointer; }
.modal .sep{ border:0; border-top:1px solid var(--border,#2a2f36); margin:12px 0; }
.modal .body{ font-size:14px; line-height:1.6; max-height:60vh; overflow-y:auto; }

/* Card v2, badges (reuse) */
