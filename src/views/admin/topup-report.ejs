<script>
  // dropdown perpage
  (function(){
    const btn  = document.getElementById('ppBtn');
    const menu = document.getElementById('ppMenu');
    const valEl= document.getElementById('ppVal');
    if (!btn || !menu) return;

    const toggle = ()=>{ menu.hidden = !menu.hidden; };
    const close  = (e)=>{ if (!menu.hidden && !e.target.closest('.perpage-control')) menu.hidden = true; };

    btn.addEventListener('click', toggle);
    document.addEventListener('click', close);
    document.addEventListener('keydown', e=>{ if (e.key==='Escape') menu.hidden = true; });

    menu.querySelectorAll('.pp-item').forEach(it=>{
      it.addEventListener('click', ()=>{
        const v = it.dataset.val;
        valEl.textContent = v;
        menu.hidden = true;
        // ไปหน้าแรกของเพจใหม่
        const url = new URL(location.href);
        url.searchParams.set('perpage', v);
        url.searchParams.set('page', '1');
        location.href = url.toString();
      });
    });
  })();
</script>

<script>
  // ====== Utils ======
  function debounce(fn, ms=250){ let t; return (...a)=>{ clearTimeout(t); t=setTimeout(()=>fn(...a), ms); }; }

  function renderUserDatalist(items){
    const dl = document.getElementById('userList');
    if (!dl) return;
    dl.innerHTML = '';
    (items||[]).forEach(u=>{
      const opt = document.createElement('option');
      opt.value = u.username;
      opt.label = `${u.username}${u.email?' · '+u.email:''}`;
      dl.appendChild(opt);
    });
  }

  const doUserSearch = debounce(async function(q){
    try{
      const url = q && q.length
        ? `/admin/api/users/search?q=${encodeURIComponent(q)}&limit=20`
        : `/admin/api/users/search?limit=20`;
      const r = await fetch(url);
      const j = await r.json();
      if (j?.ok) renderUserDatalist(j.items);
    }catch{}
  }, 250);

  // ====== Mobile accordion toggle ======
  (function initTxAccordion(){
    document.querySelectorAll('.tx-accordion')?.forEach(card=>{
      card.querySelector('.tx-accordion__head')?.addEventListener('click', ()=>{
        card.dataset.open = (card.dataset.open === '1' ? '0' : '1');
      });
    });
  })();

  // ====== Modal controls ======
  function openManualTopupModal(txId = null, amount = null, suggestedUsername = ''){
    const modal = document.getElementById("manualTopupModal");
    modal.classList.remove("hidden");

    const form = document.getElementById("manualTopupForm");
    form.reset();
    document.getElementById("manualTopupStatus").innerHTML = "";

    window.currentTxId = txId;

    const amtInput = document.getElementById("manualAmount");
    if (amount){
      amtInput.value = Number(amount).toFixed(2);
      amtInput.readOnly = true;
      amtInput.style.opacity = "0.7";
    } else {
      amtInput.value = "";
      amtInput.readOnly = false;
      amtInput.style.opacity = "1";
    }

    const userInput = document.getElementById('manualUsername');
    if (suggestedUsername && suggestedUsername !== 'null'){
      userInput.value = suggestedUsername;
      doUserSearch(suggestedUsername); // preload
    } else {
      userInput.value = '';
      doUserSearch('');                 // preload 20 รายการแรก
    }

    setTimeout(()=>{ userInput.dispatchEvent(new Event('input')); }, 50);
  }

  function closeManualTopupModal(){
    document.getElementById("manualTopupModal").classList.add("hidden");
    document.getElementById("manualTopupStatus").innerHTML = "";
  }

  document.getElementById("manualTopupClose")?.addEventListener('click', closeManualTopupModal);
  document.getElementById("manualTopupModal")?.addEventListener("click",(e)=>{ if(e.target.dataset.close==="1") closeManualTopupModal(); });
  document.addEventListener("keydown",(e)=>{ if(e.key==="Escape") closeManualTopupModal(); });

  // ====== Submit manual topup ======
  async function submitManualTopup(ev) {
    ev.preventDefault();
    const username = document.getElementById("manualUsername").value.trim();
    const amount   = parseFloat(document.getElementById("manualAmount").value || 0);
    const txId     = window.currentTxId || null;

    if (!username || !(amount > 0)) {
      document.getElementById("manualTopupStatus").innerHTML =
        '<div class="card soft">❌ กรุณากรอกข้อมูลให้ครบถ้วน</div>';
      return false;
    }

    document.getElementById("manualTopupStatus").innerHTML =
      '<div class="muted">⏳ กำลังทำรายการ...</div>';

    try {
      const res = await fetch("/admin/manual-topup", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ username, amount, txId }),
      });

      const data = await res.json();
      if (data.ok) {
        document.getElementById("manualTopupStatus").innerHTML = `
          <div class="card soft">
            ✅ เติมเงินสำเร็จให้ผู้ใช้ <b>${username}</b><br>
            <b>จำนวน:</b> ${amount.toLocaleString()} บาท
          </div>`;
        setTimeout(() => closeManualTopupModal(), 1200);
        setTimeout(() => window.location.reload(), 1400);
      } else {
        document.getElementById("manualTopupStatus").innerHTML =
          '<div class="card soft">❌ ' + (data.error || "เกิดข้อผิดพลาด") + "</div>";
      }
    } catch (err) {
      document.getElementById("manualTopupStatus").innerHTML =
        '<div class="card soft">❌ ขัดข้อง: ' + err.message + "</div>";
    }
  }

  // ====== Reject Tx (ใช้ uiConfirm จาก layout.ejs) ======
  async function rejectTx(id){
    if (!id) return alert('ไม่พบรหัสรายการ');

    const ok = await (window.uiConfirm?.({
      variant: 'danger',
      title: 'ยืนยันปฏิเสธรายการ?',
      sub: 'การปฏิเสธจะเปลี่ยนสถานะเป็น Reject และไม่เพิ่มยอดผู้ใช้',
      okText: 'ปฏิเสธ',
      cancelText: 'ยกเลิก',
      focus: 'cancel'
    }) || Promise.resolve(confirm('ยืนยันปฏิเสธรายการนี้?')));

    if (!ok) return;

    try {
      const r = await fetch(`/admin/topup/${encodeURIComponent(id)}/reject`, {
        method:'POST', headers:{'Content-Type':'application/json'}
      });
      const j = await r.json().catch(()=> ({}));
      if (!r.ok || !j.ok) throw new Error(j?.error || 'ปฏิเสธไม่สำเร็จ');

      await window.uiConfirm?.({
        variant:'success',
        title:'สำเร็จ',
        sub:'ปฏิเสธรายการเรียบร้อย',
        okText:'ปิด',
        cancelText:'Cancel'
      });

      location.reload();
    } catch(err){
      await window.uiConfirm?.({
        variant:'danger',
        title:'ล้มเหลว',
        sub:String(err?.message || err),
        okText:'ลองอีกครั้ง',
        cancelText:'ปิด'
      });
    }
  }
</script>

<script>
(function(){
  const MONTH_NAMES_TH = ['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'];

  const input   = document.getElementById('monthInput');
  const btnOpen = document.getElementById('btnOpenPicker');
  const popup   = document.getElementById('monthPicker');
  const yearEl  = document.getElementById('mpYear');
  const grid    = document.getElementById('mpGrid');
  const btnPrevY= document.getElementById('mpPrevYear');
  const btnNextY= document.getElementById('mpNextYear');
  const btnOK   = document.getElementById('mpOK');
  const btnClear= document.getElementById('mpClear');
  const btnThis = document.getElementById('mpThisMonth');

  const btnPrev = document.getElementById('btnPrev');
  const btnNext = document.getElementById('btnNext');
  const btnThisMonth = document.getElementById('btnThisMonth');

  const toolbarEl = document.querySelector('.month-toolbar');
  const card = popup?.querySelector('.mp-card');

  const now = new Date();
  let selYear  = now.getFullYear();
  let selMonth = now.getMonth(); // 0..11
  let tempYear, tempMonth;

  const monthStrInit = (input?.value || '').slice(0,7);
  if (monthStrInit){
    const [yy,mm] = monthStrInit.split('-').map(n=>+n);
    if (yy && mm){ selYear = yy; selMonth = mm-1; }
  }
  tempYear = selYear; tempMonth = selMonth;

  function toYYYYMM(y,m){ return `${y}-${String(m+1).padStart(2,'0')}`; }
  function go(monthStr){
    const u = new URL(location.href);
    u.searchParams.set('month', monthStr);
    location.href = u.toString();
  }

  // ── Toolbar prev/next/เดือนนี้ ──
  btnPrev?.addEventListener('click', ()=>{
    const d = new Date(selYear, selMonth-1, 1);
    go(toYYYYMM(d.getFullYear(), d.getMonth()));
  });
  btnNext?.addEventListener('click', ()=>{
    const d = new Date(selYear, selMonth+1, 1);
    go(toYYYYMM(d.getFullYear(), d.getMonth()));
  });
  btnThisMonth?.addEventListener('click', ()=>{
    go(toYYYYMM(now.getFullYear(), now.getMonth()));
  });

  // ── วาด grid เดือน ──
  function renderGrid(){
    if (!yearEl || !grid) return;
    yearEl.textContent = String(tempYear);
    grid.innerHTML = '';
    for (let m=0;m<12;m++){
      const b = document.createElement('button');
      b.type='button';
      b.className = 'mp-m'
        + (m===tempMonth && tempYear===selYear ? ' active' : '')
        + (m===now.getMonth() && tempYear===now.getFullYear() ? ' current' : '');
      b.textContent = MONTH_NAMES_TH[m];
      b.setAttribute('role','gridcell');
      b.addEventListener('click', ()=>{
        tempMonth = m;
        [...grid.children].forEach(c=>c.classList.remove('active'));
        b.classList.add('active');
      });
      grid.appendChild(b);
    }
  }

  // ── โหมดจัดวาง: center (เดสก์ท็อป) / anchor (มือถือ) ──
  function chooseMode(){
    return 'anchor'; // เดสก์ท็อปก็วางใต้ toolbar เสมอ
  }
  function clamp(n,min,max){ return Math.max(min, Math.min(max, n)); }
  function positionAnchored(){
    if (!toolbarEl || !popup || !card) return;
    const rect = toolbarEl.getBoundingClientRect();
    const gap  = 8;
    const cardW = Math.min(320, Math.round(window.innerWidth * 0.92));
    let left = rect.left + (rect.width/2) - (cardW/2);
    left = clamp(left, 12, window.innerWidth - cardW - 12);
    let top  = rect.bottom + gap;
    const cardH = card.offsetHeight || 260;
    top = clamp(top, 12, window.innerHeight - cardH - 12);
    card.style.setProperty('--mp-left', `${Math.round(left)}px`);
    card.style.setProperty('--mp-top',  `${Math.round(top)}px`);
  }
  function applyMode(mode){
    popup.classList.remove('center','anchor');
    popup.classList.add(mode);
    if (mode==='anchor') positionAnchored();
  }
  function onRelayout(){
    if (!popup || popup.hasAttribute('hidden')) return;
    if (popup.classList.contains('anchor')) positionAnchored();
  }

  // ── เปิด/ปิด ──
  function openPicker(){
    if (!popup || !popup.hasAttribute('hidden')===false) {/* no-op */}
    if (!popup.hasAttribute('hidden')) return;

    // sync grid state ทุกครั้ง
    tempYear = selYear; tempMonth = selMonth;
    renderGrid();

    applyMode(chooseMode());
    popup.removeAttribute('hidden');
    popup.setAttribute('aria-hidden','false');

    setTimeout(()=> popup.querySelector('.mp-m')?.focus(), 0);
    window.addEventListener('resize', onRelayout, {passive:true});
    window.addEventListener('scroll', onRelayout, {passive:true});
  }
  function closePicker(){
    if (!popup) return;
    popup.setAttribute('hidden','');
    popup.setAttribute('aria-hidden','true');
    popup.classList.remove('center','anchor');
    window.removeEventListener('resize', onRelayout);
    window.removeEventListener('scroll', onRelayout);
  }

  // ปุ่มเปิด
  btnOpen?.addEventListener('click', openPicker);
  input?.addEventListener('click', openPicker);

  // เดินปี
  btnPrevY?.addEventListener('click', ()=>{ tempYear--; renderGrid(); });
  btnNextY?.addEventListener('click', ()=>{ tempYear++; renderGrid(); });

  // ยืนยัน / ล้าง / เดือนนี้
  btnOK?.addEventListener('click', ()=>{
    selYear = tempYear; selMonth = tempMonth;
    input.value = toYYYYMM(selYear, selMonth);
    closePicker();
    go(input.value);
  });
  btnClear?.addEventListener('click', ()=>{
    input.value = '';
    closePicker();
    go(toYYYYMM(now.getFullYear(), now.getMonth()));
  });
  btnThis?.addEventListener('click', ()=>{
    tempYear = now.getFullYear(); tempMonth = now.getMonth();
    renderGrid();
  });

  // ESC ปิด
  window.addEventListener('keydown', (e)=>{
    if (e.key==='Escape' && !popup.hasAttribute('hidden')) closePicker();
  });
  // คลิกฉากทึบ (เฉพาะโหมด center) เพื่อปิด
  popup.addEventListener('click', (e)=>{
    if (popup.classList.contains('center') && e.target === popup) closePicker();
  });

  // เผื่อเรียกจากที่อื่น
  window.__monthPicker__ = { openPicker, closePicker, positionAnchored };
})();
</script>
