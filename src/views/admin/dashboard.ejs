<!-- //admin/dashboard.ejs -->
<h2 style="text-align: center;">Admin Panel | หลังบ้าน</h2>
<div class="grid cards">
  <section class="card2">
    <div class="card-head row-head">
      <h3>ขายแล้ว</h3>
      <div class="head-right">
        <span class="metric-badge">
          <%= (stats?.orderCount || 0).toLocaleString() %> รายการ
        </span>
      </div>
    </div>
  </section>
  <section class="card2">
    <div class="card-head row-head">
      <h3>สมาชิกทั้งหมดในเว็บ</h3>
      <div class="head-right">
        <span class="metric-badge">
          <%= (stats?.userCount || 0).toLocaleString() %> คน
        </span>
      </div>
    </div>
  </section>
  <section class="card2">
    <div class="card-head row-head">
      <h3>รายงานการเติมเงิน</h3>
      <a class="btn" href="/admin/topup-report">รายงานการเติมเงิน</a>
    </div>
  </section>
</div>

<div class="grid cards">
  <section class="card">
    <h3>เครดิตผู้ให้บริการ</h3>
    <div id="bal" class="big"><%= balance %></div>
    <button class="btn" onclick="refreshBal()">รีเฟรชเครดิต</button>
  </section>
  <section class="card">
    <div class="card-head row-head">
      <h3>ซิงก์บริการ</h3>

      <!-- ชิดขวา: จำนวนบริการปัจจุบัน -->
      <div class="head-right muted">
        บริการในปัจจุบัน:
        <b id="svcTotal"><%= (servicesTotal ?? 0).toLocaleString() %></b> รายการ
      </div>
    </div>

    <button class="btn" onclick="syncServices()">ดึงบริการทั้งหมด</button>

    <div id="syncRes" class="mt muted">
      ล่าสุด: <%= lastSyncAt ? new Date(lastSyncAt).toLocaleString() : '—' %>
    </div>
  </section>
  <section class="card">
    <h3>ตั้งค่าราคา</h3>
    <a class="btn" href="/admin/pricing">ไปหน้ากฎปรับราคา</a>
    <p class="muted mt">
      ปรับทั้งเว็บ, รายหมวด, หมวดย่อย หรือรายบริการ | โหมด: % / +คงที่ / set
      ราคา
    </p>
  </section>
</div>

<div class="grid cards">
  <section class="card">
    <h3>ข้อมูลผู้ใช้ทั้งหมด</h3>
    <a class="btn" href="/admin/users">ข้อมูลผู้ใช้</a>
    <p class="muted mt">ไปที่หน้าข้อมูลผู้ใช้</p>
  </section>
  <section class="card">
    <h3>รายการสั่งซื้อบริการ</h3>
    <a class="btn" href="/admin/orders">รายการออเดอร์</a>
    <p class="muted mt">ไปที่หน้ารายการสั่งซื้อออบริการของผู้ใช้</p>
  </section>
  <section class="card">
    <h3>สรุปยอดขายรายเดือน</h3>
    <a class="btn" href="/admin/report/summary">สรุปยอดขายรายเดือน</a>
    <p class="muted mt">ไปที่หน้าสรุปยอดขายรายเดือน</p>
  </section>
</div>
<% const BANK_LABELS = { bbl: 'ธนาคารกรุงเทพ', kbank: 'ธนาคารกสิกรไทย', ktb:
'ธนาคารกรุงไทย', bay: 'ธนาคารกรุงศรีอยุธยา', scb: 'ธนาคารไทยพาณิชย์', tmb:
'ทหารไทยธนชาต (TTB)', cimb: 'ธนาคารซีไอเอ็มบีไทย', uob: 'ธนาคารยูโอบี', gsb:
'ธนาคารออมสิน', baac: 'ธ.เพื่อการเกษตรและสหกรณ์การเกษตร', kkb:
'ธนาคารเกียรตินาคินภัทร', lhfg: 'ธนาคารแลนด์ แอนด์ เฮ้าส์', icbc:
'ธนาคารไอซีบีซี (ไทย)', tisco: 'ธนาคารทิสโก้', tw: 'TrueMoney Wallet' }; %>

<div class="history-wrapper card soft">
  <h3 class="title flex-between">
    รายการเติมเงินที่รอดำเนินการ
    <button class="btn small primary" onclick="openManualTopupModal()">
      + เติมเงินด้วยตนเอง
    </button>
  </h3>

  <% if (transactions && transactions.length > 0) { %>

  <!-- ===== Desktop/Table view (คงของเดิม) ===== -->
  <div class="desktop-only">
    <table class="history-table">
      <thead>
        <tr>
          <th>วันที่ / เวลา</th>
          <th>ข้อมูลผู้โอน</th>
          <th>ข้อมูลผู้รับ</th>
          <th>จำนวนเงิน</th>
          <th>สถานะ</th>
          <th>จัดการ</th>
        </tr>
      </thead>
      <tbody>
        <% transactions.forEach(tx => {
             const method = tx.method?.toLowerCase() || "";
             const wallet = (webWallets || []).find(w => w.accountCode === method);
             const statusLabel =
               tx.status === "completed" ? "สำเร็จ" :
               tx.status === "pending"   ? "รอดำเนินการ" :
               (tx.status === "reject" || tx.status === "rejected") ? "ถูกปฏิเสธ" :
               tx.status === "failed"    ? "ล้มเหลว" : "ยกเลิก";
        %>
        <tr>
          <!-- วันที่ -->
          <td class="muted">
            <%= new Date(tx.createdAt).toLocaleString('th-TH', {
              year:'numeric', month:'short', day:'numeric', hour:'2-digit', minute:'2-digit'
            }) %>
          </td>

          <!-- ข้อมูลผู้โอน -->
          <td>
            <% if (method === 'truewallet' || method === 'tw') { %>
              <img src="/static/assets/payment/tw.webp" class="bank-logo" />
              <div><b>TrueWallet</b></div>
              <div class="muted">เบอร์ผู้โอน: <%= tx.senderNumber || '-' %></div>
            <% } else { %>
              <img src="/static/assets/payment/mobilebanking.png" class="bank-logo" />
              <div><b><%= BANK_LABELS[tx.senderBank] || 'ไม่ระบุธนาคาร' %></b></div>
              <div class="muted">เลขท้ายบัญชีผู้โอน: <%= tx.senderLast6 || '-' %></div>
            <% } %>
          </td>

          <!-- ข้อมูลผู้รับ -->
          <td>
            <% if (wallet) { %>
              <img src="/static/assets/payment/<%= wallet.accountCode %>.webp" class="bank-logo" />
              <div><b><%= wallet.accountName %></b></div>
              <div class="muted">เลขบัญชี: <%= wallet.accountNumber %></div>
            <% } else { %>
              <span class="muted">ไม่พบข้อมูลผู้รับ</span>
            <% } %>
          </td>

          <!-- จำนวนเงิน -->
          <td class="amount">
            ฿<%= Number(tx.amount).toLocaleString(undefined,{ minimumFractionDigits: 2 }) %>
          </td>

          <!-- สถานะ -->
          <td class="status <%= tx.status.toLowerCase() %>"><%= statusLabel %></td>

          <!-- Action -->
          <td>
            <button
              class="btn small success"
              onclick="openManualTopupModal('<%= tx.transactionId %>', <%= tx.amount %>, '<%= (tx.user?.username||'').replace(/'/g, "\\'") %>')">
              เติมให้ผู้ใช้
            </button>
            <button
              class="btn small danger"
              onclick="rejectTx('<%= (tx._id || tx.transactionId) %>')">
              ปฏิเสธ
            </button>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- ===== Mobile/Card view (หุบ/ขยาย) ===== -->
  <div class="mobile-only tx-accordion-list">
    <% transactions.forEach(tx => {
         const method = (tx.method||'').toLowerCase();
         const wallet = (webWallets || []).find(w => w.accountCode === method);
         const statusLabel =
           tx.status === "completed" ? "สำเร็จ" :
           tx.status === "pending"   ? "รอดำเนินการ" :
           (tx.status === "reject" || tx.status === "rejected") ? "ถูกปฏิเสธ" :
           tx.status === "failed"    ? "ล้มเหลว" : "ยกเลิก";
    %>
    <div class="tx-accordion" data-open="0">
      <!-- แถวหัว (ปิดอยู่) -->
      <button class="tx-accordion__head" type="button">
        <div class="tx-accordion__title">
          <span class="tx-id" title="<%= tx.transactionId || '' %>">
            <%= tx.transactionId || '—' %>
          </span>
        </div>
        <div class="tx-accordion__meta">
          <span class="tx-date">
            <%= new Date(tx.createdAt).toLocaleString('th-TH', {
              year:'numeric', month:'2-digit', day:'2-digit',
              hour:'2-digit', minute:'2-digit', second:'2-digit'
            }) %>
          </span>
          <span class="tx-toggle"></span>
        </div>
      </button>

      <!-- เนื้อหารายละเอียด -->
      <div class="tx-accordion__body">
        <div class="tx-row">
          <div class="tx-label">ผู้โอน</div>
          <div class="tx-value">
            <% if (method === 'truewallet' || method === 'tw') { %>
              <img src="/static/assets/payment/tw.webp" class="bank-logo" alt="">
              <b>TrueWallet</b><br>
              <span class="muted">เบอร์ผู้โอน: <%= tx.senderNumber || '-' %></span>
            <% } else { %>
              <img src="/static/assets/payment/<%= tx.senderBank %>.webp" class="bank-logo" alt="">
              <b><%= BANK_LABELS[tx.senderBank] || 'ไม่ระบุธนาคาร' %></b><br>
              <span class="muted">เลขท้ายบัญชีผู้โอน: <%= tx.senderLast6 || '-' %></span>
            <% } %>
          </div>
        </div>

        <div class="tx-row">
          <div class="tx-label">ผู้รับ</div>
          <div class="tx-value">
            <% if (wallet) { %>
              <img src="/static/assets/payment/<%= wallet.accountCode %>.webp" class="bank-logo" alt="">
              <b><%= wallet.accountName %></b><br>
              <span class="muted">เลขบัญชี: <%= wallet.accountNumber %></span>
            <% } else { %>
              <span class="muted">ไม่พบข้อมูลผู้รับ</span>
            <% } %>
          </div>
        </div>

        <div class="tx-row">
          <div class="tx-label">จำนวนเงิน</div>
          <div class="tx-value">
            <b>฿<%= Number(tx.amount).toLocaleString(undefined,{minimumFractionDigits:2}) %></b>
          </div>
        </div>

        <div class="tx-row">
          <div class="tx-label">สถานะ</div>
          <div class="tx-value">
            <span class="pill pill--<%= (tx.status||'').toLowerCase() %>"><%= statusLabel %></span>
          </div>
        </div>

        <div class="tx-actions">
          <button class="btn small success" style="width: 100%;"
            onclick="openManualTopupModal('<%= tx.transactionId %>', <%= tx.amount %>, '<%= (tx.user?.username||'').replace(/'/g, "\\'") %>')">
            เติมให้ผู้ใช้
          </button>
          <button class="btn small danger" style="width: 100%; margin-top: 8px;"
            onclick="rejectTx('<%= (tx._id || tx.transactionId) %>')">
            ปฏิเสธ
          </button>
        </div>
      </div>
    </div>
    <% }) %>
  </div>

  <% } else { %>
    <div class="empty-history">
      <img src="/static/assets/emoji/empty.png" alt="ยังไม่มีรายการเติมเงิน" />
      <p class="muted">ยังไม่มีรายการเติมเงิน</p>
    </div>
  <% } %>
</div>

<div id="manualTopupModal" class="hidden modal">
  <div class="overlay" data-close="1"></div>
  <div
    class="dialog"
    role="dialog"
    aria-modal="true"
    aria-labelledby="manualTitle"
  >
    <div class="hdr">
      <div class="title" id="manualTitle">เติมเงินให้ผู้ใช้</div>
      <button class="icon close" id="manualTopupClose" aria-label="ปิด">
        ×
      </button>
    </div>
    <hr class="sep" />

    <div class="body">
      <form id="manualTopupForm" onsubmit="return submitManualTopup(event)">
        <label>
          ชื่อผู้ใช้ (Username)
          <input
            type="text"
            id="manualUsername"
            list="userList"
            autocomplete="off"
            required
            placeholder="พิมพ์ค้นหา เช่น: ad"
            class="block input mt-sm"
          />
          <datalist id="userList"></datalist>
        </label>

        <label>
          จำนวนเงิน
          <input
            type="number"
            id="manualAmount"
            required
            class="block input mt-sm"
          />
        </label>

        <div class="card soft mt">
          💡 ระบบจะเพิ่มยอดเงินเข้าบัญชีของผู้ใช้ทันที และบันทึกในระบบ
        </div>

        <div class="footer d-flex justify-content-center mt">
          <button class="block btn primary" type="submit">
            ยืนยันเติมเงิน
          </button>
        </div>
      </form>
      <div id="manualTopupStatus" class="mt"></div>
    </div>
  </div>
</div>

<script>
async function refreshBal(){
  const r = await fetch('/admin/refresh-balance',{ method:'POST' });
  const d = await r.json();
  document.getElementById('bal').innerText = d.balance + (d.currency ? (' '+d.currency) : '');
  window.showMsg({
    variant: 'success',
    title: 'อัปเดตเครดิตสำเร็จ',
    text: `ยอดคงเหลือ: ${d.balance}${d.currency?(' '+d.currency):''}`,
    okText: 'ปิด'
  });
  // toast.success('อัปเดตเครดิตสำเร็จ', `ยอดคงเหลือ: ${d.balance}${d.currency?(' '+d.currency):''}`);
}

async function syncServices() {
  try {
    const res   = await fetch('/admin/sync-services', {
      method: 'POST',
      headers: { 'Accept': 'application/json' } // ขอ JSON ชัดๆ
    });

    const text  = await res.text(); // อ่านเป็นข้อความก่อน
    let data    = null;
    try { data = JSON.parse(text); } catch { /* ไม่ใช่ JSON */ }

    // ตรวจทุกเคส: HTTP ไม่ ok หรือ payload ไม่ ok
    if (!res.ok) {
      const msg = data?.error || `${res.status} ${res.statusText}: ${text}`;
      throw new Error(msg);
    }
    if (!data?.ok) {
      throw new Error(data?.error || 'Unknown error');
    }

    // สำเร็จ
    const synced = data.synced ?? data.count ?? 0;
    notify?.success?.('ซิงก์สำเร็จ', `ดึงบริการสำเร็จ ${synced.toLocaleString()} รายการ`);
    // อัปเดต UI ใต้ปุ่ม (ถ้ามี element id="syncRes")
    const el = document.getElementById('syncRes');
    if (el) el.textContent = `ดึงบริการ ${synced.toLocaleString()} รายการแล้ว`;
  } catch (err) {
    notify?.error?.('ซิงก์ล้มเหลว', String(err?.message || err));
    console.error('[syncServices] failed:', err);
  }
}
</script>

<script>
  async function rejectTx(id){
    if (!id) return alert('ไม่พบรหัสรายการ');

    // 🔔 ใช้การ์ดยืนยันแบบภาพตัวอย่าง (โหมด danger)
    const ok = await uiConfirm({
      variant: 'danger',
      title: 'ยืนยันปฏิเสธรายการ?',
      sub: 'การปฏิเสธจะเปลี่ยนสถานะเป็น Reject และไม่เพิ่มยอดผู้ใช้',
      okText: 'ปฏิเสธ',
      cancelText: 'ยกเลิก',
      focus: 'cancel'
    });
    if (!ok) return;

    try {
      const r = await fetch(`/admin/topup/${encodeURIComponent(id)}/reject`, {
        method:'POST', headers:{'Content-Type':'application/json'}
      });
      const j = await r.json().catch(()=> ({}));
      if (!r.ok || !j.ok) throw new Error(j?.error || 'ปฏิเสธไม่สำเร็จ');

      // โชว์การ์ด Success
      await uiConfirm({
        variant:'success',
        title:'สำเร็จ',
        sub:'ปฏิเสธรายการเรียบร้อย',
        okText:'ปิด',
        cancelText:'Cancel'
      });

      location.reload();
    } catch(err){
      await uiConfirm({
        variant:'danger',
        title:'ล้มเหลว',
        sub:String(err?.message || err),
        okText:'ลองอีกครั้ง',
        cancelText:'ปิด'
      });
    }
  }
</script>

<script>
  function debounce(fn, ms=250){ let t; return (...a)=>{ clearTimeout(t); t=setTimeout(()=>fn(...a), ms); }; }

  function renderUserDatalist(items){
    const dl = document.getElementById('userList');
    dl.innerHTML = '';
    (items||[]).forEach(u=>{
      const opt = document.createElement('option');
      opt.value = u.username;                      // ค่าที่จะถูกกรอก
      opt.label = `${u.username}${u.email?' · '+u.email:''}`;
      dl.appendChild(opt);
    });
  }

  const doUserSearch = debounce(async function(q){
    try{
      const url = q && q.length
        ? `/admin/api/users/search?q=${encodeURIComponent(q)}&limit=20`
        : `/admin/api/users/search?limit=20`;      // อนุญาต preload (q ว่าง)
      const r = await fetch(url);
      const j = await r.json();
      if (j?.ok) renderUserDatalist(j.items);
    }catch{}
  }, 250);

  function bindUsernameSearchOnce(){
    const el = document.getElementById('manualUsername');
    if (!el || el.__binded) return;
    el.addEventListener('input', e => doUserSearch(e.target.value.trim()));
    el.__binded = true;
  }

  /* 🟣 Modal Controls (เหมือน QR Modal) */
  function openManualTopupModal(txId = null, amount = null, suggestedUsername = ''){
    const modal = document.getElementById("manualTopupModal");
    modal.classList.remove("hidden");

    const form = document.getElementById("manualTopupForm");
    form.reset();
    document.getElementById("manualTopupStatus").innerHTML = "";

    window.currentTxId = txId;

    const amtInput = document.getElementById("manualAmount");
    if (amount){
      amtInput.value = Number(amount).toFixed(2);
      amtInput.readOnly = true;
      amtInput.style.opacity = "0.7";
    }else{
      amtInput.value = "";
      amtInput.readOnly = false;
      amtInput.style.opacity = "1";
    }

    const userInput = document.getElementById('manualUsername');
    if (suggestedUsername && suggestedUsername !== 'null'){
      userInput.value = suggestedUsername;
      doUserSearch(suggestedUsername);             // preload รายการที่เกี่ยวข้อง
    }else{
      userInput.value = '';
      doUserSearch('');                            // preload 10–20 คนแรก
    }

    bindUsernameSearchOnce();

    // ช่วยให้ dropdown โผล่ไวขึ้นบนบาง browser: ยิง input event เบาๆ
    setTimeout(()=>{ userInput.dispatchEvent(new Event('input')); }, 50);
  }

  function closeManualTopupModal(){
    document.getElementById("manualTopupModal").classList.add("hidden");
    document.getElementById("manualTopupStatus").innerHTML = "";
  }

  // ปุ่มปิด (×)
  document.getElementById("manualTopupClose").onclick = closeManualTopupModal;
  // คลิก overlay ปิด
  document.getElementById("manualTopupModal").addEventListener("click",(e)=>{ if(e.target.dataset.close==="1") closeManualTopupModal(); });
  // ปุ่ม Escape ปิด
  document.addEventListener("keydown",(e)=>{ if(e.key==="Escape") closeManualTopupModal(); });

  /* 🧾 ส่งข้อมูลเติมเงิน */
  async function submitManualTopup(ev) {
    ev.preventDefault();
    const username = document.getElementById("manualUsername").value.trim();
    const amount = parseFloat(
      document.getElementById("manualAmount").value || 0
    );
    const txId = window.currentTxId || null;

    if (!username || !(amount > 0)) {
      document.getElementById("manualTopupStatus").innerHTML =
        '<div class="card soft">❌ กรุณากรอกข้อมูลให้ครบถ้วน</div>';
      return false;
    }

    document.getElementById("manualTopupStatus").innerHTML =
      '<div class="muted">⏳ กำลังทำรายการ...</div>';

    try {
      const res = await fetch("/admin/manual-topup", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ username, amount, txId }),
      });

      const data = await res.json();
      if (data.ok) {
        document.getElementById("manualTopupStatus").innerHTML = `
          <div class="card soft">
            ✅ เติมเงินสำเร็จให้ผู้ใช้ <b>${username}</b><br>
            <b>จำนวน:</b> ${amount.toLocaleString()} บาท
          </div>`;
        setTimeout(() => closeManualTopupModal(), 1500);
        setTimeout(() => window.location.reload(), 1700);
      } else {
        document.getElementById("manualTopupStatus").innerHTML =
          '<div class="card soft">❌ ' +
          (data.error || "เกิดข้อผิดพลาด") +
          "</div>";
      }
    } catch (err) {
      document.getElementById("manualTopupStatus").innerHTML =
        '<div class="card soft">❌ ขัดข้อง: ' + err.message + "</div>";
    }
  }
  // Toggle หุบ/ขยายสำหรับมือถือ
  (function initTxAccordion(){
    document.querySelectorAll('.tx-accordion').forEach(card=>{
