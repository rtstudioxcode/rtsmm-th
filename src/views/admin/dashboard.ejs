    const r = await fetch('/admin/refresh-balance', { method: 'POST' });
    const text = await r.text();
    let d = null; try { d = JSON.parse(text); } catch {}

    if (!r.ok || !d?.ok) {
      const msg = (d && (d.error || d.message)) || text || `HTTP ${r.status}`;
      throw new Error(msg);
    }

    window.showMsg?.({
      variant: 'success',
