<!-- //admin/dashboard.ejs -->
<h2 style="text-align: center;">Admin Panel | หลังบ้าน</h2>
<div class="grid cards">
  <section class="card2">
    <div class="card-head row-head">
      <h3>ขายแล้ว</h3>
      <div class="head-right">
        <span class="metric-badge">
          <%= (stats?.totalSoldCount || 0).toLocaleString() %> รายการ
        </span>
      </div>
    </div>
  </section>
  <section class="card2">
    <div class="card-head row-head">
      <h3>สมาชิกทั้งหมดในเว็บ</h3>
      <div class="head-right">
        <span class="metric-badge">
          <%= (stats?.userCount || 0).toLocaleString() %> คน
        </span>
      </div>
    </div>
  </section>
  <section class="card2">
    <div class="card-head row-head">
      <h3>รายงานการเติมเงิน</h3>
      <a class="btn" href="/admin/topup-report">รายงานการเติมเงิน</a>
    </div>
  </section>
</div>

<div class="grid cards2">
  <section class="card">
    <h3>ระบบ Bonustime</h3>
    <a class="btn" href="/admin/bonustime-panel">ดูรายละเอียด</a>
    <p class="muted mt">
      เช็ครายละเอียดการใช้งานระบบ Bonustime | ตั้งค่าระบบ Bonustime
    </p>
  </section>
</div>

<div class="grid cards2">
  <section class="card2">
    <div class="card-head row-head">
      <h3>เครดิตผู้ให้บริการ OTP24</h3>
      <div class="head-right">
        <span class="metric-badge" id="otpSync">
          ล่าสุด: <%= otp24LastSyncAt ? new Date(otp24LastSyncAt).toLocaleString() : '—' %>
        </span>
      </div>
    </div>

    <div id="otpBal" class="big">
      <%= Number(otp24Bal || 0).toLocaleString(undefined,{ minimumFractionDigits: 2 }) %> THB
    </div>

    <% if (otp24LastError) { %>
      <div class="muted" id="otpErr">⚠️ <%= otp24LastError %></div>
    <% } else { %>
      <div class="muted" id="otpErr"></div>
    <% } %>

    <button id="btnOtp24" class="btn" onclick="refreshOtp24()">ดึงยอด OTP24</button>
  </section>
  <section class="card2">
    <div class="card-head row-head">
      <h3>ซิงก์บริการ OTP24</h3>

      <div class="head-right muted">
        บริการในปัจจุบัน:
        <b id="otpSvcTotal"><%= (otp24ProductsTotal ?? 0).toLocaleString() %></b> รายการ
      </div>
    </div>

    <button class="btn" onclick="syncOtpServices()">ดึงบริการ OTP</button>

    <div id="otpSvcRes" class="mt muted">
      ล่าสุด: <%= otp24ProductsLastSyncAt ? new Date(otp24ProductsLastSyncAt).toLocaleString() : '—' %>
    </div>
  </section>

  <section class="card2">
    <h3>สรุปยอดขาย OTP</h3>
    <a class="btn" href="/admin/otp-report">ไปหน้าสรุปยอดขาย OTP</a>
    <p class="muted mt">
      ประวัติการขาย OTP | สรุปยอดขาย OTP
    </p>
  </section>
</div>

<div class="grid cards">
  <section class="card">
    <h3>เครดิตผู้ให้บริการ</h3>
    <div id="bal" class="big"><%= balance %></div>
    <button id="btnIp" class="btn" onclick="refreshBal()">ดึงยอด iPlusview</button>
  </section>
  <section class="card">
    <div class="card-head row-head">
      <h3>ซิงก์บริการ</h3>

      <!-- ชิดขวา: จำนวนบริการปัจจุบัน -->
      <div class="head-right muted">
        บริการในปัจจุบัน:
        <b id="svcTotal"><%= (servicesTotal ?? 0).toLocaleString() %></b> รายการ
      </div>
    </div>

    <button class="btn" onclick="syncServices()">ดึงบริการทั้งหมด</button>

    <div id="syncRes" class="mt muted">
      ล่าสุด: <%= lastSyncAt ? new Date(lastSyncAt).toLocaleString() : '—' %>
    </div>
  </section>
  <section class="card">
    <h3>ตั้งค่าราคา</h3>
    <a class="btn" href="/admin/pricing">ไปหน้ากฎปรับราคา</a>
    <p class="muted mt">
      ปรับทั้งเว็บ, รายหมวด, หมวดย่อย หรือรายบริการ | โหมด: % / +คงที่ / set
      ราคา
    </p>
  </section>
</div>

<div class="grid cards2">
  <section class="card2">
    <h3>ข้อมูลผู้ใช้ทั้งหมด</h3>
    <a class="btn" href="/admin/users">ข้อมูลผู้ใช้</a>
    <p class="muted mt">ไปที่หน้าข้อมูลผู้ใช้</p>
  </section>
  <section class="card2">
    <h3>รายการสั่งซื้อบริการ</h3>
    <a class="btn" href="/admin/orders">รายการออเดอร์</a>
    <p class="muted mt">ไปที่หน้ารายการสั่งซื้อออบริการของผู้ใช้</p>
  </section>
  <section class="card2">
    <h3>สรุปยอดขายรายเดือน</h3>
    <a class="btn" href="/admin/report/summary">สรุปยอดขายรายเดือน</a>
    <p class="muted mt">ไปที่หน้าสรุปยอดขายรายเดือน</p>
  </section>
</div>
<% const BANK_LABELS = { bbl: 'ธนาคารกรุงเทพ', kbank: 'ธนาคารกสิกรไทย', ktb:
'ธนาคารกรุงไทย', bay: 'ธนาคารกรุงศรีอยุธยา', scb: 'ธนาคารไทยพาณิชย์', tmb:
'ทหารไทยธนชาต (TTB)', cimb: 'ธนาคารซีไอเอ็มบีไทย', uob: 'ธนาคารยูโอบี', gsb:
'ธนาคารออมสิน', baac: 'ธ.เพื่อการเกษตรและสหกรณ์การเกษตร', kkb:
'ธนาคารเกียรตินาคินภัทร', lhfg: 'ธนาคารแลนด์ แอนด์ เฮ้าส์', icbc:
'ธนาคารไอซีบีซี (ไทย)', tisco: 'ธนาคารทิสโก้', tw: 'TrueMoney Wallet' }; %>

<div class="history-wrapper card soft">
  <h3 class="title flex-between">
    รายการเติมเงินที่รอดำเนินการ
    <button class="btn small primary" onclick="openManualTopupModal()">
      + เติมเงินด้วยตนเอง
    </button>
  </h3>

  <% if (transactions && transactions.length > 0) { %>

  <!-- ===== Desktop/Table view (คงของเดิม) ===== -->
  <div class="desktop-only">
    <table class="history-table">
      <thead>
        <tr>
          <th>วันที่ / เวลา</th>
          <th>ข้อมูลผู้โอน</th>
          <th>ข้อมูลผู้รับ</th>
          <th>จำนวนเงิน</th>
          <th>สถานะ</th>
          <th>จัดการ</th>
        </tr>
      </thead>
      <tbody>
        <% transactions.forEach(tx => {
             const method = tx.method?.toLowerCase() || "";
             const wallet = (webWallets || []).find(w => w.accountCode === method);
             const statusLabel =
               tx.status === "completed" ? "สำเร็จ" :
               tx.status === "pending"   ? "รอดำเนินการ" :
               (tx.status === "reject" || tx.status === "rejected") ? "ถูกปฏิเสธ" :
               tx.status === "failed"    ? "ล้มเหลว" : "ยกเลิก";
        %>
        <tr>
          <!-- วันที่ -->
          <td class="muted">
            <%= new Date(tx.createdAt).toLocaleString('th-TH', {
              year:'numeric', month:'short', day:'numeric', hour:'2-digit', minute:'2-digit'
            }) %>
          </td>

          <!-- ข้อมูลผู้โอน -->
          <td>
            <% if (method === 'truewallet' || method === 'tw') { %>
              <img src="/static/assets/payment/tw.webp" class="bank-logo" />
              <div><b>TrueWallet</b></div>
              <div class="muted">เบอร์ผู้โอน: <%= tx.senderNumber || '-' %></div>
            <% } else { %>
              <img src="/static/assets/payment/mobilebanking.png" class="bank-logo" />
              <div><b><%= BANK_LABELS[tx.senderBank] || 'ไม่ระบุธนาคาร' %></b></div>
              <div class="muted">เลขท้ายบัญชีผู้โอน: <%= tx.senderLast6 || '-' %></div>
            <% } %>
          </td>

          <!-- ข้อมูลผู้รับ -->
          <td>
            <% if (wallet) { %>
              <img src="/static/assets/payment/<%= wallet.accountCode %>.webp" class="bank-logo" />
              <div><b><%= wallet.accountName %></b></div>
              <div class="muted">เลขบัญชี: <%= wallet.accountNumber %></div>
            <% } else { %>
              <span class="muted">ไม่พบข้อมูลผู้รับ</span>
            <% } %>
          </td>

          <!-- จำนวนเงิน -->
          <td class="amount">
            ฿<%= Number(tx.amount).toLocaleString(undefined,{ minimumFractionDigits: 2 }) %>
          </td>

          <!-- สถานะ -->
          <td class="status <%= tx.status.toLowerCase() %>"><%= statusLabel %></td>

          <!-- Action -->
          <td>
            <button
              class="btn small success"
              onclick="openManualTopupModal(
                '<%= tx.transactionId %>',
                <%= tx.amount %>,
                '<%= (tx.user?.username||'').replace(/'/g,'\\\'') %>',
                '<%= (tx.method || 'admin').toLowerCase() %>',
                true   // ⬅️ ล็อกค่า
              )">
              เติมให้ผู้ใช้
            </button>
            <button
              class="btn small danger"
              onclick="rejectTx('<%= (tx._id || tx.transactionId) %>')">
              ปฏิเสธ
            </button>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- ===== Mobile/Card view (หุบ/ขยาย) ===== -->
  <div class="mobile-only tx-accordion-list">
    <% transactions.forEach(tx => {
         const method = (tx.method||'').toLowerCase();
         const wallet = (webWallets || []).find(w => w.accountCode === method);
         const statusLabel =
           tx.status === "completed" ? "สำเร็จ" :
           tx.status === "pending"   ? "รอดำเนินการ" :
           (tx.status === "reject" || tx.status === "rejected") ? "ถูกปฏิเสธ" :
           tx.status === "failed"    ? "ล้มเหลว" : "ยกเลิก";
    %>
    <div class="tx-accordion" data-open="0">
      <!-- แถวหัว (ปิดอยู่) -->
      <button class="tx-accordion__head" type="button">
        <div class="tx-accordion__title">
          <span class="tx-id" title="<%= tx.transactionId || '' %>">
            <%= tx.transactionId || '—' %>
          </span>
        </div>
        <div class="tx-accordion__meta">
          <span class="tx-date">
            <%= new Date(tx.createdAt).toLocaleString('th-TH', {
              year:'numeric', month:'2-digit', day:'2-digit',
              hour:'2-digit', minute:'2-digit', second:'2-digit'
            }) %>
          </span>
          <span class="tx-toggle"></span>
        </div>
      </button>

      <!-- เนื้อหารายละเอียด -->
      <div class="tx-accordion__body">
        <div class="tx-row">
          <div class="tx-label">ผู้โอน</div>
          <div class="tx-value">
            <% if (method === 'truewallet' || method === 'tw') { %>
              <img src="/static/assets/payment/tw.webp" class="bank-logo" alt="">
              <b>TrueWallet</b><br>
              <span class="muted">เบอร์ผู้โอน: <%= tx.senderNumber || '-' %></span>
            <% } else { %>
              <img src="/static/assets/payment/<%= tx.senderBank %>.webp" class="bank-logo" alt="">
              <b><%= BANK_LABELS[tx.senderBank] || 'ไม่ระบุธนาคาร' %></b><br>
              <span class="muted">เลขท้ายบัญชีผู้โอน: <%= tx.senderLast6 || '-' %></span>
            <% } %>
          </div>
        </div>

        <div class="tx-row">
          <div class="tx-label">ผู้รับ</div>
          <div class="tx-value">
            <% if (wallet) { %>
              <img src="/static/assets/payment/<%= wallet.accountCode %>.webp" class="bank-logo" alt="">
              <b><%= wallet.accountName %></b><br>
              <span class="muted">เลขบัญชี: <%= wallet.accountNumber %></span>
            <% } else { %>
              <span class="muted">ไม่พบข้อมูลผู้รับ</span>
            <% } %>
          </div>
        </div>

        <div class="tx-row">
          <div class="tx-label">จำนวนเงิน</div>
          <div class="tx-value">
            <b>฿<%= Number(tx.amount).toLocaleString(undefined,{minimumFractionDigits:2}) %></b>
          </div>
        </div>

        <div class="tx-row">
          <div class="tx-label">สถานะ</div>
          <div class="tx-value">
            <span class="pill pill--<%= (tx.status||'').toLowerCase() %>"><%= statusLabel %></span>
          </div>
        </div>

        <div class="tx-actions">
          <button class="btn small success" style="width:100%;"
            onclick="openManualTopupModal(
              '<%= tx.transactionId %>',
              <%= tx.amount %>,
              '<%= (tx.user?.username||'').replace(/'/g, "\\'") %>',
              '<%= (tx.method || 'admin').toLowerCase() %>',
              true   // ⬅️ ล็อกค่า
            )">
            เติมให้ผู้ใช้
          </button>
          <button class="btn small danger" style="width: 100%; margin-top: 8px;"
            onclick="rejectTx('<%= (tx._id || tx.transactionId) %>')">
            ปฏิเสธ
          </button>
        </div>
      </div>
    </div>
    <% }) %>
  </div>

  <% } else { %>
    <div class="empty-history">
      <img src="/static/assets/emoji/empty.png" alt="ยังไม่มีรายการเติมเงิน" />
      <p class="muted">ยังไม่มีรายการเติมเงิน</p>
    </div>
  <% } %>
</div>

<div id="manualTopupModal" class="hidden modal">
  <div class="overlay" data-close="1"></div>
  <div class="dialog" role="dialog" aria-modal="true" aria-labelledby="manualTitle">
    <div class="hdr">
      <div class="title" id="manualTitle">เติมเงินให้ผู้ใช้</div>
      <button class="icon close" id="manualTopupClose" aria-label="ปิด">×</button>
    </div>
    <hr class="sep" />

    <div class="body">
      <form id="manualTopupForm" onsubmit="return submitManualTopup(event)">
        <label>
          ชื่อผู้ใช้ (Username)
          <input
            type="text"
            id="manualUsername"
            list="userList"
            autocomplete="off"
            required
            placeholder="พิมพ์ค้นหา เช่น: ad"
            class="block input mt-sm"
          />
          <datalist id="userList"></datalist>
        </label>

        <div class="row2 mt">
          <label class="grow">
            จำนวนเงิน
            <input
              type="number"
              id="manualAmount"
              required
              min="1"
              step="0.01"
              placeholder="เช่น 100.00"
              class="block input mt-sm"
            />
          </label>

          <label class="grow">
            วิธีการเติม (Method)
            <div class="select-wrap">
              <select id="manualMethod" required class="block input mt-sm">
                <option value="admin" selected>แอดมิน</option>
                <option value="truewallet">True Wallet</option>
                <option value="kbank">KBank</option>
                <option value="scb">SCB</option>
                <option value="manual">เติมมือ</option>
              </select>
            </div>
          </label>
        </div>

        <div class="card soft mt">
          💡 ระบบจะเพิ่มยอดเงินเข้าบัญชีของผู้ใช้ทันที และบันทึกในระบบ
        </div>

        <div class="footer d-flex justify-content-center mt">
          <button class="block btn primary" type="submit">
            ยืนยันเติมเงิน
          </button>
        </div>
      </form>
      <div id="manualTopupStatus" class="mt"></div>
    </div>
  </div>
</div>

<script>
async function refreshOtp24(){
  const btn   = document.getElementById('btnOtp24');
  const balEl = document.getElementById('otpBal');
  const syncEl= document.getElementById('otpSync');
  const errEl = document.getElementById('otpErr');

  try{
    if (btn){ btn.disabled = true; btn.dataset._label = btn.textContent; btn.textContent = 'กำลังดึง…'; }
    if (balEl){ balEl.dataset._val = balEl.textContent; balEl.textContent = 'กำลังดึง…'; }
    if (errEl){ errEl.textContent = ''; }

    const r = await fetch('/admin/otp24hr/refresh-balance', { method: 'POST', headers:{'Accept':'application/json'} });
    const text = await r.text();
    let d = null; try { d = JSON.parse(text); } catch {}

    if (!r.ok || !d?.ok) {
      const msg = (d && (d.error || d.message)) || text || `HTTP ${r.status}`;
      throw new Error(msg);
    }

    if (balEl){
      balEl.textContent = Number(d.balance).toLocaleString(undefined,{ minimumFractionDigits: 2 }) + (d.currency?(' '+d.currency):'');
    }
    if (syncEl){
      syncEl.textContent = 'ล่าสุด: ' + new Date().toLocaleString();
    }
    if (errEl){ errEl.textContent = ''; }

    window.showMsg?.({
      variant: 'success',
      title: 'ดึงยอด OTP24 สำเร็จ',
      text: `ยอดคงเหลือ: ${Number(d.balance).toLocaleString(undefined,{ minimumFractionDigits:2 })}${d.currency?(' '+d.currency):''}`,
      okText: 'ปิด'
    });
  }catch(err){
    if (balEl && balEl.dataset._val) balEl.textContent = balEl.dataset._val;
    if (syncEl){ syncEl.textContent = 'ล่าสุด: ' + new Date().toLocaleString(); }
    if (errEl){ errEl.textContent = String(err?.message || err); }

    window.showMsg?.({
      variant: 'danger',
      title: 'ล้มเหลว',
      text: String(err?.message || err),
      okText: 'ปิด'
    });
    console.error('refreshOtp24 error:', err);
  }finally{
    if (btn){ btn.disabled = false; if (btn.dataset._label) btn.textContent = btn.dataset._label; }
  }
}

async function syncOtpServices() {
  try {
    const res = await fetch('/admin/otp24hr/sync-services', {
      method: 'POST',
      headers: { 'content-type': 'application/json', 'accept': 'application/json' },
      body: JSON.stringify({ apiPerc: 0, addPerc: 50 })
    });
    const data = await res.json();
    if (!res.ok || !data?.ok) throw new Error(data?.error || 'sync failed');

    notify?.success?.('ซิงก์สำเร็จ', `อัปเดตแล้ว ${data.count?.toLocaleString?.() ?? data.count} รายการ`);

    // อัปเดตตัวเลขรวม
    const totalEl = document.getElementById('otpSvcTotal');
    if (totalEl) totalEl.textContent = (data.total ?? 0).toLocaleString();

    // ✅ อัปเดต “ล่าสุด: …”
    const lastEl = document.getElementById('otpSvcRes');
    if (lastEl) lastEl.textContent = `ล่าสุด: ${new Date().toLocaleString()}`;
  } catch (err) {
    notify?.error?.('ซิงก์ล้มเหลว', String(err?.message || err));
    console.error('[syncOtpServices] failed:', err);
  }
}
</script>

