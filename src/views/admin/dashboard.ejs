      okText: 'ปิด'
    });
  }catch(err){
    window.showMsg?.({
      variant: 'danger',
      title: 'ล้มเหลว',
      text: String(err?.message || err),
      okText: 'ปิด'
    });
    console.error('refreshiPlusview error:', err);
  }finally{
    if (btn){ btn.disabled = false; if (btn.dataset._label) btn.textContent = btn.dataset._label; }
  }
}
