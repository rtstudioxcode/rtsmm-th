async function syncServices() {
  try {
    const res   = await fetch('/admin/sync-services', {
      method: 'POST',
      headers: { 'Accept': 'application/json' } // ขอ JSON ชัดๆ
    });

    const text  = await res.text(); // อ่านเป็นข้อความก่อน
    let data    = null;
    try { data = JSON.parse(text); } catch { /* ไม่ใช่ JSON */ }

    // ตรวจทุกเคส: HTTP ไม่ ok หรือ payload ไม่ ok
    if (!res.ok) {
      const msg = data?.error || `${res.status} ${res.statusText}: ${text}`;
      throw new Error(msg);
    }
    if (!data?.ok) {
      throw new Error(data?.error || 'Unknown error');
    }

    // สำเร็จ
    const synced = data.synced ?? data.count ?? 0;
    notify?.success?.('ซิงก์สำเร็จ', `ดึงบริการสำเร็จ ${synced.toLocaleString()} รายการ`);
    // อัปเดต UI ใต้ปุ่ม (ถ้ามี element id="syncRes")
    const el = document.getElementById('syncRes');
    if (el) el.textContent = `ดึงบริการ ${synced.toLocaleString()} รายการแล้ว`;
  } catch (err) {
    notify?.error?.('ซิงก์ล้มเหลว', String(err?.message || err));
    console.error('[syncServices] failed:', err);
  }
}
</script>

<script>
  async function rejectTx(id){
    if (!id) return alert('ไม่พบรหัสรายการ');

    // 🔔 ใช้การ์ดยืนยันแบบภาพตัวอย่าง (โหมด danger)
    const ok = await uiConfirm({
      variant: 'danger',
      title: 'ยืนยันปฏิเสธรายการ?',
      sub: 'การปฏิเสธจะเปลี่ยนสถานะเป็น Reject และไม่เพิ่มยอดผู้ใช้',
      okText: 'ปฏิเสธ',
      cancelText: 'ยกเลิก',
      focus: 'cancel'
    });
    if (!ok) return;

    try {
      const r = await fetch(`/admin/topup/${encodeURIComponent(id)}/reject`, {
        method:'POST', headers:{'Content-Type':'application/json'}
      });
      const j = await r.json().catch(()=> ({}));
      if (!r.ok || !j.ok) throw new Error(j?.error || 'ปฏิเสธไม่สำเร็จ');

      // โชว์การ์ด Success
      await uiConfirm({
        variant:'success',
        title:'สำเร็จ',
        sub:'ปฏิเสธรายการเรียบร้อย',
        okText:'ปิด',
        cancelText:'Cancel'
      });

      location.reload();
    } catch(err){
      await uiConfirm({
        variant:'danger',
        title:'ล้มเหลว',
        sub:String(err?.message || err),
        okText:'ลองอีกครั้ง',
        cancelText:'ปิด'
      });
    }
  }
</script>

<script>
  function debounce(fn, ms=250){ let t; return (...a)=>{ clearTimeout(t); t=setTimeout(()=>fn(...a), ms); }; }

  function renderUserDatalist(items){
    const dl = document.getElementById('userList');
    dl.innerHTML = '';
    (items||[]).forEach(u=>{
      const opt = document.createElement('option');
      opt.value = u.username;                      // ค่าที่จะถูกกรอก
      opt.label = `${u.username}${u.email?' · '+u.email:''}`;
      dl.appendChild(opt);
    });
  }

  const doUserSearch = debounce(async function(q){
    try{
      const url = q && q.length
        ? `/admin/api/users/search?q=${encodeURIComponent(q)}&limit=20`
        : `/admin/api/users/search?limit=20`;      // อนุญาต preload (q ว่าง)
      const r = await fetch(url);
      const j = await r.json();
      if (j?.ok) renderUserDatalist(j.items);
    }catch{}
  }, 250);

  function bindUsernameSearchOnce(){
    const el = document.getElementById('manualUsername');
    if (!el || el.__binded) return;
    el.addEventListener('input', e => doUserSearch(e.target.value.trim()));
    el.__binded = true;
  }

  (function makeBeautifulSelect(){
    const sel = document.getElementById('manualMethod');
    const wrap = sel?.closest('.select-wrap');
    if (!sel || !wrap) return;

    // ปุ่มหลัก
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'fake-select';
    btn.innerHTML = `
      <span class="fake-label">${sel.options[sel.selectedIndex]?.text || 'เลือกวิธีการ'}</span>
      <span class="fake-caret">▾</span>
    `;

    // เมนู
    const menu = document.createElement('div');
    menu.className = 'fake-menu';

    const rebuildMenu = () => {
      menu.innerHTML = '';
      [...sel.options].forEach((o, idx) => {
        const it = document.createElement('button');
        it.type = 'button';
        it.className = 'fake-item';
        it.textContent = o.textContent;
        if (o.disabled) it.disabled = true;
        if (idx === sel.selectedIndex) it.setAttribute('aria-selected', 'true');
        it.addEventListener('click', () => {
          if (o.disabled) return;
          sel.value = o.value;
          btn.querySelector('.fake-label').textContent = o.textContent;
          wrap.classList.remove('open');
          sel.dispatchEvent(new Event('change', { bubbles: true }));
        });
        menu.appendChild(it);
      });
    };
    rebuildMenu();

    // เปิด/ปิดเมนู
    btn.addEventListener('click', () => { if (!btn.disabled) wrap.classList.toggle('open'); });
    document.addEventListener('click', (e) => { if (!wrap.contains(e.target)) wrap.classList.remove('open'); });

    // sync disabled/selected จาก select
    const syncState = () => {
      btn.disabled = sel.disabled;
      btn.querySelector('.fake-label').textContent = sel.options[sel.selectedIndex]?.text || '';
      rebuildMenu();
    };
    const mo = new MutationObserver(syncState);
    mo.observe(sel, { attributes: true, attributeFilter: ['disabled'] });
    sel.addEventListener('change', syncState);

    // ป้องกันเมนูล้นขอบจอ (คำนวณความสูงตาม viewport)
    const fitMenu = () => {
      const r = wrap.getBoundingClientRect();
      const spaceBelow = window.innerHeight - r.bottom - 16;
      menu.style.maxHeight = Math.max(160, Math.min(320, spaceBelow)).toFixed(0) + 'px';
    };
    window.addEventListener('resize', fitMenu);
    window.addEventListener('scroll', fitMenu, { passive: true });
    btn.addEventListener('click', fitMenu);

    wrap.appendChild(btn);
    wrap.appendChild(menu);
  })();

  function openManualTopupModal(txId = null, amount = null, suggestedUsername = '', method = 'admin', lock = false){
    const modal = document.getElementById("manualTopupModal");
    if (!modal) return;
    modal.classList.remove("hidden");

    const form    = document.getElementById("manualTopupForm");
    const status  = document.getElementById("manualTopupStatus");
    const userInp = document.getElementById("manualUsername");
    const amtInp  = document.getElementById("manualAmount");
    const mSel    = document.getElementById("manualMethod");

    if (form) form.reset();
    if (status) status.innerHTML = "";

    window.currentTxId = txId;

    // จำนวนเงิน
    if (amtInp){
      if (amount){
        amtInp.value = Number(amount).toFixed(2);
        amtInp.readOnly = true;
        amtInp.classList.add('is-readonly');
      }else{
        amtInp.readOnly = false;
        amtInp.classList.remove('is-readonly');
      }
    }

    // Username
    if (userInp){
      if (suggestedUsername && suggestedUsername !== 'null'){
        userInp.value = suggestedUsername;
        doUserSearch(suggestedUsername);
      }else{
        userInp.value = '';
        doUserSearch('');
      }
      bindUsernameSearchOnce();
      setTimeout(()=>{ try{ userInp.dispatchEvent(new Event('input')); }catch{} }, 50);
      userInp.readOnly = !!lock;                 // ⬅️ ล็อกเมื่อกดจากรายการ
      userInp.classList.toggle('is-readonly', !!lock);
    }

    // Method
    if (mSel){
      mSel.value = (method || 'admin').toLowerCase();
      mSel.disabled = !!lock;                    // ⬅️ ล็อกเมื่อกดจากรายการ
      mSel.classList.toggle('is-disabled', !!lock);
    }

    // จัด layout ให้ Method ขึ้นระดับเดียวกับจำนวนเงิน (Desktop)
    document.getElementById('manualMethod')?.closest('label')?.classList.add('align-top');
  }

  function closeManualTopupModal(){
    const modal  = document.getElementById("manualTopupModal");
    const status = document.getElementById("manualTopupStatus");
    if (!modal) return;
    modal.classList.add("hidden");
    if (status) status.innerHTML = "";
  }

  // ปุ่มปิด / overlay / ESC (ผูกกับของเดิม แต่กัน null)
  document.getElementById("manualTopupClose")?.addEventListener('click', closeManualTopupModal);
  document.getElementById("manualTopupModal")?.addEventListener("click", (e)=>{
    if (e.target?.dataset?.close === "1") closeManualTopupModal();
  });
  document.addEventListener("keydown", (e)=>{
    if (e.key === "Escape") {
      const modal = document.getElementById("manualTopupModal");
      if (modal && !modal.classList.contains("hidden")) closeManualTopupModal();
    }
  });
