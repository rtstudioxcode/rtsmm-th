<!-- 🟣 Tab-style header buttons -->
<div class="tabs">
  <button class="tab active" data-tab="tab-topup">
    การเติมเครดิต
  </button>
  <button class="tab" data-tab="tab-history">
    ประวัติการเติมเงิน
  </button>
</div>

<!-- 🧩 Tab content wrapper -->
<section id="tab-topup" class="tabpane show">
  <p class="muted">เลือกวิธีเติมเงิน และกรอกจำนวนที่ต้องการเติม</p>

  <section class="card soft">
    <h3 class="title">ช่องทางเติมเงินของคุณ</h3>

    <%
    // ✅ กรองเฉพาะกระเป๋าที่ใช้งานอยู่เท่านั้น (isActive !== false)
    const wallets = (webWallets || []).filter(w => w && w.isActive !== false);

    // ป้ายชื่อธนาคาร
    const BANK_LABELS = {
      bbl:'ธนาคารกรุงเทพ', kbank:'ธนาคารกสิกรไทย', ktb:'ธนาคารกรุงไทย',
      bay:'ธนาคารกรุงศรีอยุธยา', scb:'ธนาคารไทยพาณิชย์', tmb:'ทหารไทยธนชาต (TTB)',
      cimb:'ธนาคารซีไอเอ็มบีไทย', uob:'ธนาคารยูโอบี', gsb:'ธนาคารออมสิน',
      baac:'ธ.เพื่อการเกษตรและสหกรณ์การเกษตร', kkb:'ธนาคารเกียรตินาคินภัทร',
      lhfg:'ธนาคารแลนด์ แอนด์ เฮ้าส์', icbc:'ธนาคารไอซีบีซี (ไทย)',
      tisco:'ธนาคารทิสโก้', tw:'TrueMoney Wallet'
    };

    const hasAny = wallets.length > 0;
    %>

    <!-- 🟣 ปุ่มสลับแท็บ: แสดงเฉพาะเมื่อมีมากกว่า 1 บัญชีที่ active -->
    <% if (hasAny) { %>
      <div class="tab-bar">
        <% wallets.forEach((w, i) => { %>
          <button
            class="tab-btn <%= i === 0 ? 'active' : '' %>"
            data-tab="wallet-<%= i %>"
          >
            <img src="/static/assets/payment/<%= w.accountCode %>.webp" alt="<%= w.accountCode %>"/>
            <span><%= BANK_LABELS[w.accountCode] || w.accountCode.toUpperCase() %></span>
          </button>
        <% }) %>
      </div>
    <% } %>

    <!-- 🏦 เนื้อหาแท็บ: แสดงเฉพาะรายการที่ active; ถ้าไม่มีเลย แสดงข้อความว่าง -->
    <% if (wallets.length === 0) { %>
      <p class="muted">ยังไม่มีช่องทางเติมเงินที่พร้อมใช้งาน</p>
    <% } else { %>
      <% wallets.forEach((w, i) => { const isTW = w.accountCode === 'tw'; %>
        <div class="tab-content <%= i === 0 ? 'active' : '' %>" id="wallet-<%= i %>">

          <% if (!isTW) { %>
            <!-- 🟢 บัญชีธนาคารทั่วไป -->
            <section class="card soft">
              <h3 class="title" style="text-align:center;">มายังบัญชี</h3>
              <div class="grid method-grid">
                <div class="method-tile">
                  <img src="/static/assets/payment/<%= w.accountCode %>.webp" alt="<%= w.accountCode %>"/>
                  <div><%= w.accountName %></div>
                  <small>QR Code แสกนได้ทุกธนาคาร</small>
                </div>
              </div>
              <p class="muted mt" style="text-align:center;">❗️โอนสูงสุดได้ไม่เกิน 30,000 บาทต่อรอบ</p>
              <p class="muted mt" style="text-align:center;">⚠️หลีกเลี่ยงการโอนเงินช่วงเวลา 23:30 - 01:30 เพราะอาจทำให้การเติมล่าช้าไปมาก</p>
            </section>

            <form
              id="createTopupForm-<%= i %>"
              class="form topupForm"
              data-wallet-code="<%= w.accountCode %>"
              data-wallet-index="<%= i %>"
              onsubmit="return submitqrTopup(event)"
            >
              <label>
                จำนวนเงินที่ต้องการเติม (ขั้นต่ำ 10 บาท)
                <div class="input-group">
                  <span class="input-prefix">฿</span>
                  <input
                    id="amount-<%= i %>"
                    name="amount"
                    type="number"
                    min="10"
                    step="any"
                    required
                    placeholder="เช่น 100"
                    oninput="updateqrSummary(<%= i %>)"
                  />
                </div>
              </label>

              <button class="block btn primary mt-lg">ดำเนินการเติมเงิน</button>
            </form>

            <!-- กล่องแสดง QR (ซ่อนไว้ก่อน) -->
            <div id="qrBox-<%= i %>" class="card soft mt" style="display:none">
              <div class="row" style="align-items:center; gap:16px">
                <img id="qrImg-<%= i %>" src="" alt="QR Code" width="220" height="220" loading="lazy" />
                <div>
                  <div><b>ยอดที่ต้องโอน (รวมเศษ):</b> <span id="qrAmount-<%= i %>">—</span> บาท</div>
                  <small class="muted">⚠️โปรดโอน “ตรงตามยอด” และ “ครั้งเดียว” เพื่อให้ระบบเติมอัตโนมัติ⚠️</small>
                  <small class="muted">⚠️ห้ามกดปิดจนกว่าการทำรายการจะเสร็จสิ้น⚠️</small>
                  <div class="mt-sm">
                    <button type="button" class="btn" onclick="closeQr(<%= i %>)">ปิด</button>
                  </div>
                </div>
              </div>
            </div>

            <section class="card soft mt">
              <h4 class="title">📋 ขั้นตอนการโอนเงิน</h4>
              <ol class="steps">
                <li>ระบุจำนวนเงิน > <b>ตัวอย่าง: 10</b></li>
                <li>กด > <b>ดำเนินการเติมเงิน</b></li>
                <li>เข้าสู่แอปธนาคารของคุณ (เช่น SCB EASY, KBank, Krungthai NEXT)</li>
                <li>เลือกเมนู <b>“แสกนหรือจ่ายบิล”</b></li>
                <li>แสกน QRCode: <b>ใส่ยอดเงินให้ตรงกับหน้าเว็บ</b></li>
                <li>ตรวจสอบชื่อบัญชีปลายทางให้ตรงกับ: <b><%= w.accountName %></b></li>
                <li>หลังจากโอนแล้วเงินเครดิตจะเข้าอัตโนมัติ</li>
              </ol>
              <p class="muted">💡 ระบบจะตรวจสอบยอดและปรับเครดิตอัตโนมัติภายในไม่กี่นาที</p>
            </section>

          <% } else { %>
            <!-- 💜 TrueWallet -->
            <section class="card soft">
              <h3 class="title" style="text-align:center;">มายังบัญชี</h3>
              <div class="grid method-grid">
                <div class="method-tile">
                  <img src="/static/assets/payment/<%= w.accountCode %>.webp" alt="<%= w.accountCode %>"/>
                  <div><%= w.accountName %></div>
                  <small>QR Code - True Wallet เท่านั้น</small>
                </div>
              </div>
              <div class="muted mt" style="text-align:center;">❗️ใช้แอป TrueMoney Wallet สแกน QR เท่านั้น</div>
            </section>
            <form
              id="topupForm-<%= i %>"
              class="form topupForm"
              data-wallet-code="<%= w.accountCode %>"
              data-wallet-index="<%= i %>"
              onsubmit="return submitTopup(event)"
            >
              <label>
                จำนวนเงินที่ต้องการเติม (ขั้นต่ำ 10 บาท)
                <div class="input-group">
                  <span class="input-prefix">฿</span>
                  <!-- ทำ id ให้ไม่ซ้ำใน DOM -->
                  <input
                    id="amount-<%= i %>"
                    name="amount"
                    type="number"
                    min="10"
                    step="any"
                    required
                    placeholder="เช่น 100"
                  />
                </div>
              </label>

              <button class="block btn primary mt-lg">ดำเนินการเติมเงิน</button>
            </form>

            <section class="card soft mt">
              <h4 class="title">📲 วิธีการเติมเงินผ่าน TrueMoney Wallet (มีค่าธรรมเนียม 3%)</h4>
              <ol class="steps">
                <li>ระบุจำนวนเงิน > <b>ตัวอย่าง: 10</b></li>
                <li>กด > <b>ดำเนินการเติมเงิน</b></li>
                <li>เปิดแอป > <b>TrueMoney Wallet</b> บนโทรศัพท์ของคุณ</li>
                <li>เลือกเมนู > <b>“สแกน”</b></li>
                <li>กลับมาที่หน้านี้ ระบบจะตรวจสอบยอดอัตโนมัติและปิดหน้าต่างให้เอง</li>
              </ol>
              <p class="muted">💡 ระบบจะตรวจสอบยอดและปรับเครดิตอัตโนมัติภายในไม่กี่นาที</p>
            </section>
          <% } %>
        </div>
      <% }) %>
    <% } %>

    <!-- 🟡 Modal -->
    <div id="qrModal" class="hidden modal">
      <div class="overlay" data-close="1"></div>
      <div class="dialog" role="dialog" aria-modal="true" aria-labelledby="qrTitle">
        <div class="hdr" style="align-items:center; text-align:center">
          <div class="title" id="qrTitle" style="align-items:center; text-align:center">สแกน QRCode เพื่อเติมเงิน</div>
          <button class="icon close" id="qrClose" aria-label="ปิด">×</button>
        </div>
        <hr class="sep" />

        <!-- ⏳ Countdown -->
        <div id="qrCountdown" class="muted" style="text-align:center" aria-live="polite">
          หมดอายุใน 05:00
        </div>

        <div class="body">
          <!-- QR -->
          <div class="qr-img-wrap">
            <img id="qrImage" src="" alt="QR Code" class="qr-img" />
          </div>

          <!-- Meta (จะแสดงต่างกันตามโหมด) -->
          <div id="qrMeta" class="qr-meta">
            <!-- โหมดธนาคาร: โชว์เฉพาะจำนวนเงิน + คำเตือน -->
            <div data-for="bankOnly">
              <div><b>ยอดที่ต้องโอน:</b> <span id="qrAmount" class="text-success">—</span> บาท</div>
              <div style="margin-top:6px;color:#e7ac08;font-weight:400">
                ⚠️ โปรดโอนตามยอดที่แสดงเท่านั้น ไม่งั้นเครดิตไม่เข้า
              </div>
            </div>

            <!-- โหมด TrueWallet: โชว์รายละเอียดเดิม -->
            <div data-for="twOnly" style="display:none">
              <div><b>ช่องทาง:</b> <span id="qrMethod"></span></div>
              <div><b>ชื่อบัญชี:</b> <span id="qrName"></span></div>
              <div><b>เลขบัญชี:</b> <span id="qrNumber"></span></div>
              <div><b>ยอดเติม:</b> <span id="qrAmountTw" class="text-success"></span> บาท</div>
              <div class="muted" style="color:#e7ac08; text-align:center;">โปรดโอนในระยะเวลาที่กำหนด</div>
              <div class="muted" style="color:#e7ac08; text-align:center;">ห้ามกดปิดจนกว่าจะทำรายการสำเร็จ</div>
            </div>
          </div>
        </div>

        <hr class="sep" />
        <!-- ปุ่มนี้ใช้เฉพาะ TrueWallet -->
        <div class="footer d-flex justify-content-center" id="qrFooterTw" style="margin-top:12px; display:none">
          <button class="btn primary" id="confirmTopup">ยืนยันการโอนแล้ว</button>
        </div>

        <div id="qrStatus" class="mt"></div>
      </div>
    </div>

    <div id="resp" class="mt"></div>
  </section>
</section>
<section id="tab-history" class="tabpane">
  <p class="muted">รายการประวัติการเติมเงินของคุณจะปรากฏที่นี่</p>

  <div class="history-wrapper card soft">
    <h3 class="title">ประวัติการเติมเงินล่าสุด</h3>

    <% if (transactions && transactions.length) { %>

      <!-- เดสก์ท็อป: ตาราง -->
      <table class="history-table d-desktop">
        <thead>
          <tr>
            <th>วันที่</th>
            <th>ช่องทาง</th>
            <th class="right">จำนวนเงิน</th>
            <th>สถานะ</th>
          </tr>
        </thead>
        <tbody>
        <% for (var i = 0; i < transactions.length; i++) {
             var tx = transactions[i];
             var methodName = (tx.method === 'tw')  ? 'TrueWallet'
                            : (tx.method === 'scb') ? 'SCB ไทยพาณิชย์'
                            : (tx.method === 'kbank') ? 'KBANK กสิกรไทย' 
                            : (tx.method === 'manual') ? 'แอดมิน'
                            : (tx.method === 'admin') ? 'แอดมิน': 'ไม่ระบุ';
             var st = String(tx.status || '').toLowerCase(); // completed|pending|failed|canceled
             var statusLabel = (st === 'completed') ? 'สำเร็จ'
                             : (st === 'pending')   ? 'รอดำเนินการ'
                             : (st === 'failed')    ? 'ล้มเหลว'
                             : (st === 'canceled')  ? 'ยกเลิก' : st;
             var ts = tx.paidAt || tx.updatedAt || tx.createdAt;
             var amountNum = Number(tx.amount) || 0;
        %>
          <tr data-status="<%= st %>">
            <td class="mono">
              <%= new Date(ts).toLocaleString('th-TH',{
                    timeZone:'Asia/Bangkok', year:'numeric', month:'2-digit',
                    day:'2-digit', hour:'2-digit', minute:'2-digit'
                  }) %>
            </td>
            <td class="method-cell">
              <span class="method">
                <img
                  class="method-ico"
                  src="/static/assets/payment/<%= tx.method %>.webp"
                  alt="<%= methodName %>"
                  width="22"
                  height="22"
                  loading="lazy"
                  style="margin-right:0"
                >
                <span class="method-name"><%= methodName %></span>
              </span>
            </td>
            <td class="amount right">
              <span class="money">฿<%= amountNum.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
            </td>
            <td class="status">
              <span class="pill sm st-<%= st %>">
                <i class="st-ico" aria-hidden="true"></i>
                <span class="txt"><%= statusLabel %></span>
              </span>
            </td>
          </tr>
        <% } %>
        </tbody>
      </table>

      <!-- มือถือ: การ์ดแบบหุบ/ขยาย (ค่าเริ่มต้น = หุบ) -->
      <div class="history-list d-mobile">
      <% for (var j = 0; j < transactions.length; j++) {
           var t = transactions[j];
           var mName = (t.method === 'tw')  ? 'TrueWallet'
                    : (t.method === 'scb') ? 'SCB ไทยพาณิชย์'
                    : (t.method === 'kbank') ? 'KBANK กสิกรไทย'
                    : (t.method === 'scb') ? 'SCB ไทยพานิชย์'
                    : (t.method === 'manual') ? 'แอดมิน'
                    : (t.method === 'admin') ? 'แอดมิน' : 'ไม่ระบุ';
           var st2 = String(t.status || '').toLowerCase();
           var stLabel = (st2 === 'completed') ? 'สำเร็จ'
                       : (st2 === 'pending')   ? 'รอดำเนินการ'
                       : (st2 === 'failed')    ? 'ล้มเหลว'
                       : (st2 === 'canceled')  ? 'ยกเลิก' : st2;
           var ts2 = t.paidAt || t.updatedAt || t.createdAt;
           var amt = Number(t.amount) || 0;
      %>
        <details class="hx-card" data-status="<%= st2 %>">
          <summary class="hx-head">
            <!-- ตอนหุบ แสดงแค่วันที่+เวลา -->
            <span class="hx-date mono">
              <%= new Date(ts2).toLocaleString('th-TH',{
                    timeZone:'Asia/Bangkok', year:'numeric', month:'2-digit',
                    day:'2-digit', hour:'2-digit', minute:'2-digit'
                  }) %>
            </span>
            <button class="hx-toggle" type="button" aria-label="toggle"></button>
          </summary>

          <div class="hx-body">
            <div class="hx-row">
              <div class="hx-label">ช่องทาง</div>
              <div class="hx-val method">
                <img class="method-ico" src="/static/assets/payment/<%= t.method %>.webp"
                     alt="<%= mName %>" width="22" height="22" loading="lazy">
                <span><%= mName %></span>
              </div>
            </div>

            <div class="hx-row">
              <div class="hx-label">จำนวนเงิน</div>
              <div class="hx-val money">฿<%= amt.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) %></div>
            </div>

            <div class="hx-row">
              <div class="hx-label">สถานะ</div>
              <div class="hx-val">
                <span class="pill sm st-<%= st2 %>">
                  <i class="st-ico" aria-hidden="true"></i>
                  <span class="txt"><%= stLabel %></span>
                </span>
              </div>
            </div>
          </div>
        </details>
      <% } %>
      </div>

    <% } else { %>
      <div class="empty-history">
        <img src="/static/assets/empty.svg" alt="No history">
        <p class="muted">ยังไม่มีรายการเติมเงิน</p>
      </div>
    <% } %>
  </div>
</section>

<!-- topup Notice Modal -->
<dialog id="topupNoticeModal" class="toast-modal" aria-labelledby="topupNoticeTitle" aria-describedby="topupNoticeText">
  <div class="toast-card" role="alertdialog">
    <div class="toast-headbar" style="--th-bg: linear-gradient(135deg,#8b5cf6,#6d5dfc);">
      <div class="toast-badge" aria-hidden="true">⚠️</div>
      <div class="toast-headtxt">
        <h3 class="toast-title" id="topupNoticeTitle">แจ้งเตือน</h3>
        <div class="muted" style="font-weight:400;font-size:13px">โปรดอ่านข้อมูลต่อไปนี้ก่อนเติมเงิน</div>
      </div>
    </div>

    <div class="toast-body">
      <ul style="margin:0 0 0 18px; padding:10px 0; color:var(--t-muted); line-height:1.5">
        <li>ในส่วนการเติมเงินแบบแสกน QR Code ของธนาคาร</li>
        <li>ผู้ใช้งานต้องกรอกจำนวนให้ตรงกับหน้าเว็บ</li>
        <li>หากกรอกจำนวนไม่ตรงระบบจะไม่สามารถเติมเครดิตให้อัตโนมัติ</li>
        <li>หลีกเลี่ยงการโอนเงินช่วง 23:30 - 01:30 น. เพราะระบบธนาคารอัปเดตข้อมูลช้า</li>
        <li>หากเติมเงินไม่เข้าเกิน 1 ชั่วโมงให้ติดต่อไลน์แจ้งแอดมินทันที</li>
      </ul>

      <label style="display:flex; gap:10px; align-items:center; margin-top:12px; color:var(--t-muted)">
        <input id="topupNoticeDontShow" type="checkbox" style="width:18px; height:18px;"/>
        <span>ไม่แสดงอีกในวันนี้</span>
      </label>
    </div>

    <div class="toast-actions" style="padding-top:8px;">
      <!-- <button class="pill" id="topupNoticeCloseCancel" hidden>ยกเลิก</button> -->
      <button class="pill primary" id="topupNoticeClose">ปิดและยอมรับ</button>
    </div>
  </div>
</dialog>

<script>
(function(){
  const KEY = 'topup_notice_suppress_until_v1'; // localStorage key
  const modal = document.getElementById('topupNoticeModal');
  const chk = document.getElementById('topupNoticeDontShow');
  const btnClose = document.getElementById('topupNoticeClose');

  function shouldShow(){
    try {
      const v = localStorage.getItem(KEY);
      if (!v) return true;
      const ts = Number(v);
      if (!Number.isFinite(ts)) return true;
      return Date.now() > ts; // show if now past expiry
    } catch(e){
      return true;
    }
  }

  function setSuppressFor1Day(){
    const until = Date.now() + 1 * 24 * 60 * 60 * 1000;
    try { localStorage.setItem(KEY, String(until)); } catch(e){ /* ignore */ }
  }

  // show modal on DOM ready if needed
  document.addEventListener('DOMContentLoaded', ()=>{
    try {
      if (shouldShow()) {
        // wait a tick so dialog styles/backdrop applied nicely
        setTimeout(()=> {
          if (!modal.open) modal.showModal();
        }, 120);
      }
    } catch(e){}
  });

  btnClose?.addEventListener('click', ()=>{
    if (chk && chk.checked) setSuppressFor1Day();
    try { if (modal.open) modal.close(); } catch(e){}
  });

  // allow Escape/cancel to close as well but don't set suppression
  modal?.addEventListener('cancel', (ev)=> {
    ev.preventDefault();
    try { modal.close(); } catch(e){}
  });
})();
</script>

<script>
  let currentTxId = null;
  let txWatcher = null;

  function startTxWatcher(txId, timeoutSec = 300){
    stopTxWatcher();
    const started = Date.now();

    txWatcher = setInterval(async ()=> {
      try{
        if (Date.now() - started > timeoutSec*1000) {
          stopTxWatcher();
          closeQrModal();
          return;
        }
        const r = await fetch(`/topup/tx/${txId}`);
        const j = await r.json();
        if (j?.ok) {
          if (['completed','failed','cancelled'].includes(j.status)) {
            stopTxWatcher();
            closeQrModal();

            if (j.status === 'completed') {
              // ✅ โชว์ Notify มุมขวาบน พร้อมจำนวนเงิน (ถ้ามี)
              const amt = j.amount ?? j.paidAmount ?? j.displayAmount ?? j.total ?? j.credit ?? null;
              const fmt = n => Number(n).toLocaleString(undefined,{ minimumFractionDigits:2, maximumFractionDigits:2 });
              if (typeof notify?.success === 'function') {
                notify.success('เติมเงินสำเร็จ', amt != null ? `เพิ่มเครดิต ฿${fmt(amt)}` : '');
              }

              // หน่วงนิดเดียวให้ผู้ใช้เห็นแจ้งเตือน แล้วค่อยรีเฟรช
              setTimeout(()=> location.reload(), 900);
            } else {
              const msg = (j.status === 'failed')
                ? 'การชำระล้มเหลว กรุณาลองใหม่'
                : 'รายการถูกยกเลิก';
              if (typeof notify?.error === 'function') notify.error('ไม่สำเร็จ', msg);
              else alert(msg);
            }
          }
        }
      }catch(e){ /* เงียบ ๆ แล้ววนต่อ */ }
    }, 2500);
  }

  function stopTxWatcher(){
    if (txWatcher) clearInterval(txWatcher);
    txWatcher = null;
  }

  function fmtMoney(n){
    try {
      return Number(n).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    } catch { return n; }
  }

  function updateqrSummary(i){
    const v = parseFloat(document.getElementById(`amount-${i}`)?.value || '0');
    const el = document.getElementById(`summaryAmount-${i}`);
    if (!el) return;
    el.textContent = v >= 10 ? fmtMoney(v) : '—';
  }

  function closeQr(i){
    const box = document.getElementById(`qrBox-${i}`);
    if (box) box.style.display = 'none';
  }

  async function submitqrTopup(ev){
    ev.preventDefault();

    const form       = ev.currentTarget;
    const i          = form.dataset.walletIndex;
    const walletCode = form.dataset.walletCode;
    const amountEl   = document.getElementById(`amount-${i}`);
    const base       = parseFloat(amountEl?.value || '0');

    if (!Number.isFinite(base) || base < 10){
      const msg = 'จำนวนเงินขั้นต่ำ 10 บาท';
      window.showMsg ? window.showMsg({ variant:'error', title:'จำนวนเงินไม่ถูกต้อง', text: msg }) : alert(msg);
      return false;
    }

    try {
      const res = await fetch('/topup/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ amount: base, walletCode })
      });
      const j = await res.json();
      if (!res.ok || !j?.ok) {
        const err = j?.error || 'สร้างคำสั่งเติมเงินไม่สำเร็จ';
        window.showMsg ? window.showMsg({ variant:'error', title:'ไม่สำเร็จ', text: err }) : alert(err);
        return false;
      }

      // เติมข้อมูล QR + เปิดโมดัล (โหมดธนาคาร)
      currentTxId = j.txId;
      const finalAmount = Number(j.displayAmount);
      const qrUrl       = j.qrUrl;

      const img = document.getElementById('qrImage');
      if (img && qrUrl) img.src = qrUrl;
      const amtEl = document.getElementById('qrAmount');
      if (amtEl) amtEl.textContent = finalAmount.toLocaleString(undefined,{ minimumFractionDigits:2 });

      openQrModal('bank', 300);

      // 🔔 เริ่มเฝ้าสถานะ: webhook เคลียร์ปุ๊บ → ปิด modal + reload
      startTxWatcher(currentTxId, 300);
    } catch (err) {
      const msg = `ขัดข้อง: ${err.message}`;
      window.showMsg ? window.showMsg({ variant:'error', title:'ไม่สำเร็จ', text: msg }) : alert(msg);
    }
    return false;
  }
</script>

<script>
  const $ = (s, r = document) => r.querySelector(s);
  const fmt = (n) =>
    Number(n || 0).toLocaleString(undefined, {
      minimumFractionDigits: 2,
    });

  /* 🟡 Header tab switching (เติมเครดิต / ประวัติการเติมเงิน) */
  document.querySelectorAll(".tabs .tab").forEach((btn) => {
    btn.addEventListener("click", () => {
      // ปรับสถานะปุ่ม
      document
        .querySelectorAll(".tabs .tab")
        .forEach((b) => b.classList.remove("active"));

      // ซ่อนเนื้อหาเดิม
      document
        .querySelectorAll(".tabpane")
        .forEach((p) => p.classList.remove("show"));

      // แท็บที่เลือก
      btn.classList.add("active");
      const tabId = btn.dataset.tab;
      const pane = document.getElementById(tabId);
      if (pane) pane.classList.add("show");
    });
  });

  /* 🟣 Wallet tab switching */
  document.querySelectorAll(".tab-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      document
        .querySelectorAll(".tab-btn")
        .forEach((b) => b.classList.remove("active"));
      document
        .querySelectorAll(".tab-content")
        .forEach((c) => c.classList.remove("active"));
      btn.classList.add("active");
      document.getElementById(btn.dataset.tab).classList.add("active");
    });
  });

  // แสดงยอดรวม (คิด fee 3% เฉพาะ TrueWallet)
  function fmt2(n){
    try { return Number(n).toLocaleString(undefined,{ minimumFractionDigits:2, maximumFractionDigits:2 }); }
    catch { return n; }
  }

  function computeSubtotal(base, walletCode){
    const rate = (walletCode === 'tw') ? 1.03 : 1;     // TW +3%, อื่นๆ 0%
    return Math.round(base * rate * 100) / 100;        // ปัด 2 ตำแหน่ง (bankers)
  }

  function bindTopupSummary(form){
    const amt = form.querySelector('input[name="amount"]');
    const sum = form.querySelector('[id^="summaryAmount-"]');
    if (!amt || !sum) return;

    const walletCode = form.dataset.walletCode || '';  // 'tw' | 'kbank' | ...

    const update = () => {
      const base = Number(amt.value || 0);
      if (!Number.isFinite(base) || base < 10){
        sum.textContent = '—';
        return;
      }
      const subtotal = computeSubtotal(base, walletCode);
      sum.textContent = fmt2(subtotal);
    };

    amt.addEventListener('input', update);
    amt.addEventListener('change', update);
    // คำนวณครั้งแรกเผื่อมีค่าเดิม
    update();
  }

  // ผูกทุกฟอร์มที่มีคลาส .topupForm
  document.querySelectorAll('.topupForm').forEach(bindTopupSummary);

  /* ================= QR MODAL (single source of truth) ================= */
  let qrTimerId = null;
  let qrExpireAt = null;

  function formatMMSS(msLeft){
    const s = Math.max(0, Math.ceil(msLeft/1000));
    const mm = String(Math.floor(s/60)).padStart(2,'0');
    const ss = String(s%60).padStart(2,'0');
    return `${mm}:${ss}`;
  }

  function clearQrCountdown(){
    if (qrTimerId) clearInterval(qrTimerId);
    qrTimerId = null;
    const el = document.getElementById('qrCountdown');
    if (el) el.textContent = 'หมดอายุใน 05:00';
  }

  function setQrMode(mode){
    window.qrMode = mode; // 'bank' | 'tw'
    const bankEls = document.querySelectorAll('#qrMeta [data-for="bankOnly"]');
    const twEls   = document.querySelectorAll('#qrMeta [data-for="twOnly"]');
    const footerTw = document.getElementById('qrFooterTw');

    bankEls.forEach(e => e.style.display = (mode === 'bank' ? '' : 'none'));
    twEls.forEach(e   => e.style.display = (mode === 'tw'   ? '' : 'none'));
    // ❗️สำคัญ: ซ่อนปุ่มยืนยันเสมอ (เราใช้ watcher อัตโนมัติแทน)
    if (footerTw) footerTw.style.display = 'none';
  }

  function startQrCountdown(seconds = 300){
    clearQrCountdown();
    const el = document.getElementById('qrCountdown');
    qrExpireAt = Date.now() + seconds * 1000;

    const tick = () => {
      const left = qrExpireAt - Date.now();
      if (left <= 0){
        clearQrCountdown();
        if (el) el.textContent = 'หมดเวลาแล้ว';
        closeQrModal(); // ปิดออโต้เมื่อหมดเวลา
        return;
      }
      if (el) el.textContent = `หมดอายุใน ${formatMMSS(left)}`;
    };

    tick();
    qrTimerId = setInterval(tick, 1000);
  }

  /* 🟢 Modal controls */
  function openQrModal(mode = 'bank', seconds = 300) {
    setQrMode(mode);
    const m = document.getElementById('qrModal');
    m?.classList.remove('hidden');
    document.getElementById('qrStatus').innerHTML = '';
    startQrCountdown(seconds);
  }

  function closeQrModal(){
    const m = document.getElementById('qrModal');
    m?.classList.add('hidden');
    document.getElementById('qrStatus').innerHTML = '';
    clearQrCountdown();
    stopTxWatcher();
  }

  /* bind ปิดด้วยปุ่ม/overlay (ครั้งเดียว) */
  document.getElementById('qrClose')?.addEventListener('click', closeQrModal);
  document.getElementById('qrModal')?.addEventListener('click', (e)=>{
    if (e.target.dataset.close === '1') closeQrModal();
  });

  let TW_LOCK = false;

  /* 💸 Submit TrueWallet topup */
  async function submitTopup(ev){
    ev.preventDefault();
    if (TW_LOCK) return false;                 // กันกดรัว
    TW_LOCK = true;

    try{
      const form       = ev.currentTarget || ev.target;
      const walletCode = form.dataset.walletCode; // ควรเป็น 'tw'
      const amountEl   = form.querySelector('input[name="amount"]');
      const base       = Number(amountEl?.value || 0);

      if (walletCode !== 'tw'){
        document.querySelector("#resp").innerHTML =
          `<div class="card soft">❌ วิธีนี้รองรับเฉพาะ TrueWallet</div>`;
        return false;
      }
      if (!Number.isFinite(base) || base < 10){
        document.querySelector("#resp").innerHTML =
          `<div class="card soft">❌ จำนวนเงินขั้นต่ำ 10 บาท</div>`;
        return false;
      }

      // 1) รวมค่าธรรมเนียม 3% (ปัดทศนิยม 2 ตำแหน่งให้แน่นอน)
      const subtotal = Math.round((base * 1.03 + Number.EPSILON) * 100) / 100;

      // 2) ให้ backend สุ่มเศษ + สร้าง tx (สำคัญ: walletCode='tw')
      //    หมายเหตุ: ถ้าแบ็กเอนด์คืน pendingTxId มา → reuse ไม่สร้างซ้ำ
      const cRes = await fetch('/topup/create', {
        method: 'POST',
        headers: { 'Content-Type':'application/json' },
        body: JSON.stringify({ amount: subtotal, walletCode: 'tw' })
      });
      const c = await cRes.json();

      if (!cRes.ok || !c?.ok){
        // ถ้ามี tx ค้างคืนมาให้ ก็ใช้ตัวนั้นต่อ (หลีกเลี่ยง Pending ซ้ำ)
        if (c?.pendingTxId) {
          window.currentTxId = c.pendingTxId;
        } else {
          const err = c?.error || 'สร้างคำสั่งเติมเงินไม่สำเร็จ';
          window.showMsg ? window.showMsg({ variant:'error', title:'ไม่สำเร็จ', text: err }) : alert(err);
          return false;
        }
      } else {
        // ปกติได้ tx ใหม่
        window.currentTxId = c.txId || c.id || c.pendingTxId;
      }

      // จำนวนที่ต้องจ่ายจริง (สุ่มเศษแล้ว)
      const payAmount = Number((c?.displayAmount ?? subtotal));

      // 3) ขอลิงก์จ่ายจาก TrueMoney
      const gRes = await fetch('/topup/truewallet/gen/link', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ amount: payAmount })
      });
      const g = await gRes.json();
      if (!gRes.ok || !g?.url){
        const err = g?.message || 'ไม่สามารถสร้างลิงก์ TrueWallet ได้';
        window.showMsg ? window.showMsg({ variant:'error', title:'ไม่สำเร็จ', text: err }) : alert(err);
        return false;
      }

      // 4) เคลียร์ watcher เก่า (ถ้ามี) ก่อนเริ่มรอบใหม่
      try { stopTxWatcher(); } catch {}

      // 5) ใส่ข้อมูลลงโมดัล + เปิดโหมด TW
      const img = document.getElementById('qrImage');
      if (img) img.src = `https://api.qrserver.com/v1/create-qr-code/?size=512x512&data=${encodeURIComponent(g.url)}`;

      document.getElementById('qrMethod')?.replaceChildren(document.createTextNode('TrueMoney Wallet'));
      document.getElementById('qrName')?.replaceChildren(document.createTextNode(g.accountName || 'RTSMM'));
      document.getElementById('qrNumber')?.replaceChildren(document.createTextNode(g.accountNumber || '-'));
      document.getElementById('qrAmountTw')?.replaceChildren(document.createTextNode(
        payAmount.toLocaleString(undefined,{minimumFractionDigits:2, maximumFractionDigits:2})
      ));

      // เปิด modal โหมด TW + เริ่มจับเวลา
      openQrModal('tw', 300);

      // 6) เริ่มเฝ้าสถานะ (webhook สำเร็จ → watcher ปิด modal + reload)
      startTxWatcher(window.currentTxId, 300);

      return false;
    } catch(err){
      const msg = `ขัดข้อง: ${err.message}`;
      window.showMsg ? window.showMsg({ variant:'error', title:'ไม่สำเร็จ', text: msg }) : alert(msg);
      return false;
    } finally {
      TW_LOCK = false; // ปลดล็อคไม่ว่าผลจะสำเร็จ/ล้มเหลว
    }
  }

  /* 🧾 Confirm topup */
   document.getElementById("confirmTopup")?.addEventListener("click", async () => {
    const activeTab = document.querySelector(".tab-content.active");
    const amountEl  = activeTab?.querySelector('input[name="amount"]');
    const amount    = Number(amountEl?.value || 0);
    if (!(amount > 0)) return;

    document.querySelector("#qrStatus").innerHTML = `<div class="muted">⏳ กำลังตรวจสอบรายการ...</div>`;
    try {
      const res = await fetch("/topup/truewallet/check", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ amount }),
      });
      const data = await res.json();
      if (data.verified) {
        // ✅ แจ้งเตือนมุมขวาบน + จำนวนเงิน (ถ้ามี)
        const amt = data.amount ?? data.paidAmount ?? data.displayAmount ?? data.total ?? null;
        const fmt = n => Number(n).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        if (typeof window.notify?.success === 'function') {
          window.notify.success('เติมเงินสำเร็จ', amt != null ? `เพิ่มเครดิต ฿${fmt(amt)}` : '');
        }

        // อัปเดตสถานะในโมดัลให้ผู้ใช้เห็นด้วย
        document.querySelector("#qrStatus").innerHTML = `
          <div class="card soft">
            ✅ ยืนยันการโอนสำเร็จแล้ว<br>
            <b>รหัสธุรกรรม:</b> ${data.transactionId || data._id || "-"}<br>
            <b>สถานะ:</b> ${data.status}
          </div>`;

        // ปิดโมดัลแล้วค่อยรีเฟรช (ให้ทันเห็น notify ก่อน)
        setTimeout(() => { try { closeQrModal?.(); } catch {} ; window.location.reload(); }, 1200);

      } else {
        document.querySelector("#qrStatus").innerHTML = `
          <div class="card soft">
            ⚠️ ยังไม่พบรายการ กรุณารอสักครู่ แล้วกด "ยืนยันการโอนแล้ว" อีกครั้ง
          </div>`;
      }
    } catch (err) {
      if (typeof window.notify?.error === 'function') {
        window.notify.error('ขัดข้อง', err.message || 'โปรดลองใหม่');
      }
      document.querySelector("#qrStatus").innerHTML =
        `<div class="card soft">❌ ขัดข้อง: ${err.message}</div>`;
    }
  });
  (() => {
    const $cards = document.getElementById('orderCards');
    if (!$cards) return;

    $cards.addEventListener('click', (e) => {
      const card = e.target.closest('.o-card');
      if (!card) return;

      // กดที่หัว/ปุ่ม ถึงจะ toggle (ไม่รบกวนลิงก์/ปุ่มภายใน o-body)
      const hitHeader = e.target.closest('.o-head, .o-toggle');
      const isInsideBodyAction = e.target.closest('.o-body a, .o-body button, .o-body .xbtn');
      if (!hitHeader || isInsideBodyAction) return;

      // ปิดใบอื่นก่อน
      $cards.querySelectorAll('.o-card.open').forEach(el => { if (el !== card) el.classList.remove('open'); });

      // toggle ใบที่กด
      card.classList.toggle('open');

      // อัปเดตสัญลักษณ์ +/−
      const t = card.querySelector('.o-toggle');
      if (t) t.textContent = card.classList.contains('open') ? '' : '';
    });
  })();
  document.addEventListener('DOMContentLoaded', () => {
    // ปิดทุกการ์ดเมื่อโหลดแท็บนี้
    document.querySelectorAll('.history-list .hx-card[open]').forEach(el => el.removeAttribute('open'));
    // ให้คลิกทั้งหัว summary ก็ทำงาน (no extra JS needed) — ปุ่ม +/− เปลี่ยนด้วย CSS แล้ว
  });
</script>

<style>
/* 🟡 Header tab switcher */
.topup-tab-header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  background: #0e0e0e;
  padding: 0.5rem 1rem;
  border-radius: 1rem;
  margin-bottom: 1.2rem;
}

.tab-switch-btn {
  flex: 1;
  text-align: center;
  font-weight: 400;
  font-size: 0.95rem;
  border: none;
  border-radius: 0.75rem;
  padding: 0.6rem 0.8rem;
  cursor: pointer;
  transition: all 0.25s ease;
}

.tab-section {
  display: none;
}

.tab-section.active {
  display: block;
}

/* 🟢 Wallet tab bar */
.tab-bar {
  display: flex;
  gap: 0.5rem;
  border-bottom: 1px solid var(--border-color, #333);
  margin-bottom: 1rem;
  overflow-x: auto;
}

.tab-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 10px;
  border: none;
  background: transparent;
  color: var(--text, #aaa);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  transition: 0.2s;
}

.tab-btn.active {
  color: var(--accent, #3bd);
  border-color: var(--accent, #3bd);
}

.tab-btn img {
  width: 24px;
  height: 24px;
}

.tab-content {
  display: none;
}

.tab-content.active {
  display: block;
}

/* 💰 Amount form */
.method-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 1rem;
}

.method-tile {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--border-color, #444);
  border-radius: 1rem;
  padding: 1rem;
}

.method-tile img {
  width: 48px;
  height: 48px;
  object-fit: contain;
  margin-bottom: 0.5rem;
}

/* ให้กระดาน (list) เป็นคอลัมน์เดียวเสมอ */
.methods-grid, .method-list {
  display: grid;
  grid-template-columns: 1fr;
}

/* ให้ tile กินเต็มแถวใน grid ใด ๆ */
.method-tile {
  grid-column: 1 / -1;   /* full row */
  width: 100%;
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 16px 18px;
  border: 1px solid var(--border, #2a2f36);
  background: var(--card, #1c1f24);
  border-radius: 14px;
}

/* โลโก้และข้อความ */
.method-tile img {
  width: 44px;
  height: 44px;
  object-fit: contain;
}
.method-tile > div {
  font-weight: 400;
}
.method-tile small {
  display: block;
  color: var(--muted, #a7b0bb);
  margin-top: 2px;
}

/* เผื่ออยู่ใน layout ที่ไม่ใช่ grid */
.method-tile { max-width: 100%; }

/* 🧾 Steps */
.steps {
  list-style: decimal inside;
  padding-left: 1rem;
  margin-top: 0.5rem;
  margin-bottom: 0.5rem;
  line-height: 1.7;
}

.steps li {
  margin-bottom: 0.3rem;
}

.steps b {
  color: var(--accent, #3bd);
}

/* 🪟 Modal */
.modal.hidden {
  display: none;
}

.modal {
  position: fixed;
  inset: 0;
  z-index: 60;
}

.modal .overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.55);
}

.modal .dialog {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  max-width: 420px;
  width: calc(100% - 24px);
  background: var(--card, #1c1f24);
  border: 1px solid var(--border, #2a2f36);
  border-radius: 14px;
  box-shadow: 0 18px 60px rgba(0, 0, 0, 0.4);
  padding: 16px 18px 18px;
  animation: modalFadeIn 0.25s ease-out;
  z-index: 200;
}

.modal .hdr {
  display: flex;
  justify-content: space-between;
  align-items: center;
  text-align: center;
