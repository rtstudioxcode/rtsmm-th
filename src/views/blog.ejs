<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="utf-8" />
  <meta http-equiv="content-language" content="th" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <% 
    const defaultPageTitle = 'บทความการตลาดออนไลน์ 2025 | ปั้มวิว ปั้มไลค์ เพิ่มผู้ติดตาม | RTSMM-TH';
    const headTitle = pageTitle || defaultPageTitle;
    const headDesc  = (typeof metaDescription !== 'undefined' && metaDescription) 
      ? metaDescription 
      : 'รวมบทความสายการตลาดออนไลน์ ปั้มวิว ปั้มไลค์ เพิ่มผู้ติดตาม เทคนิคไวรัล TikTok, YouTube, Instagram, Facebook และการทำคอนเทนต์ให้โตแบบยั่งยืน อัปเดตปี 2025';
    const canonicalUrl = 'https://rtsmm-th.com/blog';
    const ogImage = 'https://rtsmm-th.com/static/assets/img/main-pic-3.png';
  %>

  <!-- ================= BASIC SEO ================= -->
  <title><%= headTitle %></title>
  <meta name="description" content="<%= headDesc %>" />
  <meta name="keywords" content="บทความ, การตลาดออนไลน์, ปั้มวิว, ปั้มไลค์, เพิ่มผู้ติดตาม, TikTok, YouTube, Instagram, Facebook, SEO, SMM Panel ไทย" />
  <meta name="author" content="RTSSM-TH.COM" />
  <meta name="robots" content="index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1" />
  <link rel="canonical" href="<%= canonicalUrl %>" />

  <!-- ================= OPEN GRAPH ================= -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="RTSSM-TH.COM" />
  <meta property="og:locale" content="th_TH" />
  <meta property="og:title" content="<%= headTitle %>" />
  <meta property="og:description" content="<%= headDesc %>" />
  <meta property="og:url" content="<%= canonicalUrl %>" />
  <meta property="og:image" content="<%= ogImage %>" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- ================= TWITTER CARD ================= -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="<%= headTitle %>" />
  <meta name="twitter:description" content="<%= headDesc %>" />
  <meta name="twitter:image" content="<%= ogImage %>" />

  <!-- ================= STRUCTURED DATA (BLOG) ================= -->
  <script type="application/ld+json">
  <%
    const blogSchema = {
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": "บทความการตลาดออนไลน์ | RTSMM-TH",
      "description": headDesc,
      "url": canonicalUrl,
      "publisher": {
        "@type": "Organization",
        "name": "RTSSM-TH.COM",
        "logo": {
          "@type": "ImageObject",
          "url": "https://rtsmm-th.com/static/logo/icon-logo.png"
        }
      },
      "blogPost": (posts || []).slice(0, 8).map(p => ({
        "@type": "BlogPosting",
        "headline": p.title,
        "description": p.excerpt || headDesc,
        "url": "https://rtsmm-th.com/blog/" + p.slug,
        "image": p.thumbnail || ogImage,
        "datePublished": p.dateISO || p.dateText || undefined,
        "author": {
          "@type": "Person",
          "name": p.author || "RTSSM-TH"
        }
      }))
    };
  %>
  <%- JSON.stringify(blogSchema, null, 2) %>
  </script>

  <!-- Favicon -->
  <link rel="icon" href="/static/logo/icon-logo.png" type="image/png">
  <link rel="shortcut icon" href="/static/logo/icon-logo.png" type="image/png">
  <link rel="apple-touch-icon" href="/static/logo/icon-logo.png">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400..800&family=Noto+Sans+Thai:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- Bootstrap & Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flag-icons@7.2.3/css/flag-icons.min.css"/>

  <!-- Effects -->
  <link rel="stylesheet" href="https://iplusview.store/assets-landing/css/animate.min.css">
  <link rel="stylesheet" href="https://iplusview.store/assets-landing/css/main.css">

  <!-- Theme Bridge: map data-theme -> CSS variables (เหมือน index.ejs) -->
  <script>
  (() => {
    const html = document.documentElement;
    const PALETTE_LIGHT = Object.assign({
      primary:'#16a34a', accent:'#7c3aed', dark:'#0e314c', muted:'#6084a4',
      surface:'#f7fafd', surface2:'#ffffff',
      gradient:'linear-gradient(135deg,#22c55e 0%, #06b6d4 100%)'
    }, (window.THEME_LIGHT||{}));
    const PALETTE_DARK = Object.assign({
      primary:'#22d3ee', accent:'#a78bfa', dark:'#e6edf3', muted:'#9fb6c6',
      surface:'#0b1620', surface2:'#0f1e2b',
      gradient:'linear-gradient(135deg,#06b6d4 0%, #14b8a6 100%)'
    }, (window.THEME_DARK||{}));
    function setVars(p){
      const s = html.style;
      s.setProperty('--theme-primary',p.primary);
      s.setProperty('--theme-accent',p.accent);
      s.setProperty('--theme-dark',p.dark);
      s.setProperty('--theme-muted',p.muted);
      s.setProperty('--theme-surface',p.surface);
      s.setProperty('--theme-surface-2',p.surface2);
      s.setProperty('--theme-gradient',p.gradient);
      html.setAttribute('data-bs-theme', html.getAttribute('data-theme')==='dark'?'dark':'light');
    }
    function apply(){ setVars(html.getAttribute('data-theme')==='dark'?PALETTE_DARK:PALETTE_LIGHT); }
    apply();
    window.addEventListener('themechange', apply);
    window.ThemeBridge = {
      setLight(vars){ Object.assign(PALETTE_LIGHT, vars||{}); apply(); },
      setDark(vars){ Object.assign(PALETTE_DARK, vars||{}); apply(); }
    };
  })();
  </script>

  <!-- Dark tokens + overrides (ของเดิมนาย) -->
  <style>
    :root{
      --pv-primary:var(--theme-primary,#22c55e);
      --pv-accent:var(--theme-accent,#0ea5e9);
      --pv-dark:var(--theme-dark,#0e314c);
      --pv-muted:var(--theme-muted,#6084a4);
      --pv-bg:var(--theme-bg,#f7fafd);
      --pv-surface:var(--theme-surface,#ffffff);
      --pv-surface-2:var(--theme-surface-2,#ffffff);
      --pv-border:var(--theme-border,#e6eef5);
      --pv-border-soft:var(--theme-border-soft,#cdf1d8);
      --pv-soft-bg:var(--theme-soft-bg,#e7f8ee);
      --pv-soft-text:var(--theme-soft-text,#198754);
      --pv-soft-border:var(--theme-soft-border,#cdf1d8);
      --pv-hero-a:rgba(68,206,111,.08);
      --pv-hero-b:rgba(99,74,165,.06);
      --pv-shadow:0 12px 24px rgba(14,49,76,.08);
      --pv-gradient:var(--theme-gradient,linear-gradient(135deg,#22c55e 0%, #06b6d4 100%));
      --font-sans:"Inter","Noto Sans Thai",system-ui,-apple-system,"Segoe UI",Roboto,"Helvetica Neue",Arial,"Apple Color Emoji","Segoe UI Emoji","Segoe UI Symbol";
    }
    html[data-theme="dark"]{
      --pv-primary:var(--theme-primary,#22d3ee);
      --pv-accent:var(--theme-accent,#a78bfa);
      --pv-dark:var(--theme-dark,#e6edf3);
      --pv-muted:var(--theme-muted,#9fb6c6);
      --pv-bg:var(--theme-bg,#07131b);
      --pv-surface:var(--theme-surface,#0b1620);
      --pv-surface-2:var(--theme-surface-2,#0f1e2b);
      --pv-border:var(--theme-border,#173046);
      --pv-border-soft:var(--theme-border-soft,#1d3b54);
      --pv-soft-bg:var(--theme-soft-bg,#0f2a24);
      --pv-soft-text:var(--theme-soft-text,#8fe3b4);
      --pv-soft-border:var(--theme-soft-border,#1b3f34);
      --pv-hero-a:rgba(34,211,238,.10);
      --pv-hero-b:rgba(167,139,250,.08);
      --pv-shadow:0 12px 24px rgba(0,0,0,.35);
      --pv-gradient:var(--theme-gradient,linear-gradient(135deg,#06b6d4 0%, #14b8a6 100%));
      color-scheme:dark;
    }
    a, a:hover, .nav-link, .dropdown-item, .btn, .btn:hover { text-decoration:none !important; border-bottom:0 !important; }
    html,body{ font-family:var(--font-sans); -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale; text-rendering:optimizeLegibility; font-variant-numeric:tabular-nums; background:var(--pv-surface); }
    h1,h2,h3,h4,h5,h6{ font-weight:800; letter-spacing:-.01em; }
    .hero{ background:
      radial-gradient(1200px 600px at 85% 20%, var(--pv-hero-a), transparent 60%),
      radial-gradient(1000px 600px at 10% 80%, var(--pv-hero-b), transparent 60%),
      var(--pv-surface);
    }
    .section-title .bar{width:72px;height:4px;border-radius:999px;background:var(--pv-primary)}
    .badge-soft{ background:var(--pv-soft-bg); color:var(--pv-soft-text); border:1px dashed var(--pv-soft-border); border-radius:999px; font-weight:500; }
    .dash-card{ background:var(--pv-surface-2); border:1px dashed var(--pv-border-soft)!important; border-radius:16px; height:100%; transition:transform .2s, box-shadow .2s; }
    .dash-card:hover{ box-shadow:var(--pv-shadow); transform:translateY(-3px) }
    .footer{ background:var(--pv-bg) }
    html[data-theme="dark"] .bg-white{ background:var(--pv-surface-2)!important; }
    html[data-theme="dark"] .border{ border-color:var(--pv-border)!important; }
    html[data-theme="dark"] .text-dark{ color:var(--pv-dark)!important; }
    html[data-theme="dark"] .text-secondary{ color:var(--pv-muted)!important; }

    /* การ์ดบทความ */
    .post-card{ background:var(--pv-surface-2); border:1px dashed var(--pv-border); border-radius:16px; overflow:hidden; height:100%; display:flex; flex-direction:column; }
    .post-thumb{ aspect-ratio:16/9; object-fit:cover; width:100%; }
    .post-body{ padding:16px 16px 18px; display:flex; flex-direction:column; gap:.35rem; }
    .post-title{ font-weight:800; font-size:1.05rem; line-height:1.35; }
    .post-meta{ font-size:.85rem; color:var(--pv-muted); }
    .post-excerpt{ color:var(--pv-dark); }
    .read-more{ margin-top:auto; }
    @media (min-width:1200px){
      .container, .container-fluid{ max-width:100vw!important; padding-left:2rem; padding-right:2rem; }
    }
  </style>

  <script>
    (function syncBsTheme(){
      const html=document.documentElement;
      function apply(){ html.setAttribute('data-bs-theme', html.getAttribute('data-theme')==='dark'?'dark':'light'); }
      apply(); window.addEventListener('themechange', apply);
    })();
  </script>
</head>
<body>

