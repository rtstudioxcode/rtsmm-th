          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOG GRID -->
  <section class="py-4 py-lg-5" style="background:var(--pv-bg)">
    <div class="container-fluid px-4 px-xl-5">
      <div class="row g-3 g-md-4">
        <% (posts||[]).forEach(function(p){ %>
          <div class="col-12 col-md-6 col-lg-4">
            <article class="post-card h-100">
              <% if (p.thumbnail) { %>
                <a href="/blog/<%= p.slug %>">
                  <img class="post-thumb" src="<%= p.thumbnail %>" alt="<%= p.title %>">
                </a>
              <% } %>
              <div class="post-body">
                <div class="post-meta"><i class="fa-regular fa-calendar me-1"></i><%= p.dateText %> · <%= p.author %></div>
                <h3 class="post-title">
                  <a href="/blog/<%= p.slug %>"><%= p.title %></a>
                </h3>
                <% if (p.excerpt) { %>
                  <p class="post-excerpt"><%= p.excerpt %></p>
                <% } %>
                <div class="read-more">
                  <a class="btn btn-sm btn-primary" href="/blog/<%= p.slug %>">
                    อ่านต่อ <i class="fa-solid fa-arrow-right ms-1"></i>
                  </a>
                </div>
              </div>
            </article>
          </div>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-5 text-center" style="background:var(--pv-gradient); color:#fff">
