  <!-- uiConfirm Goble Modal -->
  <script>
  (function(){
    const root = document.getElementById('uiConfirm');
    const card = root.querySelector('.uicf__card');
    const titleEl = root.querySelector('#uicfTitle');
    const subEl   = root.querySelector('#uicfSub');
    const btnOk   = root.querySelector('#uicfOk');
    const btnCancel = root.querySelector('#uicfCancel');

    let resolver = null;

    function show(opts){
      // default
      const {
        variant = 'success', 
        title   = (variant==='success'?'Success':'Cancel'),
        sub     = (variant==='success'?'Woah, successfully completed 3/5 Tasks':'Just a small miss, 2/5 Tasks'),
        okText  = (variant==='success'?'Dashboard':'Try Again'),
        cancelText = 'Cancel',
        // focus control
        focus = 'ok', // 'ok'|'cancel'
      } = opts || {};

      // set variant class
      root.classList.remove('hidden', 'uicf--success', 'uicf--danger');
      root.classList.add(variant==='danger' ? 'uicf--danger' : 'uicf--success');

      // set texts
      titleEl.textContent = title;
      subEl.textContent   = sub;
      btnOk.textContent   = okText;
      btnCancel.textContent = cancelText;

      // lock scroll
      document.documentElement.style.overflow = 'hidden';

      // focus
      setTimeout(()=> (focus==='cancel' ? btnCancel : btnOk).focus(), 10);

      return new Promise((resolve)=>{
        resolver = resolve;
      });
    }

    function hide(){
      root.classList.add('hidden');
      document.documentElement.style.overflow = '';
      if (resolver){ resolver = null; }
    }

    function decide(val){
      const r = resolver;
      hide();
      if (r) r(val);
    }

    // events
    btnOk.addEventListener('click',   ()=>decide(true));
    btnCancel.addEventListener('click',()=>decide(false));
    root.addEventListener('click', (e)=>{
      if (e.target.dataset.close === '1') decide(false);
    });
    document.addEventListener('keydown', (e)=>{
      if (root.classList.contains('hidden')) return;
      if (e.key === 'Escape') decide(false);
    });

    // expose global
    window.uiConfirm = show;
  })();
  </script>
