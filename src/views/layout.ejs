      <div class="toast-headbar">
        <div class="toast-badge" id="msgBadge" aria-hidden="true">?</div>
        <div class="toast-headtxt">
          <h3 class="toast-title" id="msgTitle">หัวข้อ</h3>
        </div>
      </div>
      <div class="toast-body">
        <p class="toast-desc" id="msgText">รายละเอียดข้อความ</p>
      </div>
      <div class="toast-actions">
        <button class="pill ghost" id="msgCancel" hidden>ยกเลิก</button>
        <button class="pill primary" id="msgClose">ตกลง</button>
      </div>
    </div>
  </dialog>

  <!-- Reset Password Modal (server-driven) -->
  <div id="resetPwModal" class="modal" hidden>
    <div class="modal__backdrop" aria-hidden="true"></div>
    <div class="modal__card" role="dialog" aria-modal="true" aria-labelledby="rpTitle">
      <h3 class="modal__title" id="rpTitle">ตั้งรหัสผ่านใหม่</h3>
      <p class="modal__desc">
        อีเมล: <span id="rpEmail"><%= resetEmail || '' %></span>
      </p>

      <label class="modal__field">
        รหัสผ่านใหม่
        <input id="newPw" type="password" autocomplete="new-password" minlength="6" placeholder="อย่างน้อย 6 ตัวอักษร">
      </label>
      <label class="modal__field">
        ยืนยันรหัสผ่านใหม่
        <input id="newPw2" type="password" autocomplete="new-password" minlength="6">
      </label>

      <div class="modal__actions">
        <button class="pill ghost" id="resetCancel" type="button">ยกเลิก</button>
        <button class="pill primary" id="resetSubmit" type="button">บันทึกรหัสผ่าน</button>
      </div>
    </div>
  </div>

  <script>
    // กัน undefined เสมอ
    window.__rp = {
      allowed: <%- JSON.stringify(!!resetAllowed) %>,
      email:   <%- JSON.stringify(resetEmail || null) %>
    };
  </script>

  <script>
    (function(){
      const $ = (s,p=document)=>p.querySelector(s);
      // ======= RESET PASSWORD (server-driven grant) =======
      const modal = $('#resetPwModal');
      if (!modal) return; // ไม่มี modal ก็ไม่ต้องทำอะไร

      const open  = () => { if (modal.hidden) { modal.hidden = false; document.body.classList.add('blurred'); } };
      const close = () => { if (!modal.hidden) { modal.hidden = true;  document.body.classList.remove('blurred'); } };

      // เปิดได้เฉพาะเมื่อเซิร์ฟเวอร์อนุญาต (ผู้ใช้มากดลิงก์ในเมลมาแล้ว)
      if (window.__rp?.allowed === true) open();

      // ปิด = ยกเลิก grant ฝั่ง server ด้วย
      $('#resetCancel')?.addEventListener('click', async () => {
        close();
        try { await fetch('/password/reset/cancel', { method:'POST' }); } catch {}
      });

      // บันทึกรหัสใหม่ (ไม่ต้องส่ง token/email — server ดูจาก session grant)
      $('#resetSubmit')?.addEventListener('click', async () => {
        const p1 = ($('#newPw')?.value || '').trim();
        const p2 = ($('#newPw2')?.value || '').trim();

        if (p1.length < 6) return alert('รหัสผ่านต้องมีอย่างน้อย 6 ตัวอักษร');
        if (p1 !== p2)     return alert('รหัสผ่านไม่ตรงกัน');

        try {
          const r = await fetch('/password/reset', {
            method: 'POST',
            headers: { 'Content-Type':'application/json' },
            body: JSON.stringify({ newPassword: p1 })
          });
          const j = await r.json();
          if (!j.ok) throw new Error(j.error || 'รีเซ็ตไม่สำเร็จ');

          // สำเร็จ → login ให้แล้วในฝั่ง server
          const t = document.createElement('div');
          t.textContent = 'รีเซ็ตรหัสผ่านแล้ว กำลังเข้าสู่ระบบ...';
          t.style.cssText = 'position:fixed;top:16px;right:16px;background:#10b981;color:#fff;padding:10px 14px;border-radius:10px;z-index:2000';
          document.body.appendChild(t);
          setTimeout(() => { t.remove(); location.href = '/'; }, 1200);
        } catch (e) {
          alert(e.message);
        }
      });

      // คลิกฉากหลังเพื่อปิด (ทางเลือก)
      modal.querySelector('.modal__backdrop')?.addEventListener('click', async () => {
        close();
        try { await fetch('/password/reset/cancel', { method:'POST' }); } catch {}
      });

      // ======= Modal Dialog Main =======
      const dlg = $('#msgDialog'), badge=$('#msgBadge'), title=$('#msgTitle'), text=$('#msgText');
      const btnOk = $('#msgClose'), btnCancel=$('#msgCancel');

      window.showMsg = function({
        variant='info', icon, title:tt='ข้อความ', text:tx='', okText='ตกลง', cancelText,
        onOk, onCancel
      } = {}) {
        const iconMap = { info:'❔', success:'✅', warn:'⚠️', error:'✖' };
        dlg.setAttribute('data-variant', variant);
        badge.textContent = icon || iconMap[variant] || '❔';
        title.textContent = tt;
        text.textContent  = tx;

        btnOk.textContent = okText || 'ตกลง';
        if (cancelText) { btnCancel.hidden=false; btnCancel.textContent=cancelText; } else { btnCancel.hidden=true; }

        btnOk.onclick    = () => { dlg.close(); onOk && onOk(); };
        btnCancel.onclick= () => { dlg.close(); onCancel && onCancel(); };

        if (!dlg.open && dlg.showModal) dlg.showModal();
        requestAnimationFrame(()=> btnOk.focus());
      };

      dlg?.addEventListener('cancel', (e)=>{ e.preventDefault(); dlg.close(); });
    })();

    // อ่าน flash ที่ฝั่ง server ยัดมาไว้ใน res.locals.flash (ตั้งแล้วใน index.js)
    window.__flash = <%- JSON.stringify(flash || null) %>;
    document.addEventListener('DOMContentLoaded', () => {
      if (window.__flash && typeof window.showMsg === 'function') {
        window.showMsg(window.__flash);
        window.__flash = null;
      }
    });
  </script>

  <script>
  (() => {
    const sb = document.getElementById('sb');
    const sbBtns = document.querySelectorAll('[id=sbToggle]');
    const sbBrand = document.querySelector('.sb-brand');

    function toggleSidebar() {
      const willOpen = !sb.classList.contains('open');
      sb.classList.toggle('open', willOpen);
      document.body.classList.toggle('sb-open', willOpen);

      // สลับโลโก้แบบเนียน: รอสไลด์เมนูเริ่ม แล้วค่อยเฟด wordmark
      if (willOpen) {
        // ล้างก่อนเผื่อเปิดซ้ำเร็ว ๆ
        sbBrand?.classList.remove('logo-swap');
        requestAnimationFrame(() => {
          setTimeout(() => sbBrand?.classList.add('logo-swap'), 120); // ดีเลย์ ~0.12s
        });
      } else {
        sbBrand?.classList.remove('logo-swap');
      }
    }

    sbBtns.forEach(btn => btn.addEventListener('click', toggleSidebar));

    // คลิกฉากหลังปิดเมนู
    document.addEventListener('click', (e) => {
      if (!sb.classList.contains('open')) return;
      const inside = e.target.closest('#sb');
      const toggle = e.target.closest('[id=sbToggle]');
      if (!inside && !toggle) {
        sb.classList.remove('open');
        document.body.classList.remove('sb-open');
        sbBrand?.classList.remove('logo-swap');
      }
    });

    /* ปุ่มธีม / ปักหมุด (ตามเดสก์ท็อป) เหมือนเดิมได้ */
    const themeBtns = document.querySelectorAll('[id=themeToggle]');
    const renderThemeIcon = () => {
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      themeBtns.forEach(b => b.textContent = isDark ? '🌞' : '🌗');
    };
    renderThemeIcon();
    themeBtns.forEach(b => b.addEventListener('click', () => {
      window.toggleTheme?.();
      renderThemeIcon();
    }));
    window.addEventListener?.('themechange', renderThemeIcon);

    // ซ่อนปุ่ม pin บนมือถืออยู่แล้วใน CSS; เดสก์ท็อปใช้ได้ปกติ
    const pinBtn = document.getElementById('sbPin');
    const KEY = 'sidebarPinned';
    const pinned = localStorage.getItem(KEY) === '1';
    if (pinned) { sb?.classList.add('pinned'); pinBtn?.classList.add('active'); pinBtn?.setAttribute('aria-pressed','true'); }
    pinBtn?.addEventListener('click', () => {
      const willPin = !sb.classList.contains('pinned');
      sb.classList.toggle('pinned', willPin);
      pinBtn?.classList.toggle('active', willPin);
      pinBtn?.setAttribute('aria-pressed', willPin ? 'true' : 'false');
      localStorage.setItem(KEY, willPin ? '1' : '0');
    });

    // ไฮไลต์เมนูปัจจุบัน
    const path = location.pathname.replace(/\/+$/,'') || '/';
    document.querySelectorAll('.sb-item').forEach(a => {
      const href = (a.getAttribute('href')||'').replace(/\/+$/,'') || '/';
      if (href === '/' ? path === '/' : path.startsWith(href)) a.classList.add('active');
    });
  })();
  </script>
</body>
</html>
