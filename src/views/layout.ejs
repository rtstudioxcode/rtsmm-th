  <script>
  /* ==========================================================
    NOTIFY SYSTEM (Top-Left) + Back-Compat showMsg/alert
    - ใช้ notify.push({ variant, title, text, timeout })
    - ช็อตคัต: notify.info/success/warn/error(title, text)
    - แม็ป showMsg(opts) เดิม -> แจ้งเตือนแบบ Notify อัตโนมัติ
    - โหลดครั้งเดียวใน layout แล้วใช้ได้ทุกหน้า
    ========================================================== */
  (() => {
    // สร้าง <style> และ <div id="notify-root"> ให้อัตโนมัติ ถ้ายังไม่มี
    const STYLES = `
    .notify-root{
      position:fixed; inset:16px 16px auto auto;  /* top-right */
      z-index:2147483647; display:flex; flex-direction:column; gap:12px;
      pointer-events:none;
    }
    .notify{
      width:min(440px,92vw);
      background:#ffffff; color:#111827;
      border:1px solid #e5e7eb; border-radius:12px;
      box-shadow:0 10px 30px rgba(2,6,23,.12), 0 2px 8px rgba(2,6,23,.08);
      pointer-events:auto; overflow:hidden; opacity:1; transform:translateY(0);
      transition:opacity .18s ease, transform .18s ease;
      font-family: system-ui, -apple-system, "Segoe UI", Roboto, "Noto Sans Thai", "Prompt", Arial, sans-serif;
    }
    .notify.hide{ opacity:0; transform:translateY(-6px); }
    .notify__head{
      display:flex; align-items:center; gap:10px; padding:10px 12px 8px 12px;
    }
    .notify__icon{
      width:22px; height:22px; display:grid; place-items:center;
      background:#d1fae5; color:#059669; border-radius:999px; flex:0 0 22px;
    }
    .notify__title{
      font-weight:600; color:#111827; font-size:14px; line-height:1;
    }
    .notify__meta{
      margin-left:auto; color:#6b7280; font-size:12px;
      display:flex; align-items:center; gap:10px;
    }
    .notify__close{
      appearance:none; background:transparent; border:0; color:#9ca3af;
      cursor:pointer; font-size:16px; line-height:1; padding:2px; border-radius:6px;
    }
    .notify__close:hover{ color:#6b7280; background:#f3f4f6; }
    .notify__body{
      padding:10px 12px 12px 12px; color:#374151; font-size:13px;
      border-top:1px solid #f3f4f6;
    }
    /* variants: ปรับเฉพาะสีไอคอน (พื้น+ตัว) */
    .notify--success .notify__icon{ background:#d1fae5; color:#059669; }
    .notify--info    .notify__icon{ background:#e0e7ff; color:#4f46e5; }
    .notify--warn    .notify__icon{ background:#fef3c7; color:#d97706; }
    .notify--error   .notify__icon{ background:#fee2e2; color:#dc2626; }
    `;

    const ensureStyle = () => {
      if (!document.getElementById('notify-style')) {
        const s = document.createElement('style');
        s.id = 'notify-style'; s.textContent = STYLES; document.head.appendChild(s);
      }
    };
    const ensureRoot = () => {
      let root = document.getElementById('notify-root');
      if (!root) { root = document.createElement('div'); root.id = 'notify-root'; root.className='notify-root'; document.body.appendChild(root); }
      return root;
    };
    const html = (s) => { const t=document.createElement('template'); t.innerHTML=s.trim(); return t.content.firstElementChild; };
    const nowLabel = () => 'just now';

    function push({ variant='info', title='', text='', timeout=3500 } = {}) {
      ensureStyle();
      const root = ensureRoot();

      // ไอคอนติ๊กถูก (SVG) ให้เหมือนตัวอย่าง
      const iconSVG = `
        <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">
          <path d="M9.55 16.2 5.8 12.45a1 1 0 1 1 1.4-1.4l2.35 2.34 5.24-5.24a1 1 0 1 1 1.42 1.42l-5.95 5.95a1 1 0 0 1-1.41 0Z"/>
        </svg>`;

      const el = html(`
        <div class="notify notify--${variant}" role="status" aria-live="polite">
          <div class="notify__head">
            <span class="notify__icon">${iconSVG}</span>
            <span class="notify__title">${title}</span>
            <div class="notify__meta">
              <span class="notify__time">${nowLabel()}</span>
              <button class="notify__close" aria-label="close">×</button>
            </div>
          </div>
          ${text ? `<div class="notify__body">${text}</div>` : ``}
        </div>
      `);

      const close = () => { el.classList.add('hide'); setTimeout(() => el.remove(), 180); };
      el.querySelector('.notify__close')?.addEventListener('click', close);

      // แทรกบนสุด (ล่าสุดอยู่บน)
      root.prepend(el);
      if (timeout > 0) setTimeout(close, timeout);
      return close;
    }

    // Public API
    window.notify = {
      push,
      success: (t,d) => push({ variant:'success', title:t, text:d }),
      info:    (t,d) => push({ variant:'info',    title:t, text:d }),
      warn:    (t,d) => push({ variant:'warn',    title:t, text:d }),
      error:   (t,d) => push({ variant:'error',   title:t, text:d }),
    };

    // Back-compat: showMsg(opts) -> notify
    window.showMsg = (opts={}) => {
      const { variant='info', title='', text='', timeout } = opts;
      return push({ variant, title, text, timeout });
    };

    // alert ให้เป็นการ์ด Notify
    window.alert = (msg) => push({ variant:'info', title:'แจ้งเตือน', text:String(msg ?? '') });
    // เก็บ confirm เดิมไว้ใช้ (ถ้าต้องยืนยันจริง ๆ)
    window.originalConfirm = window.confirm;
  })();
  </script>

  <script>
  /* ==========================================================
    RESET PASSWORD MODAL (คงไว้ เพราะเป็นฟอร์มโต้ตอบจริง)
    ========================================================== */
  (() => {
    const $ = (s,p=document)=>p.querySelector(s);
    const modal = $('#resetPwModal');
    if (!modal) return;

    const open  = () => { if (modal.hidden) { modal.hidden = false; document.body.classList.add('blurred'); } };
    const close = () => { if (!modal.hidden) { modal.hidden = true;  document.body.classList.remove('blurred'); } };

    if (window.__rp?.allowed === true) open();

    $('#resetCancel')?.addEventListener('click', async () => {
      close();
      try { await fetch('/password/reset/cancel', { method:'POST' }); } catch {}
    });

    $('#resetSubmit')?.addEventListener('click', async () => {
      const p1 = ($('#newPw')?.value || '').trim();
      const p2 = ($('#newPw2')?.value || '').trim();

      if (p1.length < 6) return notify.warn('รหัสผ่านสั้นเกินไป','รหัสผ่านต้องมีอย่างน้อย 6 ตัวอักษร');
      if (p1 !== p2)     return notify.warn('รหัสผ่านไม่ตรงกัน','กรุณาพิมพ์ใหม่อีกครั้ง');

      try {
        const r = await fetch('/password/reset', {
          method: 'POST',
          headers: { 'Content-Type':'application/json' },
          body: JSON.stringify({ newPassword: p1 })
        });
        const j = await r.json();
        if (!j.ok) throw new Error(j.error || 'รีเซ็ตไม่สำเร็จ');

        notify.success('รีเซ็ตรหัสผ่านแล้ว', 'กำลังเข้าสู่ระบบ...');
        setTimeout(() => { location.href = '/'; }, 1100);
      } catch (e) {
        notify.error('รีเซ็ตไม่สำเร็จ', String(e.message||e));
      }
    });

    modal.querySelector('.modal__backdrop')?.addEventListener('click', async () => {
      close();
      try { await fetch('/password/reset/cancel', { method:'POST' }); } catch {}
    });
  })();
  </script>

  <script>
  /* ==========================================================
    FLASH MESSAGE จาก server (res.locals.flash) -> Notify
    ========================================================== */
  (() => {
    window.__flash = <%- JSON.stringify(flash || null) %>;
    document.addEventListener('DOMContentLoaded', () => {
      if (window.__flash) {
        // รองรับรูปแบบเดิม { variant, title, text, timeout }
        const f = window.__flash;
        notify.push({ variant: f.variant || 'info', title: f.title || '', text: f.text || '', timeout: f.timeout ?? 3500 });
        window.__flash = null;
      }
    });
  })();
  </script>

  <script>
  /* ==========================================================
    SIDEBAR / THEME (คงลอจิกเดิม)
    ========================================================== */
  (() => {
    const sb = document.getElementById('sb');
    const sbBtns = document.querySelectorAll('[id=sbToggle]');
    const sbBrand = document.querySelector('.sb-brand');

    function toggleSidebar() {
      const willOpen = !sb.classList.contains('open');
      sb.classList.toggle('open', willOpen);
      document.body.classList.toggle('sb-open', willOpen);

      if (willOpen) {
        sbBrand?.classList.remove('logo-swap');
        requestAnimationFrame(() => {
          setTimeout(() => sbBrand?.classList.add('logo-swap'), 120);
        });
      } else {
        sbBrand?.classList.remove('logo-swap');
      }
    }

    sbBtns.forEach(btn => btn.addEventListener('click', toggleSidebar));

    document.addEventListener('click', (e) => {
      if (!sb?.classList.contains('open')) return;
      const inside = e.target.closest('#sb');
      const toggle = e.target.closest('[id=sbToggle]');
      if (!inside && !toggle) {
        sb.classList.remove('open');
        document.body.classList.remove('sb-open');
        sbBrand?.classList.remove('logo-swap');
      }
    });

    const themeBtns = document.querySelectorAll('[id=themeToggle]');
    const renderThemeIcon = () => {
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      themeBtns.forEach(b => b.textContent = isDark ? '🌞' : '🌗');
    };
    renderThemeIcon();
    themeBtns.forEach(b => b.addEventListener('click', () => {
      window.toggleTheme?.();
      renderThemeIcon();
    }));
    window.addEventListener?.('themechange', renderThemeIcon);

    const pinBtn = document.getElementById('sbPin');
    const KEY = 'sidebarPinned';
    const pinned = localStorage.getItem(KEY) === '1';
    if (pinned) { sb?.classList.add('pinned'); pinBtn?.classList.add('active'); pinBtn?.setAttribute('aria-pressed','true'); }
    pinBtn?.addEventListener('click', () => {
      const willPin = !sb.classList.contains('pinned');
      sb.classList.toggle('pinned', willPin);
      pinBtn?.classList.toggle('active', willPin);
      pinBtn?.setAttribute('aria-pressed', willPin ? 'true' : 'false');
      localStorage.setItem(KEY, willPin ? '1' : '0');
    });

    const path = location.pathname.replace(/\/+$/,'') || '/';
    document.querySelectorAll('.sb-item').forEach(a => {
      const href = (a.getAttribute('href')||'').replace(/\/+$/,'') || '/';
      if (href === '/' ? path === '/' : path.startsWith(href)) a.classList.add('active');
    });
  })();
  </script>
