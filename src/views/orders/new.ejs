/* --------- Utils --------- */
function oid(x){
  if (!x) return '';
  if (typeof x === 'string') return x;
  if (typeof x === 'object'){
    if (x.$oid) return String(x.$oid);
    if (x._id)  return oid(x._id);
  }
  return String(x);
}
function groupSubId(g){ return oid(g?.subcategory); }

/* --------- นิยามชิปภาษาไทย + คีย์เวิร์ด --------- */
const CHIP_DEFS = [
  { id:"",               label:"ทั้งหมด",              kw:[] },
  { id:"views",          label:"วิว",                  kw:["view","views","watch","play","ชม","วิว"] },
  { id:"likes",          label:"ไลก์",                 kw:["like","likes","heart","react","reactions","ถูกใจ","ไลก์"] },
  { id:"members",        label:"สมาชิก/ผู้ติดตาม",     kw:["follow","follower","followers","subscriber","subscribers","subs","ติดตาม","ผู้ติดตาม","สมาชิก","members"] },
  { id:"comments",       label:"คอมเมนต์",            kw:["comment","comments","คอมเมน"] },
  { id:"shares",         label:"แชร์",                 kw:["share","shares","รีโพสต์","repost","retweet","แชร์"] },
  { id:"traffic",        label:"คลิก/ทราฟฟิก",        kw:["link click","click","traffic","คลิก","ทราฟฟิก"] },
  { id:"shorts_reels",   label:"Shorts/Reels/Live",    kw:["short","shorts","reel","reels","live","สตรีม","ไลฟ์"] },
  { id:"general",        label:"ทั่วไป",               kw:["general","รวม","รวมบริการ","all-in-one"] },
];

function groupMatchesChip(group, chip){
  if (!chip || chip.id==="") return true;
  if (chip.realId){
    const gSub = groupSubId(group);
    if (gSub && gSub === chip.realId) return true;
  }
  const name = `${group?.name||''} ${group?.details?.name||''}`.toLowerCase();
  return chip.kw.some(k => name.includes(k.toLowerCase()));
}

