<script>
// ✅ local wrapper: ใช้ชื่อ notify ในไฟล์นี้โดยไม่พึ่ง window.notify
const notify = (opts = {}) => {
  const { variant='info', title='ข้อความ', text='' } = opts || {};
  // ถ้ามี window.notify ที่เป็นฟังก์ชัน ให้เรียกอันนั้น
  if (typeof window.notify === 'function') {
    return window.notify({ variant, title, text });
  }
  // ถ้ามี showMsg (ของ dialog) ก็ใช้ได้
  if (typeof window.showMsg === 'function') {
    return window.showMsg({ variant, title, text });
  }
  // fallback สุดท้าย
  alert((title ? title + '\n' : '') + (text || ''));
};
</script>

<script>
// === ไอคอนสถานะ (ใช้ซ้ำ) ===
const __STATUS_ICONS__ = {
  processing: '/static/assets/status/processing.png',
  inprogress: '/static/assets/status/inprogress.png',
  completed:  '/static/assets/status/completed.png',
  partial:    '/static/assets/status/partial.png',
  canceled:   '/static/assets/status/canceled.png',
  canceling:  '/static/assets/status/processing.png',
  default:    '/static/assets/status/processing.png'
};

function ensureStatusIcon(pill, status){
  if (!pill) return;
  const url = __STATUS_ICONS__[String(status||'').toLowerCase()] || __STATUS_ICONS__.default;

  // หา/สร้างตัวไอคอน
  let ico = pill.querySelector(':scope .label .st-ico, :scope > .st-ico');
  if (!ico) {
    ico = document.createElement('span');
    ico.className = 'st-ico';
    // ใส่หน้า label ถ้ามี ไม่งั้นใส่ต้น pill
    const lbl = pill.querySelector(':scope .label');
    (lbl || pill).prepend(ico);
  }
  ico.style.setProperty('--st-ico', `url("${url}")`);
  pill.classList.add('has-ico'); // กัน ::before ซ้อน
}
</script>

<script>
// ⬇️ helper: อ่านเหตุผลจาก response (รองรับ JSON หรือ text เผื่อ 502/HTML)
async function extractErrorInfo(res) {
  let bodyText = '';
  const ct = res.headers.get('content-type') || '';
  try {
    if (ct.includes('application/json')) {
      const j = await res.json();
      // คืนทั้ง object และข้อความสรุป
      const msg =
        j?.error ||
        j?.message ||
        (typeof j?.detail === 'string' ? j.detail :
          (j?.detail?.message || j?.detail?.error)) ||
        '';
      return { data:j, message: String(msg || '').trim() };
    }
    // ไม่ใช่ JSON -> เอา text
    bodyText = (await res.text() || '').trim();
  } catch {
    // ถ้า parse พัง ลองอ่านเป็น text อีกที
    try { bodyText = (await res.text() || '').trim(); } catch {}
  }
  return { data:null, message: bodyText };
}

// ⬇️ แปลงรหัสสถานะให้เป็นเหตุผลที่อ่านง่าย
function explainHttpStatus(status, fallbackMsg='') {
  const clean = (fallbackMsg || '').replace(/\s+/g,' ').trim();
  switch (status) {
    case 400: return clean || 'คำขอไม่ถูกต้อง (ข้อมูลไม่ครบ/รูปแบบไม่ถูกต้อง)';
    case 401: return clean || 'ยังไม่ได้เข้าสู่ระบบ หรือสิทธิ์ไม่พอ';
    case 402: return clean || 'เครดิต/ยอดเงินไม่เพียงพอ';
    case 403: return clean || 'ไม่มีสิทธิ์ทำรายการนี้';
    case 404: return clean || 'ไม่พบบริการหรือเส้นทาง /orders';
    case 409: return clean || 'รายการซ้ำ/ชนเงื่อนไขบางอย่าง';
    case 422: return clean || 'จำนวนไม่อยู่ในช่วงขั้นต่ำ-สูงสุด หรือข้อมูลไม่ผ่าน validation';
    case 429: return clean || 'ส่งคำขอบ่อยเกินไป (rate limit)';
    case 500: return clean || 'ระบบภายในขัดข้อง';
    case 502: return clean || 'Gateway รับคำตอบจากผู้ให้บริการไม่สำเร็จ (ปลายทางล่ม/timeout/format ผิด)';
    case 503: return clean || 'ผู้ให้บริการปิดปรับปรุง/โหลดสูง';
    case 504: return clean || 'ผู้ให้บริการตอบช้าเกินกำหนด (timeout)';
    default:  return clean || 'เกิดข้อผิดพลาดที่ไม่ทราบสาเหตุ';
  }
}
</script>

<script>
const $=(s,r=document)=>r.querySelector(s), $$=(s,r=document)=>Array.from(r.querySelectorAll(s));
const br = s=>String(s||'').replace(/\r?\n/g,'<br>');
const linkify = s=>String(s||'').replace(/https?:\/\/\S+/g,m=>`<a href="${m}" target="_blank" rel="noopener">${m}</a>`);
const fmt = n=>Number(n||0).toLocaleString(undefined,{maximumFractionDigits:4});
const debounce = (fn,ms=220)=>{ let t; return (...a)=>{ clearTimeout(t); t=setTimeout(()=>fn(...a),ms); }; };

let platforms=[], groups=[], children=[];
let subcats=[];
let currentPlatform=null, currentGroup=null, currentChild=null;
let currentChipId="";
let visibleChipList=[];
let rate=0, currency='THB';
let effectiveRate=null; // อัตราตามกฎ (ถ้า endpoint มี)
let rateSource='base';  // 'base' | 'effective'

/* ✅ flag สำหรับตรวจว่า service นี้เป็น comment/SEO หรือไม่ */
let isCommentService = false;
let isSeoService = false;

/* ✅ ช่วงขั้นต่ำ/สูงสุดของ service ปัจจุบัน (ไว้ใช้ validate ตอน submit) */
let currentMin = 1;
let currentMax = Infinity;

/* ✅ helper นับบรรทัดที่ไม่ว่าง */
function countNonEmptyLines(str) {
  return String(str || '')
    .split(/\r?\n/)
    .map(s => s.trim())
    .filter(Boolean).length;
}

/* ✅ sync จำนวนบรรทัด → quantity อัตโนมัติ */
function syncAutoQtyFromFields() {
  const qtyInput = document.getElementById('qty');
  if (!qtyInput) return;
  if (!(isCommentService || isSeoService)) return;

  const commentsVal = document.getElementById('comments')?.value || '';
  const keywordsVal = document.getElementById('keywords')?.value || '';

  let total = 0;
  if (isCommentService) total += countNonEmptyLines(commentsVal);
  if (isSeoService)    total += countNonEmptyLines(keywordsVal);

  qtyInput.value = total > 0 ? String(total) : '';
  updateEstimate();
}

document.addEventListener('click',e=>{
