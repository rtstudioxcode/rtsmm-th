function pickGroupIcon(group) {
  const text = String(group?.name || '').toLowerCase();

  for (const def of GROUP_ICON_MAP) {
    const hit = def.match.some(k => text.includes(k.toLowerCase()));
    if (hit) return def.icon;
  }
  return null; // ไม่มีไอคอนตรงคำ -> ไม่ต้องโชว์รูป
}

function getPlatformNameById(id) {
  const p = platforms.find(p => String(p._id) === String(id));
  return p ? (p.name || '') : '';
}

// เลือกแพลตฟอร์มจาก id + ทำ tile ให้ active
async function ensurePlatformSelected(platformId) {
  platformId = String(platformId);
  if (String(currentPlatform) !== platformId) {
    // เปลี่ยน active tile
    $$('#platformGrid .p-tile').forEach(el => {
      el.classList.toggle('active', el.dataset.id === platformId);
    });
    await choosePlatform(platformId);
  }
}

/* ---------- Boot ---------- */
async function init(){
  await loadPlatforms();
  await tryAutoSelectFromURL();

  // ค้นหาโดยเลขบริการ: ลองในแพลตฟอร์มปัจจุบันก่อน แล้วค่อยไล่ทุกแพลตฟอร์ม
  async function autoPickByServiceId(pid){
    const pidStr = String(pid);

    const pickInsideCurrent = () => {
      const grp = (groups || []).find(g =>
        Array.isArray(g?.details?.services) &&
        g.details.services.some(s => String(s.id) === pidStr)
      );
      if (!grp) return false;

      chooseGroup(grp);
      const svc = grp.details.services.find(s => String(s.id) === pidStr);
      if (svc) {
        chooseChild(svc);
        document.getElementById('detailBox').style.display = '';
        document.getElementById('qty')?.focus();
      }
      return true;
    };

    // 1) หาในแพลตฟอร์มปัจจุบันก่อน
    if (pickInsideCurrent()) return true;

    // 2) ไม่เจอ -> วนทุกแพลตฟอร์ม
    for (const p of platforms){
      if (String(p._id) === String(currentPlatform)) continue;
      await choosePlatform(p._id);
      if (pickInsideCurrent()){
        // ทำ tile ให้ active ให้ตรงแพลตฟอร์มที่เจอ
        $$('#platformGrid .p-tile').forEach(el=>{
          el.classList.toggle('active', el.dataset.id === String(p._id));
        });
        return true;
      }
    }
    // ไม่พบ -> ไม่ทำอะไร (ตามที่ต้องการ)
    return false;
  }

  const onGlobalSearch = debounce(async () => {
    const v = ($('#searchAll').value || '').trim();

    // ✅ โหลด groups ของทุกแพลตฟอร์มเข้า groupsByPlatform ให้ครบก่อน
    await ensureAllGroupsLoaded();

    // กรองรายชื่อ service ในเมนูเดิม (ในกล่อง select ด้านล่าง)
    filterChildrenFromGlobal();

    // แสดง dropdown ผลลัพธ์ (แพลตฟอร์ม / หมวดหมู่ / บริการ) จากทุก platform
    await runGlobalSearchDropdown(v);

    // ถ้าเป็นเลขล้วน และไม่คลิกอะไรเลย -> auto jump ตาม ID เหมือนเดิม
    if (/^\d+$/.test(v)) {
      await autoPickByServiceId(v);
    }
  }, 160);

  $('#searchAll').addEventListener('input', onGlobalSearch);

  // ปิด dropdown ด้วย ESC
  $('#searchAll').addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      const box = document.getElementById('searchSuggest');
      if (box) {
        box.hidden = true;
      }
    }
  });
}

/* ---------- auto-pick service from ?type=service&id=xxx ---------- */
async function tryAutoSelectFromURL(){
  const sp = new URLSearchParams(location.search);
  const type = sp.get('type');
  const pid  = sp.get('id');
  if (type !== 'service' || !pid) return;

  const pickInsideCurrent = ()=>{
    const grp = (groups||[]).find(g =>
      Array.isArray(g?.details?.services) &&
      g.details.services.some(s => String(s.id) === String(pid))
    );
    if (!grp) return false;
    chooseGroup(grp);
    const svc = grp.details.services.find(s => String(s.id) === String(pid));
    if (svc) chooseChild(svc);
    document.getElementById('detailBox').style.display = '';
    document.getElementById('qty')?.focus();
    return true;
  };

  if (pickInsideCurrent()) return;

  for (const p of platforms){
    await choosePlatform(p._id);
    if (pickInsideCurrent()){
      $$('#platformGrid .p-tile').forEach(el=>{
        el.classList.toggle('active', el.dataset.id === String(p._id));
      });
      break;
    }
  }
}

/* ---------- ชิปคลิก ---------- */
function onChip(e) {
  const b = e.target.closest('.chip');
  if (!b) return;

  const chipId = b.dataset.chip ?? b.dataset.sub ?? '';

  const chip = visibleChipList.find(c => c.id === chipId);
  if (chip && chip.id !== "" && chip.count === 0) return;

  currentChipId = chipId;

  document.querySelectorAll('#chipBar .chip')
    .forEach(x => x.classList.remove('active'));

  b.classList.add('active');

  renderGroupList(true);
}

/* ---------- โหลดแพลตฟอร์ม ---------- */
async function loadPlatforms(){
  const res = await fetch('/api/platforms');
  platforms = await res.json();

  const grid = $('#platformGrid');
  grid.innerHTML = platforms.map(p=>{
    const img = pickIconUrl(p.name||'');
    return `
      <div class="p-tile" data-id="${p._id}" data-name="${p.name||''}">
        <div class="p-icon"><img loading="lazy" src="${img}" alt="${p.name||''}"></div>
        <div class="p-name">${p.name||''}</div>
      </div>`;
  }).join('');

  grid.addEventListener('click', async e=>{
    const t = e.target.closest('.p-tile'); if(!t) return;
    $$('#platformGrid .p-tile').forEach(x=>x.classList.remove('active'));
    t.classList.add('active');
    await choosePlatform(t.dataset.id);
  });

  if (platforms.length){
    const first = $('#platformGrid .p-tile');
    first?.classList.add('active');
    choosePlatform(platforms[0]._id);
  }
}

/* ---------- เมื่อเลือกแพลตฟอร์ม ---------- */
async function choosePlatform(catId){
  currentPlatform = catId;
  currentChipId   = "";

  try{
    const subRes = await fetch(`/api/subcategories?cat=${catId}`);
    subcats = await subRes.json();
  }catch(e){ subcats = []; }

  const res = await fetch(`/api/service-groups?cat=${catId}`);
  groups = await res.json();

  groupsByPlatform.set(String(catId), groups);

  const chipsWithCount = CHIP_DEFS.map(ch=>{
    const sub = subcats.find(s => (s.name||'').toLowerCase() === ch.label.toLowerCase());
    const realId = sub ? oid(sub._id) : null;
    const chipObj = { ...ch, realId, count:0 };
    chipObj.count = groups.filter(g => groupMatchesChip(g, chipObj)).length;
    return chipObj;
  });

  visibleChipList = chipsWithCount.filter(ch => ch.id==="" || ch.count>0);
  renderChipsTH();
  renderGroupList(true);
}

/* ---------- วาดชิปภาษาไทย (เฉพาะที่มีจริง) ---------- */
function renderChipsTH() {
  const bar = document.getElementById('chipBar');
  bar.innerHTML = visibleChipList.map(ch => `
    <button type="button"
            class="chip ${currentChipId === ch.id ? 'active' : ''} 
                          ${ch.id !== '' && ch.count === 0 ? 'disabled' : ''}"
            data-chip="${ch.id}">
      ${ch.label}${ch.id === '' ? '' : ` (${ch.count})`}
    </button>
  `).join('');
}

/* ---------- กลุ่มบริการ (ซ้าย) กรองด้วยชิป + คำค้น ---------- */
function renderGroupList(reset=false){
  const q = ($('#groupSearch').value||'').toLowerCase().trim();
  const chip = visibleChipList.find(c => c.id===currentChipId) || visibleChipList[0];

  const filtered = groups.filter(g =>
    groupMatchesChip(g, chip) &&
    (String(g.name||'').toLowerCase().includes(q))
  );

  $('#groupList').innerHTML = filtered.length
    ? filtered.map(x => {
        const iconUrl = pickGroupIcon(x);
        return `
          <div class="opt" data-id="${x._id}">
            ${iconUrl ? `<img class="grp-icon" src="${iconUrl}" alt="" loading="lazy">` : ''}
            <span class="grp-name">${x.name || '-'}</span>
          </div>
        `;
      }).join('')
    : `<div class="empty muted">ไม่พบกลุ่มบริการที่ตรงกับคำค้น</div>`;

  $('#groupList').onclick = e=>{
    const el=e.target.closest('.opt'); if(!el) return;
    $('#groupSel').classList.remove('open');
    $('#groupBtn').setAttribute('aria-expanded','false');
    const grp = filtered.find(v=>String(v._id)===el.dataset.id);
    chooseGroup(grp);
  };

  if(reset){
    if(filtered.length) chooseGroup(filtered[0]); else clearAll();
  }
}

/* ---------- เลือกกลุ่ม → บริการย่อย ---------- */
function chooseGroup(grp){
  currentGroup = grp;
  children = Array.isArray(grp?.details?.services) ? grp.details.services : [];

  const name = grp?.name || '—';
  const iconUrl = pickGroupIcon(grp);   // ⬅ เปลี่ยนจาก name → grp

  const span = document.getElementById('groupText');
  if (iconUrl) {
    span.innerHTML = `<img class="grp-icon" src="${iconUrl}" alt=""> <span>${name}</span>`;
  } else {
    span.textContent = name;
  }

  $('#groupId').value = grp?._id || '';
  renderChildList();
  if (children.length) chooseChild(children[0]); else resetDetail();
}
/* ---------- รายการบริการย่อย ---------- */
function renderChildList(){
  const q = ($('#childSearch').value || '').toLowerCase().trim();
  const globalQ = ($('#searchAll').value || '').toLowerCase().trim();

  const list = children.filter(c=>{
    const s = `${c.id} ${c.name}`.toLowerCase();
    return (!q || s.includes(q)) && (!globalQ || s.includes(globalQ));
  });

  const gid = $('#groupId').value;

  // ใส่ base rate ไว้ก่อน
  $('#childList').innerHTML = list.length ? list.map(c=>`
    <div class="opt" data-id="${c.id}">
      <div class="row">
        <div>
          <span class="id">ID: ${c.id}</span>
          <span class="name"> — ${c.name||''}</span>
        </div>
        <div class="rate" data-rate-for="${c.id}">
          ${fmt(c.rate||0)} ${c.currency||'THB'} / 1,000
        </div>
      </div>
    </div>`).join('') : `<div class="empty muted">ไม่พบบริการที่ตรงกับคำค้น</div>`;

  // แล้วค่อยอัปเดตเป็น effective rate ทีละตัว (async + cache)
  list.forEach(async (c) => {
    const er = await fetchEffectiveRateIfAvailable(gid, String(c.id), Number(c.rate||0));
    if (er !== null) {
      const el = document.querySelector(`.rate[data-rate-for="${CSS.escape(String(c.id))}"]`);
      if (el) el.textContent = `${fmt(er)} ${c.currency||'THB'} / 1,000`;
    }
  });

  $('#childList').onclick = e=>{
    const el=e.target.closest('.opt'); if(!el) return;
    $('#childSel').classList.remove('open');
    $('#childBtn').setAttribute('aria-expanded','false');
    const svc = children.find(v=>String(v.id)===el.dataset.id);
    chooseChild(svc);
  };
}

// ✅ โหลด service-groups ของทุกแพลตฟอร์มเข้า groupsByPlatform ให้ครบก่อนค้นหา
async function ensureAllGroupsLoaded() {
  if (allGroupsLoaded) return;
  if (!Array.isArray(platforms) || !platforms.length) return;

  const jobs = platforms.map(async (p) => {
    const key = String(p._id);
    if (groupsByPlatform.has(key)) return; // โหลดแล้วข้าม

    try {
      const res = await fetch(`/api/service-groups?cat=${key}`);
      const data = await res.json();
      if (Array.isArray(data)) {
        groupsByPlatform.set(key, data);
      } else {
        groupsByPlatform.set(key, []);
      }
    } catch (e) {
      console.error('load groups for', key, 'error', e);
      groupsByPlatform.set(key, []);
    }
  });

  await Promise.all(jobs);
  allGroupsLoaded = true;
}

function renderSearchChunk(reset = false) {
  const box = document.getElementById('searchSuggest');
  if (!box) return;
  if (reset) {
    box.innerHTML = '';
    searchRendered = 0;
  }

  // ถ้าแสดงครบแล้วก็ไม่ต้องทำอะไร
  if (searchRendered >= searchResults.length) return;

  const slice = searchResults.slice(
    searchRendered,
    searchRendered + SEARCH_CHUNK_SIZE
  );

  const html = slice.map(r => {
    let kindClass = 'sg-kind-s';
    let kindLabel = 'บริการ';
    let iconHtml = '';

    if (r.kind === 'platform') {
      kindClass = 'sg-kind-p';
      kindLabel = 'แพลตฟอร์ม';
    } else if (r.kind === 'group') {
      kindClass = 'sg-kind-g';
      kindLabel = 'หมวดหมู่';

      // icon กลุ่ม (เหมือนเดิม)
      const grpArr = groupsByPlatform.get(r.platformId) || [];
      const gObj = grpArr.find(g => String(g._id) === String(r.groupId));
      const iconUrl = gObj ? pickGroupIcon(gObj) : null;
      if (iconUrl) {
        iconHtml = `<img class="sg-icon" src="${iconUrl}" alt="">`;
      }
    }

    const labelSafe = r.label.replace(/"/g, '&quot;');

    return `
      <button type="button"
              class="sg-opt"
              data-kind="${r.kind}"
              data-platform="${r.platformId || ''}"
              data-group="${r.groupId || ''}"
              data-service="${r.serviceId || ''}">
        ${iconHtml}
        <span class="sg-kind ${kindClass}">${kindLabel}</span>
        <span class="sg-main" title="${labelSafe}">${r.label}</span>
        ${r.sub ? `<span class="sg-sub">${r.sub}</span>` : ''}
      </button>
    `;
  }).join('');

  box.insertAdjacentHTML('beforeend', html);
  searchRendered += slice.length;
}

async function runGlobalSearchDropdown(query) {
  const box = document.getElementById('searchSuggest');
  if (!box) return;

  const q = String(query || '').trim().toLowerCase();
  if (q.length < 2) {
    box.hidden = true;
    box.innerHTML = '';
    searchResults = [];
    searchRendered = 0;
    return;
  }

  const results = [];

  // 1) แพลตฟอร์ม
  for (const p of platforms) {
    if ((p.name || '').toLowerCase().includes(q)) {
      results.push({
        kind: 'platform',
        platformId: String(p._id),
        label: p.name || '',
      });
    }
  }

  // 2) หมวดหมู่/บริการทุกแพลตฟอร์ม (ไม่จำกัดแค่ current)
  groupsByPlatform.forEach((grpArr, platId) => {
    const platName = getPlatformNameById(platId);

    grpArr.forEach(g => {
      const gName = g?.name || '';
      const gNameLower = gName.toLowerCase();

      if (gNameLower.includes(q)) {
        results.push({
          kind: 'group',
          platformId: String(platId),
          groupId: String(g._id),
          label: gName,
          sub: platName || ''
        });
      }

      const svcList = Array.isArray(g?.details?.services) ? g.details.services : [];
      svcList.forEach(svc => {
        const text = `${svc.id} ${svc.name || ''}`.toLowerCase();
        if (text.includes(q)) {
          results.push({
            kind: 'service',
            platformId: String(platId),
            groupId: String(g._id),
            serviceId: String(svc.id),
            label: `ID: ${svc.id} — ${svc.name || ''}`,
            sub: gName || platName || ''
          });
        }
      });
    });
  });

  if (!results.length) {
    box.innerHTML = `<div class="sg-empty muted">ไม่พบผลลัพธ์ที่ตรงกับคำค้น</div>`;
    box.hidden = false;
    searchResults = [];
    searchRendered = 0;
    return;
  }

  // ✅ เก็บผลไว้ global แล้วให้ render ทีละก้อน
  searchResults = results;
  box.hidden = false;
  renderSearchChunk(true);
}

function filterChildrenFromGlobal(){ renderChildList(); }
let effectiveRateCache = new Map();

document.addEventListener('click', async (e) => {
  const box = document.getElementById('searchSuggest');
  if (!box) return;

  const btn = e.target.closest('.sg-opt');
  if (btn && box.contains(btn)) {
    const kind = btn.dataset.kind;
    const platformId = btn.dataset.platform;
    const groupId = btn.dataset.group;
    const serviceId = btn.dataset.service;

    // ซ่อน dropdown ก่อน
    box.hidden = true;

    if (kind === 'platform') {
      await ensurePlatformSelected(platformId);
      return;
    }

    if (kind === 'group') {
      await ensurePlatformSelected(platformId);
      const grpArr = groupsByPlatform.get(String(platformId)) || groups;
      const gObj = grpArr.find(g => String(g._id) === String(groupId));
      if (gObj) chooseGroup(gObj);
      return;
    }

    if (kind === 'service') {
      // ใช้ตัวช่วยเดิมที่มี already: autoPickByServiceId
      if (serviceId) {
        // จะวิ่งหา service ทุกแพลตฟอร์มให้เอง
        await autoPickByServiceId(serviceId);
      }
      return;
    }
  } else {
    // คลิกรอบนอก -> ปิด
    if (!box.contains(e.target) && e.target.id !== 'searchAll') {
      box.hidden = true;
    }
  }
});

/* ---------- ดึง effective rate (ถ้า endpoint มี) ---------- */
async function fetchEffectiveRateIfAvailable(groupId, childId, baseRate){
  const key = `${groupId}:${childId}`;
  if (effectiveRateCache.has(key)) return effectiveRateCache.get(key);

  try{
    const url = `/api/pricing/effective-rate?serviceId=${encodeURIComponent(groupId)}&childId=${encodeURIComponent(childId)}`;
    const r = await fetch(url);
    if (!r.ok) { effectiveRateCache.set(key, null); return null; }
    const data = await r.json();
    const val = Number(data?.rate ?? data?.effectiveRate);
    if (Number.isFinite(val) && val >= 0) {
      effectiveRateCache.set(key, val);
      return val;
    }
  }catch{}
  effectiveRateCache.set(key, null);
  return null; // ไม่มี/ใช้ไม่ได้ -> fallback base
}

/* ---------- รายละเอียด/ฟอร์ม ---------- */
async function chooseChild(svc){
  currentChild = svc;

  $('#childText').textContent = svc?.name || '—';
  $('#providerServiceId').value = svc?.id || '';

  // base rate
  rate     = Number(svc?.rate || 0);
  currency = svc?.currency || 'THB';
  effectiveRate = null;
  rateSource = 'base';
  $('#rateNote').style.display = 'none';

  const gid = $('#groupId').value;
  const cid = String(svc?.id || '');
  const er = await fetchEffectiveRateIfAvailable(gid, cid, rate);
  if (er !== null) {
    effectiveRate = er;
    rateSource = 'effective';
    $('#rateNote').style.display = '';
    $('#rateNote').textContent = `อัตรานี้เป็นราคาหลังปรับตามกฎของบัญชีคุณ (ต่อ 1,000 หน่วย)`;
  }

  const displayRate = rateSource==='effective' ? effectiveRate : rate;

  const bits = [];
  bits.push(`อัตรา: ${fmt(displayRate)} ${currency} / 1,000`);
  bits.push(`ช่วง: ${svc.min||0}-${svc.max||0}${svc.step? ' | ขั้นละ '+svc.step: ''}`);
  if (svc.average_delivery) bits.push(`เฉลี่ย: ${svc.average_delivery}`);
  if (svc.dripfeed) bits.push('Dripfeed');
  if (svc.refill)   bits.push('Refill');
  if (svc.cancel)   bits.push('ยกเลิกได้');

  $('#hdr').innerHTML  = svc?.name || '';
  $('#meta').innerHTML = bits.join(' | ');
  $('#desc').innerHTML =
    (svc?.description ? linkify(br(svc.description)) :
    (currentGroup?.description ? linkify(br(currentGroup.description)) : '—'));

  const q    = $('#qty');
  const min  = Math.max(1, Number(svc.min || 1));
  const max  = Math.max(min, Number(svc.max || min));
  const step = Number(svc.step || 1);

  currentMin = min;
  currentMax = max;

  q.min  = String(min);
  q.max  = String(max);
  q.step = 'any';
  q.value = '';
  q.placeholder = `เช่น ${min.toLocaleString()} – ${max.toLocaleString()}`;

  const minVal = $('#minVal'), maxVal = $('#maxVal');
  if (minVal) minVal.textContent = min.toLocaleString();
  if (maxVal) maxVal.textContent = max.toLocaleString();

  q.removeEventListener('input', updateEstimate);
  q.addEventListener('input', updateEstimate);

  $('#drip').disabled = !svc.dripfeed;
  $('#drip').checked  = !!svc.dripfeed;

  // 👇 ตรวจชื่อ service เพื่อตัดสินว่าเป็น comments/SEO ไหม
  const svcName = (svc?.name || "").toLowerCase();

  isCommentService =
    svcName.includes("custom comment") ||
    svcName.includes("custom comments") ||
    svcName.includes("comment package") ||
    svcName.includes("comment reply") ||
    (svc?.type && String(svc.type).toLowerCase().includes("comment"));

  isSeoService =
    svcName.includes("seo") ||
    svcName.includes("keyword") ||
    (svc?.type && String(svc.type).toLowerCase().includes("seo"));

  const commentBoxEl = document.getElementById("commentBox");
  const keywordBoxEl = document.getElementById("keywordBox");
  const qtyLabelWrap = q.closest('.with-hint');

  if (commentBoxEl) commentBoxEl.style.display = isCommentService ? "" : "none";
  if (keywordBoxEl) keywordBoxEl.style.display = isSeoService ? "" : "none";

  // 🔒 ถ้าเป็น service ที่ต้องกรอกข้อความ → lock ช่องปริมาณ + ให้ระบบคำนวณเอง
  if (isCommentService || isSeoService) {
    q.readOnly = true;
    q.classList.add('auto-qty');
    if (qtyLabelWrap) qtyLabelWrap.classList.add('auto-qty');
    syncAutoQtyFromFields();       // ดึงจาก textarea ครั้งแรกเลย
  } else {
    q.readOnly = false;
    q.classList.remove('auto-qty');
    if (qtyLabelWrap) qtyLabelWrap.classList.remove('auto-qty');
  }

  updateEstimate();
  $('#detailBox').style.display = '';
}
function resetDetail(){ $('#childText').textContent='—'; $('#detailBox').style.display='none'; }
function clearAll(){
  $('#groupText').textContent = '—';
  $('#childText').textContent = '—';
  $('#groupList').innerHTML = '';
  $('#childList').innerHTML = '';
  resetDetail();
}
function calcUnitRate(){
  return rateSource==='effective' && Number.isFinite(effectiveRate) ? effectiveRate : rate;
}
function updateEstimate(){
  const n = Number($('#qty').value || 0);
  const unit = calcUnitRate();
  const price = Math.max(0, (n/1000) * unit);
  const el = document.getElementById('est');
  el.value = `${fmt(price)} ${currency}`;
}

/* ---------- ส่งคำสั่งซื้อ ---------- */
async function submitOrder(ev){
  ev.preventDefault();

  // ก่อนส่ง ให้ sync จำนวนจาก textarea → qty อีกรอบ
  syncAutoQtyFromFields();

  const groupId = $('#groupId').value?.trim();
  const childId = $('#providerServiceId').value?.trim();
  const link    = $('#link').value?.trim();
  const qty     = Number($('#qty').value || 0);

  const commentsVal = document.getElementById('comments')?.value.trim() || '';
  const keywordsVal = document.getElementById('keywords')?.value.trim() || '';

  const errs = [];
  if (!groupId) errs.push('ไม่พบรหัสกลุ่มบริการ (groupId)');
  if (!childId) errs.push('ยังไม่ได้เลือก “บริการย่อย”');
  if (!link)    errs.push('กรุณากรอกลิงก์/เป้าหมาย');
  if (!(qty > 0)) errs.push('จำนวนต้องมากกว่า 0');

  // ✅ บังคับให้อยู่ในช่วงขั้นต่ำ-สูงสุดของบริการ
  if (qty > 0 && (qty < currentMin || qty > currentMax)) {
    errs.push(`จำนวนต้องอยู่ในช่วงขั้นต่ำ ${currentMin.toLocaleString()} ถึงสูงสุด ${currentMax.toLocaleString()}`);
  }

  if (isCommentService && !commentsVal) {
    errs.push('บริการนี้ต้องกรอกคอมเมนต์ (1 บรรทัด = 1 คอมเมนต์)');
  }
  if (isSeoService && !keywordsVal) {
    errs.push('บริการ SEO ต้องใส่ Keyword');
  }

  if (errs.length){
    notify({
      variant: 'warn',
      title: 'ข้อมูลไม่ครบถ้วน',
      text: errs.join(' • ')
    });
    return false;
  }

  const payload = {
    groupId,
    providerServiceId: childId,
    link,
    quantity: qty,
    dripfeed: $('#drip').checked,
    follow_system: $('#sys').checked
  };

  if (isCommentService) payload.comments = commentsVal;
  if (isSeoService)    payload.keywords = keywordsVal;

  const submitBtn = $('#orderForm button[type="submit"]');
  submitBtn && (submitBtn.disabled = true);

  try {
    const res  = await fetch('/orders', {
      method: 'POST',
      headers: { 'Content-Type':'application/json', 'Accept': 'application/json' },
      body: JSON.stringify(payload)
    });

    const ok = res.ok;
    let data = {};
    try { data = await res.json(); } catch {}

    if (!ok || !data?.ok) {
      const titleErr =
        (typeof data?.error === 'string' && data.error.trim()) ||
        `สั่งซื้อไม่สำเร็จ (${res.status})`;

      const reason =
        (typeof data?.detail === 'string' && data.detail) ||
        (typeof data?.detail?.error === 'string' && data.detail.error) ||
        (typeof data?.message === 'string' && data.message) ||
        explainHttpStatus(res.status, '');

      notify({
        variant: 'error',
        title: titleErr,
        text: `เหตุผล: ${reason}`
      });

      console.warn('ORDER ERROR => status:', res.status, 'reason:', titleErr, 'payload:', data);
      return false;
    }

    notify({
      variant: 'success',
      title: 'สั่งซื้อสำเร็จ',
      text: `สร้างคำสั่งซื้อแล้ว • Provider Order: ${data.providerOrderId || '-'}`
    });

    $('#qty').value  = '';
    $('#link').value = '';
    if (isCommentService) $('#comments').value = '';
    if (isSeoService)     $('#keywords').value = '';
    updateEstimate();
    return false;

  } catch (err) {
    notify({
      variant: 'error',
      title: 'เครือข่ายมีปัญหา',
      text: `ไม่สามารถติดต่อเซิร์ฟเวอร์ได้ (${err?.message || 'unknown'})`
    });
    console.error('network error:', err);
    return false;
  } finally {
    submitBtn && (submitBtn.disabled = false);
  }
}
</script>

<script>
// — เพิ่มตรงสคริปต์ของหน้าเดียวกับ loadLatestUpdates() —
const DIFF_TH = {
  new: 'เพิ่มใหม่',
  open: 'เปิดใช้งาน',
  close: 'ปิดการใช้งาน',
  removed: 'ลบออก',
  updated: 'อัปเดต',
  state: 'สถานะเริ่มต้น',
};
const STATUS_TH = {
  new: 'เพิ่มใหม่',
  open: 'เปิดใช้งาน',
  active: 'เปิดใช้งาน',
  close: 'ปิดการใช้งาน',
  closed: 'ปิดการใช้งาน',
  removed: 'ลบออก',
  delete: 'ลบออก',
  deleted: 'ลบออก',
};

function tDiff(s){ const k = String(s||'').toLowerCase(); return DIFF_TH[k] || s || '—'; }
function tStatus(s){ const k = String(s||'').toLowerCase(); return STATUS_TH[k] || s || '—'; }

// ===== ดึงอัปเดตของ "วันล่าสุด" ผ่าน API เดิมที่คุณมีอยู่แล้ว =====
// /api/changes?latest=1&target=service&limit=300
async function loadLatestUpdates(){
  const el = document.getElementById('updatesList');
  if (!el) return;
  try {
    const r = await fetch('/api/changes?latest=1&target=service&limit=300');
    const j = await r.json();
    if (!j.ok) { el.innerHTML = '<div class="muted">โหลดข้อมูลไม่สำเร็จ</div>'; return; }
    const items = Array.isArray(j.items) ? j.items : [];
    if (!items.length) { el.innerHTML = '<div class="muted">วันนี้ยังไม่มีอัปเดต</div>'; return; }

    el.innerHTML = '';
    items.forEach(x => {
      const d = new Date(x.ts);
      const hh = String(d.getHours()).padStart(2,'0');
      const mm = String(d.getMinutes()).padStart(2,'0');
      const icon = getGroupIconByName(x.serviceName);
      const row = document.createElement('div');
      row.className = 'update-item';
      row.innerHTML = `
        <div class="update-head">
          <span class="muted">${hh}:${mm}</span>
          <div class="update-badges">
            ${x.platform ? `<span class="badge">${escapeHtml(x.platform)}</span>` : ''}
            ${x.categoryName ? `<span class="badge">${escapeHtml(x.categoryName)}</span>` : ''}
            ${x.diff ? `<span class="badge">${escapeHtml(tDiff(x.diff))}</span>` : ''}
            ${(x.oldStatus || x.newStatus)
              ? `<span class="badge">${escapeHtml(tStatus(x.newStatus))}</span>`
              : ''
            }
          </div>
        </div>

        <div class="update-title">
          ${icon ? `<img class="up-icon" src="${icon}">` : ''}
          <b>${escapeHtml(x.serviceName || '—')}</b>
          <small class="muted">#${escapeHtml(x.providerServiceId||'')}</small>
        </div>
      `;
      el.appendChild(row);
    });
  } catch (e) {
    console.error(e);
    el.innerHTML = '<div class="muted">เครือข่ายมีปัญหา</div>';
  }
}

function escapeHtml(s){
  return String(s).replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
}

// ===== ปรับความสูงรวมของสองการ์ดขวาให้เท่ากับฟอร์มซ้าย =====
function syncRightRailHeights(){
  const left   = document.getElementById('detailBox');
  const rail   = document.querySelector('.right-rail');
  const updates= document.querySelector('.updates-card');
  const legend = document.querySelector('.emoji-legend');
  if (!left || !rail || !updates || !legend) return;

  const total = Math.round(left.offsetHeight);

  const GAP = 6; // ให้ตรงกับ .right-rail{ gap:6px }

  rail.style.height = total + 'px';

  const updatesH = Math.max(160, Math.round((total - GAP) * 0.47));
  const legendH  = Math.max(160, (total - GAP) - updatesH);

  updates.style.height = updatesH + 'px';
  legend .style.height = legendH  + 'px';
  updates.style.overflow = 'auto';
  legend .style.overflow = 'auto';
}

function initHeightSync(){
  syncRightRailHeights();
  window.addEventListener('resize', syncRightRailHeights);

  const ro = new ResizeObserver(syncRightRailHeights);
  const left = document.getElementById('detailBox');
  if (left) ro.observe(left);
}

// ===== เปิด/ปิด dropdown ของ .select =====
function bindSelectToggle(selId) {
  const sel = document.getElementById(selId);
  if (!sel) return;

  const btn = sel.querySelector('.select-btn');
  if (!btn) return;

  btn.addEventListener('click', (e) => {
    e.preventDefault();
    e.stopPropagation(); // กันไม่ให้ event หลุดไปถึงตัวที่ปิดทั้งหมด

    const isOpen = sel.classList.toggle('open');
    btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  });
}

document.addEventListener('DOMContentLoaded', () => {
  init();
  // เปิด/ปิด dropdown หมวดหมู่ + บริการ
  bindSelectToggle('groupSel');
  bindSelectToggle('childSel');

  loadLatestUpdates();
  initHeightSync();

  // ผูก auto-qty กับการพิมพ์คอมเมนต์/คีย์เวิร์ด
  const cmtEl = document.getElementById('comments');
  const kwEl  = document.getElementById('keywords');
  if (cmtEl) cmtEl.addEventListener('input', syncAutoQtyFromFields);
  if (kwEl)  kwEl.addEventListener('input', syncAutoQtyFromFields);

  const box = document.getElementById('searchSuggest');
  if (box) {
    box.addEventListener('scroll', () => {
      if (box.hidden) return;

      const nearBottom =
        box.scrollTop + box.clientHeight >= box.scrollHeight - 40;
      if (nearBottom) {
        renderSearchChunk(false);
      }
    });
  }
});

function getGroupIconByName(name){
  const n = (name || '').toLowerCase();

  for (const g of GROUP_ICON_MAP) {
    for (const kw of g.match) {
      if (n.includes(kw.toLowerCase())) {
        return g.icon;
      }
    }
  }
  return null;
}
</script>
