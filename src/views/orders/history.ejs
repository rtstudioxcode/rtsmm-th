  /* ---------- สั่งซ้ำ (Repeat) ---------- */
  async function repeatOrder(btn){
    const id = btn?.dataset?.id;
    if (!id) return;

    const cache = (window.__ORDERS__||[]).find(x => x._id === id);
    if (!cache) { alert('ไม่พบบันทึกออเดอร์'); return; }

    if (!confirm('ต้องการสั่งซ้ำรายการนี้อีกครั้งใช่ไหม?')) return;

    btn.disabled = true; const keep = btn.textContent; btn.textContent = '…';

    try{
      const childProvId = cache.providerServiceId; 
      const parentProvId = cache.svcProviderServiceId;

      let body;
      if (childProvId && String(childProvId) !== String(parentProvId)) {
        body = {
          groupId: cache.serviceId,
          providerServiceId: childProvId, 
          link: cache.link,
          quantity: cache.quantity
        };
      } else {
        body = {
          serviceId: cache.serviceId,
          link: cache.link,
          quantity: cache.quantity
        };
      }

      const res = await fetch('/orders', {
        method:'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify(body)
      });
      const data = await res.json();
      if (!data?.ok) throw new Error(data?.error || 'repeat failed');

      alert('สั่งซ้ำสำเร็จ! หมายเลขใหม่: ' + (data.providerOrderId || data.orderId || '—'));
    }catch(e){
      console.error(e);
      alert('สั่งซ้ำไม่สำเร็จ: ' + (e.message||''));
    }finally{
      btn.textContent = keep; btn.disabled = false;
    }
  }

  document.addEventListener('click', e=>{
    const b = e.target.closest('.btn-repeat'); 
    if (!b) return;
    e.preventDefault();
    repeatOrder(b);
  });

  /* ---------- ปุ่ม/ยูทิล ---------- */
  function setBusy(btns, on=true){
    btns.forEach(b => {
      if(!b) return;
      if(on){
        b.disabled = true;
        b.dataset.keep = b.textContent;
        b.textContent = '…';
      }else{
        b.disabled = false;
        if(b.dataset.keep){ b.textContent = b.dataset.keep; delete b.dataset.keep; }
      }
    });
  }

  /* ---------- refresh-all แบบไม่ reload หน้า ---------- */
  function setBusyTargets(targets, on = true) {
    const list = Array.isArray(targets) ? targets : [targets];
    const seen = new Set();

    for (const el of list) {
      if (!el || seen.has(el)) continue;
      seen.add(el);

      if (on) {
        if (!el.dataset.savedHtml) el.dataset.savedHtml = el.innerHTML;
        el.disabled = true;
        el.setAttribute('aria-busy', 'true');
        el.classList.add('is-loading');
      } else {
        el.disabled = false;
        el.removeAttribute('aria-busy');
        el.classList.remove('is-loading');
        if (el.dataset.savedHtml) el.innerHTML = el.dataset.savedHtml;
      }
    }
  }

  /* ---------- รีเฟรชเฉพาะออเดอร์เดียว ---------- */
  function setBtnBusy(btn, on = true) {
    if (!btn) return;
    if (on) {
      btn.disabled = true;
      if (!btn.dataset.keepHtml) btn.dataset.keepHtml = btn.innerHTML;
      btn.setAttribute('aria-busy', 'true');
      btn.classList.add('is-loading');
    } else {
      btn.disabled = false;
      btn.removeAttribute('aria-busy');
      btn.classList.remove('is-loading');
      if (btn.dataset.keepHtml) {
        btn.innerHTML = btn.dataset.keepHtml;
        delete btn.dataset.keepHtml;
      }
    }
  }

  async function refreshOneOrder(orderId, triggerBtn) {
    if (!orderId) return;
    setBtnBusy(triggerBtn, true);
    try {
      // ↙↙↙ เปลี่ยนมาใช้ endpoint ที่อ่านจาก DB เท่านั้น
      const res = await fetch(`/api/orders/${orderId}/local-status`, { method: 'GET' });
      const data = await res.json();

      // รองรับรูปแบบ { ok, ... } และ fallback เดิม
      const status        = data.status;
      const progress      = data.progress;
      const remains       = data.remains;
      const start_count   = data.start_count;
      const current_count = data.current_count;
      const updatedAt     = data.updatedAt || new Date().toISOString();
      const refundAmount  = data.refundAmount;
      const refundType    = data.refundType;

      // สร้าง patch แล้วอัปเดต DOM ผ่าน applyOrderPatch
      const patch = {
        _id: orderId,
        status,
        progress,
        remains,
        startCount:   start_count,
        currentCount: current_count,
        updatedAt,
        refundAmount,
        refundType
      };
      window.applyOrderPatch?.(patch);

      // อัปเดต cache modal (__ORDERS__) ถ้ามี
      const arr = window.__ORDERS__ || [];
      const idx = arr.findIndex(x => x._id === orderId);
      if (idx > -1) {
        const o = arr[idx];
        o.status        = (patch.status        ?? o.status);
        o.progress      = (typeof patch.progress      === 'number') ? patch.progress      : o.progress;
        o.remains       = (typeof patch.remains       === 'number') ? patch.remains       : o.remains;
        o.startCount    = (typeof patch.startCount    === 'number') ? patch.startCount    : o.startCount;
        o.currentCount  = (typeof patch.currentCount  === 'number') ? patch.currentCount  : o.currentCount;
        o.updatedAt     = patch.updatedAt || o.updatedAt;
        if (typeof patch.refundAmount === 'number') o.refundAmount = patch.refundAmount;
        if (typeof patch.refundType   === 'string') o.refundType   = patch.refundType;
      }
    } catch (e) {
      console.error('refresh one (local) failed:', e);
    } finally {
      setBtnBusy(triggerBtn, false);
    }
  }

