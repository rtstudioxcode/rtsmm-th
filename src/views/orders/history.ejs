<script>
document.addEventListener('DOMContentLoaded', () => {
  const tabs   = document.querySelectorAll('.tabs .tab');
  const panes  = document.querySelectorAll('.tabpane');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab; // "order" หรือ "history"

      // ✅ ถ้าเป็นแท็บประวัติ ให้ redirect ไป /my/orders ทันที
      if (target === 'order') {
        window.location.href = '/orders/new';
        return;
      }

      // แท็บอื่น ๆ ใช้วิธีเดิม: สลับ active + show pane
      tabs.forEach(t => t.classList.remove('active'));
      panes.forEach(p => p.classList.remove('show'));

      tab.classList.add('active');
      const pane = document.getElementById('tab-' + target);
      if (pane) pane.classList.add('show');
    });
  });
});

// === ไอคอนสถานะ (GLOBAL) ===
window.__STATUS_ICONS__ = {
  processing: '/static/assets/status/processing.png',
  inprogress: '/static/assets/status/inprogress.png',
  completed:  '/static/assets/status/completed.png',
  partial:    '/static/assets/status/partial.png',
  canceled:   '/static/assets/status/canceled.png',
  canceling:  '/static/assets/status/processing.png',
  default:    '/static/assets/status/processing.png'
};

window.ensureStatusIcon = function ensureStatusIcon(pill, status){
  if (!pill) return;
  const url = (window.__STATUS_ICONS__||{})[String(status||'').toLowerCase()] 
              || window.__STATUS_ICONS__.default;

  let ico = pill.querySelector(':scope .label .st-ico, :scope > .st-ico');
  if (!ico) {
    ico = document.createElement('span');
    ico.className = 'st-ico';
    const lbl = pill.querySelector(':scope .label');
    (lbl || pill).prepend(ico);
  }
  ico.style.setProperty('--st-ico', `url("${url}")`);
  pill.classList.add('has-ico');
};

/* ==== ส่งข้อมูลออเดอร์มาไว้ฝั่ง client (Render ข้อมูลจาก Server เป็น JSON) ==== */
window.__ORDERS__ = <%- JSON.stringify((list || []).map(o => {
  // คำนวณค่าใช้จ่าย (Cost Calculation)
  const costNum = Number(o.estCost ?? o.cost ?? (((o.quantity || 0) / 1000) * (o.service?.rate || 0)));
  
  return {
    _id: o._id,
    providerOrderId: o.providerOrderId || '-',
    link: o.link || '#',
    quantity: Number(o.quantity) || 0,
    startCount: o.startCount ?? 0,
    currentCount: o.currentCount ?? 0,
    remains: o.remains ?? 0,
    progress: o.progress ?? 0,
    status: (o.status || 'processing').toLowerCase(),
    createdAt: o.createdAt,
    updatedAt: o.updatedAt ?? o.createdAt,
    currency: o.currency || o.service?.currency || 'THB',
    estCost: costNum,
    refundAmount: Number(o.refundAmount || 0),
    refundType: o.refundType || null,
    comments: (o.providerResponse?.raw?.comments) || (o.providerResponse?.raw?.comment) || (o.comments) || ''
  };
})) %>;

(function() {
    // --- [Helper Functions] ---
    // ป้องกัน Error '$ is not defined' โดยสร้างฟังก์ชันเลือก Element เอง
    const $ = (s, r = document) => r.querySelector(s);
    const $$ = (s, r = document) => Array.from(r.querySelectorAll(s));

    const fmtTH = (d) => { try { return d ? new Date(d).toLocaleString('th-TH') : '-'; } catch { return '-'; } };
    const fmtMoney = (n, cur = 'THB') => (Number(n) || 0).toLocaleString(undefined, { minimumFractionDigits: 2 }) + ' ' + cur;

    /**
     * 2. CORE LOGIC: PROGRESS ENGINE
     * แก้ปัญหา 'calcPercents is not defined' โดยการย้าย Logic มาไว้ใน Scope นี้
     */
    function shmdCalculateProgress(o) {
        const qty = Number(o.quantity) || 0;
        if (qty <= 0) return { donePct: 0, leftAbs: 0 };
        let donePct = 0;
        if (typeof o.progress === 'number' && o.progress > 0) {
            donePct = o.progress;
        } else if (typeof o.remains === 'number') {
            donePct = Math.max(0, (1 - (o.remains / qty)) * 100);
        } else if (o.startCount != null && o.currentCount != null) {
            donePct = ((o.currentCount - o.startCount) / qty) * 100;
        }
        donePct = Math.max(0, Math.min(100, donePct));
        const leftAbs = Math.max(0, Math.round(qty - (qty * donePct / 100)));
        return { donePct, leftAbs };
    }

    /**
     * 3. MODAL RENDERER
     * แก้ปัญหา 'textContent of null' โดยตรวจสอบ Element ก่อนเขียนค่าเสมอ
     */
    function renderShmdModal(o) {
        if (!o) return;

        const safeSet = (sel, val, attr = 'textContent') => {
            const el = $(sel);
            if (el) el[attr] = val;
        };

        // ข้อมูลพื้นฐาน
        safeSet('#shmd-id-val', '#' + o.providerOrderId);
        safeSet('#shmd-cost-val', fmtMoney(o.estCost, o.currency));
        
        const linkEl = $('#shmd-link-val');
        if (linkEl) { linkEl.href = o.link; linkEl.textContent = o.link; }

        safeSet('#shmd-qty-val', o.quantity.toLocaleString());
        safeSet('#shmd-start-val', (o.startCount ?? 0).toLocaleString());
        safeSet('#shmd-total-val', o.quantity.toLocaleString());

        // ความคืบหน้า
        const prog = shmdCalculateProgress(o);
        safeSet('#shmd-pct-val', prog.donePct.toFixed(2) + '%');
        const bar = $('#shmd-bar-val');
        if (bar) bar.style.width = prog.donePct + '%';
        safeSet('#shmd-left-val', prog.leftAbs.toLocaleString());

        // ระบบคืนเงิน
        const refAmt = Number(o.refundAmount || 0);
        const refBox = $('#shmd-refund-box');
        if (refBox) {
            refBox.style.display = refAmt > 0 ? 'flex' : 'none';
            safeSet('#shmd-refund-val', fmtMoney(refAmt, o.currency));
        }

        // สถานะและไทม์ไลน์
        const st = String(o.status || '').toLowerCase();
        let statusTitle = 'กำลังดำเนินการ';
        let themeColor = '#38bdf8'; // Blue

        if (st === 'completed') {
            statusTitle = 'เสร็จสิ้นสมบูรณ์';
            themeColor = '#22c55e'; // Green
        } else if (['canceled', 'partial'].includes(st)) {
            statusTitle = st === 'partial' ? 'คืนเงินบางส่วน' : 'ยกเลิกคำสั่งซื้อ';
            themeColor = '#fb7185'; // Red
        }

        const finalStep = $('#shmd-step-final');
        if (finalStep) finalStep.style.setProperty('--shmd-primary', themeColor);
        safeSet('#shmd-final-label', statusTitle);
        safeSet('#shmd-final-time', fmtTH(o.updatedAt));
        safeSet('#shmd-updated-time', fmtTH(o.updatedAt));
        safeSet('#shmd-created-time', fmtTH(o.createdAt));

        // คอมเมนต์
        const commSec = $('#shmd-comments-sec');
        const commVal = $('#shmd-comments-val');

        if (commSec && commVal) {
            const raw = (o.comments || '').trim();
            if (raw) {
                commSec.style.display = 'block';
                // ใช้คำสั่งนี้เพื่อแทนที่ขึ้นบรรทัดใหม่ และป้องกัน XSS เบื้องต้น
                commVal.innerHTML = raw.split('\n').map(line => `<div>${line}</div>`).join('');
                
                // รีเซ็ตตำแหน่งการเลื่อนให้ไปที่ด้านบนสุดทุกครั้งที่เปิด modal ใหม่
                commVal.scrollTop = 0; 
            } else {
                commSec.style.display = 'none';
            }
        }

        // ปุ่ม Refresh ใน Modal
        const refBtn = $('#shmd-refresh-btn');
        if (refBtn) refBtn.style.display = ['completed', 'canceled', 'partial'].includes(st) ? 'none' : 'flex';
    }

    // --- [Global Actions] ---

    window.openOrderModal = function(id) {
        const order = (window.__ORDERS__ || []).find(x => x._id === id);
        if (order) {
            renderShmdModal(order);
            const modal = $('#shmdOrderModal');
            if (modal) {
                modal.classList.add('active');
                document.body.style.overflow = 'hidden';
            }
        }
    };

    window.closeShmdModal = function() {
        const modal = $('#shmdOrderModal');
        if (modal) {
            modal.classList.remove('active');
            document.body.style.overflow = '';
        }
    };

    // --- [Icon Injector] ---
    window.ensureStatusIcon = function(pill, status) {
        if (!pill) return;
        const url = window.__STATUS_ICONS__[String(status || '').toLowerCase()] || window.__STATUS_ICONS__.default;
        let ico = pill.querySelector('.st-ico');
        if (!ico) {
            ico = document.createElement('span');
            ico.className = 'st-ico';
            const target = pill.querySelector('.label') || pill;
            target.prepend(ico);
        }
        ico.style.setProperty('--st-ico', `url("${url}")`);
    };

    // --- [Event Listeners] ---

    document.addEventListener('DOMContentLoaded', () => {
        // Tabs
        $$('.tabs .tab[data-tab]').forEach(tab => {
            tab.addEventListener('click', () => {
                if (tab.dataset.tab === 'order') { window.location.href = '/orders/new'; return; }
                $$('.tabs .tab').forEach(t => t.classList.remove('active'));
                $$('.tabpane').forEach(p => p.classList.remove('show'));
                tab.classList.add('active');
                const pane = $('#tab-' + tab.dataset.tab);
                if (pane) pane.classList.add('show');
            });
        });

        // Pagination
        const ppSelect = $('#ppSelect');
        if (ppSelect) ppSelect.addEventListener('change', () => {
            const url = new URL(window.location.href);
            url.searchParams.set('perPage', ppSelect.value);
            url.searchParams.set('page', '1');
            window.location.href = url.toString() + '#page-bottom';
        });

        // Delegate Clicks (เปิด Modal, ปิด Modal, เปลี่ยนสถานะ)
        document.addEventListener('click', (e) => {
            const t = e.target;
            // ปุ่มเปิด Modal
            const openBtn = t.closest('.open-order');
            if (openBtn) {
                e.preventDefault();
                const id = openBtn.dataset.id || openBtn.closest('[data-order-id]')?.dataset.orderId;
                if (id) openOrderModal(id);
                return;
            }
            // ปุ่มปิด Modal
            if (t.closest('[data-close-shmd]') || t.classList.contains('shmd-backdrop')) {
                closeShmdModal();
                return;
            }
            // ปุ่มตัวกรองสถานะ
            const statusBtn = t.closest('[data-st]');
            if (statusBtn && !statusBtn.closest('.tabs')) { // เลี่ยงชนกับระบบ Tab บน
                const st = statusBtn.dataset.st;
                const url = new URL(window.location.href);
                url.searchParams.set("status", st);
                url.searchParams.set("page", "1");
                window.location.href = url.toString();
            }
        });

        // ESC Key
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeShmdModal(); });

        // Initial Icons injection
        $$('.pill.long, .pill.progress').forEach(p => {
            const status = p.closest('[data-status]')?.dataset.status;
            window.ensureStatusIcon(p, status);
        });
    });

    // 4. API ACTIONS (Refresh Single Order)
    const refBtnModal = $('#shmd-refresh-btn');
    if (refBtnModal) {
        refBtnModal.addEventListener('click', async () => {
            const idNode = $('#shmd-id-val');
            if (!idNode || refBtnModal.disabled) return;
            
            // หา ID จริงจาก Cache (ใช้ slice(-6) หรือ ID เต็ม)
            const displayId = idNode.textContent.replace('#', '');
            const order = window.__ORDERS__.find(x => x.providerOrderId == displayId || x._id.slice(-6) == displayId);
            if (!order) return;

            refBtnModal.disabled = true;
            const oldTxt = refBtnModal.innerHTML;
            refBtnModal.innerHTML = '<span>กำลังอัปเดต...</span>';

            try {
                const res = await fetch(`/api/orders/${order._id}/refresh`, { method: 'POST' });
                const data = await res.json();
                if (data && data._id) {
                    const idx = window.__ORDERS__.findIndex(x => x._id === order._id);
                    if (idx > -1) window.__ORDERS__[idx] = { ...window.__ORDERS__[idx], ...data };
                    renderShmdModal(window.__ORDERS__[idx]);
                    if (window.applyOrderPatch) window.applyOrderPatch(data);
                }
            } catch (e) { console.error(e); } finally {
                refBtnModal.disabled = false;
                refBtnModal.innerHTML = oldTxt;
            }
        });
    }

})();

/* ===== UI helpers (ใช้ทั้ง Desktop & Mobile) ===== */

// อัปเดต DOM ทั้งฝั่งตารางและการ์ดให้ตรงกับ payload ล่าสุด
window.applyOrderPatch = function(payload){
  // sync cache
  const arr = window.__ORDERS__ || [];
  const idx = arr.findIndex(x => x._id === payload._id);
  if (idx > -1) {
    Object.assign(arr[idx], {
      status: payload.status ?? arr[idx].status,
      progress: payload.progress ?? arr[idx].progress,
      remains: payload.remains ?? arr[idx].remains,
      startCount: payload.startCount ?? arr[idx].startCount,
      currentCount: payload.currentCount ?? arr[idx].currentCount,
      updatedAt: payload.updatedAt ?? arr[idx].updatedAt,
      refundAmount: (payload.refundAmount ?? arr[idx].refundAmount),
      refundType: (payload.refundType ?? arr[idx].refundType)
    });
  }

  const displayPayload = {
    status: payload.status,
    progress: payload.progress,
    remains: payload.remains,
    startCount: payload.startCount,
    currentCount: payload.currentCount,
    quantity: (payload.quantity != null ? payload.quantity :
                (idx > -1 ? arr[idx].quantity : 0)),
    refundAmount: payload.refundAmount,
    refundType: payload.refundType
  };

  const newSt = String(displayPayload.status || '').toLowerCase();
  const isPartialRefundCanceled = (newSt === 'canceled') &&
    (Number(displayPayload.refundAmount||0) > 0) &&
    (displayPayload.refundType === 'partial');

  // Desktop row
  const tr = document.querySelector(`tr[data-order-id="${payload._id}"]`);
  if (tr) {
    tr.dataset.status = newSt;
    renderProgressPill(tr, displayPayload);

    // toggle buttons
    tr.querySelectorAll('.btn-cancel').forEach(b => {
      b.style.display = (newSt === 'processing') ? '' : 'none';
      if (newSt === 'canceling') b.style.display = 'none'; // ⬅️ ซ่อนทันที
    });
    tr.querySelectorAll('.btn-refresh').forEach(b => {
      b.style.display = (newSt === 'completed' || newSt === 'canceled' || newSt === 'partial' || newSt === 'canceling') ? 'none' : '';
    });
    tr.querySelectorAll('.btn-repeat').forEach(b => {
      b.style.display = ((newSt === 'completed') || (newSt === 'partial') || isPartialRefundCanceled) ? '' : 'none';
    });
  }

  // Mobile card
  const card = document.querySelector(`.o-card[data-order-id="${payload._id}"]`);
  if (card) {
    card.dataset.status = newSt;
    renderProgressPill(card, displayPayload);

    card.querySelectorAll('.btn-cancel').forEach(b => {
      b.style.display = (newSt === 'processing') ? '' : 'none';
      if (newSt === 'canceling') b.style.display = 'none'; // ⬅️ ซ่อนทันที
    });
    card.querySelectorAll('.btn-refresh').forEach(b => {
      b.style.display = (newSt === 'completed' || newSt === 'canceled' || newSt === 'partial' || newSt === 'canceling') ? 'none' : '';
    });
    card.querySelectorAll('.btn-repeat').forEach(b => {
      b.style.display = ((newSt === 'completed') || (newSt === 'partial') || isPartialRefundCanceled) ? '' : 'none';
    });
  }
};

// รองรับทั้ง .pill.long (ใหม่) และ .pill.progress (เดิม)
window.renderProgressPill = function(container, payload){
  const pillLong = container?.querySelector?.('.pill.long') || container?.querySelector?.('.pill.progress');
  if (!pillLong) return;

  const dd = (window.decideDisplay ? window.decideDisplay(payload) : null) ||
            { label:'รอดำเนินการ', donePct:0, showPct:false, isDone:false };

  const stLower       = String(payload.status||'').toLowerCase();
  const isCanceled    = stLower === 'canceled';
  const isPartial     = stLower === 'partial';
  const isCanceling   = stLower === 'canceling';
  const isPartialRefund = (isCanceled && Number(payload.refundAmount||0) > 0 && payload.refundType === 'partial');

  pillLong.classList.toggle('ok', !!dd.isDone);
  pillLong.classList.toggle('danger', isCanceled);
  pillLong.classList.toggle('warn', isPartial || isCanceling);

  // โครงสร้างใหม่: มี .bar + .label
  const barEl = pillLong.querySelector('.bar');
  const lblEl = pillLong.querySelector('.label');
  if (barEl && lblEl) {
    // ถ้า canceling แถบความคืบหน้าให้ 0%
    const widthPct = isCanceling ? 0 : (dd.isDone ? 100 : Math.max(0, Math.min(100, dd.donePct)));
    barEl.style.width = widthPct + '%';

    // ถ้า canceling แสดงข้อความเฉพาะ
    const mainLabel = isCanceling
      ? 'กำลังส่งยกเลิก…'
      : (dd.showPct ? `ดำเนินการ ~ <span class="pct">${Number(dd.donePct||0).toFixed(2)}%</span>` : dd.label);

    lblEl.innerHTML = isPartialRefund
      ? `<span class="badge warn" style="margin-right:8px">คืนบางส่วน</span>${mainLabel}`
      : mainLabel;

    ensureStatusIcon(pillLong, stLower);
    
    return;
  }

  // fallback: pill เดิม (ไม่มี .bar/.label)
  if (isCanceling) {
    pillLong.textContent = 'กำลังส่งยกเลิก…';
    ensureStatusIcon(pillLong, 'canceling');
  } else {
    pillLong.innerHTML = dd.showPct
      ? `ดำเนินการ ~ <span class="pct" data-pct="${dd.donePct}">${Number(dd.donePct||0).toFixed(2)}%</span>`
      : dd.label;
    ensureStatusIcon(pillLong, stLower);
  }
};

(() => {
  const $  = (s,r=document)=>r.querySelector(s);
  const $$ = (s,r=document)=>Array.from(r.querySelectorAll(s));

  /* ===========================
  * Auto Refresh (DB-only)
  * - ดึงสถานะจาก DB orders อย่างเดียว
  * - ไม่ยุ่งกับการเปลี่ยนสถานะเอง (no canceling logic)
  * - รีเฟรชเฉพาะออเดอร์ที่ยังทำงานอยู่ (processing/inprogress)
  * =========================== */
  const AutoRefresh = (() => {
    const NORMAL_INTERVAL    = 10_000; // 10s (ปรับได้)
    const ERR_BACKOFF_FACTOR = 2.0;

    const CONCURRENCY      = 3;   // ขอพร้อมกันสูงสุด
    const PER_ORDER_GAP_MS = 300; // หน่วงระหว่างคำขอ

    let timer   = null;
    let running = false;

    const isVisible = el => !!(el && el.offsetParent !== null);
    const qsa = (sel) => Array.from(document.querySelectorAll(sel));

    // เลือกเฉพาะรายการที่ยังทำงานอยู่
    function getRefreshableIds(){
      const nodes = qsa('#orderTable tbody tr[data-order-id], .o-card[data-order-id]')
        .filter(n => isVisible(n));
      const ids = [];
      for (const n of nodes){
        const st = String(n.dataset.status || '').toLowerCase();
        if (st === 'processing' || st === 'inprogress' || st === 'canceling'){
          const id = n.dataset.orderId;
          if (id) ids.push(id);
        }
      }
      return [...new Set(ids)];
    }

    function schedule(ms){
      clearTimeout(timer);
      timer = setTimeout(tick, Math.max(0, ms));
    }

    // ยิงทีละออเดอร์แบบจำกัด concurrency
    async function refreshPerOrder(ids){
      if (!ids.length) return;

      const btnFor = (id) =>
        document.querySelector(`.btn-refresh[data-id="${id}"]`) ||
        document.querySelector(`[data-order-id="${id}"] .btn-refresh`) || undefined;

      const queue = ids.slice();
      const workers = new Array(Math.min(CONCURRENCY, queue.length)).fill(0).map(async () => {
        while (queue.length){
          const id = queue.shift();
          try{
            await refreshOneOrder(id, btnFor(id)); // ← ฟังก์ชันของคุณที่เรียก /local-status แล้ว applyOrderPatch
          }catch(e){
            console.warn('refreshOneOrder failed:', id, e);
          }
          if (PER_ORDER_GAP_MS) {
            await new Promise(s => setTimeout(s, PER_ORDER_GAP_MS));
          }
        }
      });
      await Promise.allSettled(workers);
    }

    async function doRun(nextMs){
      if (running) { schedule(Math.max(nextMs, 1_000)); return; }
      running = true;
      try{
        const ids = getRefreshableIds();
        await refreshPerOrder(ids);
        schedule(NORMAL_INTERVAL);
      } catch (e){
        console.error('auto refresh failed:', e);
        const backoff = Math.floor((nextMs || NORMAL_INTERVAL) * ERR_BACKOFF_FACTOR);
        schedule(backoff);
      } finally {
        running = false;
      }
    }

    async function tick(){
      if (document.hidden) { schedule(NORMAL_INTERVAL); return; }
      await doRun(NORMAL_INTERVAL);
    }

    // โฟกัสกลับหน้า → เริ่มรอบใหม่ไวหน่อย
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) return;
      clearTimeout(timer);
      schedule(200);
    });

    // เริ่มทำงาน
    window.addEventListener('load', () => schedule(200));

    // ปุ่ม Sync → รีเฟรชเฉพาะที่ยังทำงานอยู่
    document.querySelector('#btnSync')?.addEventListener('click', async () => {
      clearTimeout(timer);
      try{
        const ids = getRefreshableIds();
        await refreshPerOrder(ids);
      } finally {
        schedule(NORMAL_INTERVAL);
      }
    });

    return { start: () => schedule(500), stop: () => clearTimeout(timer) };
  })();


  /* === decideDisplay (ฝั่ง client) === */
  const clampPct = v => Math.max(0, Math.min(100, Number(v)||0));

  window.decideDisplay = function(o){
    const qty = Number(o.quantity)||0;
    const st  = String(o.status||'').toLowerCase();

    if (st === 'canceling') return { label:'กำลังส่งยกเลิก…', donePct:0, showPct:false, isDone:false };
    if (st === 'canceled')  return { label:'ยกเลิก',         donePct:0, showPct:false, isDone:false };
    if (st === 'partial')   return { label:'คืนบางส่วน',     donePct:0, showPct:false, isDone:false };

    const hasProgress = (typeof o.progress === 'number' && isFinite(o.progress));
    const hasRemains  = (typeof o.remains  === 'number' && isFinite(o.remains));
    const hasCounts   = (typeof o.startCount === 'number' && typeof o.currentCount === 'number');

    let donePct = 0;

    if (hasProgress) {
      donePct = clampPct(o.progress);
    } else if (hasRemains && qty > 0) {
      // ใช้ remains เป็นหลัก ถ้ามี → ถือว่าเริ่มทำงานแล้ว
      donePct = clampPct((1 - Math.max(0, o.remains)/qty) * 100);
    } else if (hasCounts && qty > 0) {
      donePct = clampPct(((o.currentCount - o.startCount)/qty) * 100);
    }

    // รอดำเนินการ เฉพาะกรณี "ไม่มีข้อมูลความคืบหน้าเลย"
    const isWaiting = (st === 'processing') && !hasProgress && !hasRemains && !hasCounts;
    if (isWaiting) return { label:'รอดำเนินการ', donePct:0, showPct:false, isDone:false };

    const isDone = (st === 'completed') || donePct >= 99.995;

    return isDone
      ? { label:'เสร็จสิ้น', donePct:100, showPct:false, isDone:true }
      : { label:`ดำเนินการ ~ ${donePct.toFixed(2)}%`, donePct, showPct:true, isDone:false };
  };

  /* ---------- สั่งซ้ำ (Repeat) ---------- */
  async function repeatOrder(btn){
    const id = btn?.dataset?.id;
    if (!id) return;

    const cache = (window.__ORDERS__||[]).find(x => x._id === id);
    if (!cache) { alert('ไม่พบบันทึกออเดอร์'); return; }

    if (!confirm('ต้องการสั่งซ้ำรายการนี้อีกครั้งใช่ไหม?')) return;

    btn.disabled = true;
    const keep = btn.textContent;
    btn.textContent = '…';

    try{
      const body = {};

      // ───────── กรณีออเดอร์เก่า ไม่มี serviceId ─────────
      if (!cache.serviceId && cache.providerServiceId){
        body.providerServiceId = cache.providerServiceId;
        body.link      = cache.link;
        body.quantity  = cache.quantity;
      }
      else {
        // ───────── ออเดอร์ปกติ ─────────
        body.serviceId = cache.serviceId;
        body.link      = cache.link;
        body.quantity  = cache.quantity;

        // ───────── มี providerServiceId ลูก? (เช่นบริการใน group เดิมเปลี่ยน) ─────────
        if (cache.svcProviderServiceId &&
            String(cache.svcProviderServiceId) !== String(cache.providerServiceId))
        {
          delete body.serviceId;
          body.groupId            = cache.serviceId;
          body.providerServiceId  = cache.svcProviderServiceId;
        }
      }

      const res = await fetch('/orders', {
        method:'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify(body)
      });

      const data = await res.json();
      if (!data?.ok) throw new Error(data?.error || 'repeat failed');

      alert('สั่งซ้ำสำเร็จ! หมายเลขใหม่: ' + (data.orderId || data.providerOrderId || '—'));

    }catch(e){
      console.error(e);
      alert('สั่งซ้ำไม่สำเร็จ: ' + e.message);
    }finally{
      btn.textContent = keep;
      btn.disabled = false;
    }
  }

  document.addEventListener('click', async e => { // เพิ่ม async ตรงนี้ด้วย
      const b = e.target.closest('.btn-repeat'); 
