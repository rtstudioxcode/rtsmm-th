<script>
(function(){
  const ICONS = {
    processing: '/static/assets/status/processing.png',
    inprogress: '/static/assets/status/inprogress.png',
    completed:  '/static/assets/status/completed.png',
    partial:    '/static/assets/status/partial.png',
    canceled:   '/static/assets/status/canceled.png',
    default:    '/static/assets/status/processing.png'
  };

  document.querySelectorAll('.pill.progress, .pill.long .label').forEach(node => {
    const pill = node.closest('.pill.progress, .pill.long');
    if (!pill || pill.classList.contains('has-ico')) return;

    const st = (pill.closest('[data-status]')?.dataset?.status || '').toLowerCase();
    const url = ICONS[st] || ICONS.default;

    // สร้างกล่องไอคอน
    const ico = document.createElement('span');
    ico.className = 'st-ico';
    ico.style.setProperty('--st-ico', `url("${url}")`);

    // ใส่หน้า label/text
    if (node.classList.contains('label')) node.prepend(ico);
    else pill.prepend(ico);

    pill.classList.add('has-ico'); // <- ป้ายเพื่อปิด ::before
  });
})();

/* helpers */
async function postJSON(url, body) {
  const r = await fetch(url, {
    method: 'POST',
    headers: { 'Content-Type':'application/json' },
    body: body ? JSON.stringify(body) : null
  });
  let j = null; try { j = await r.json(); } catch {}
  if (!r.ok) {
    const msg = (j && j.error) ? j.error : ('HTTP ' + r.status);
    const err = new Error(msg); err.status = r.status; err.payload = j; throw err;
  }
  return j || {};
}

function setPillCanceling(orderId) {
  const row  = document.querySelector(`[data-order-id="${orderId}"]`);
  const card = document.querySelector(`.o-card[data-order-id="${orderId}"]`);
  const pill = row?.querySelector('.pill.long, .pill.progress') || card?.querySelector('.pill.long, .pill.progress');

  // อัปเดต data-status เป็น canceling (ให้ตัวกรองและไอคอนรู้)
  if (row)  row.dataset.status  = 'canceling';
  if (card) card.dataset.status = 'canceling';

  // ซ่อนปุ่มยกเลิก (กันสับสนว่าเป็นสถานะ)
  row?.querySelectorAll('.btn-cancel').forEach(b => b.style.display = 'none');
  card?.querySelectorAll('.btn-cancel').forEach(b => b.style.display = 'none');

  // ปรับ pill ให้เป็นกำลังยกเลิก
  if (pill) {
    pill.classList.remove('ok','danger','violet','blue');
    pill.classList.add('warn');
    const bar   = pill.querySelector('.bar');   if (bar)   bar.style.width = '0%';
    const label = pill.querySelector('.label'); if (label) label.textContent = 'กำลังส่งยกเลิก…';
    // fallback โครงสร้างเก่า
    if (!label) pill.textContent = 'กำลังส่งยกเลิก…';
    ensureStatusIcon(pill, 'canceling');
  }
}

async function pollCancel(orderId, {
  timeoutMs = 7 * 60 * 1000,
  gapMs = 800
} = {}) {
  const t0 = Date.now();
  // บอก AutoRefresh ว่ามี long-poll ยกเลิกกำลังรอ
  window.__CANCEL_AWAITING__?.add(orderId);

  try {
    while (Date.now() - t0 < timeoutMs) {
      try {
        const j = await postJSON(`/orders/${orderId}/cancel/await`);
        if (j?.updated) { location.reload(); return; }
      } catch {}
      await new Promise(s => setTimeout(s, gapMs));
    }
    // หมดเวลารอบนี้ → ให้ AutoRefresh (โหมด 7 นาที) ทำงานต่อ
    window.showMsg?.({ variant:'info', title:'กำลังรอยืนยัน', text:'ระบบจะอัปเดตให้อัตโนมัติเมื่อยกเลิกสำเร็จ' });
  } finally {
    window.__CANCEL_AWAITING__?.delete(orderId);
  }
}

async function startCancel(orderId) {
  const btn = document.querySelector(`tr[data-order-id="${orderId}"] .btn-cancel`)
          || document.querySelector(`.o-card[data-order-id="${orderId}"] .btn-cancel`)
          || document.querySelector(`[data-order-id="${orderId}"] .btn.small.danger`)
          || document.querySelector(`button[onclick*="${orderId}"]`);
  if (btn) btn.disabled = true;

  try {
    await postJSON(`/orders/${orderId}/cancel`);
    setPillCanceling(orderId);          // UI: แสดง "กำลังส่งยกเลิก…"
    await pollCancel(orderId);          // รอผลจริงจาก API → แล้วค่อยอัปเดต
  } catch (e) {
    if (window.showMsg) showMsg({ variant:'error', title:'ยกเลิกไม่สำเร็จ', text: e.message || 'โปรดลองใหม่' });
    else alert('ยกเลิกไม่สำเร็จ: ' + (e.message || 'โปรดลองใหม่'));
    if (btn) btn.disabled = false;
  }
}
</script>


<script>
(function(){
  const sel = document.getElementById('ppSelect');
  if (!sel) return;

  /* ── ใช้ร่วมกัน: เปลี่ยนค่า perPage + กระโดดไปล่างหน้า ── */
  function applySelection(v){
    const params = new URLSearchParams(window.location.search);
    if (v === 'all'){
      params.set('perPage', 'all');   // ให้ backend แปลงต่อ
      params.set('page', '1');
    } else {
      params.set('perPage', String(v));
      params.set('page', '1');
    }
    const url = window.location.pathname + '?' + params.toString() + '#page-bottom';
    window.location.href = url;
  }

  /* ── เดสก์ท็อป: ใช้ select ปกติ ── */
  sel.addEventListener('change', () => applySelection(sel.value));

  /* ── มือถือ: สร้างเมนูแบบ drop-up ── */
  const isMobile = matchMedia('(max-width:640px)').matches;
  if (!isMobile) return;

  // โครงสร้างปุ่ม + เมนู
  const wrap = document.createElement('div');
  wrap.className = 'ppc-wrap';

  const btn = document.createElement('button');
  btn.type = 'button';
  btn.className = 'ppc-btn';
  btn.textContent = (sel.value === 'all') ? 'All records' : sel.value;

  const menu = document.createElement('ul');
  menu.className = 'ppc-menu';
  menu.setAttribute('role','listbox');

  // รายการจาก option เดิม (1:1)
  Array.from(sel.options).forEach(op => {
    const li = document.createElement('li');
    li.className = 'ppc-item' + (op.selected ? ' active' : '');
    li.dataset.value = op.value;
    li.setAttribute('role','option');
    li.textContent = (op.value === 'all') ? 'All records' : op.value;
    li.addEventListener('click', () => {
      sel.value = op.value;                 // sync ค่า select
      btn.textContent = li.textContent;     // อัปเดตปุ่ม
      applySelection(op.value);             // ไปหน้าใหม่
    });
    menu.appendChild(li);
  });

  wrap.appendChild(btn);
  wrap.appendChild(menu);

  // ใส่ wrap ข้าง select (ให้ CSS ซ่อน select บนมือถือ)
  sel.parentElement.style.position = 'relative';
  sel.parentElement.appendChild(wrap);

  // เปิด/ปิดเมนู (กำหนดกว้างเท่ากล่องทุกครั้ง)
  btn.addEventListener('click', () => {
    const rect = wrap.getBoundingClientRect();
    menu.style.width = rect.width + 'px';
    wrap.classList.toggle('open');
  });

  // ปิดเมื่อคลิกรอบนอก
  document.addEventListener('click', (e) => {
    if (!wrap.contains(e.target)) wrap.classList.remove('open');
  });

  // ถ้าหน้าจอขยายกลับเป็นเดสก์ท็อป → ปิดเมนู
  window.addEventListener('resize', () => {
    if (!matchMedia('(max-width:640px)').matches) wrap.classList.remove('open');
  });
})();
</script>
