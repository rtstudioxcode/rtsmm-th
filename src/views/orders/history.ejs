<% const title = "ประวัติ ออเดอร์"; %>
<% bodyClass = 'orders-wide'; %>
<%
function decideDisplaySSR(o){
  const qty = Number(o.quantity)||0;
  const st  = String(o.status||'').toLowerCase();

  const isWaiting =
    st === 'processing' &&
    (o.progress == null) &&
    ((typeof o.remains === 'number' ? o.remains >= qty : true) || o.currentCount == null);

  if (isWaiting) return { label: 'รอดำเนินการ', donePct: 0, showPct: false, isDone: false };

  let donePct = 0;
  if (typeof o.progress === 'number') {
    donePct = Math.max(0, Math.min(100, o.progress));
  } else if (typeof o.remains === 'number' && qty > 0) {
    donePct = Math.max(0, Math.min(100, (1 - Math.max(0, o.remains)/qty) * 100));
  } else if (typeof o.startCount === 'number' && typeof o.currentCount === 'number' && qty > 0) {
    donePct = Math.max(0, Math.min(100, ((o.currentCount - o.startCount)/qty) * 100));
  }
  const isDone = (st === 'completed') || donePct >= 99.995;

  return isDone
    ? { label: 'เสร็จสิ้น', donePct: 100, showPct: false, isDone: true }
    : { label: `ดำเนินการ ~ ${donePct.toFixed(2)}%`, donePct, showPct: true, isDone: false };
}
%>

<section class="orders-history page-head">
  <div class="page-title">
    <h1>ประวัติ ออเดอร์</h1>
    <small class="muted">หน้าหลัก → ประวัติ ออเดอร์</small>
  </div>

  <div class="right-actions">
    <button id="btnSync" class="btn primary">
      <span style="font-size:14px">🔄</span> อัปเดตสถานะล่าสุด
    </button>
  </div>
</section>

<% if (typeof syncError === 'string' && syncError) { %>
  <div class="orders-history alert error">⚠️ <%= syncError %></div>
<% } else { %>
  <div class="orders-history alert info">ℹ️ ปุ่มนี้สามารถกดซ้ำได้ทุก ๆ 1 นาที เพื่อดึงสถานะล่าสุดจากผู้ให้บริการ</div>
<% } %>

<!-- แท็บตัวกรองสถานะ -->
<div class="orders-history tabs chips" id="statusTabs">
  <button class="chip active" data-st="all">ทั้งหมด</button>
  <button class="chip" data-st="processing">รอดำเนินการ</button>
  <button class="chip" data-st="inprogress">กำลังทำ</button>
  <button class="chip" data-st="completed">เสร็จสิ้น</button>
  <button class="chip" data-st="partial">ส่วนบางส่วน</button>
  <button class="chip" data-st="canceled">ยกเลิก</button>
</div>

<!-- ฟิลเตอร์ -->
<form class="orders-history filters card" method="get">
  <div class="row wrap">
    <div class="inline">
      <label class="muted">ช่วงเวลา</label>
      <input class="input" type="date" name="from" value="<%= from || '' %>" />
      <span class="muted">–</span>
      <input class="input" type="date" name="to"   value="<%= to || '' %>" />
    </div>

    <div class="inline">
      <label class="muted">ค้นหาแบบละเอียด</label>
      <div class="searchbox">
        <span aria-hidden="true">🔎</span>
        <input class="input" name="q" id="q" placeholder="ค้นหา ID/ลิงก์/บริการ…" value="<%= q||'' %>">
        <button class="btn">ค้นหา</button>
      </div>
    </div>

    <div class="inline grow">
      <label class="muted">ค้นหาเร็ว</label>
      <input class="input" id="quick" placeholder="พิมพ์เพื่อกรองทันที…">
    </div>
  </div>
</form>

<!-- ตารางออเดอร์ (เดสก์ท็อป) -->
<div class="orders-history table-wrap card order-desktop">
  <table class="table order-table" id="orderTable">
    <thead>
      <tr>
        <th style="width:62px">ID</th>
        <th style="width:170px">วันที่</th>
        <th>บริการ / ลิงก์</th>
        <th style="width:140px">ค่าใช้จ่าย</th>
        <th style="width:110px">ปริมาณ</th>
        <th style="width:160px">สถานะ</th>
      </tr>
    </thead>
    <tbody>
      <% (list || []).forEach(o => { %>
        <tr data-status="<%= (o.status||'').toLowerCase() %>" data-order-id="<%= o._id %>">
          <td>
            <a class="mono" href="/orders/<%= o._id %>" title="DB _id: <%= o._id %>">
              <%= o.providerOrderId || '-' %>
            </a>
          </td>
          <td class="mono"><%= new Date(o.createdAt).toLocaleString() %></td>
          <td>
            <div class="svc">
              <div class="svc-name">
                <span class="badge soft">#<%= o.service?.providerServiceId || o.providerServiceId || '-' %></span>
                <b><%= o.service?.name || o.serviceName || '-' %></b>
                <% if (o.meta?.country) { %><span class="badge flag"><%= o.meta.country %></span><% } %>
                <% if (o.meta?.speed)   { %><span class="badge blue"><%= o.meta.speed %></span><% } %>
              </div>
              <div class="link ellipsis">
                <span class="muted" aria-hidden="true">🔗</span>
                <a href="<%= o.link %>" target="_blank" rel="noopener"><%= o.link %></a>
              </div>
            </div>
          </td>
          <td class="mono">
            <%
              const costNum = Number(
                o.estCost ?? o.cost ?? (((o.quantity||0)/1000) * (o.service?.rate||0))
              );
              const costText = Number.isFinite(costNum)
                ? costNum.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })
                : '0.00';
              const cur = o.currency || o.service?.currency || 'THB';
            %>
            <%= costText %> <%= cur %>
          </td>
          <td class="mono"><%= o.quantity %></td>
          <td class="st-cell">
            <% const dd = decideDisplaySSR(o); %>
            <div class="st-block">
              <!-- แถบสถานะยาว -->
              <div class="pill long <%= dd.isDone ? 'ok' : '' %>" data-pct="<%= dd.donePct %>">
                <i class="bar" style="width:<%= dd.isDone ? '100' : dd.donePct %>%"></i>
                <span class="label">
                  <% if (dd.showPct) { %>
                    ดำเนินการ ~ <span class="pct"><%= dd.donePct.toFixed(2) %>%</span>
                  <% } else { %>
                    <%= dd.label %>
                  <% } %>
                </span>
              </div>

              <!-- ปุ่มย้ายมาไว้ใต้สถานะ -->
              <div class="st-actions under">
                <button type="button" class="xbtn xbtn-sync btn-refresh" data-id="<%= o._id %>" title="อัปเดตสถานะออเดอร์">🔄</button>
                <button type="button" class="xbtn xbtn-info open-order"  data-id="<%= o._id %>" title="รายละเอียด">i</button>
              </div>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <% if (!(list||[]).length) { %>
    <div class="empty muted">ยังไม่มีออเดอร์ในช่วงนี้</div>
  <% } %>
</div>

<!-- การ์ดออเดอร์ (มือถือ) -->
<div class="orders-history order-cards" id="orderCards">
  <% (list || []).forEach(o => { 
     const st = (o.status||'').toLowerCase();
  %>
    <article class="o-card" data-status="<%= st %>" data-order-id="<%= o._id %>">
      <header class="o-head">
        <div class="o-id mono">
          <a href="/orders/<%= o._id %>" title="DB _id: <%= o._id %>">
            <%= o.providerOrderId || '-' %>
          </a>
        </div>
        <div class="o-date mono"><%= new Date(o.createdAt).toLocaleString() %></div>
        <button class="o-toggle" aria-label="toggle">＋</button>
      </header>

      <div class="o-body">
        <div class="o-row">
          <div class="o-label">บริการ / ลิงก์</div>
          <div class="o-val">
            <div class="svc-name">
              <span class="badge soft">#<%= o.service?.providerServiceId || o.providerServiceId || '-' %></span>
              <b><%= o.service?.name || o.serviceName || '-' %></b>
              <% if (o.meta?.country) { %><span class="badge flag"><%= o.meta.country %></span><% } %>
              <% if (o.meta?.speed)   { %><span class="badge blue"><%= o.meta.speed %></span><% } %>
            </div>
            <div class="link">
              <span class="muted" aria-hidden="true">🔗</span>
              <a href="<%= o.link %>" target="_blank" rel="noopener"><%= o.link %></a>
            </div>
          </div>
        </div>

        <div class="o-row">
          <div class="o-label">ค่าใช้จ่าย</div>
          <div class="o-val mono">
            <%
              const mCostNum = Number(
                o.estCost ?? o.cost ?? (((o.quantity||0)/1000) * (o.service?.rate||0))
              );
              const mCostText = Number.isFinite(mCostNum)
                ? mCostNum.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })
                : '0.00';
              const mCur = o.currency || o.service?.currency || 'THB';
            %>
            <%= mCostText %> <%= mCur %>
          </div>
        </div>

        <div class="o-row">
          <div class="o-label">ปริมาณ</div>
          <div class="o-val mono"><%= o.quantity %></div>
        </div>

        <div class="o-row">
          <div class="o-label">สถานะ</div>
          <div class="o-val">
            <% const mdd = decideDisplaySSR(o); %>
            <div class="st-stack">
              <span class="pill progress <%= mdd.isDone ? 'ok' : '' %>">
                <% if (mdd.showPct) { %>
                  ดำเนินการ ~ <span class="pct" data-pct="<%= mdd.donePct %>"><%= mdd.donePct.toFixed(2) %>%</span>
                <% } else { %>
                  <%= mdd.label %>
                <% } %>
              </span>
              <div class="st-actions">
                <button type="button" class="xbtn xbtn-sync btn-refresh" data-id="<%= o._id %>" title="อัปเดตสถานะออเดอร์">🔄</button>
                <button type="button" class="xbtn xbtn-info open-order" title="รายละเอียด" data-id="<%= o._id %>">i</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </article>
  <% }) %>

  <% if (!(list||[]).length) { %>
    <div class="empty muted">ยังไม่มีออเดอร์ในช่วงนี้</div>
  <% } %>
</div>

<!-- ===== Modal: รายละเอียดคำสั่งซื้อ ===== -->
<div id="orderModal" class="omodal" role="dialog" aria-modal="true" aria-hidden="true">
  <div class="omodal-backdrop" data-close="1"></div>

  <div class="omodal-dialog">
    <header class="omodal-head">
      <div class="omodal-title">
        คำสั่งซื้อ ID: <span id="om-title">#</span>
      </div>
      <button class="omodal-close" title="ปิด" data-close="1">×</button>
    </header>

    <div class="omodal-body">
      <!-- ค่าใช้จ่าย -->
      <section class="omodal-sec">
        <h4>รายละเอียดค่าใช้จ่าย</h4>
        <div class="ometa">
          <div class="muted">ค่าใช้จ่าย ทั้งหมด</div>
          <div id="om-cost">-</div>
        </div>
      </section>

      <!-- ไทม์ไลน์คำสั่งซื้อ -->
      <section class="omodal-sec">
        <h4>ไทม์ไลน์คำสั่งซื้อ</h4>
        <div class="otimeline">
          <label class="ot-item">
            <input type="radio" name="otime" checked>
            <div>
              เวลาที่เซิร์ฟเวอร์อัปเดต
              <div class="ottime" id="om-updatedAt">-</div>
            </div>
          </label>
          <label class="ot-item">
            <input type="radio" name="otime">
            <div>
              เวลาที่คำสั่งซื้อเข้ามา
              <div class="ottime" id="om-createdAt">-</div>
            </div>
          </label>
        </div>
      </section>

      <!-- รายละเอียดคำสั่งซื้อ -->
      <section class="omodal-sec">
        <h4>รายละเอียดคำสั่งซื้อ</h4>
        <div class="ometa">
          <div class="muted">ลิงก์</div>
          <div class="olink"><a id="om-link" href="#" target="_blank" rel="noopener">-</a></div>

          <div class="muted">ปริมาณ</div>
          <div id="om-qty" class="mono">-</div>

          <div class="muted">เริ่มจาก</div>
          <div id="om-start" class="mono">-</div>

          <div class="muted" hidden>นับปัจจุบัน (current)</div>
          <div id="om-current" class="mono" hidden>-</div>

          <div class="muted">ปริมาณที่เหลือ</div>
          <div>
            <div class="oprog" style="margin-bottom:6px">
              <span class="opct" id="om-left-pct">0.00%</span>
              <div class="opbar"><i id="om-bar" style="width:0%"></i></div>
            </div>
            <div class="mono muted">
              เหลือ <span id="om-left-abs">0</span> จากทั้งหมด <span id="om-qty-abs">0</span>
            </div>
          </div>
        </div>
      </section>
    </div>

    <footer class="omodal-foot">
      <button class="btn-ghost" data-close="1">ปิด</button>
      <button id="om-refresh" class="btn-ghost">รีเฟรชสถานะ</button>
    </footer>
  </div>
</div>

<script>
/* ==== ส่งข้อมูลออเดอร์มาไว้ฝั่ง client (เฉพาะที่ต้องใช้ใน modal) ==== */
window.__ORDERS__ = <%- JSON.stringify((list||[]).map(o => ({
  _id: o._id,
  providerOrderId: o.providerOrderId,
  link: o.link,
  quantity: o.quantity,
  startCount: o.startCount ?? null,
  currentCount: o.currentCount ?? null,
  remains: o.remains ?? null,
  progress: o.progress ?? null,
  status: o.status,
  createdAt: o.createdAt,
  updatedAt: o.updatedAt ?? o.createdAt,
  currency: (o.currency || o.service?.currency || 'THB'),
  estCost: (o.estCost ?? o.cost ?? (((o.quantity||0)/1000) * (o.service?.rate||0)))
}))) %>;

(function(){
  const $ = (s,r=document)=>r.querySelector(s);

  // utils
  const fmtDate = x => {
    if(!x) return '-';
    try{ return new Date(x).toLocaleString(); }catch{ return '-'; }
  };
  const fmtMoney = (n,cur='THB') =>
    (Number(n)||0).toLocaleString(undefined,{minimumFractionDigits:3, maximumFractionDigits:3}) + ' ' + cur;

  function clamp01(x){ return Math.max(0, Math.min(1, x)); }

  // คำนวณเปอร์เซ็นต์ ทำ/เหลือ (ใช้ใน modal)
  function calcPercents(o){
    const qty = Number(o.quantity)||0;
    if (qty <= 0){
      const progress = (typeof o.progress === 'number') ? clamp01(o.progress/100) : 0;
      return { donePct: progress*100, leftPct: (1-progress)*100, leftAbs: null };
    }
    if (typeof o.remains === 'number') {
      const r = Math.max(0, o.remains);
      const leftPct = clamp01(r/qty)*100;
      const donePct = 100 - leftPct;
      return { donePct, leftPct, leftAbs: r };
    }
    if (typeof o.progress === 'number'){
      const donePct = clamp01(o.progress/100)*100;
      const leftPct = 100 - donePct;
      const leftAbs = Math.round((leftPct/100)*qty);
      return { donePct, leftPct, leftAbs };
    }
    if (typeof o.startCount === 'number' && typeof o.currentCount === 'number'){
      const gained = Math.max(0, o.currentCount - o.startCount);
      const donePct = clamp01(gained/qty)*100;
      const leftPct = 100 - donePct;
      const leftAbs = Math.max(0, qty - gained);
      return { donePct, leftPct, leftAbs };
    }
    const st = String(o.status||'').toLowerCase();
    if (st === 'completed') return { donePct:100, leftPct:0, leftAbs:0 };
    if (st === 'processing') return { donePct:0, leftPct:100, leftAbs:qty };
    return { donePct:0, leftPct:100, leftAbs:qty };
  }

  // ===== Modal =====
  const wrap = $('#orderModal');
  const title = $('#om-title'), cost = $('#om-cost'), link = $('#om-link');
  const qty = $('#om-qty'), start = $('#om-start'), current = $('#om-current');
  const leftAbsEl = $('#om-left-abs'), qtyAbsEl = $('#om-qty-abs');
  const leftPctEl = $('#om-left-pct'), bar = $('#om-bar');
  const createdAt = $('#om-createdAt'), updatedAt = $('#om-updatedAt');
  const btnRefresh = $('#om-refresh');

  let currentId = null;

  function render(o){
    currentId = o._id;
    title.textContent = '#' + (o.providerOrderId || '-');
    cost.textContent  = fmtMoney(o.estCost, o.currency);
    link.href = o.link; link.textContent = o.link;

    qty.textContent    = Number(o.quantity)||0;
    start.textContent  = (o.startCount ?? '-');
    current.textContent= (o.currentCount ?? '-');

    createdAt.textContent = fmtDate(o.createdAt);
    updatedAt.textContent = fmtDate(o.updatedAt);

    const { donePct, leftPct, leftAbs } = calcPercents(o);
    leftPctEl.textContent = leftPct.toFixed(2) + '%';
    bar.style.width = donePct + '%';

    qtyAbsEl.textContent  = Number(o.quantity)||0;
    leftAbsEl.textContent = (leftAbs==null ? '—' : leftAbs);
  }

  function openModal(o){
    render(o);
    wrap.classList.add('show');
    wrap.setAttribute('aria-hidden','false');
    document.documentElement.style.overflow = 'hidden';
  }
  function closeModal(){
    wrap.classList.remove('show');
    wrap.setAttribute('aria-hidden','true');
    document.documentElement.style.overflow = '';
    currentId = null;
  }

  document.addEventListener('click', e=>{
    const btn = e.target.closest('.open-order'); if(!btn) return;
    e.preventDefault();
    const row = btn.closest('[data-order-id]');
    const id  = row?.dataset?.orderId;
    const o   = (window.__ORDERS__||[]).find(x=>x._id===id);
    if (o) openModal(o);
  });

  btnRefresh.addEventListener('click', async ()=>{
    if(!currentId) return;
    btnRefresh.disabled = true; const keep = btnRefresh.textContent; btnRefresh.textContent='กำลังรีเฟรช…';
    try{
      const res = await fetch(`/api/orders/${currentId}/refresh`, {method:'POST'});
      const data = await res.json();

      const arr = window.__ORDERS__||[];
      const idx = arr.findIndex(x=>x._id===currentId);
      if (idx>-1){
        const o = arr[idx];
        o.status       = data.status ?? o.status;
        if (typeof data.progress === 'number')      o.progress = data.progress;
        if (typeof data.remains  === 'number')      o.remains  = data.remains;
        if (typeof data.start_count === 'number')   o.startCount   = data.start_count;
        if (typeof data.current_count === 'number') o.currentCount = data.current_count;
        o.updatedAt = data.updatedAt ?? new Date().toISOString();
        render(o);
      }
    }catch{}
    btnRefresh.disabled = false; btnRefresh.textContent = keep;
  });

  wrap.addEventListener('click', e=>{
    if (e.target.dataset.close) closeModal();
  });
  document.addEventListener('keydown', e=>{
    if(e.key==='Escape' && wrap.classList.contains('show')) closeModal();
  });

  /* ===== UI helpers (ใช้ทั้ง Desktop & Mobile) ===== */

  // อัปเดต DOM ทั้งฝั่งตารางและการ์ดให้ตรงกับ payload ล่าสุด
  window.applyOrderPatch = function(payload){
    // sync cache
    const arr = window.__ORDERS__ || [];
    const idx = arr.findIndex(x => x._id === payload._id);
    if (idx > -1) {
      Object.assign(arr[idx], {
        status: payload.status ?? arr[idx].status,
        progress: payload.progress ?? arr[idx].progress,
        remains: payload.remains ?? arr[idx].remains,
        startCount: payload.startCount ?? arr[idx].startCount,
        currentCount: payload.currentCount ?? arr[idx].currentCount,
        updatedAt: payload.updatedAt ?? arr[idx].updatedAt
      });
    }

    const displayPayload = {
      status: payload.status,
      progress: payload.progress,
      remains: payload.remains,
      startCount: payload.startCount,
      currentCount: payload.currentCount,
      quantity: (payload.quantity != null ? payload.quantity :
                 (idx > -1 ? arr[idx].quantity : 0))
    };

    // Desktop row
    const tr = document.querySelector(`tr[data-order-id="${payload._id}"]`);
    if (tr) {
      tr.dataset.status = String(payload.status || '').toLowerCase();
      renderProgressPill(tr, displayPayload);
    }

    // Mobile card
    const card = document.querySelector(`.o-card[data-order-id="${payload._id}"]`);
    if (card) {
      card.dataset.status = String(payload.status || '').toLowerCase();
      renderProgressPill(card, displayPayload);
    }
  };

  // รองรับทั้ง .pill.long (ใหม่) และ .pill.progress (เดิม)
  window.renderProgressPill = function(container, payload){
    const pillLong = container?.querySelector?.('.pill.long') || container?.querySelector?.('.pill.progress');
    if (!pillLong) return;

    const dd = (window.decideDisplay ? window.decideDisplay(payload) : null) ||
               { label:'รอดำเนินการ', donePct:0, showPct:false, isDone:false };

    pillLong.classList.toggle('ok', !!dd.isDone);

    // โครงสร้างใหม่: มี .bar + .label
    const barEl = pillLong.querySelector('.bar');
    const lblEl = pillLong.querySelector('.label');
    if (barEl && lblEl) {
      barEl.style.width = (dd.isDone ? 100 : Math.max(0, Math.min(100, dd.donePct))) + '%';
      lblEl.innerHTML = dd.showPct
        ? `ดำเนินการ ~ <span class="pct">${Number(dd.donePct||0).toFixed(2)}%</span>`
        : dd.label;
      return;
    }

    // fallback: pill เดิม
    pillLong.innerHTML = dd.showPct
      ? `ดำเนินการ ~ <span class="pct" data-pct="${dd.donePct}">${Number(dd.donePct||0).toFixed(2)}%</span>`
      : dd.label;
  };
})();
</script>

<script>
(() => {
  const $  = (s,r=document)=>r.querySelector(s);
  const $$ = (s,r=document)=>Array.from(r.querySelectorAll(s));

  /* === decideDisplay (ฝั่ง client) === */
  window.decideDisplay = function(o){
    const qty = Number(o.quantity)||0;
    const st  = String(o.status||'').toLowerCase();

    const isWaiting =
      st === 'processing' &&
      (o.progress == null) &&
      ((typeof o.remains === 'number' ? o.remains >= qty : true) || o.currentCount == null);

    if (isWaiting) return { label: 'รอดำเนินการ', donePct: 0, showPct: false, isDone: false };

    let donePct = 0;
    if (typeof o.progress === 'number') {
      donePct = Math.max(0, Math.min(100, o.progress));
    } else if (typeof o.remains === 'number' && qty > 0) {
      donePct = Math.max(0, Math.min(100, (1 - Math.max(0, o.remains)/qty) * 100));
    } else if (typeof o.startCount === 'number' && typeof o.currentCount === 'number' && qty > 0) {
      donePct = Math.max(0, Math.min(100, ((o.currentCount - o.startCount)/qty) * 100));
    }
    const isDone = (st === 'completed') || donePct >= 99.995;

    return isDone
      ? { label: 'เสร็จสิ้น', donePct: 100, showPct: false, isDone: true }
      : { label: `ดำเนินการ ~ ${donePct.toFixed(2)}%`, donePct, showPct: true, isDone: false };
  };

  /* ---------- ปุ่ม/ยูทิล ---------- */
  function setBusy(btns, on=true){
    btns.forEach(b => {
      if(!b) return;
      if(on){
        b.disabled = true;
        b.dataset.keep = b.textContent;
        b.textContent = '…';
      }else{
        b.disabled = false;
        if(b.dataset.keep){ b.textContent = b.dataset.keep; delete b.dataset.keep; }
      }
    });
  }

  /* ---------- refresh-all แบบไม่ reload หน้า ---------- */
  function setBusy(targets, on = true) {
    // รองรับ single node หรือ array
    const list = Array.isArray(targets) ? targets : [targets];
    const seen = new Set();

    for (const el of list) {
      if (!el || seen.has(el)) continue;
      seen.add(el);

      if (on) {
        // เซฟ HTML เดิมไว้ 1 ครั้ง
        if (!el.dataset.savedHtml) el.dataset.savedHtml = el.innerHTML;
        // ตั้งสถานะ busy (ไม่เปลี่ยนข้อความ)
        el.disabled = true;                   // กันกดซ้ำ
        el.setAttribute('aria-busy', 'true'); // สำหรับ CSS/assistive tech
        el.classList.add('is-loading');
      } else {
        // คืนสภาพเดิม
        el.disabled = false;
        el.removeAttribute('aria-busy');
        el.classList.remove('is-loading');
        if (el.dataset.savedHtml) el.innerHTML = el.dataset.savedHtml;
      }
    }
  }

  async function refreshAll(triggerBtn){
    const btnSync = $('#btnSync');       // สมมติว่ามี helper $
    const rowBtns = $$('.btn-refresh');  // สมมติว่ามี helper $$

    // รวมเป้าหมายและลบตัวซ้ำ
    const targets = [triggerBtn, btnSync, ...rowBtns].filter(Boolean);
    const uniqTargets = [...new Set(targets)];

    setBusy(uniqTargets, true);
    try{
      const res = await fetch('/api/orders/refresh-all', { method: 'POST' });
      const data = await res.json();

      if (!data?.ok) throw new Error(data?.error || 'refresh failed');

      (data.changes || []).forEach(patch => {
        window.applyOrderPatch(patch);
      });
    }catch(e){
      console.error(e);
      // TODO: แจ้ง error ตาม UX ที่ต้องการ (toast/alert)
    }finally{
      // ✅ ไม่ว่าผลจะเป็นอย่างไร คืนปุ่มเสมอ
      setBusy(uniqTargets, false);
    }
  }

  /* ---------- ค้นหาเร็ว ---------- */
  $('#quick')?.addEventListener('input', e=>{
    const q = e.target.value.trim().toLowerCase();
    $$('#orderTable tbody tr').forEach(tr=>{
      const text = tr.innerText.toLowerCase();
      tr.style.display = text.includes(q) ? '' : 'none';
    });
    $$('#orderCards .o-card').forEach(card=>{
      const text = card.innerText.toLowerCase();
      card.style.display = text.includes(q) ? '' : 'none';
    });
  });

  /* ---------- ตัวกรองสถานะ ---------- */
  $('#statusTabs')?.addEventListener('click', e=>{
    const b = e.target.closest('.chip'); if(!b) return;
    $('#statusTabs').querySelectorAll('.chip').forEach(x=>x.classList.remove('active'));
    b.classList.add('active');
    const st = b.dataset.st;
    const ok = el => (st==='all') || (el.dataset.status===st);
    $$('#orderTable tbody tr').forEach(tr=>tr.style.display = ok(tr) ? '' : 'none');
    $$('#orderCards .o-card').forEach(c=>c.style.display = ok(c) ? '' : 'none');
  });

  /* ---------- คัดลอกลิงก์ ---------- */
  document.addEventListener('click', e=>{
    const btn = e.target.closest('.btn-copy'); if(!btn) return;
    navigator.clipboard.writeText(btn.dataset.copy||'').then(()=>{
      const old = btn.textContent; btn.textContent='✅';
      setTimeout(()=>btn.textContent=old,900);
    });
  });

  /* ---------- ปุ่มซิงก์ ---------- */
  $('#btnSync')?.addEventListener('click', (e)=>{
    e.preventDefault();
    refreshAll(e.currentTarget);
  });
  document.addEventListener('click', (e)=>{
    const b = e.target.closest('.btn-refresh'); if(!b) return;
    e.preventDefault();
    refreshAll(b);
  });

  /* ---------- mobile card toggle ---------- */
  $('#orderCards')?.addEventListener('click', (e) => {
    const card = e.target.closest('.o-card'); if (!card) return;
    if (e.target.closest('a') || e.target.closest('button') || e.target.closest('.btn-copy') || e.target.closest('.btn-refresh')) return;
    card.classList.toggle('open');
    const t = card.querySelector('.o-toggle');
    if (t) t.textContent = card.classList.contains('open') ? '−' : '＋';
  });

  /* ---------- maps (เผื่อใช้ที่อื่น) ---------- */
  window.pillClass = window.pillClass || (s => {
    s = String(s||'').toLowerCase();
    if (s==='processing') return 'warn';
    if (s==='inprogress') return 'blue';
    if (s==='completed')  return 'ok';
    if (s==='partial')    return 'violet';
    if (s==='canceled')   return 'danger';
    return '';
  });
  window.thStatus = window.thStatus || (s => ({
    processing: 'รอดำเนินการ',
    inprogress: 'กำลังทำ',
    completed:  'เสร็จสิ้น',
    partial:    'บางส่วน',
    canceled:   'ยกเลิก',
  }[String(s||'').toLowerCase()] || s));
})();
</script>
