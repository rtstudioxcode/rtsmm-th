<!-- // history.ejs -->
<% const title = "ประวัติการใช้บริการ Social"; %>
<% bodyClass = 'orders-wide'; %>
<%
function decideDisplaySSR(o){
  const qty = Number(o.quantity)||0;
  const st  = String(o.status||'').toLowerCase();

  if (st === 'canceled') {
    return { label: 'ยกเลิก', donePct: 0, showPct: false, isDone: false };
  }

  if (st === 'canceling') {
    return { label: 'กำลังยกเลิก…', donePct: 0, showPct: false, isDone: false };
  }

  if (st === 'partial') {
    return { label: 'คืนบางส่วน', donePct: 0, showPct: false, isDone: false };
  }

  const isWaiting =
    st === 'processing' &&
    (o.progress == null) &&
    ((typeof o.remains === 'number' ? o.remains >= qty : true) || o.currentCount == null);

  if (isWaiting) return { label: 'รอดำเนินการ', donePct: 0, showPct: false, isDone: false };

  let donePct = 0;
  if (typeof o.progress === 'number') {
    donePct = Math.max(0, Math.min(100, o.progress));
  } else if (typeof o.remains === 'number' && qty > 0) {
    donePct = Math.max(0, Math.min(100, (1 - Math.max(0, o.remains)/qty) * 100));
  } else if (typeof o.startCount === 'number' && typeof o.currentCount === 'number' && qty > 0) {
    donePct = Math.max(0, Math.min(100, ((o.currentCount - o.startCount)/qty) * 100));
  }
  const isDone = (st === 'completed') || donePct >= 99.995;

  return isDone
    ? { label: 'เสร็จสิ้น', donePct: 100, showPct: false, isDone: true }
    : { label: `ดำเนินการ ~ ${donePct.toFixed(2)}%`, donePct, showPct: true, isDone: false };
}
%>
<%
// helper แปลงวันเวลาไทย (พ.ศ.)
function fmtTH(d){
  try {
    return new Date(d).toLocaleString('th-TH', {
      timeZone: 'Asia/Bangkok',
      year: 'numeric',      // พ.ศ.
      month: 'long',        // เดือนภาษาไทย
      day: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
      hour12: false
    });
  } catch { return '-'; }
}

// เฉพาะวันที่ (ไม่เอาเวลา)
function fmtTHDate(d){
  try {
    return new Date(d).toLocaleDateString('th-TH', {
      timeZone: 'Asia/Bangkok',
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    });
  } catch { return '-'; }
}
%>

<section class="orders-history page-head">
  <div class="page-title">
    <h1>ประวัติการใช้บริการ Social</h1>
    <small class="muted">หน้าหลัก → ประวัติการใช้บริการ Social</small>
  </div>

  <!-- <div class="right-actions">
    <button id="btnSync" class="btn primary">
      <span style="font-size:14px;">🔄</span> อัปเดตสถานะล่าสุด
    </button>
  </div> -->
</section>

<% if (typeof syncError === 'string' && syncError) { %>
  <div class="orders-history alert error">⚠️ <%= syncError %></div>
<% } else { %>
  <div class="orders-history alert info">
    ℹ️ ระบบจะอัปเดตสถานะอัตโนมัติทุก ~ 1–2 นาที 
  </div>
<% } %>

<!-- แท็บตัวกรองสถานะ -->
<div class="orders-history tabs chips" id="statusTabs">
  <button class="chip active" data-st="all">ทั้งหมด</button>
  <button class="chip" data-st="processing">รอดำเนินการ</button>
  <button class="chip" data-st="inprogress">กำลังทำ</button>
  <button class="chip" data-st="completed">เสร็จสิ้น</button>
  <button class="chip" data-st="partial">คืนบางส่วน</button>
  <button class="chip" data-st="canceled">ยกเลิก</button>
</div>

<!-- ฟิลเตอร์ -->
<form class="orders-history filters card" method="get">
  <div class="row wrap">
    <div class="inline">
      <label class="muted">ช่วงเวลา</label>
      <input class="input" type="date" name="from" value="<%= from || '' %>" />
      <span class="muted">–</span>
      <input class="input" type="date" name="to"   value="<%= to || '' %>" />
    </div>

    <div class="inline">
      <label class="muted">ค้นหาแบบละเอียด</label>
      <div class="searchbox">
        <span aria-hidden="true">🔎</span>
        <input class="input" name="q" id="q" placeholder="ค้นหา ID/ลิงก์/บริการ…" value="<%= q||'' %>">
        <button class="btn">ค้นหา</button>
      </div>
    </div>

    <div class="inline grow">
      <label class="muted">ค้นหาเร็ว</label>
      <input class="input" id="quick" placeholder="พิมพ์เพื่อกรองทันที…">
    </div>
  </div>
</form>

<!-- ตารางออเดอร์ (เดสก์ท็อป) -->
<div class="orders-history table-wrap card order-desktop">
  <table class="table order-table" id="orderTable">
    <thead>
      <tr>
        <th style="width:62px">ID</th>
        <th style="width:170px">วันที่</th>
        <th>บริการ / ลิงก์</th>
        <th style="width:140px">ค่าใช้จ่าย</th>
        <th style="width:110px">ปริมาณ</th>
        <th style="width:160px">สถานะ</th>
      </tr>
    </thead>
    <tbody>
      <% (list || []).forEach(o => { %>
        <tr data-status="<%= (o.status||'').toLowerCase() %>" data-order-id="<%= o._id %>">
          <td>
            <a class="mono" href="/orders/<%= o._id %>" title="DB _id: <%= o._id %>">
              <%= o.providerOrderId || '-' %>
            </a>
          </td>
          <td class="mono"><%= fmtTH(o.createdAt) %></td>
          <td>
            <div class="svc">
              <div class="svc-name">
                <span class="badge soft">#<%= o.service?.providerServiceId || o.providerServiceId || '-' %></span>
                <b><%= o.service?.name || o.serviceName || '-' %></b>
                <% if (o.meta?.country) { %><span class="badge flag"><%= o.meta.country %></span><% } %>
                <% if (o.meta?.speed)   { %><span class="badge blue"><%= o.meta.speed %></span><% } %>
              </div>
              <div class="link ellipsis">
                <span class="muted" aria-hidden="true">🔗</span>
                <a href="<%= o.link %>" target="_blank" rel="noopener"><%= o.link %></a>
              </div>
            </div>
          </td>
          <td class="mono">
            <%
              const costNum = Number(
                o.estCost ?? o.cost ?? (((o.quantity||0)/1000) * (o.service?.rate||0))
              );
              const costText = Number.isFinite(costNum)
                ? costNum.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })
                : '0.00';
              const cur = o.currency || o.service?.currency || 'THB';
            %>
            <%= costText %> <%= cur %>
          </td>
          <td class="mono"><%= o.quantity %></td>
          <td class="st-cell">
            <% const dd = decideDisplaySSR(o); %>
            <%
              const canCancel  = !!(o.uiFlags && o.uiFlags.canCancel);
              const isDone     = !!(o.uiFlags && o.uiFlags.isDone);
              const canRepeat  = isDone && !!(o.service && o.service._id);
              const stLower    = String(o.status||'').toLowerCase();
            %>

          <div class="st-block">
            <!-- pill สถานะยาว -->
            <div
              class="pill long <%= dd.isDone
                ? 'ok'
                : (stLower==='canceled' ? 'danger'
                  : (stLower==='canceling' ? 'warn'
                    : (stLower==='partial' ? 'warn' : ''))) %>"
              data-pct="<%= dd.donePct %>">

              <i class="bar" style="width:<%= (stLower==='canceling')
                ? '0'
                : (dd.isDone ? '100' : dd.donePct) %>%"></i>

              <span class="label">
                <% const isPartialRefund =
                    (stLower==='canceled' && Number(o.refundAmount||0)>0 && o.refundType==='partial'); %>
                <% if (isPartialRefund) { %>
                  <span class="badge warn" style="margin-right:8px">คืนบางส่วน</span>
                <% } %>

                <% if (stLower === 'canceling') { %>
                  <!-- ⬅️ กำลังสั่งยกเลิก -->
                  กำลังส่งยกเลิก…
                <% } else if (dd.showPct) { %>
                  ดำเนินการ ~ <span class="pct"><%= dd.donePct.toFixed(2) %>%</span>
                <% } else { %>
                  <%= dd.label %>
                <% } %>
              </span>
            </div>

            <!-- ปุ่มใต้สถานะ -->
            <div class="st-actions under">
              <% if (o.uiFlags?.canCancel) { %>
                <button
                  type="button"
                  class="xbtn xbtn-sync btn-cancel"
                  title="ยกเลิกออเดอร์นี้"
                  onclick="startCancel('<%= o._id %>')">
                  <img src="/static/assets/emoji/cancel.png" alt="" class="icon" />
                </button>
              <% } %>

              <% if (!(dd.isDone || stLower === 'canceled' || stLower === 'partial' || stLower === 'canceling')) { %>
                <button type="button" class="xbtn xbtn-sync btn-refresh" data-id="<%= o._id %>"
                        title="อัปเดตสถานะออเดอร์" aria-label="อัปเดตสถานะออเดอร์">
                  <img src="/static/assets/emoji/updatestatus.png" alt="" class="icon" />
                </button>
              <% } %>

              <% const isPartialRefundCanceled = (stLower === 'canceled' && Number(o.refundAmount||0)>0 && o.refundType==='partial'); %>
              <% const canRepeatStrict = ((stLower === 'completed') || (stLower === 'partial') || isPartialRefundCanceled) && !!(o.service && o.service._id); %>
              <% if (canRepeatStrict) { %>
                <button type="button" class="xbtn xbtn-primary btn-repeat" data-id="<%= o._id %>"
                        title="สั่งซ้ำรายการนี้" aria-label="สั่งซ้ำรายการนี้">
                  <img src="/static/assets/emoji/repeat.png" alt="" class="icon" />
                </button>
              <% } %>

              <button type="button" class="xbtn xbtn-info open-order" data-id="<%= o._id %>"
                      title="รายละเอียด" aria-label="รายละเอียด">
                <img src="/static/assets/emoji/detail.png" alt="" class="icon" />
              </button>
            </div>
          </div>
        </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
  
  <% if (!(list||[]).length) { %>
    <div class="empty muted">ยังไม่มีออเดอร์ในช่วงนี้</div>
  <% } %>
</div>

<!-- การ์ดออเดอร์ (มือถือ) -->
<div class="orders-history order-cards" id="orderCards">
  <% (list || []).forEach(o => { 
     const st = (o.status||'').toLowerCase();
  %>
    <article class="o-card" data-status="<%= st %>" data-order-id="<%= o._id %>">
      <header class="o-head">
        <div class="o-id mono">
          <a href="/orders/<%= o._id %>" title="DB _id: <%= o._id %>">
            <%= o.providerOrderId || '-' %>
          </a>
        </div>
        <div class="o-date mono"><%= fmtTH(o.createdAt) %></div>
        <button class="o-toggle" aria-label="toggle">＋</button>
      </header>

      <div class="o-body">
        <div class="o-row">
          <div class="o-label">บริการ / ลิงก์</div>
          <div class="o-val">
            <div class="svc-name">
              <span class="badge soft">#<%= o.service?.providerServiceId || o.providerServiceId || '-' %></span>
              <b><%= o.service?.name || o.serviceName || '-' %></b>
              <% if (o.meta?.country) { %><span class="badge flag"><%= o.meta.country %></span><% } %>
              <% if (o.meta?.speed)   { %><span class="badge blue"><%= o.meta.speed %></span><% } %>
            </div>
            <div class="link">
              <span class="muted" aria-hidden="true">🔗</span>
              <a href="<%= o.link %>" target="_blank" rel="noopener"><%= o.link %></a>
            </div>
          </div>
        </div>

        <div class="o-row">
          <div class="o-label">ค่าใช้จ่าย</div>
          <div class="o-val mono">
            <%
              const mCostNum = Number(
                o.estCost ?? o.cost ?? (((o.quantity||0)/1000) * (o.service?.rate||0))
              );
              const mCostText = Number.isFinite(mCostNum)
                ? mCostNum.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })
                : '0.00';
              const mCur = o.currency || o.service?.currency || 'THB';
            %>
            <%= mCostText %> <%= mCur %>
          </div>
        </div>

        <div class="o-row">
          <div class="o-label">ปริมาณ</div>
          <div class="o-val mono"><%= o.quantity %></div>
        </div>

        <div class="o-row">
          <div class="o-label">สถานะ</div>
          <div class="o-val">
            <% const mdd = decideDisplaySSR(o); %>
            <%
              const canCancel = !!(o.uiFlags && o.uiFlags.canCancel);
              const isDone    = !!(o.uiFlags && o.uiFlags.isDone);
              const canRepeat = isDone && !!(o.service && o.service._id);
            %>
            <% const stLower = String(o.status||'').toLowerCase(); %>

            <div class="st-stack">
              <span
                class="pill progress <%= mdd.isDone
                  ? 'ok'
                  : (stLower==='canceled' ? 'danger'
                    : (stLower==='canceling' ? 'warn'
                      : (stLower==='partial' ? 'warn' : ''))) %>"
                data-pct="<%= (stLower==='canceling') ? 0 : mdd.donePct %>">

                <% const isPartialRefund = (
                    stLower === 'canceled' &&
                    Number(o.refundAmount || 0) > 0 &&
                    o.refundType === 'partial'
                  ); %>

                <% if (isPartialRefund) { %>
                  <span class="badge warn" style="margin-right:8px">คืนบางส่วน</span>
                <% } %>

                <% if (stLower === 'canceling') { %>
                  กำลังส่งยกเลิก…
                <% } else if (mdd.showPct) { %>
                  ดำเนินการ ~ <span class="pct" data-pct="<%= mdd.donePct %>"><%= mdd.donePct.toFixed(2) %>%</span>
                <% } else { %>
                  <%= mdd.label %>
                <% } %>
              </span>
              <div class="st-actions">
                <!-- ยกเลิก: เฉพาะ "processing" -->
                <% if (o.uiFlags?.canCancel) { %>
                  <button
                    type="button"
                    class="xbtn xbtn-sync btn-cancel"
                    style="width:100%;"
                    title="ยกเลิกออเดอร์นี้"
                    onclick="startCancel('<%= o._id %>')">
                    <img src="/static/assets/emoji/cancel.png" alt="" class="icon" />
                  </button>
                <% } %>

                <!-- รีเฟรช: ไม่แสดงเมื่อ completed หรือ canceled -->
                <% if (!(mdd.isDone || stLower === 'canceled' || stLower === 'partial' || stLower === 'canceling')) { %>
                  <button
                    type="button"
                    class="xbtn xbtn-sync btn-refresh"
                    data-id="<%= o._id %>"
                    title="อัปเดตสถานะออเดอร์"
                    aria-label="อัปเดตสถานะออเดอร์">
                    <img src="/static/assets/emoji/updatestatus.png" alt="" class="icon" />
                  </button>
                <% } %>

                <!-- สั่งซื้อใหม่: เฉพาะ "completed" -->
                <% const isPartialRefundCanceled = (stLower === 'canceled' && Number(o.refundAmount||0) > 0 && o.refundType === 'partial'); %>
                <% const canRepeatStrict = ((stLower === 'completed') || (stLower === 'partial') || isPartialRefundCanceled) && !!(o.service && o.service._id); %>
                <% if (canRepeatStrict) { %>
                  <button
                    type="button"
                    class="xbtn xbtn-primary btn-repeat"
                    data-id="<%= o._id %>"
                    title="สั่งซ้ำรายการนี้"
                    aria-label="สั่งซ้ำรายการนี้">
                    <img src="/static/assets/emoji/repeat.png" alt="" class="icon" />
                  </button>
                <% } %>

                <button
                  type="button"
                  class="xbtn xbtn-info open-order"
                  data-id="<%= o._id %>"
                  title="รายละเอียด"
                  aria-label="รายละเอียด">
                  <img src="/static/assets/emoji/detail.png" alt="" class="icon" />
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </article>
  <% }) %>

  <% if (!(list||[]).length) { %>
    <div class="empty muted">ยังไม่มีออเดอร์ในช่วงนี้</div>
  <% } %>
</div>

<!-- ───── Page Controls (ใต้รายการ) ───── -->
<%
  const pageNum    = Number(typeof page    !== 'undefined' ? page    : 1)  || 1;
  const perPageNum = Number(typeof perPage !== 'undefined' ? perPage : 20) || 20;
  const totalCount = Number(typeof total   !== 'undefined' ? total   : 0)  || 0;

  const pages   = Math.max(1, Math.ceil(totalCount / Math.max(1, perPageNum)));
  const fromIdx = totalCount ? Math.min(totalCount, (pageNum - 1) * perPageNum + 1) : 0;
  const toIdx   = totalCount ? Math.min(totalCount, pageNum * perPageNum) : 0;

  const keep = {
    from: (typeof from   !== 'undefined' ? from   : ''),
    to:   (typeof to     !== 'undefined' ? to     : ''),
    q:    (typeof q      !== 'undefined' ? q      : ''),
    st:   (typeof status !== 'undefined' ? status : '')
  };

  function linkTo(p, pp) {
    const sp = new URLSearchParams();
    if (keep.from) sp.set('from', keep.from);
    if (keep.to)   sp.set('to',   keep.to);
    if (keep.q)    sp.set('q',    keep.q);
    if (keep.st)   sp.set('status', keep.st);
    sp.set('page', p);
    sp.set('perPage', pp);
    return '/my/orders?' + sp.toString();
  }

  const PERPAGE_OPTIONS = [10, 20, 50, 100, 250, 500, 1000];
%>

<div class="pager-wrap">
  <div class="pager-left">
    <label class="muted" style="margin-right:8px;">แสดง</label>
    <div class="perpage">
      <select id="ppSelect" class="pp-select">
        <% PERPAGE_OPTIONS.forEach(n => { %>
          <option value="<%= n %>" <%= perPageNum===n ? 'selected' : '' %>><%= n %></option>
        <% }) %>
        <option value="all" <%= (perPageNum>=totalCount && totalCount>0) ? 'selected' : '' %>>All records</option>
      </select>
    </div>
    <span class="muted" style="margin-left:8px;">แถว</span>
  </div>

  <div class="pager-center muted">
    <% if (totalCount > 0) { %>
      แสดง <%= fromIdx %> ถึง <%= toIdx %> จาก <%= totalCount %> แถว
    <% } else { %>ไม่มีข้อมูล<% } %>
  </div>

  <nav class="pager-right" aria-label="pagination">
    <a class="page-btn <%= pageNum<=1 ? 'disabled' : '' %>" href="<%= pageNum<=1 ? '#' : linkTo(pageNum-1, perPageNum) %>">ก่อนหน้า</a>

    <%
      const span = 2;
      const start = Math.max(1, pageNum - span);
      const end   = Math.min(pages, pageNum + span);
      const showFirst = start > 1;
      const showLast  = end < pages;
    %>

    <% if (showFirst) { %>
      <a class="page-btn" href="<%= linkTo(1, perPageNum) %>">1</a>
      <% if (start > 2) { %><span class="page-ellipsis">…</span><% } %>
    <% } %>

    <% for (let p=start; p<=end; p++) { %>
      <a class="page-btn <%= p===pageNum ? 'active' : '' %>" href="<%= linkTo(p, perPageNum) %>"><%= p %></a>
    <% } %>

    <% if (showLast) { %>
      <% if (end < pages-1) { %><span class="page-ellipsis">…</span><% } %>
      <a class="page-btn" href="<%= linkTo(pages, perPageNum) %>"><%= pages %></a>
    <% } %>

    <a class="page-btn <%= pageNum>=pages ? 'disabled' : '' %>" href="<%= pageNum>=pages ? '#' : linkTo(pageNum+1, perPageNum) %>">ถัดไป</a>
  </nav>
</div>

<div id="page-bottom"></div>

<!-- ===== Modal: รายละเอียดคำสั่งซื้อ ===== -->
<div id="orderModal" class="omodal" role="dialog" aria-modal="true" aria-hidden="true">
  <div class="omodal-backdrop" data-close="1"></div>

  <div class="omodal-dialog">
    <header class="omodal-head">
      <div class="omodal-title">
        คำสั่งซื้อ ID: <span id="om-title">#</span>
      </div>
      <button class="omodal-close" title="ปิด" data-close="1">×</button>
    </header>

    <div class="omodal-body">
      <!-- ค่าใช้จ่าย -->
      <section class="omodal-sec">
        <h4>รายละเอียดค่าใช้จ่าย</h4>
        <div class="ometa">
          <div class="muted">ค่าใช้จ่าย ทั้งหมด</div>
          <div id="om-cost">-</div>

          <div class="muted" id="om-refund-label" style="margin-top:8px; display:none;">ยอดคืนเงิน</div>
          <div id="om-refund" style="display:none;">-</div>
        </div>
      </section>

      <!-- ไทม์ไลน์คำสั่งซื้อ -->
      <section class="omodal-sec">
        <h4>ไทม์ไลน์คำสั่งซื้อ</h4>
        <div class="otimeline">
          <!-- จุดสุดท้าย (สถานะล่าสุด) -->
          <label class="ot-item ot-item--final">
            <input type="radio" name="otime" id="om-final-radio" checked>
            <div>
              <span id="om-final-label">สถานะล่าสุด</span>
              <div class="ottime" id="om-final-time">-</div>
            </div>
          </label>

          <!-- เวลาที่เซิร์ฟเวอร์อัปเดต -->
          <label class="ot-item">
            <input type="radio" name="otime" disabled>
            <div>
              เวลาที่เซิร์ฟเวอร์อัปเดต
              <div class="ottime" id="om-updatedAt">-</div>
            </div>
          </label>

          <!-- เวลาที่คำสั่งซื้อเข้ามา -->
          <label class="ot-item">
            <input type="radio" name="otime" disabled>
            <div>
              เวลาที่คำสั่งซื้อเข้ามา
              <div class="ottime" id="om-createdAt">-</div>
            </div>
          </label>
        </div>
      </section>

      <!-- รายละเอียดคำสั่งซื้อ -->
      <section class="omodal-sec">
        <h4>รายละเอียดคำสั่งซื้อ</h4>
        <div class="ometa">
          <div class="muted">ลิงก์</div>
          <div class="olink"><a id="om-link" href="#" target="_blank" rel="noopener">-</a></div>

          <div class="muted">ปริมาณ</div>
          <div id="om-qty" class="mono">-</div>

          <div class="muted">เริ่มจาก</div>
          <div id="om-start" class="mono">-</div>

          <div class="muted" hidden>นับปัจจุบัน (current)</div>
          <div id="om-current" class="mono" hidden>-</div>

          <div class="muted">ปริมาณที่เหลือ</div>
          <div>
            <div class="oprog" style="margin-bottom:6px">
              <span class="opct" id="om-left-pct">0.00%</span>
              <div class="opbar"><i id="om-bar" style="width:0%"></i></div>
            </div>
            <div class="mono muted">
              เหลือ <span id="om-left-abs">0</span> จากทั้งหมด <span id="om-qty-abs">0</span>
            </div>
          </div>
        </div>
      </section>
    </div>

    <footer class="omodal-foot">
      <button class="btn-ghost" data-close="1">ปิด</button>
      <button id="om-refresh" class="btn-ghost">รีเฟรชสถานะ</button>
    </footer>
  </div>
</div>

<script>
// === ไอคอนสถานะ (GLOBAL) ===
window.__STATUS_ICONS__ = {
  processing: '/static/assets/status/processing.png',
  inprogress: '/static/assets/status/inprogress.png',
  completed:  '/static/assets/status/completed.png',
  partial:    '/static/assets/status/partial.png',
  canceled:   '/static/assets/status/canceled.png',
  canceling:  '/static/assets/status/processing.png',
  default:    '/static/assets/status/processing.png'
};

window.ensureStatusIcon = function ensureStatusIcon(pill, status){
  if (!pill) return;
  const url = (window.__STATUS_ICONS__||{})[String(status||'').toLowerCase()] 
              || window.__STATUS_ICONS__.default;

  let ico = pill.querySelector(':scope .label .st-ico, :scope > .st-ico');
  if (!ico) {
    ico = document.createElement('span');
    ico.className = 'st-ico';
    const lbl = pill.querySelector(':scope .label');
    (lbl || pill).prepend(ico);
  }
  ico.style.setProperty('--st-ico', `url("${url}")`);
  pill.classList.add('has-ico');
};
</script>

<script>
/* ==== ส่งข้อมูลออเดอร์มาไว้ฝั่ง client (เฉพาะที่ต้องใช้ใน modal) ==== */
window.__ORDERS__ = <%- JSON.stringify((list||[]).map(o => ({
  _id: o._id,
  providerOrderId: o.providerOrderId,
  link: o.link,
  quantity: o.quantity,
  startCount: o.startCount ?? null,
  currentCount: o.currentCount ?? null,
  remains: o.remains ?? null,
  progress: o.progress ?? null,
  status: o.status,
  createdAt: o.createdAt,
  updatedAt: o.updatedAt ?? o.createdAt,
  currency: (o.currency || o.service?.currency || 'THB'),
  estCost: (o.estCost ?? o.cost ?? (((o.quantity||0)/1000) * (o.service?.rate||0))),
  serviceId: (o.service && o.service._id) || null, 
  svcProviderServiceId: (o.service && o.service.providerServiceId) || (o.providerServiceId || null),
  providerServiceId: o.providerServiceId || null,
  refundAmount: (o.refundAmount ?? 0),
  refundType: (o.refundType || null)
}))) %>;

(function(){
  const $ = (s,r=document)=>r.querySelector(s);

  // utils
  const fmtDate = x => {
    if(!x) return '-';
    try{ return new Date(x).toLocaleString(); }catch{ return '-'; }
  };
  const fmtMoney = (n,cur='THB') =>
    (Number(n)||0).toLocaleString(undefined,{minimumFractionDigits:3, maximumFractionDigits:3}) + ' ' + cur;

  function clamp01(x){ return Math.max(0, Math.min(1, x)); }

  // คำนวณเปอร์เซ็นต์ ทำ/เหลือ (ใช้ใน modal)
  function calcPercents(o){
    const qty = Number(o.quantity)||0;
    if (qty <= 0){
      const progress = (typeof o.progress === 'number') ? clamp01(o.progress/100) : 0;
      return { donePct: progress*100, leftPct: (1-progress)*100, leftAbs: null };
    }
    if (typeof o.remains === 'number') {
      const r = Math.max(0, o.remains);
      const leftPct = clamp01(r/qty)*100;
      const donePct = 100 - leftPct;
      return { donePct, leftPct, leftAbs: r };
    }
    if (typeof o.progress === 'number'){
      const donePct = clamp01(o.progress/100)*100;
      const leftPct = 100 - donePct;
      const leftAbs = Math.round((leftPct/100)*qty);
      return { donePct, leftPct, leftAbs };
    }
    if (typeof o.startCount === 'number' && typeof o.currentCount === 'number'){
      const gained = Math.max(0, o.currentCount - o.startCount);
      const donePct = clamp01(gained/qty)*100;
      const leftPct = 100 - donePct;
      const leftAbs = Math.max(0, qty - gained);
      return { donePct, leftPct, leftAbs };
    }
    const st = String(o.status||'').toLowerCase();
    if (st === 'partial') {
      return { label: 'คืนบางส่วน', donePct: 0, showPct: false, isDone: false };
    }
    if (st === 'completed') return { donePct:100, leftPct:0, leftAbs:0 };
    if (st === 'processing') return { donePct:0, leftPct:100, leftAbs:qty };
    return { donePct:0, leftPct:100, leftAbs:qty };
  }

  // ===== Modal =====
  const wrap = $('#orderModal');
  const title = $('#om-title'), cost = $('#om-cost'), link = $('#om-link');
  const qty = $('#om-qty'), start = $('#om-start'), current = $('#om-current');
  const leftAbsEl = $('#om-left-abs'), qtyAbsEl = $('#om-qty-abs');
  const leftPctEl = $('#om-left-pct'), bar = $('#om-bar');
  const createdAt = $('#om-createdAt'), updatedAt = $('#om-updatedAt');
  const btnRefresh = $('#om-refresh');

  let currentId = null;

  // ===== Render =====
  function render(o){
    currentId = o._id;
    title.textContent = '#' + (o.providerOrderId || '-');
    cost.textContent  = fmtMoney(o.estCost, o.currency);
    link.href = o.link; link.textContent = o.link;

    qty.textContent     = Number(o.quantity)||0;
    start.textContent   = (o.startCount ?? '-');
    current.textContent = (o.currentCount ?? '-');

    createdAt.textContent = fmtDate(o.createdAt);
    updatedAt.textContent = fmtDate(o.updatedAt);

    // ==== สรุปเปอร์เซ็นต์ ====
    const { donePct, leftPct, leftAbs } = calcPercents(o);
    leftPctEl.textContent = leftPct.toFixed(2) + '%';
    bar.style.width = donePct + '%';
    qtyAbsEl.textContent  = Number(o.quantity)||0;
    leftAbsEl.textContent = (leftAbs==null ? '—' : leftAbs);

    // ==== Refund display ====
    const refund = Number(o.refundAmount||0);
    const refLabel = document.getElementById('om-refund-label');
    const refVal   = document.getElementById('om-refund');
    if (refund > 0) {
      refLabel.style.display = '';
      refVal.style.display = '';
      refVal.textContent = fmtMoney(refund, o.currency) + (o.refundType==='partial' ? ' (คืนบางส่วน)' : ' (คืนเต็ม)');
    } else {
      refLabel.style.display = 'none';
      refVal.style.display = 'none';
    }

    // ==== ไทม์ไลน์: จุดสุดท้าย (แข็งแรง + ครอบคลุมสถานะ) ====
    const stRaw = String(o.status || '').toLowerCase();
    const isPartialRefundCanceled =
      stRaw === 'canceled' && o.refundType === 'partial' && Number(o.refundAmount || 0) > 0;

    // เลือก label + class ตามสถานะ
    function decideFinalTimeline(status) {
      switch (status) {
        case 'completed':
          return { label: 'เวลาที่คำสั่งซื้อเสร็จสิ้น', cls: 'ot-final--success' };
        case 'partial':
          return { label: 'เวลาที่เซิร์ฟเวอร์ยืนยัน (คืนบางส่วน)', cls: 'ot-final--partial' };
        case 'canceled':
          if (isPartialRefundCanceled) {
            return { label: 'เวลาที่คำสั่งซื้อยกเลิก (คืนเงินบางส่วน)', cls: 'ot-final--partial' };
          }
          return { label: 'เวลาที่เซิร์ฟเวอร์ยกเลิก / คำสั่งซื้อผิดพลาด', cls: 'ot-final--canceled' };
        case 'canceling':
          return { label: 'สถานะล่าสุด (กำลังสั่งยกเลิก...)', cls: 'ot-final--progress' };
        case 'processing':
        case 'inprogress':
        default:
          return { label: 'สถานะล่าสุด (กำลังดำเนินการ)', cls: 'ot-final--progress' };
      }
    }

    const finalWrap  = document.querySelector('.ot-item--final');
    const finalLabel = document.getElementById('om-final-label');
    const finalTime  = document.getElementById('om-final-time');

    // อัปเดตเฉพาะเมื่อ element มีจริง (กัน null)
    if (finalWrap && finalLabel && finalTime) {
      // เคลียร์คลาสเก่า
      finalWrap.classList.remove(
        'ot-final--success',
        'ot-final--canceled',
        'ot-final--partial',
        'ot-final--progress'
      );

      // คำนวณค่าที่จะแสดง
      const { label, cls } = decideFinalTimeline(stRaw);
      finalLabel.textContent = label;
      finalTime.textContent  = fmtDate(o.updatedAt || o.createdAt);
      if (cls) finalWrap.classList.add(cls);
    }

    // ===== ควบคุมปุ่มรีเฟรชในโมดัล ตามสถานะ =====
    const showRefresh = shouldShowModalRefresh(o);
    if (btnRefresh) {
      btnRefresh.style.display = showRefresh ? '' : 'none';
      btnRefresh.disabled = !showRefresh;
    }
  }
  // ===== END =====

  function openModal(o){
    render(o);
    // ย้ำอีกชั้นเผื่ออนาคตมีการเปลี่ยนแปลงลำดับ render
    const showRefresh = shouldShowModalRefresh(o);
    if (btnRefresh) {
      btnRefresh.style.display = showRefresh ? '' : 'none';
      btnRefresh.disabled = !showRefresh;
    }


    wrap.classList.add('show');
    wrap.setAttribute('aria-hidden','false');
    document.documentElement.style.overflow = 'hidden';
  }
  function closeModal(){
    wrap.classList.remove('show');
    wrap.setAttribute('aria-hidden','true');
    document.documentElement.style.overflow = '';
    currentId = null;
  }

  document.addEventListener('click', e=>{
    const btn = e.target.closest('.open-order'); if(!btn) return;
    e.preventDefault();
    const row = btn.closest('[data-order-id]');
    const id  = row?.dataset?.orderId;
    const o   = (window.__ORDERS__||[]).find(x=>x._id===id);
    if (o) openModal(o);
  });

  function shouldShowModalRefresh(o){
    const st = String(o?.status || '').toLowerCase();
    // ไม่ให้รีเฟรชเมื่อกำลังยกเลิก / เสร็จแล้ว / คืนบางส่วน / ยกเลิกแล้ว
    return !(st === 'canceling' || st === 'completed' || st === 'partial' || st === 'canceled');
  }

  if (btnRefresh) btnRefresh.addEventListener('click', async ()=>{
    if (btnRefresh.disabled || btnRefresh.style.display === 'none') return;
    if (!currentId) return;

    btnRefresh.disabled = true;
    btnRefresh.setAttribute('aria-busy','true');
    const keep = btnRefresh.textContent;
    btnRefresh.textContent = 'กำลังรีเฟรช…';

    try {
      const res = await fetch(`/api/orders/${currentId}/refresh`, { method:'POST' });
      const data = await res.json();

      const arr = window.__ORDERS__||[];
      const idx = arr.findIndex(x=>x._id===currentId);
      if (idx>-1){
        const o = arr[idx];
        o.status        = data.status ?? o.status;
        if (typeof data.progress === 'number')      o.progress = data.progress;
        if (typeof data.remains  === 'number')      o.remains  = data.remains;
        if (typeof data.start_count === 'number')   o.startCount   = data.start_count;
        if (typeof data.current_count === 'number') o.currentCount = data.current_count;
        if (typeof data.refundAmount === 'number')  o.refundAmount = data.refundAmount;
        if (typeof data.refundType === 'string')    o.refundType   = data.refundType;
        o.updatedAt = data.updatedAt ?? new Date().toISOString();

        render(o); // จะจัดการโชว์/ซ่อนปุ่มให้เอง
      }
    } catch {
      // เงียบไว้หรือจะแจ้งเตือนก็ได้
    } finally {
      btnRefresh.textContent = keep;
      btnRefresh.removeAttribute('aria-busy');

      const arr = window.__ORDERS__||[];
      const idx = arr.findIndex(x=>x._id===currentId);
      const o = idx>-1 ? arr[idx] : null;
      const showRefresh = shouldShowModalRefresh(o);
      btnRefresh.style.display = showRefresh ? '' : 'none';
      btnRefresh.disabled = !showRefresh;
    }
  });

  wrap.addEventListener('click', e=>{
    if (e.target.dataset.close) closeModal();
  });
  document.addEventListener('keydown', e=>{
    if(e.key==='Escape' && wrap.classList.contains('show')) closeModal();
  });

  /* ===== UI helpers (ใช้ทั้ง Desktop & Mobile) ===== */

  // อัปเดต DOM ทั้งฝั่งตารางและการ์ดให้ตรงกับ payload ล่าสุด
  window.applyOrderPatch = function(payload){
    // sync cache
    const arr = window.__ORDERS__ || [];
    const idx = arr.findIndex(x => x._id === payload._id);
    if (idx > -1) {
      Object.assign(arr[idx], {
        status: payload.status ?? arr[idx].status,
        progress: payload.progress ?? arr[idx].progress,
        remains: payload.remains ?? arr[idx].remains,
        startCount: payload.startCount ?? arr[idx].startCount,
        currentCount: payload.currentCount ?? arr[idx].currentCount,
        updatedAt: payload.updatedAt ?? arr[idx].updatedAt,
        refundAmount: (payload.refundAmount ?? arr[idx].refundAmount),
        refundType: (payload.refundType ?? arr[idx].refundType)
      });
    }

    const displayPayload = {
      status: payload.status,
      progress: payload.progress,
      remains: payload.remains,
      startCount: payload.startCount,
      currentCount: payload.currentCount,
      quantity: (payload.quantity != null ? payload.quantity :
                 (idx > -1 ? arr[idx].quantity : 0)),
      refundAmount: payload.refundAmount,
      refundType: payload.refundType
    };

    const newSt = String(displayPayload.status || '').toLowerCase();
    const isPartialRefundCanceled = (newSt === 'canceled') &&
      (Number(displayPayload.refundAmount||0) > 0) &&
      (displayPayload.refundType === 'partial');

    // Desktop row
    const tr = document.querySelector(`tr[data-order-id="${payload._id}"]`);
    if (tr) {
      tr.dataset.status = newSt;
      renderProgressPill(tr, displayPayload);

      // toggle buttons
      tr.querySelectorAll('.btn-cancel').forEach(b => {
        b.style.display = (newSt === 'processing') ? '' : 'none';
        if (newSt === 'canceling') b.style.display = 'none'; // ⬅️ ซ่อนทันที
      });
      tr.querySelectorAll('.btn-refresh').forEach(b => {
        b.style.display = (newSt === 'completed' || newSt === 'canceled' || newSt === 'partial' || newSt === 'canceling') ? 'none' : '';
      });
      tr.querySelectorAll('.btn-repeat').forEach(b => {
        b.style.display = ((newSt === 'completed') || (newSt === 'partial') || isPartialRefundCanceled) ? '' : 'none';
      });
    }

    // Mobile card
    const card = document.querySelector(`.o-card[data-order-id="${payload._id}"]`);
    if (card) {
      card.dataset.status = newSt;
      renderProgressPill(card, displayPayload);

      card.querySelectorAll('.btn-cancel').forEach(b => {
        b.style.display = (newSt === 'processing') ? '' : 'none';
        if (newSt === 'canceling') b.style.display = 'none'; // ⬅️ ซ่อนทันที
      });
      card.querySelectorAll('.btn-refresh').forEach(b => {
        b.style.display = (newSt === 'completed' || newSt === 'canceled' || newSt === 'partial' || newSt === 'canceling') ? 'none' : '';
      });
      card.querySelectorAll('.btn-repeat').forEach(b => {
        b.style.display = ((newSt === 'completed') || (newSt === 'partial') || isPartialRefundCanceled) ? '' : 'none';
      });
    }
  };

  // รองรับทั้ง .pill.long (ใหม่) และ .pill.progress (เดิม)
  window.renderProgressPill = function(container, payload){
    const pillLong = container?.querySelector?.('.pill.long') || container?.querySelector?.('.pill.progress');
    if (!pillLong) return;

    const dd = (window.decideDisplay ? window.decideDisplay(payload) : null) ||
              { label:'รอดำเนินการ', donePct:0, showPct:false, isDone:false };

    const stLower       = String(payload.status||'').toLowerCase();
    const isCanceled    = stLower === 'canceled';
    const isPartial     = stLower === 'partial';
    const isCanceling   = stLower === 'canceling';
    const isPartialRefund = (isCanceled && Number(payload.refundAmount||0) > 0 && payload.refundType === 'partial');

    pillLong.classList.toggle('ok', !!dd.isDone);
    pillLong.classList.toggle('danger', isCanceled);
    pillLong.classList.toggle('warn', isPartial || isCanceling);

    // โครงสร้างใหม่: มี .bar + .label
    const barEl = pillLong.querySelector('.bar');
    const lblEl = pillLong.querySelector('.label');
    if (barEl && lblEl) {
      // ถ้า canceling แถบความคืบหน้าให้ 0%
      const widthPct = isCanceling ? 0 : (dd.isDone ? 100 : Math.max(0, Math.min(100, dd.donePct)));
      barEl.style.width = widthPct + '%';

      // ถ้า canceling แสดงข้อความเฉพาะ
      const mainLabel = isCanceling
        ? 'กำลังส่งยกเลิก…'
        : (dd.showPct ? `ดำเนินการ ~ <span class="pct">${Number(dd.donePct||0).toFixed(2)}%</span>` : dd.label);

      lblEl.innerHTML = isPartialRefund
        ? `<span class="badge warn" style="margin-right:8px">คืนบางส่วน</span>${mainLabel}`
        : mainLabel;

      ensureStatusIcon(pillLong, stLower);
      
      return;
    }

    // fallback: pill เดิม (ไม่มี .bar/.label)
    if (isCanceling) {
      pillLong.textContent = 'กำลังส่งยกเลิก…';
      ensureStatusIcon(pillLong, 'canceling');
    } else {
      pillLong.innerHTML = dd.showPct
        ? `ดำเนินการ ~ <span class="pct" data-pct="${dd.donePct}">${Number(dd.donePct||0).toFixed(2)}%</span>`
        : dd.label;
      ensureStatusIcon(pillLong, stLower);
    }
  };
})();
</script>

<script>
(() => {
  const $  = (s,r=document)=>r.querySelector(s);
  const $$ = (s,r=document)=>Array.from(r.querySelectorAll(s));

  /* ===========================
  * Auto Refresh (DB-only)
  * - ดึงสถานะจาก DB orders อย่างเดียว
  * - ไม่ยุ่งกับการเปลี่ยนสถานะเอง (no canceling logic)
  * - รีเฟรชเฉพาะออเดอร์ที่ยังทำงานอยู่ (processing/inprogress)
  * =========================== */
  const AutoRefresh = (() => {
    const NORMAL_INTERVAL    = 10_000; // 10s (ปรับได้)
    const ERR_BACKOFF_FACTOR = 2.0;

    const CONCURRENCY      = 3;   // ขอพร้อมกันสูงสุด
    const PER_ORDER_GAP_MS = 300; // หน่วงระหว่างคำขอ

    let timer   = null;
    let running = false;

    const isVisible = el => !!(el && el.offsetParent !== null);
    const qsa = (sel) => Array.from(document.querySelectorAll(sel));

    // เลือกเฉพาะรายการที่ยังทำงานอยู่
    function getRefreshableIds(){
      const nodes = qsa('#orderTable tbody tr[data-order-id], .o-card[data-order-id]')
        .filter(n => isVisible(n));
      const ids = [];
      for (const n of nodes){
        const st = String(n.dataset.status || '').toLowerCase();
        if (st === 'processing' || st === 'inprogress' || st === 'canceling'){
          const id = n.dataset.orderId;
          if (id) ids.push(id);
        }
      }
      return [...new Set(ids)];
    }

    function schedule(ms){
      clearTimeout(timer);
      timer = setTimeout(tick, Math.max(0, ms));
    }

    // ยิงทีละออเดอร์แบบจำกัด concurrency
    async function refreshPerOrder(ids){
      if (!ids.length) return;

      const btnFor = (id) =>
        document.querySelector(`.btn-refresh[data-id="${id}"]`) ||
        document.querySelector(`[data-order-id="${id}"] .btn-refresh`) || undefined;

      const queue = ids.slice();
      const workers = new Array(Math.min(CONCURRENCY, queue.length)).fill(0).map(async () => {
        while (queue.length){
          const id = queue.shift();
          try{
            await refreshOneOrder(id, btnFor(id)); // ← ฟังก์ชันของคุณที่เรียก /local-status แล้ว applyOrderPatch
          }catch(e){
            console.warn('refreshOneOrder failed:', id, e);
          }
          if (PER_ORDER_GAP_MS) {
            await new Promise(s => setTimeout(s, PER_ORDER_GAP_MS));
          }
        }
      });
      await Promise.allSettled(workers);
    }

    async function doRun(nextMs){
      if (running) { schedule(Math.max(nextMs, 1_000)); return; }
      running = true;
      try{
        const ids = getRefreshableIds();
        await refreshPerOrder(ids);
        schedule(NORMAL_INTERVAL);
      } catch (e){
        console.error('auto refresh failed:', e);
        const backoff = Math.floor((nextMs || NORMAL_INTERVAL) * ERR_BACKOFF_FACTOR);
        schedule(backoff);
      } finally {
        running = false;
      }
    }

    async function tick(){
      if (document.hidden) { schedule(NORMAL_INTERVAL); return; }
      await doRun(NORMAL_INTERVAL);
    }

    // โฟกัสกลับหน้า → เริ่มรอบใหม่ไวหน่อย
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) return;
      clearTimeout(timer);
      schedule(200);
    });

    // เริ่มทำงาน
    window.addEventListener('load', () => schedule(200));

    // ปุ่ม Sync → รีเฟรชเฉพาะที่ยังทำงานอยู่
    document.querySelector('#btnSync')?.addEventListener('click', async () => {
      clearTimeout(timer);
      try{
        const ids = getRefreshableIds();
        await refreshPerOrder(ids);
      } finally {
        schedule(NORMAL_INTERVAL);
      }
    });

    return { start: () => schedule(500), stop: () => clearTimeout(timer) };
  })();


  /* === decideDisplay (ฝั่ง client) === */
  const clampPct = v => Math.max(0, Math.min(100, Number(v)||0));

  window.decideDisplay = function(o){
    const qty = Number(o.quantity)||0;
    const st  = String(o.status||'').toLowerCase();

    if (st === 'canceling') return { label:'กำลังส่งยกเลิก…', donePct:0, showPct:false, isDone:false };
    if (st === 'canceled')  return { label:'ยกเลิก',         donePct:0, showPct:false, isDone:false };
    if (st === 'partial')   return { label:'คืนบางส่วน',     donePct:0, showPct:false, isDone:false };

    const hasProgress = (typeof o.progress === 'number' && isFinite(o.progress));
    const hasRemains  = (typeof o.remains  === 'number' && isFinite(o.remains));
    const hasCounts   = (typeof o.startCount === 'number' && typeof o.currentCount === 'number');

    let donePct = 0;

    if (hasProgress) {
      donePct = clampPct(o.progress);
    } else if (hasRemains && qty > 0) {
      // ใช้ remains เป็นหลัก ถ้ามี → ถือว่าเริ่มทำงานแล้ว
      donePct = clampPct((1 - Math.max(0, o.remains)/qty) * 100);
    } else if (hasCounts && qty > 0) {
      donePct = clampPct(((o.currentCount - o.startCount)/qty) * 100);
    }

    // รอดำเนินการ เฉพาะกรณี "ไม่มีข้อมูลความคืบหน้าเลย"
    const isWaiting = (st === 'processing') && !hasProgress && !hasRemains && !hasCounts;
    if (isWaiting) return { label:'รอดำเนินการ', donePct:0, showPct:false, isDone:false };

    const isDone = (st === 'completed') || donePct >= 99.995;

    return isDone
      ? { label:'เสร็จสิ้น', donePct:100, showPct:false, isDone:true }
      : { label:`ดำเนินการ ~ ${donePct.toFixed(2)}%`, donePct, showPct:true, isDone:false };
  };
  // window.decideDisplay = function(o){
