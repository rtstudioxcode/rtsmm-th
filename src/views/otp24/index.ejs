<%
// code ธงตาม ct ของ API
const CT2CODE = {
  52:'th',187:'us',16:'gb',6:'id',10:'vn',5:'mm',1:'ua',19:'ng',62:'tr',
  3:'cn',4:'ph',24:'kh',25:'la',7:'my',21:'eg'
};
// path รูปธง
const FLAGIMG = (id) => `/static/assets/otp24/${CT2CODE[id] || 'xx'}.png`;

// (คง FLAG เดิมไว้เผื่อใช้ที่อื่น)
const FLAG = id => ({
  52:'🇹🇭',187:'🇺🇸',16:'🇬🇧',6:'🇮🇩',10:'🇻🇳',5:'🇲🇲',1:'🇺🇦',19:'🇳🇬',62:'🇹🇷',
  3:'🇨🇳',4:'🇵🇭',24:'🇰🇭',25:'🇱🇦',7:'🇲🇾',21:'🇪🇬'
}[id] || '🏳️');
%>

<section class="page container otp24">
    <div class="tabs">
        <button class="tab active" style="width: 100%;" data-target="shop">สั่งซื้อ OTP</button>
        <button class="tab" style="width: 100%;" data-target="orders">ประวัติสั่งซื้อ</button>
    </div>

    <!-- ============ SECTION 1: สั่งซื้อ OTP ============ -->
    <section id="section-shop" class="tabpane show">
        <form method="get" class="row mt">
        <input class="input" name="q" placeholder="ค้นหาแอพ…" value="<%= q || '' %>" />
        <button class="btn" type="submit">ค้นหา</button>
        </form>
        
        <%
          // key ที่ใช้ตัดสินใจว่า “ถือว่าอันเดียวกัน”
          const keyOf = p => `${(p.alias || p.name || '').trim().toLowerCase()}|${Number(p.price||0)}`;
          const seen = new Set();
          const uniqueProducts = [];
          (products || []).forEach(p => {
            const k = keyOf(p);
            if (!seen.has(k)) { seen.add(k); uniqueProducts.push(p); }
          });
        %>
        <!-- เดิม: <div class="grid cards mt-lg"> ... มีปุ่มเช่าในแต่ละการ์ด -->
        <div class="grid cards mt-lg" id="appsGrid">
        <% uniqueProducts.forEach(p => { %>
            <section class="card app"
            data-id="<%= p._id %>"
            data-name="<%= p.name %>"
            data-price="<%= p.price %>"
            role="button"
            tabindex="0"
            aria-label="เช่า OTP สำหรับ <%= p.name %> ราคา <%= p.price.toFixed(2) %> บาท">
            <div class="price-badge">฿ <%= p.price.toFixed(2) %></div>
            <div class="app-icon">
                <% if (p.icon) { %>
                <img src="<%= p.icon %>" alt="<%= p.name %>" loading="lazy"/>
                <% } else { %>
                <div class="placeholder"><%= p.name?.[0] || '?' %></div>
                <% } %>
            </div>
            <div class="app-name"><%= p.name %></div>
            <!-- ตัดปุ่มเช่าออก -->
            </section>
        <% }) %>
        </div>
    </section>

    <!-- ============ SECTION 2: ประวัติ OTP (แบบภาพตัวอย่าง #3) ============ -->
    <section id="section-orders" class="tabpane">
        <!-- Controls: per page + pager -->
        <div class="orders-controls" id="ordersControlsDesktop">
            <div class="left">
                แสดง
                <select id="perPageSelect">
                <option value="10">10</option>
                <option value="20" selected>20</option>
                <option value="50">50</option>
                <option value="100">100</option>
                </select>
                รายการ/หน้า
            </div>
            <div class="right pager">
                <button class="pg-btn" data-act="first" aria-label="หน้าแรก">«</button>
                <button class="pg-btn" data-act="prev" aria-label="ก่อนหน้า">‹</button>
                <span id="pageInfo">หน้า 1/1</span>
                <button class="pg-btn" data-act="next" aria-label="ถัดไป">›</button>
                <button class="pg-btn" data-act="last" aria-label="หน้าสุดท้าย">»</button>
            </div>
        </div>
        <div class="orders-wrap">
        <table class="tbl">
            <thead>
            <tr>
                <th>เลขออเดอร์</th>
                <th>แอป</th>
                <th>เบอร์</th>
                <th>OTP / เวลา</th>
                <th class="center">ราคา</th>
                <th class="right">สถานะ</th>
                <!-- <th class="right">การกระทำ</th> -->
            </tr>
            </thead>
            <tbody id="ordersBody">
            <% (orders||[]).forEach(o => {
            const st = String(o.status || 'processing').toLowerCase();
            const createdAtStr = new Date(o.createdAt).toISOString().replace('T',' ').slice(0,19);
            %>
            <tr data-orderid="<%= o.orderId %>" data-ct="<%= Number(o.countryId||0) %>" data-expires="<%= o.expiresAt ? new Date(o.expiresAt).toISOString() : '' %>">
                <td class="mono"><%= o.orderId || '-' %></td>
                <td>
                <span class="badge app"><%= o.appName || '—' %></span>
                <span class="flag"><img src="<%= FLAGIMG(Number(o.countryId||0)) %>" alt="" /></span>
                </td>
                <td>
                  <div class="mono phone-cell">
                    <% 
                      const phoneStrTable = o.phone
                        ? (Number(o.countryId)===52 ? String(o.phone).replace(/^\+?66/,'0') : String(o.phone))
                        : '-';
                    %>
                    <span class="v"><%= phoneStrTable %></span>
                    <% if (o.phone) { %>
                      <button class="copy" data-copy="<%= phoneStrTable %>" aria-label="คัดลอกเบอร์">
                        <img src="/static/assets/otp24/copy.png" alt="">
                      </button>
                    <% } %>
                  </div>
                </td>

                <td>
                <% if (o.otp) { %>
                    <div class="otp">OTP : <b><%= o.otp %></b>
                    <button class="copy" data-copy="<%= o.otp %>" aria-label="คัดลอก OTP">
                        <img src="/static/assets/otp24/copy.png" alt="" />
                    </button>
                    </div>
                <% } else { %>
                    <div class="otp none">OTP : <span class="muted">ไม่พบข้อความ</span></div>
                <% } %>
                <div class="ts"><%= new Date(o.createdAt).toISOString().replace('T',' ').slice(0,19) %></div>
                </td>

                <td class="center">฿ <%= Number(o.salePrice||0).toFixed(2) %></td>

                <td class="right">
                <span class="pill <%= st %>">
                    <%= st==='success'   ? 'สำเร็จ'
                    : st==='refunded'  ? 'คืนเครดิต'
                    : st==='timeout'   ? 'หมดเวลา'
                    : st==='failed'    ? 'ล้มเหลว'
                    : /* processing / อื่นๆ */ 'กำลังรอ OTP' %>
                </span>
                <% /* ใส่ตัวนับถอยหลังเฉพาะที่ยัง processing และมี expiresAt */ %>
                <% if (st==='processing' && o.expiresAt) { %>
                    <div class="countdown" data-expires="<%= new Date(o.expiresAt).toISOString() %>">
                    เหลือเวาอีก —:— นาที หากไม่ได้รับ OTP ระบบจะคืนเงินอัตโนมัติ
                    </div>
                <% } %>
                </td>
            </tr>
            <% }) %>
            </tbody>
        </table>
        </div>
    </section>

    <div class="orders-controls mobile-only" id="ordersControlsMobile">
        <div class="left">
            แสดง
            <select id="perPageSelectMobile">
            <option value="10">10</option>
            <option value="20" selected>20</option>
            <option value="50">50</option>
            <option value="100">100</option>
            </select>
            รายการ/หน้า
        </div>
        <div class="right pager">
            <button class="pg-btn" data-act="first">«</button>
            <button class="pg-btn" data-act="prev">‹</button>
            <span id="pageInfoMobile">หน้า 1/1</span>
            <button class="pg-btn" data-act="next">›</button>
            <button class="pg-btn" data-act="last">»</button>
        </div>
    </div>
    <!-- ลิสต์แบบมือถือ (แสดงเฉพาะจอเล็ก) -->
    <div id="mOrders" class="m-orders">
    <% (orders||[]).forEach(o => { 
        const st = String(o.status || 'processing').toLowerCase();
        const createdStr = new Date(o.createdAt).toISOString().replace('T',' ').slice(0,19);
        const phoneStr = o.phone
        ? (Number(o.countryId)===52 ? String(o.phone).replace(/^\+?66/,'0') : String(o.phone))
        : '-';
    %>
    <div class="m-item collapsed"
        data-orderid="<%= o.orderId %>"
        data-ct="<%= Number(o.countryId||0) %>"
        data-expires="<%= o.expiresAt ? new Date(o.expiresAt).toISOString() : '' %>">
        <!-- หัวการ์ด: แตะตรงไหนก็พับ/กาง -->
        <div class="m-head">
          <div class="row1">
              <div class="oid mono"><%= o.orderId %></div>
              <div class="when mono"><%= createdStr %></div>
              <button class="toggle" aria-label="toggle" type="button">+</button>
          </div>
          <div class="row2">
            <div class="phone mono">
              เบอร์: <span class="v"><%= phoneStr %></span>
              <% if (o.phone) { %>
                <button class="copy" data-copy="<%= phoneStr %>" aria-label="คัดลอกเบอร์">
                  <img src="/static/assets/otp24/copy.png" alt="">
                </button>
              <% } %>
            </div>

            <% if (o.otp) { %>
              <div class="otp">OTP: <b class="v"><%= o.otp %></b>
                <button class="copy" data-copy="<%= o.otp %>" aria-label="คัดลอก OTP">
                  <img src="/static/assets/otp24/copy.png" alt="">
                </button>
              </div>
            <% } else { %>
              <div class="otp none">OTP: <span class="muted v">ไม่พบข้อความ</span></div>
            <% } %>
          </div>
        </div>

        <!-- เนื้อหาเมื่อกาง -->
        <div class="m-body">
        <div class="pair"><span>แอป</span> <span class="badge app"><%= o.appName||'—' %></span></div>
        <div class="pair"><span>ประเทศ</span>
            <span class="flag"><img src="<%= FLAGIMG(Number(o.countryId||0)) %>" alt=""></span>
        </div>
        <div class="pair"><span>ราคา</span> <span class="mono">฿ <%= Number(o.salePrice||0).toFixed(2) %></span></div>
        <div class="pair">
            <span>สถานะ</span>
            <span>
            <span class="pill <%= st %>">
                <%= st==='success'   ? 'เสร็จสิ้น'
                : st==='refunded'  ? 'คืนเครดิต'
                : st==='timeout'   ? 'หมดเวลา'
                : st==='failed'    ? 'ล้มเหลว'
                : 'กำลังรอ OTP' %>
            </span>
            <% if (st==='processing' && o.expiresAt) { %>
                <div class="countdown" data-expires="<%= new Date(o.expiresAt).toISOString() %>">
                เหลือเวลาอีก —:— นาที
                </div>
            <% } %>
            </span>
        </div>
        </div>
    </div>
    <% }) %>
    </div>
</section>

<!-- Modal ซื้อ -->
<dialog id="buyModal">
  <form method="dialog" class="modal modal-otp24">
    <h2 class="modal-title">คุณต้องการเช่าเบอร์ OTP ?</h2>

    <div class="modal-sub">
      <div id="selApp">รายการ : —</div>
      <div id="selPrice">ราคา : — บาท</div>
    </div>

    <div class="modal-label">กรุณาเลือกประเทศ</div>
    <div class="modal-divider"></div>

    <div class="flags-grid">
        <%
            // จัดลำดับ: ไทย (52) ก่อน เสมอ ที่เหลือเรียงตามชื่อ
            const FLAG_LIST = Object.entries(countries)
            .map(([id, name]) => ({ id: Number(id), name }))
            .sort((a, b) => (a.id === 52 ? -1 : b.id === 52 ? 1 : a.name.localeCompare(b.name, 'th')));

            FLAG_LIST.forEach(c => { %>
            <button type="button" class="flag-btn" data-ct="<%= c.id %>" title="<%= c.name %>">
                <img src="<%= FLAGIMG(c.id) %>" alt="<%= c.name %>" loading="lazy">
            </button>
        <% }); %>
    </div>

    <div class="actions">
      <button class="btn modal-primary" id="btnConfirm" disabled>ตกลง</button>
      <button class="btn modal-secondary" style="background: rgb(231, 11, 11); box-shadow: none;" value="close">ยกเลิก</button>
    </div>
  </form>
</dialog>

<script>
/* ----- Tabs ----- */
document.querySelectorAll('.tab').forEach(t=>{
  t.addEventListener('click', ()=>{
    document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));
    document.querySelectorAll('.tabpane').forEach(x=>x.classList.remove('show'));
    t.classList.add('active');
    document.getElementById('section-'+t.dataset.target).classList.add('show');
  });
});

/* ----- Buy flow ----- */
let chosen = { productId:null, countryId:null, name:'', price:0 };
function openBuyModal(id, name, price){
  chosen = { productId:id, countryId:null, name, price };
  document.getElementById('selApp').textContent   = `รายการ : ${name}`;
  document.getElementById('selPrice').textContent = `ราคา : ${price.toFixed(2)} บาท`;
  document.querySelectorAll('#buyModal .flag').forEach(b=>b.classList.remove('active'));
  document.getElementById('btnConfirm').disabled = true;
  document.getElementById('buyModal').showModal();
}
document.querySelectorAll('#buyModal .flag-btn').forEach(btn=>{
  btn.addEventListener('click', ()=>{
    document.querySelectorAll('#buyModal .flag-btn').forEach(b=>b.classList.remove('active','selected'));
    btn.classList.add('active','selected');       // ← ใช้คู่กับ CSS ด้านบน
    chosen.countryId = Number(btn.dataset.ct);
    document.getElementById('btnConfirm').disabled = false;
  });
});
// สลับแท็บไป "ประวัติ"
function goOrdersTab(){
  document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));
  document.querySelectorAll('.tabpane').forEach(x=>x.classList.remove('show'));
  document.querySelector('.tab[data-target="orders"]')?.classList.add('active');
  document.getElementById('section-orders')?.classList.add('show');
}

// โพลลิ่งเช็คสถานะออเดอร์ทุก 1 วิ จนจบ
const POLL_DONE = new Set(['success','timeout','failed','refunded']);
const pollers = new Map();
function startOrderPolling(orderId){
  if (!orderId || pollers.has(orderId)) return;

  const tick = async () => {
    try{
      const r = await fetch(`/otp24/orders/${encodeURIComponent(orderId)}/refresh`, { method:'POST' });
      const j = await r.json();
      if (!j?.ok) return;

      const { patch } = j;
      const tr = document.querySelector(`tr[data-orderid="${CSS.escape(orderId)}"]`);
      if (tr && patch){
        // อัปเดต OTP/เวลา
        const cell = tr.children[3];
        if (patch.otp){
          cell.innerHTML = `
            <div class="otp">OTP : <b>${patch.otp}</b>
                <button class="copy" data-copy="${patch.otp}" aria-label="คัดลอก OTP">
                    <img src="/static/assets/otp24/copy.png" alt="" />
                </button>
            </div>
            <div class="ts">${new Date().toISOString().replace('T',' ').slice(0,19)}</div>`;
        }else{
          cell.innerHTML = `
            <div class="otp muted">OTP : <b>ไม่พบข้อความ</b></div>
            <div class="ts">${new Date().toISOString().replace('T',' ').slice(0,19)}</div>`;
        }

        // อัปเดตสถานะ/สีป้าย
        const pill = tr.querySelector('.pill');
        if (pill){
          const st = String(patch.status||'').toLowerCase();
          pill.className = `pill ${st}`;
          pill.textContent =
            st==='success'   ? 'สำเร็จ' :
            st==='processing'? 'กำลังรอ OTP' :
            st==='timeout'   ? 'หมดเวลา' :
            st==='failed'    ? 'ล้มเหลว' :
            st==='refunded'  ? 'คืนเครดิตแล้ว' : 'ล้มเหลว';
        }

        // เบอร์ (ถ้าเพิ่งได้)
        if (patch.phone){
          const ct = Number(tr.dataset.ct || 0);
          const formatted = displayPhoneByCountry(patch.phone, ct);
          const cell = tr.children[2];
          const mono = cell.querySelector('.mono .v') || cell.querySelector('.mono');
          if (mono) mono.textContent = formatted;
          // ถ้ามีปุ่ม copy แล้วอัปเดตค่า ไม่มีก็สร้าง
          let btn = cell.querySelector('.copy');
          if (!btn){
            btn = document.createElement('button');
            btn.className = 'copy';
            btn.setAttribute('aria-label','คัดลอกเบอร์');
            btn.innerHTML = `<img src="/static/assets/otp24/copy.png" alt="">`;
            (cell.querySelector('.mono') || cell).appendChild(btn);
          }
          btn.dataset.copy = formatted;

          // มือถือ
          const mCard = document.querySelector(`.m-orders .m-item[data-orderid="${orderId}"]`);
          if (mCard){
            const el = mCard.querySelector('.row2 .phone .v');
            if (el) el.textContent = formatted;
            let mBtn = mCard.querySelector('.row2 .phone .copy');
            if (!mBtn){
              mBtn = document.createElement('button');
              mBtn.className = 'copy';
              mBtn.setAttribute('aria-label','คัดลอกเบอร์');
              mBtn.innerHTML = `<img src="/static/assets/otp24/copy.png" alt="">`;
              el?.after(mBtn);
            }
            mBtn.dataset.copy = formatted;
          }
        }

        // จบงาน → หยุดโพลลิ่ง
        if (POLL_DONE.has(String(patch.status||'').toLowerCase())){
          clearInterval(pollers.get(orderId));
          pollers.delete(orderId);
          // ตัด countdown ของ card/row นี้ด้วย
          tr?.querySelector('.countdown')?.remove();
          const mCard = document.querySelector(`.m-orders .m-item[data-orderid="${orderId}"]`);
          mCard?.querySelector('.countdown')?.remove();

          if (!hasProcessingRows()) stopOrdersAutoRefresh();
        }
      }
    }catch{}
  };

  tick();
  const id = setInterval(tick, 1000);
  pollers.set(orderId, id);
}

document.getElementById('btnConfirm').addEventListener('click', async (e)=>{
  e.preventDefault();
  if (!chosen.productId || !chosen.countryId) return;
  try{
    const res = await fetch('/otp24/buy', {
      method:'POST',
      headers:{ 'content-type':'application/json', 'accept':'application/json' },
      body: JSON.stringify({ productId: chosen.productId, countryId: chosen.countryId })
    });
    const j = await res.json();
    if (!res.ok || !j?.ok) throw new Error(j?.error || 'สั่งซื้อไม่สำเร็จ');

    // ➊ ตั้งธงให้รีไดเร็กต์ไปแท็บประวัติหลังรีเฟรชรอบเดียว
    sessionStorage.setItem('OTP24_AFTER_BUY', j.redirect || '/otp24?tab=orders');

    // ➋ รีเฟรชหน้านี้ 1 ครั้ง (ให้รายการ/ยอดคงเหลือบนแท็บ “สั่งซื้อ” อัปเดตก่อน)
    window.location.reload();
  }catch(err){ alert(err.message || err); }
});

/* ----- Utilities ----- */
function setCopyIcon(btn, success) {
  const img = btn.querySelector('img');
  if (!img) return;
  img.src = success
    ? '/static/assets/otp24/copy-success.png'
    : '/static/assets/otp24/copy.png';
}
document.addEventListener('click', (e) => {
  const btn = e.target.closest('.copy');
  if (!btn) return;

  navigator.clipboard.writeText(btn.dataset.copy || '').then(() => {
    setCopyIcon(btn, true);
    // กลับเป็นไอคอนปกติใน 900ms
    setTimeout(() => setCopyIcon(btn, false), 900);
  }).catch(() => {
    // ถ้า copy ไม่ได้ อย่าค้างไอคอน success
    setCopyIcon(btn, false);
  });
});

/* ----- Refresh single order ----- */
async function refreshOne(orderId){
  try{
    const res = await fetch(`/otp24/orders/${encodeURIComponent(orderId)}/refresh`, { method:'POST' });
    const j = await res.json();
    if (!res.ok || !j?.ok) throw new Error(j?.error || 'รีเฟรชไม่สำเร็จ');
    // อัปเดตแถว
    const tr = document.querySelector(`tr[data-orderid="${orderId}"]`);
    if (!tr) return;
    if (j.patch?.phone){
      const ct = Number(tr.dataset.ct || 0);
      const formatted = displayPhoneByCountry(j.patch.phone, ct);
      const cell = tr.children[2];
      const mono = cell.querySelector('.mono .v') || cell.querySelector('.mono');
      if (mono) mono.textContent = formatted;
      let btn = cell.querySelector('.copy');
      if (!btn){
        btn = document.createElement('button');
        btn.className = 'copy';
        btn.setAttribute('aria-label','คัดลอกเบอร์');
        btn.innerHTML = `<img src="/static/assets/otp24/copy.png" alt="">`;
        (cell.querySelector('.mono') || cell).appendChild(btn);
      }
      btn.dataset.copy = formatted;
    }
    if (j.patch?.otp){
      tr.querySelector('.otp')?.remove();
      const cell = tr.children[3];
      const div = document.createElement('div');
      div.className = 'otp';
      div.innerHTML = `OTP : <b>${j.patch.otp}</b>
        <button class="copy" data-copy="${j.patch.otp}" aria-label="คัดลอก OTP">
            <img src="/static/assets/otp24/copy.png" alt="">
        </button>`;
      cell.prepend(div);
    }
    if (j.patch?.status){
      const pill = tr.querySelector('.pill');
      pill.className = `pill ${j.patch.status}`;
      pill.textContent = j.patch.status==='success'?'สำเร็จ':
                         j.patch.status==='processing'?'กำลังรอ':
                         j.patch.status==='timeout'?'หมดเวลา':
                         j.patch.status==='failed'?'ล้มเหลว':'ล้มเหลว';
    }
  }catch(e){ alert(e.message || e); }
}
(() => {
  const u = new URL(location.href);
  if (u.searchParams.get('tab') === 'orders' || location.hash.replace('#','') === 'orders'){
    document.querySelector('.tab[data-target="orders"]')?.click();
  }
})();
(() => {
  const grid = document.getElementById('appsGrid');
  if (!grid) return;

  // คลิกที่การ์ด = เปิดโมดัล
  grid.addEventListener('click', (e) => {
    const card = e.target.closest('section.card.app');
    if (!card) return;
    openBuyModal(
      card.dataset.id,
      card.dataset.name,
      Number(card.dataset.price || 0)
    );
  });

  // รองรับคีย์บอร์ด (Enter/Space)
  grid.addEventListener('keydown', (e) => {
    if (!['Enter', ' '].includes(e.key)) return;
    const card = e.target.closest('section.card.app');
    if (!card) return;
    e.preventDefault();
    openBuyModal(
      card.dataset.id,
      card.dataset.name,
      Number(card.dataset.price || 0)
    );
  });
})();

(() => {
  const to = sessionStorage.getItem('OTP24_AFTER_BUY');
  if (to) {
    sessionStorage.removeItem('OTP24_AFTER_BUY');
    // ไปแท็บประวัติ + เริ่มออโต้รีเฟรช (คลิกแท็บให้ CSS/JS ทำงานเหมือนผู้ใช้กด)
    window.location.replace(to);
  }
})();

function mmss(ms){
  if (!Number.isFinite(ms) || ms < 0) ms = 0;
  const s = Math.floor(ms/1000);
  const m = String(Math.floor(s/60)).padStart(2,'0');
  const ss = String(s%60).padStart(2,'0');
  return `${m}:${ss}`;
}

function tickCountdowns(){
  const now = Date.now();
  const upd = (el) => {
    const exp = Date.parse(el.dataset.expires || el.getAttribute('data-expires') || '');
    if (!Number.isFinite(exp)) return;
    const left = exp - now;
    el.textContent = left>0 ? `เหลือเวลาอีก ${mmss(left)} นาที` : 'ระบบกำลังคืนเครดิต';
    el.classList.toggle('warn', left>0 && left<=3*60*1000);
    el.classList.toggle('danger', left>0 && left<=60*1000);
  };
  document.querySelectorAll('#ordersBody .countdown').forEach(upd);
  document.querySelectorAll('#mOrders .countdown').forEach(upd);
  // ปรับหมายเลขในตาราง Desktop ให้ถูกต้องตามประเทศ
  document.querySelectorAll('#ordersBody tr').forEach(tr => {
    const ct = Number(tr.dataset.ct || 0);
    const box = tr.children?.[2];
    const mono = box?.querySelector('.mono .v') || box?.querySelector('.mono');
    if (mono){
      const formatted = displayPhoneByCountry(mono.textContent.trim(), ct);
      mono.textContent = formatted;
      const btn = box.querySelector('.copy');
      if (btn) btn.dataset.copy = formatted;
    }
  });

  // ปรับหมายเลขในลิสต์มือถือให้ถูกต้องเหมือนกัน
  document.querySelectorAll('#mOrders .m-item').forEach(card => {
    const ct = Number(card.dataset.ct || 0);
    const el = card.querySelector('.row2 .phone .v');
    if (el){
      const formatted = displayPhoneByCountry(el.textContent.trim(), ct);
      el.textContent = formatted;
      const btn = card.querySelector('.row2 .phone .copy');
      if (btn) btn.dataset.copy = formatted;
    }
  });
}

// ผูกกับลูปรีเฟรชหลัก (ทุก 1 วิอยู่แล้ว)
function startOrdersAutoRefresh(){
  stopOrdersAutoRefresh();
  ORD_AUTO_TIMER = setInterval(async () => {
    await refreshAllOrdersOnce();
    tickCountdowns();
  }, 1000);
}

function displayPhoneByCountry(rawPhone, countryId){
  if (!rawPhone) return '-';

  // เก็บเฉพาะตัวเลขกับ "+" ไว้พอประมาณ (กันเคสมี space/dash)
  let s = String(rawPhone).trim();

  // ── ไทย: countryId = 52
  if (Number(countryId) === 52) {
    // รูปแบบ +66XXXXXXXX หรือ 66XXXXXXXX → แปลงเป็น 0XXXXXXXX
    if (/^\+?66\d{8,9}$/.test(s)) return s.replace(/^\+?66/, '0');
    // ถ้าเป็น 0XXXXXXXX อยู่แล้ว → ใช้เดิม
    if (/^0\d{8,9}$/.test(s)) return s;
    // รูปแบบอื่นของไทย ไม่รู้ชัดเจน → คืนค่าเดิม
    return s;
  }

  // ── ประเทศอื่น: บังคับให้ขึ้นต้นด้วย "+"
  // ถ้ามี "+" อยู่แล้ว → ใช้เดิม
  if (s.startsWith('+')) return s;
  // ถ้าเป็นรูปแบบ 00XXXXXXXX → แปลงเป็น +XXXXXXXX
  if (s.startsWith('00')) return '+' + s.slice(2);
  // ฟอลแบ็ก: ลบ non-digits แล้วเติม "+"
  return '+' + s.replace(/[^\d]/g, '');
}
</script>

<script>
/* ===== Auto-refresh loop for orders ===== */
let ORD_AUTO_TIMER = null;

function hasProcessingRows(){
  return !!document.querySelector('#ordersBody .pill.processing');
}

function applyOrderPatch(p){
  // p: { orderId, status, otp, phone, message }
  const tr = document.querySelector(`tr[data-orderid="${p.orderId}"]`);
  if (!tr) return;

  if (p.expiresAt){
    tr.dataset.expires = p.expiresAt;
    const cd = tr.querySelector('.countdown');
    if (cd) cd.dataset.expires = p.expiresAt;
  }

  // อัปเดตเบอร์ (ถ้ามี)
  if (Object.prototype.hasOwnProperty.call(p,'phone')) {
    const cell = tr.children[2];
    const ct = Number(tr.dataset.ct || 0);
    const formatted = displayPhoneByCountry(p.phone || '-', ct);

    // desktop
    const mono = cell.querySelector('.mono .v') || cell.querySelector('.mono');
    if (mono) mono.textContent = formatted;
    let btn = cell.querySelector('.copy');
    if (!btn && p.phone){
      btn = document.createElement('button');
      btn.className = 'copy';
      btn.setAttribute('aria-label','คัดลอกเบอร์');
      btn.innerHTML = `<img src="/static/assets/otp24/copy.png" alt="">`;
      (cell.querySelector('.mono') || cell).appendChild(btn);
    }
    if (btn) btn.dataset.copy = formatted;

    // mobile
    const m = document.querySelector(`.m-orders .m-item[data-orderid="${p.orderId}"]`);
    if (m){
      const v = m.querySelector('.row2 .phone .v');
      if (v) v.textContent = formatted;
      let mBtn = m.querySelector('.row2 .phone .copy');
      if (!mBtn && p.phone){
        mBtn = document.createElement('button');
        mBtn.className = 'copy';
        mBtn.setAttribute('aria-label','คัดลอกเบอร์');
        mBtn.innerHTML = `<img src="/static/assets/otp24/copy.png" alt="">`;
        v?.after(mBtn);
      }
      if (mBtn) mBtn.dataset.copy = formatted;
    }
  }

  // อัปเดต OTP block
  const cell = tr.children[3]; // คอลัมน์ OTP/เวลา
  if (p.otp){
    // มี OTP แล้ว
    let otpDiv = cell.querySelector('.otp');
    if (!otpDiv){
      otpDiv = document.createElement('div');
      otpDiv.className = 'otp';
      cell.prepend(otpDiv);
    }
    otpDiv.innerHTML = `OTP : <b>${p.otp}</b>
        <button class="copy" data-copy="${p.otp}" aria-label="คัดลอก OTP">
            <img src="/static/assets/otp24/copy.png" alt="">
        </button>`;
  } else {
    // ยังไม่มี OTP → “ไม่พบข้อความ”
    let otpDiv = cell.querySelector('.otp');
    if (!otpDiv){
      otpDiv = document.createElement('div');
      otpDiv.className = 'otp none';
      cell.prepend(otpDiv);
    }
    otpDiv.classList.add('none');
    otpDiv.innerHTML = `OTP : <span class="muted">ไม่พบข้อความ</span>`;
  }

  // อัปเดต Pill สถานะ + ข้อความ
  if (p.status){
    const pill = tr.querySelector('.pill');
    const status = String(p.status).toLowerCase();
    pill.className = `pill ${status}`;
    pill.textContent =
      status==='success'   ? 'สำเร็จ' :
      status==='refunded'  ? 'คืนเครดิต' :
      status==='timeout'   ? 'หมดเวลา' :
      status==='failed'    ? 'ล้มเหลว' :
                             'กำลังรอ OTP';
  }

  // จัดการ countdown ใต้ pill
  const status = String(p.status||'').toLowerCase();
  let cd = tr.querySelector('.countdown');

  if (status === 'processing') {
    if (!cd) {
      cd = document.createElement('div');
      cd.className = 'countdown';
      // ถ้าเซิร์ฟเวอร์ส่ง expiresAt มาใน patch ก็ใส่ด้วย (ถ้ายังไม่มี ให้ใช้ data-expires เดิม)
      // นี่คือ display only; ถ้าไม่มี ก็ไม่เป็นไร tick จะข้าม
      cd.dataset.expires = tr.getAttribute('data-expires') || '';
      tr.children[5].appendChild(cd); // คอลัมน์สถานะ
    }
  } else {
    cd?.remove();
  }

  // ถ้าออเดอร์นี้ success → ตัด countdown ทิ้ง และถ้าไม่เหลือ processing เลย ให้หยุด auto-refresh ทันที
  if (status === 'success') {
    // ตัด countdown ของแถวนี้ทิ้ง
    tr.querySelector('.countdown')?.remove();
    tr.removeAttribute('data-expires');

    // มือถือด้วย
    const mCard = document.querySelector(`.m-orders .m-item[data-orderid="${p.orderId}"]`);
    mCard?.querySelector('.countdown')?.remove();
    mCard?.removeAttribute('data-expires');

    // ถ้าไม่เหลืองานสถานะ processing แล้ว → หยุดลูปทันที (ไม่ต้องรอรอบถัดไป)
    if (!hasProcessingRows()) stopOrdersAutoRefresh();
  }
}

async function refreshAllOrdersOnce(){
  try{
    const res = await fetch('/otp24/orders/refresh-all', { method:'POST' });
    const j = await res.json();
    if (!res.ok || !j?.ok) return;
    (j.changes || []).forEach(applyOrderPatch);

    // ถ้าไม่เหลือ processing แล้ว → หยุด
    if (!hasProcessingRows()) stopOrdersAutoRefresh();
  }catch{}
}

function startOrdersAutoRefresh(){
  stopOrdersAutoRefresh();
  ORD_AUTO_TIMER = setInterval(async () => {
    await refreshAllOrdersOnce();
    tickCountdowns();   // ← เรียกทุก ๆ วิ
  }, 1000);
}

function stopOrdersAutoRefresh(){
  if (ORD_AUTO_TIMER){ clearInterval(ORD_AUTO_TIMER); ORD_AUTO_TIMER = null; }
}

// ให้ tick ทำงานแม้ยังไม่เริ่มลูปรีเฟรช (เผื่อหน้าเปิดอยู่เฉยๆ)
tickCountdowns();
setInterval(tickCountdowns, 1000);

/* เริ่มออโต้เมื่อเปิดแท็บ "ประวัติ" */
document.querySelector('.tab[data-target="orders"]')
  ?.addEventListener('click', () => {
    startOrdersAutoRefresh();
  });

/* เริ่มออโต้ทันทีถ้าหน้าเปิดมามี processing อยู่แล้ว */
if (hasProcessingRows()) startOrdersAutoRefresh();

/* หยุด/เริ่มตาม visibility (ประหยัดโหลด) */
document.addEventListener('visibilitychange', () => {
  if (document.hidden) stopOrdersAutoRefresh();
  else if (document.querySelector('#section-orders').classList.contains('show')) {
    startOrdersAutoRefresh();
  }
});

// แตะตรงไหนก็พับ/กาง (ใช้ event delegation)
document.getElementById('mOrders')?.addEventListener('click', (e) => {
  const item = e.target.closest('.m-item');
  if (!item) return;
  // กันปุ่ม copy
  if (e.target.closest('.copy')) return;
  item.classList.toggle('collapsed');
  const btn = item.querySelector('.toggle');
  if (btn) btn.textContent = item.classList.contains('collapsed') ? '+' : '−';
});

// ------- Mobile sync: อัปเดตการ์ดมือถือให้ตรงกับ patch -------
const m = document.querySelector(`.m-orders .m-item[data-orderid="${p.orderId}"]`);
if (m) {
  // expires
  if (p.expiresAt) {
    m.dataset.expires = p.expiresAt;
    m.querySelector('.countdown')?.setAttribute('data-expires', p.expiresAt);
  }
  // phone
  if (Object.prototype.hasOwnProperty.call(p,'phone')) {
    const ct = Number(m.dataset.ct || 0);
    const phoneText = displayPhoneByCountry(p.phone || '-', ct);
    m.querySelector('.row2 .phone .v')?.replaceChildren(document.createTextNode(phoneText));
  }
  // otp
  if (Object.prototype.hasOwnProperty.call(p,'otp')) {
    const otpBox = m.querySelector('.row2 .otp');
    if (p.otp) {
      otpBox?.classList.remove('none');
      otpBox && (otpBox.innerHTML =
        `OTP: <b class="v">${p.otp}</b>
        <button class="copy" data-copy="${p.otp}" aria-label="คัดลอก OTP">
            <img src="/static/assets/otp24/copy.png" alt="">
        </button>`);
    } else {
      otpBox?.classList.add('none');
      otpBox && (otpBox.innerHTML = `OTP: <span class="muted v">ไม่พบข้อความ</span>`);
    }
  }
  // pill + countdown
  if (p.status) {
    const pill = m.querySelector('.pill');
    const st = String(p.status).toLowerCase();
    if (pill) {
      pill.className = `pill ${st}`;
      pill.textContent =
        st==='success'   ? 'เสร็จสิ้น' :
        st==='refunded'  ? 'คืนเครดิต' :
        st==='timeout'   ? 'หมดเวลา' :
        st==='failed'    ? 'ล้มเหลว'  :
                           'กำลังรอ OTP';
    }
    const cd = m.querySelector('.countdown');
    if (st === 'processing') {
      if (!cd) {
        const holder = m.querySelector('.m-body .pair:last-child span:last-child');
        const div = document.createElement('div');
        div.className = 'countdown';
        div.dataset.expires = m.getAttribute('data-expires') || '';
        div.textContent = 'เหลือเวลาอีก —:— นาที';
        holder?.appendChild(div);
      }
    } else {
      cd?.remove();
    }
  }
}

// helper: เปลี่ยนภาพไอคอน copy
function setCopyIcon(btn, success) {
  const img = btn.querySelector('img');
  if (!img) return;
  img.src = success
    ? '/static/assets/otp24/copy-success.png'
    : '/static/assets/otp24/copy.png';
}

document.addEventListener('click', (e) => {
  const btn = e.target.closest('.copy');
  if (!btn) return;

  navigator.clipboard.writeText(btn.dataset.copy || '').then(() => {
    setCopyIcon(btn, true);
    // กลับเป็นไอคอนปกติใน 900ms
    setTimeout(() => setCopyIcon(btn, false), 900);
  }).catch(() => {
    // ถ้า copy ไม่ได้ อย่าค้างไอคอน success
    setCopyIcon(btn, false);
  });
});
</script>

<script>
/* ========= Pagination (Client-side) ========= */
let ORDERS_PER_PAGE = Number(localStorage.getItem('OTP24_PER_PAGE')) || 20;
let currentPage = 1;

const $rows   = () => Array.from(document.querySelectorAll('#ordersBody tr'));
const $cards  = () => Array.from(document.querySelectorAll('#mOrders .m-item'));
const $info   = document.getElementById('pageInfo');
const $infoM  = document.getElementById('pageInfoMobile');
const $sel    = document.getElementById('perPageSelect');
const $selM   = document.getElementById('perPageSelectMobile');
const $ctrlD  = document.getElementById('ordersControlsDesktop');
const $ctrlM  = document.getElementById('ordersControlsMobile');

function totalItems(){ return (window.matchMedia('(max-width: 640px)').matches ? $cards().length : $rows().length); }
function totalPages(){ return Math.max(1, Math.ceil(totalItems() / ORDERS_PER_PAGE)); }
function clampPage(n){ return Math.min(Math.max(1, n), totalPages()); }

function applyPagination(){
  const isMobile = window.matchMedia('(max-width: 640px)').matches;
  const items = isMobile ? $cards() : $rows();

  const total = items.length;
  const pages = totalPages();
  currentPage = clampPage(currentPage);

  const start = (currentPage-1) * ORDERS_PER_PAGE;
  const end   = start + ORDERS_PER_PAGE;

  items.forEach((el, i) => {
    el.style.display = (i >= start && i < end) ? '' : 'none';
  });

  // อัปเดตตัวเลขหน้า
  if (!isMobile && $info)  $info.textContent  = `หน้า ${currentPage}/${pages}`;
  if (isMobile && $infoM)  $infoM.textContent = `หน้า ${currentPage}/${pages}`;

  // ปุ่ม disabled
  const setBtns = (root) => {
    if (!root) return;
    root.querySelector('[data-act="first"]')?.toggleAttribute('disabled', currentPage<=1);
    root.querySelector('[data-act="prev"]') ?.toggleAttribute('disabled', currentPage<=1);
    root.querySelector('[data-act="next"]') ?.toggleAttribute('disabled', currentPage>=pages);
    root.querySelector('[data-act="last"]') ?.toggleAttribute('disabled', currentPage>=pages);
  };
  setBtns($ctrlD);
  setBtns($ctrlM);
}

// เปลี่ยน per-page (เดสก์ท็อป & มือถือ)
function bindPerPage(selectEl){
  if (!selectEl) return;
  // set ค่าเริ่มต้น
  for (const opt of selectEl.options){
    opt.selected = Number(opt.value) === ORDERS_PER_PAGE;
  }
  selectEl.addEventListener('change', () => {
    ORDERS_PER_PAGE = Number(selectEl.value) || 20;
    localStorage.setItem('OTP24_PER_PAGE', ORDERS_PER_PAGE);
    currentPage = 1;
    applyPagination();
  });
}
bindPerPage($sel);
bindPerPage($selM);

// ปุ่มนำทาง (เดสก์ท็อป & มือถือ)
function bindPager(ctrlRoot){
  if (!ctrlRoot) return;
  ctrlRoot.addEventListener('click', (e) => {
    const btn = e.target.closest('.pg-btn');
    if (!btn) return;
    const act = btn.dataset.act;
    if (act === 'first') currentPage = 1;
    else if (act === 'prev') currentPage = clampPage(currentPage - 1);
    else if (act === 'next') currentPage = clampPage(currentPage + 1);
    else if (act === 'last') currentPage = totalPages();
    applyPagination();
  });
}
bindPager($ctrlD);
bindPager($ctrlM);

// เรียกครั้งแรกเมื่อโหลดหน้า
applyPagination();

// เมื่อรีเฟรชสถานะ/จำนวนรายการเปลี่ยน ให้คงหน้าปัจจุบันไว้ถ้าเป็นไปได้
const _origRefreshAll = refreshAllOrdersOnce;
refreshAllOrdersOnce = async function () {
  const out = await _origRefreshAll(); // ดึงแพตช์สถานะจากเซิร์ฟเวอร์
  applyPagination();                   // จัดหน้าใหม่ตามจำนวนรายการล่าสุด
  tickCountdowns();                    // อัปเดตตัวเลขนับถอยหลังให้ตรง DOM ล่าสุด

  // ถ้าไม่เหลือแถวสถานะ processing แล้ว ให้หยุดลูป auto-refresh ตอนนี้เลย
  if (!hasProcessingRows()) stopOrdersAutoRefresh();

  return out; // เผื่อที่อื่นยังใช้งานผลลัพธ์เดิม
};

// เมื่อสลับมือถือ/เดสก์ท็อป (resize) ให้ปรับหน้าให้เหมาะสม
let _resizeTimer = null;
window.addEventListener('resize', () => {
  clearTimeout(_resizeTimer);
  _resizeTimer = setTimeout(applyPagination, 150);
});
</script>

