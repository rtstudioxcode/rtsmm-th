.pill{ display:inline-block; padding:6px 12px; border-radius:999px; font-weight:700; }
.pill.success{ background:#16a34a22; color:#34d399; }
.pill.wait{ background:#f59e0b22; color:#fbbf24; }
.pill.timeout{ background:#ef444422; color:#f87171; }
.pill.failed{ background:#ef444422; color:#f87171; }

dialog::backdrop{ background: rgba(0,0,0,.5); }
.modal{ min-width:460px; padding:20px; border-radius:14px; border:1px solid #2e2f35; background:#17181b; }
/* ── Tabs/Lists (ของเดิมคงไว้) ─────────────────────────── */
.otp24 .tabs{ display:flex; gap:10px; }
.otp24 .tab{ padding:10px 14px; border-radius:12px; border:1px solid var(--elevated-border,#2e2f35); background:var(--elevated-bg,#151518); color:var(--text-primary,#fff); cursor:pointer; }
.otp24 .tab.active{ background:var(--accent,#63cff0); border-color:var(--accent,#63cff0); color:var(--accent-contrast,#fff); }
.tabpane{ display:none; } .tabpane.show{ display:block; }

.grid.cards{ display:grid; gap:18px; grid-template-columns: repeat(auto-fill, minmax(180px,1fr)); }
.card.app{ position:relative; text-align:center; padding:14px; border-radius:16px; background:var(--elevated-bg,#17181b); border:1px solid var(--elevated-border,#2b2d31); }
.price-badge{ position:absolute; top:8px; right:8px; background:var(--accent,#63cff0); color:var(--accent-contrast,#fff); padding:4px 10px; border-radius:999px; font-weight:700; font-size:12px; }
/* .app-icon{ display:grid; place-items:center; height:140px; border-radius:14px; background:color-mix(in oklab, var(--elevated-bg,#17181b), white 6%); overflow:hidden; } */
.app-icon img{ width:96px; height:96px; object-fit:contain; filter: drop-shadow(0 6px 10px rgba(0,0,0,.3)); }
.placeholder{ font-size:56px; opacity:.7; }
.app-name{ margin-top:10px; font-weight:700; letter-spacing:.5px; text-transform:uppercase; }
.btn{ padding:10px 14px; border-radius:12px; border:0; background:var(--accent,#63cff0); color:var(--accent-contrast,#fff); cursor:pointer; }
.btn.ghost{ background:transparent; border:1px solid var(--elevated-border,#444); color:var(--text-primary,#fff); }
.btn.small{ padding:6px 10px; border-radius:10px; }

.input{ padding:10px 12px; border-radius:12px; border:1px solid var(--elevated-border,#2e2f35); flex:1; }
.row{ display:flex; gap:12px; }
.w-100{ width:100%; } .mt{ margin-top:12px; } .mt-sm{ margin-top:8px; } .mt-lg{ margin-top:20px; }
.muted{ color:var(--text-muted,#a7b0bb); }

/* ── Flag grid (ในโมดัล) ───────────────────────────────── */
.flag-grid{ display:grid; grid-template-columns: repeat(5, 1fr); gap:20px; margin-top:10px; }
.flag{
  height:48px; border-radius:12px;
  background: color-mix(in oklab, var(--elevated-bg,#17181b), white 4%);
  border:1px solid var(--elevated-border,#2e2f35);
  display:grid; place-items:center; cursor:pointer;
  transition: transform .08s ease, box-shadow .08s ease, border-color .08s ease;
}
.flag:hover{ transform: translateY(-1px); }
.flag.selected, .flag.active{
  border-color: var(--accent,#2a84ff);
  box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent,#2a84ff), transparent 70%);
}
.flag img{ width:28px; height:28px; object-fit:cover; border-radius:6px; }

/* ── Orders table (ของเดิมปรับใช้ตัวแปรธีม) ───────────── */
.orders-wrap{ margin-top:14px; }
.tbl{ width:100%; border-collapse:separate; border-spacing:0; }
.tbl th, .tbl td{ padding:12px 14px; border-bottom:1px solid var(--elevated-border,#24262b); text-align:left; color:var(--text-primary,#f2f4f8); }
.tbl th.right, .tbl td.right{ text-align:right; }
.badge.app{ background:#ca551f; color:#fff; padding:4px 10px; border-radius:999px; font-weight:700; margin-right:6px; }
.mono{ font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace; }
.copy{ border:none; background:transparent; cursor:pointer; margin-left:6px; }
.pill{ display:inline-block; padding:6px 12px; border-radius:999px; font-weight:700; }
.pill.success{ background:#16a34a22; color:#34d399; }
.pill.wait{ background:#f59e0b22; color:#fbbf24; }
.pill.timeout,.pill.failed{ background:#ef444422; color:#f87171; }

/* ── Dialog reset: ไม่มีกรอบ/พื้นหลังขาว ─────────────── */
dialog{ border:none; padding:0; background:transparent; }
dialog::backdrop{ background: rgba(0,0,0,.55); backdrop-filter: blur(2px); }

.modal{
  min-width:460px; padding:20px; border-radius:16px;
  border:1px solid var(--elevated-border,#2e2f35);
  background: var(--elevated-bg,#17181b);
  color: var(--text-primary,#fff);
  box-shadow: var(--elevated-shadow, 0 12px 30px rgba(0,0,0,.4));
}
:root[data-theme="light"] .modal{
  background: var(--elevated-bg,#fff);
  color: var(--text-primary,#222);
  border-color: var(--elevated-border,#e7e7ea);
  box-shadow: 0 12px 26px rgba(0,0,0,.12);
}
/* ── Flag grid (เฉพาะในโมดัลซื้อ) ───────────────────── */
:root{
  /* ปรับขนาดธงได้ตรงนี้ */
  --flag-w: 48px;
  --flag-h: 38px; /* สัดส่วน 3:2 */
  --flag-radius: 10px;
}

.flag-grid{
  display:grid;
  grid-template-columns: repeat(5, var(--flag-w));
  gap:20px;
  margin-top:10px;
  justify-content: center; /* เรียงชิดซ้ายสวย ๆ */
}

/* ปุ่มธง = กรอบพอดีรูป, ไม่มี padding */
#buyModal .flag{
  width: var(--flag-w);
  height: var(--flag-h);
  padding: 0;
  border-radius: var(--flag-radius);
  overflow: hidden;
  background: color-mix(in oklab, var(--elevated-bg,#17181b), white 4%);
  border: 1px solid var(--elevated-border,#2e2f35);
  display: inline-block;
  line-height: 0;               /* กันช่องว่าง inline */
  cursor: pointer;
  transition: transform .08s ease, box-shadow .08s ease, border-color .08s ease;
}
#buyModal .flag:hover{ transform: translateY(-1px); }
#buyModal .flag.active{
  border-color: var(--accent,#2a84ff);
  box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent,#2a84ff), transparent 70%);
}

/* รูปธงเติมเต็มกรอบพอดี */
#buyModal .flag img{
  width: 100%;
  height: 100%;
  object-fit: cover;    /* ครอบเต็ม ไม่เหลือขอบ */
  display: block;       /* ตัดช่องว่าง inline */
  border-radius: inherit;
}
/* ── ธงเล็กในตารางประวัติ (ตัวอย่างรูป #3) ─────────── */
.orders-wrap .flag{
  display:inline-grid;
  place-items:center;
  width:28px;
  height:28px;
  border-radius:6px;
  background: color-mix(in oklab, var(--elevated-bg,#17181b), white 4%);
  border:1px solid var(--elevated-border,#2e2f35);
  overflow:hidden;
  line-height:0;
}
.orders-wrap .flag img{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
}
/* ─────────────────────────────
   Mobile tweaks (≤ 640px)
   ───────────────────────────── */
@media (max-width: 640px){

  /* การ์ดสินค้า: แถวละ 3 */
  .grid.cards{
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  .card.app{
    padding: 10px;
    border-radius: 14px;
  }
  .price-badge{
    top: 6px; right: 6px;
    font-size: 10px; padding: 2px 8px;
  }
  .app-icon{ height: 86px; border-radius: 12px; }
  .app-icon img{ border-radius: 13px; width: 56px; height: 56px; }
  .app-name{ margin-top: 8px; font-size: 12px; }

  .btn{ padding: 10px 12px; font-size: 13px; }
  .btn.small{ padding: 6px 10px; font-size: 12px; }
  .row{ gap: 8px; }

  /* โมดัลให้พอดีจอมือถือ */
  dialog{ padding: 0; }
  .modal{
    min-width: unset;
    width: 92vw;          /* กว้างพอดีจอ */
    max-width: 92vw;
    padding: 16px;
    border-radius: 14px;
  }
  dialog::backdrop{
    background: rgba(0,0,0,.55);
    backdrop-filter: blur(2px);
  }

  /* ธง: แถวละ 5 */
  .flag-grid{
    grid-template-columns: repeat(5, 1fr);
    gap: 20px;
  }
  .flag{
    height: 40px;
    border-radius: 10px;
  }
  .flag img{
    width: 24px; height: 24px;
    border-radius: 5px;
  }
}

/* Desktop โมดัล: จำกัดความกว้างเล็กน้อย (ไม่กระทบมือถือ) */
@media (min-width: 641px){
  .modal{ max-width: 560px; }
}

/* จัดกริดให้อยู่กึ่งกลางเสมอ */
.grid.cards{
  justify-content: center;     /* จัดชุดคอลัมน์ให้อยู่กลางคอนเทนเนอร์ */
  justify-items: stretch;      /* การ์ดกินพื้นที่คอลัมน์เต็ม */
}

/* ให้การ์ดขยายเต็มคอลัมน์ ไม่ล็อกความกว้างของตัวเอง */
.card.app{ width: 100%; }

/* มือถือ: ปรับคอลัมน์ + จัดกึ่งกลางให้ชัวร์ */
@media (max-width: 640px){
  .grid.cards{
    grid-template-columns: repeat(3, minmax(0, 1fr)); /* ไม่มี min กวนใจ */
    justify-content: center;
    justify-items: stretch;
    gap: 12px;
  }
  .card.app{ width: 100%; }
}
.card.app{
  cursor: pointer;
  transition: transform .08s ease, box-shadow .12s ease, border-color .12s ease;
}
.card.app:hover{
  transform: translateY(-2px);
  box-shadow: 0 10px 24px rgba(0,0,0,.25);
  border-color: color-mix(in oklab, var(--accent,#63cff0), transparent 60%);
}
.card.app:focus-within,
.card.app:focus{
  outline: none;
  box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent,#63cff0), transparent 70%);
  border-color: var(--accent,#63cff0);
}
/* ─────────────────────────────
   Modal: theme-aware + vivid buttons (light)
   วางต่อท้ายไฟล์เดิม เพื่อให้ override
   ───────────────────────────── */

/* ครอบคลุมทั้ง :root และ html ที่ตั้ง data-theme */
:root[data-theme="light"] .modal,
html[data-theme="light"] .modal{
  background: #fff;                     /* ขาวจริง ไม่อิงค่าดีฟอลต์มืด */
  color: #1f2328;
  border-color: #e7e7ea;
  box-shadow: 0 16px 36px rgba(0,0,0,.12);
}

/* Backdrop โปร่งขึ้นนิดสำหรับธีมสว่าง */
:root[data-theme="light"] dialog::backdrop,
html[data-theme="light"] dialog::backdrop{
  background: rgba(0,0,0,.35);
  backdrop-filter: blur(2px);
}

/* ปรับกรอบ/พื้นของธงให้คมชัดในธีมสว่าง */
:root[data-theme="light"] #buyModal .flag,
html[data-theme="light"] #buyModal .flag{
  background: #f7f8fa;
  border-color: #e2e5ea;
}
:root[data-theme="light"] #buyModal .flag.active,
html[data-theme="light"] #buyModal .flag.active{
  border-color: #2a84ff;
  box-shadow: 0 0 0 4px rgba(42,132,255,.18);
}

/* ปุ่มในโมดัล – ทำให้เด่น ไม่กลืนกับพื้นหลัง */
.modal .btn{
  border-radius: 12px;
  font-weight: 700;
  letter-spacing:.2px;
}

/* ปุ่มหลัก (ไม่ใช่ .ghost) ใช้กราเดียนท์ + เงานุ่ม */
.modal .btn:not(.ghost){
  background: linear-gradient(180deg, #2a84ff 0%, #1e6be0 100%);
  color: #fff;
  box-shadow: 0 6px 16px rgba(42,132,255,.35);
  border: 1px solid rgba(30,107,224,.2);
}
.modal .btn:not(.ghost):hover{
  filter: brightness(1.04);
  transform: translateY(-1px);
}
.modal .btn:not(.ghost):active{
  transform: translateY(0);
  box-shadow: 0 3px 10px rgba(42,132,255,.25);
}

/* ปุ่มรอง (.ghost) ให้มีขอบ+พื้นโปร่งสีอุ่นเล็กน้อย */
.modal .btn.ghost{
  background: rgba(27,31,36,.04);
  color: #222;
  border: 1px solid #dadde2;
}
:root[data-theme="dark"] .modal .btn.ghost,
html[data-theme="dark"] .modal .btn.ghost{
  background: rgba(255,255,255,.04);
  color: #f2f4f8;
  border-color: #3a3d45;
}
.modal .btn.ghost:hover{
  background: rgba(27,31,36,.06);
}

/* ฟิลด์/การ์ดราคาในโมดัล (ถ้ามี) ให้คอนทราสต์ขึ้น */
:root[data-theme="light"] .price-badge,
html[data-theme="light"] .price-badge{
  background: #2a84ff;
  color:#fff;
}

/* กันกรณีบางเพจตั้ง data-theme ไว้บน body */
body[data-theme="light"] .modal{ background:#fff; color:#1f2328; border-color:#e7e7ea; }
body[data-theme="light"] dialog::backdrop{ background: rgba(0,0,0,.35); }
body[data-theme="light"] #buyModal .flag{ background:#f7f8fa; border-color:#e2e5ea; }
body[data-theme="light"] #buyModal .flag.active{ box-shadow:0 0 0 4px rgba(42,132,255,.18); border-color:#2a84ff; }
.pill.success   { background:#16a34a22; color:#34d399; }
.pill.processing{ background:#f59e0b22; color:#fbbf24; }
.pill.failed,
.pill.timeout   { background:#ef444422; color:#f87171; }
.pill.refunded  { background:#22c5f644; color:#67e8f9; }
.countdown{ font-size:12px; opacity:.85; margin-top:4px; color:var(--text-muted,#a7b0bb); }
.countdown.warn{ color:#fbbf24; }
.countdown.danger{ color:#f87171; }

/* Desktop = ใช้ตารางเดิม, ซ่อนลิสต์มือถือ */
@media (min-width: 641px){
  .m-orders{ display:none; }
}

/* Mobile = ซ่อนไว้ตาราง, ใช้ลิสต์มือถือแทน */
@media (max-width: 640px){
  .orders-wrap{ display:none; }  /* ซ่อน table */
  .m-orders{ display:grid; gap:12px; margin-top:12px; }

  .m-item{
    background: var(--elevated-bg,#151518);
    border: 1px solid var(--elevated-border,#2e2f35);
    border-radius: 16px;
    overflow: hidden;
  }
  .m-head{
    padding: 12px 14px;
    position: relative;
    cursor: pointer;
  }
  .m-head .row1{
    display:flex; align-items:center; gap:10px;
  }
  .m-head .oid{ font-weight:700; }
  .m-head .when{ margin-left:auto; opacity:.9; }
  .m-head .toggle{
    width:28px; height:28px; border-radius:8px;
    border:1px solid var(--elevated-border,#2e2f35);
    background: transparent; color: var(--text-primary,#fff);
    margin-left:10px;
  }
  .m-head .row2{
    display:flex; gap:12px; margin-top:8px; flex-wrap:wrap;
    font-size: 13px; color: var(--text-muted,#a7b0bb);
  }
  .m-head .row2 .otp b{ font-weight:500; color: var(--text-primary,#f7d438); }

  .m-body{ padding: 12px 14px; border-top:1px dashed var(--elevated-border,#2e2f35); }
  .m-item.collapsed .m-body{ display:none; }

  .m-body .pair{
    display:flex; justify-content:space-between; align-items:center;
    padding: 8px 0; border-bottom:1px dashed var(--elevated-border,#2e2f35);
  }
  .m-body .pair:last-child{ border-bottom:0; }
  .m-body .pair > span:first-child{ opacity:.9; }
  .m-body .pair .flag{ width:28px; height:28px; border-radius:6px; overflow:hidden;
    border:1px solid var(--elevated-border,#2e2f35); display:inline-grid; place-items:center; }
  .m-body .pair .flag img{ width:100%; height:100%; object-fit:cover; display:block; }

  .pill{ padding:6px 12px; border-radius:999px; font-weight:700; }
  .pill.success   { background:#16a34a22; color:#34d399; }
  .pill.processing{ background:#f59e0b22; color:#fbbf24; }
  .pill.failed,
  .pill.timeout   { background:#ef444422; color:#f87171; }
  .pill.refunded  { background:#22c5f644; color:#67e8f9; }

  .countdown{ font-size:12px; margin-top:6px; color: var(--text-muted,#a7b0bb); }
  .countdown.warn{ color:#fbbf24; }
  .countdown.danger{ color:#f87171; }
}

/* ==== Mobile: ขยายความกว้าง + บีบระยะให้พอดีจอ ==== */
@media (max-width: 640px){

  /* ให้ container กว้างเต็มจอมากขึ้น ลด padding ข้าง */
  .page.container,
  .otp24.container{
    max-width: none;
    padding-left: 0px;
    padding-right: 0px;
  }

  /* แท็บไม่ทิ้งขอบเยอะเกิน */
  .otp24 .tabs{
    margin-left: -20px;
    margin-right: -20px;
  }

  /* ลิสต์มือถือกินเต็มจอมากขึ้น */
  .m-orders{
    margin-left: -20px;   /* ดันออกนิดให้ดูเต็ม */
    margin-right: -20px;
  }

  /* การ์ดให้กว้างขึ้นและกระชับขึ้น */
  .m-item{
    border-radius: 14px;
  }
  .m-head{ padding: 8px 54px; }
  .m-body{ padding: 8px 54px; }

  /* ===== หัวการ์ด: บังคับเวลาไม่ขึ้นบรรทัดใหม่ ===== */
  .m-head .row1{
    display:flex;
    align-items:center;
    gap: 8px;
    min-width: 0;              /* ให้ flex ภายในคำนวณกว้างได้ */
  }
  .m-head .oid{
    flex: 0 1 auto;            /* ยืดได้นิดหน่อยแต่ไม่กินจนล้น */
    min-width: 0;
  }
  .m-head .when{
    margin-left: auto;         /* ชิดขวา */
    white-space: nowrap;       /* << คีย์: ไม่ตัดบรรทัด */
    font-variant-numeric: tabular-nums;
  }
  .m-head .toggle{
    margin-left: 8px;
    flex: 0 0 auto;
  }

  /* ถ้ายังแคบจนขึ้นบรรทัด ให้ลดฟอนต์เวลาลงนิด */
  .m-head .when{ font-size: 12.5px; }       /* ปรับได้ 12–13px ตามใจ */

  /* แถวสรุปเบอร์/OTP ให้กระชับ */
  .m-head .row2{
    gap: 10px;
    font-size: 12.5px;
  }
}

.copy{
  border: none;
  background: transparent;
  cursor: pointer;
  padding: 0 4px;          /* เว้นนิดหน่อยให้คลิกง่าย */
  line-height: 0;          /* ตัดช่องว่าง inline */
  vertical-align: middle;  /* เรียงเสมอ baseline */
}
.copy img{
  width: 18px;
  height: 18px;
  display: inline-block;
}

/* ===== Flags: transparent background (override) ===== */

/* ปุ่มธงในโมดัลซื้อ */
#buyModal .flag{
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
}

/* รูปธงในโมดัลให้เต็มกรอบเหมือนเดิม แต่กรอบโปร่งใส */
#buyModal .flag img{
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  border-radius: var(--flag-radius, 10px);
}

/* ธงที่แสดงในตารางประวัติ */
.orders-wrap .flag{
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
}

/* รูปธงในตาราง */
.orders-wrap .flag img{
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  border-radius: 6px;
}

/* ธงในลิสต์มือถือ */
.m-orders .flag{
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
}
.m-orders .flag img{
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
