<% const PAGE_TITLE = "Telegram — ประวัติการใช้งาน"; %>

<section class="page telegram-page" style="padding:0; width: 100%;">

  <div class="page-head" style="padding:22px 20px 10px; width: 100%">
    <div class="page-title">
      <h1><%= PAGE_TITLE %></h1>
      <small class="muted">บริการพิเศษ → <%= PAGE_TITLE %></small>
    </div>
  </div>

  <!-- TABS -->
  <div class="tabs">
    <button type="button" class="tab" data-tab="accounts">สั่งซื้อบริการ</button>
    <button type="button" class="tab" data-tab="pull">ประวัติคำสั่งซื้อ</button>
    <button type="button" class="tab active" data-tab="history">ประวัติคำสั่งซื้อ</button>
  </div>

  <section id="tab-history" class="tabpane show">
    <section class="card" style="padding: 18px;">
        <div class="card-container">
        <% if (history && history.length > 0) { %>
            <% history.forEach(job => { %>
            <div class="card-item">
                <div class="card-header" onclick="toggleCard('<%= job._id %>')">
                <div class="order-details">
                    <span><%= job.orderId %> - <%= new Date(job.createdAt).toLocaleString("th-TH") %></span>
                    
                </div>
                <span class="status" style="color: 
                    <%= job.status === 'finished' ? '#4caf50' : 
                        (job.status === 'error' ? '#f44336' : '#fbc02d') %>;">
                    <%= job.status === 'finished' ? 'สำเร็จ' : 
                        (job.status === 'error' ? 'ไม่สำเร็จ' : 'กำลังดำเนินการ') %>
                    </span>
                </div>
                
                <div class="card-divider"></div>

                <div class="card-content" id="card-<%= job._id %>">
                <div>กลุ่มต้นทาง: <%= job.srcGroup %></div>
                <div>กลุ่มปลายทาง: <%= job.destGroup %></div>
                <div>จำนวนที่เชิญ: <%= job.invited %>/<%= job.limit %> คน</div>
                <button onclick='openLogModal(<%= JSON.stringify(job.logs) %>)'>
                    <img src="/static/assets/emoji/detail.png" alt="Details" class="detail-icon">
                </button>
                </div>
            </div>
            <% }) %>
        <% } else { %>
            <div class="muted">ยังไม่มีประวัติการดึงสมาชิก</div>
        <% } %>
        </div>
    </section>
    
    <!-- ========== MODAL: VIEW LOG ========== -->
    <div id="tgLogModal" class="modal-backdrop" style="display:none;">
        <div class="modal">
        <div class="modal-head">
            <h3>บันทึกการทำงาน</h3>
            <button class="modal-close" onclick="closeLogModal()">×</button>
        </div>
        <div id="tgModalContent" class="modal-body" style="max-height:400px; overflow-y:auto; font-size:13px;">
            <!-- logs will appear here -->
        </div>
        </div>
    </div>
  </section>

</section>

<script>
// TAB - SWITCH 
document.addEventListener('click', (e) => {
  const btn = e.target.closest('.tab');
  if (!btn) return;

  const tab = btn.dataset.tab;

  // ===== กรณี TAB 1 → Redirect ไป /telegram =====
  if (tab === 'accounts') {
    window.location.href = '/telegram';
    return;
  } else if (tab === 'pull') {
    window.location.href = '/telegram';
    return;
  }
  
  // ===== เปลี่ยนแท็บปกติ (TAB 1) =====
  document.querySelectorAll('.tab').forEach(t =>
    t.classList.remove('active')
  );
  btn.classList.add('active');

  document.querySelectorAll('.tabpane').forEach(p =>
    p.classList.remove('show')
  );
  document.getElementById('tab-' + tab).classList.add('show');
});

/* ---------- SSE STREAM ---------- */
function attachStream() {
  if (evtSource) evtSource.close();

  // ⭐ FIX: ใช้ currentJob ไม่ใช่ jobId
  evtSource = new EventSource(`/telegram/jobs/${currentJob}/stream`);

  evtSource.onmessage = (ev) => {
    const msg = JSON.parse(ev.data);

    if (msg.log) appendLog(msg.log);

    if (msg.invited != null && msg.total != null) {
      const pct = Math.round((msg.invited / msg.total) * 100);
      progressBar.style.width = pct + "%";
      countText.textContent =
        `เชิญแล้ว ${msg.invited} คน • ล้มเหลว ${msg.failed || 0} คน • ทั้งหมด ${msg.total} คน`;
    }

    // ถ้า PRECHECK FAIL
    if (msg.type === "precheck_fail") {

      showPrecheckErrors(msg.reasons || []);

      // ปิด progress UI (ถ้าเริ่มแสดง)
      progressBox.style.display = "none";

      // ปิด stream
      if (evtSource) evtSource.close();

      return; 
    }

    if (msg.status) {
      statusText.textContent =
        msg.status === "finished" ? "สำเร็จ" :
        msg.status === "running"  ? "กำลังทำงาน…" :
        msg.status === "stopped"  ? "หยุดแล้ว" :
        msg.status === "failed"  ? "ล้มเหลว" :
        msg.status === "error"    ? "มีข้อผิดพลาด" : msg.status;
    }

    if (msg.status === "finished") {
      notify.success("งาน #" + orderId + " เสร็จสิ้นแล้ว!");
      evtSource.close();
    }
  };
}

/* ---------- LOG HELPER ---------- */
function appendLog(t) {
  const div = document.createElement("div");
  div.textContent = t;
  logBox.appendChild(div);
  logBox.scrollTop = logBox.scrollHeight;
}

/* ====================================================== 
   HELPERS
====================================================== */
function mapStatus(s) {
  return s === "running"  ? "กำลังทำงาน" :
         s === "pending"  ? "กำลังทำงาน" :
         s === "finished" ? "สำเร็จ" :
         s === "stopped"  ? "หยุด" :
         s === "failed" ? "ล้มเหลว" :
         s === "error"    ? "ผิดพลาด" :
         (s || "-");
}

function formatDate(d) {
  return new Date(d).toLocaleString("th-TH", {
    dateStyle: "short",
    timeStyle: "short"
  });
}

/* ====================================================== 
   OPEN LOG MODAL
====================================================== */
// Open the modal to show logs
function openLogModal(logs = []) {
  const modal = document.getElementById("tgLogModal");
  const body = document.getElementById("tgModalContent");

  if (!logs || logs.length === 0) {
    body.innerHTML = `<div class="muted">ไม่มีบันทึก</div>`;
  } else {
    body.innerHTML = logs
      .map(l => `<div>[${new Date(l.time).toLocaleString("th-TH")}] ${l.text}</div>`)
      .join(""); // แสดงข้อมูล logs
  }

  modal.style.display = "flex";
}

// Close the modal
function closeLogModal() {
  document.getElementById("tgLogModal").style.display = "none";
}

/* ===================== Toggle Card ===================== */
function toggleCard(jobId) {
  const cardContent = document.getElementById('card-' + jobId);
  const toggleButton = document.querySelector(`#card-${jobId} .toggle`);
  
  if (cardContent.style.display === "block") {
    cardContent.style.display = "none";
  } else {
    cardContent.style.display = "block";
  }
}
</script>

