<% const PAGE_TITLE = "Telegram — รวมบอท"; %>

<section class="page telegram-page" style="padding:0; width: 100%;">

  <!-- ====================== PAGE HEADER ====================== -->
  <div class="page-head" style="padding:22px 20px 10px; width: 100%">
    <div class="page-title">
      <h1><%= PAGE_TITLE %></h1>
      <small class="muted">เครื่องมือ → <%= PAGE_TITLE %></small>
    </div>
  </div>

  <!-- ====================== TABS ====================== -->
  <div class="tabs" id="tgTabs" style="padding:0 25px; width: 100%;">
    <button class="tab" data-tab="accounts">
      ตั้งค่าบัญชี
    </button>
    <button class="tab active" data-tab="pull">
      ดึงสมาชิก
    </button>
    <button class="tab" data-tab="history">
      ประวัติการดึง
    </button>
  </div>

  <!-- ========== TAB 1: ACCOUNTS (ตั้งค่าบัญชีเทเลแกรม) ========== -->
  <section id="tab-accounts" class="tabpane">
    <section class="card" style="padding:18px;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:14px;">
            <div class="title">
                บัญชี Telegram ของคุณ <span id="tgAccCount">(โหลดข้อมูล...)</span>
            </div>

            <button id="btnAddTgAcc" class="btn gold" style="padding:6px 14px; font-size:13px;">
                ➕ เพิ่มบัญชี Telegram
            </button>
        </div>
        <!-- รายการบัญชี -->
        <div id="tgAccList" class="tg-acc-list">
            <!-- JS จะเติมข้อมูลลงตรงนี้ -->
        </div>
    </section>

    <!-- ───────────── วิธีเพิ่มบัญชี Telegram ───────────── -->
    <section class="card howto-add-telegram" style="margin-top:22px; padding:20px 20px 26px;">

    <h3 class="title" style="margin-bottom:14px;">วิธีเพิ่มบัญชี Telegram (แบบละเอียด)</h3>

    <ol style="list-style:none; padding-left:0; margin:0;">
        
        <!-- STEP 1 -->
        <li style="margin-bottom:18px; display:flex; gap:12px; align-items:flex-start;">
        <div class="step-circle">1</div>
        <div>
            เข้าเว็บไซต์สำหรับสร้าง <b style="color:#e3b863;">APP_ID</b> และ <b style="color:#e3b863;">API_HASH</b>  
            <br>
            <a href="https://my.telegram.org/auth" target="_blank" rel="noopener" style="
                /* background:#111; */
                padding:3px 6px;
                border-radius:4px;
                font-family: monospace;
                color:#4ea1ff;
                text-decoration: underline;
                ">https://my.telegram.org/auth
            </a>
        </div>
        </li>

        <!-- STEP 2 -->
        <li style="margin-bottom:18px; display:flex; gap:12px; align-items:flex-start;">
        <div class="step-circle">2</div>
        <div>
            ล็อกอินด้วยเบอร์โทรของคุณ (Telegram จะส่งรหัส OTP ให้ในแอป)
        </div>
        </li>

        <!-- STEP 3 -->
        <li style="margin-bottom:18px; display:flex; gap:12px; align-items:flex-start;">
        <div class="step-circle">3</div>
        <div>
            เลือกเมนู <b style="color:#e3b863;">API Development Tools</b>
        </div>
        </li>

        <!-- STEP 4 -->
        <li style="margin-bottom:18px; display:flex; gap:12px; align-items:flex-start;">
        <div class="step-circle">4</div>
        <div>
            กรอกข้อมูลให้ครบ:
            <ul style="margin:4px 0 0 6px; color:#cfcfcf; font-size:14px;">
            <li><b style="color:#e3b863;">App title:</b> ใส่อะไรก็ได้ เช่น RTSMMBOT (ใส่ตัวเลขก็ได้)</li>
            <li><b style="color:#e3b863;">Short name:</b> ชื่อย่อ เช่น rtsmm (ใส่ตัวเลขก็ได้)</li>
            <li><b style="color:#e3b863;">Platform:</b> Android</li>
            <li><b style="color:#e3b863;">Description:</b> ใส่หรือไม่ใส่ก็ได้</li>
            </ul>
             <div class="tg-help-img mt-xs" style="max-width:520px;">
                <img
                src="/static/telegrambot/helpers.jpg"
                alt="ตัวอย่างการคัดลอก โดยตรง link จาก pic.in.th"
                loading="lazy"
                class="previewable"
                >
            </div>
        </div>
        </li>

        <!-- STEP 5 -->
        <li style="margin-bottom:18px; display:flex; gap:12px; align-items:flex-start;">
        <div class="step-circle">5</div>
        <div>
            ระบบจะสร้าง <b style="color:#e3b863;">APP_ID</b> และ  
            <b style="color:#e3b863;">API_HASH</b> ให้คุณ — ให้คัดลอกไปใส่ในฟอร์มเพิ่มบัญชี
        </div>
        </li>

        <!-- STEP 6 -->
        <li style="margin-bottom:18px; display:flex; gap:12px; align-items:flex-start;">
        <div class="step-circle">6</div>
        <div>
            เมื่อกด <b style="color:#e3b863;">“เริ่มเข้าสู่ระบบ”</b> ระบบจะส่งรหัส <b style="color:#639ae3;">OTP</b> ไปที่แอป Telegram ของคุณทันที  
            <br>กรอกให้ถูกต้อง → หากมี <b style="color:#639ae3;">2FA</b> ให้ใส่รหัสผ่านด้วย
        </div>
        </li>

        <!-- STEP 7 -->
        <li style="margin-bottom:10px; display:flex; gap:12px; align-items:flex-start;">
        <div class="step-circle">7</div>
        <div>
            เพิ่มสำเร็จแล้ว บัญชีจะขึ้นสถานะ  
            <span style="color:#9be169; font-weight:600;">READY</span>  
            และพร้อมใช้งานทันที
        </div>
        </li>
    </ol>

    </section>

    <!-- ===================== Modal เริ่มต้น Login ===================== -->
    <div id="tgLoginBackdrop" class="modal-backdrop" style="display:none;">
        <div class="modal tg-modal">

            <div class="modal-head">
            <h3 class="title modal-title">เพิ่มบัญชี Telegram</h3>
            <button id="tgLoginClose" class="modal-close">&times;</button>
            </div>

            <div class="modal-body">
            
            <!-- <div class="form-group">
              <label>ชื่อ</label>
              <input id="tg_name" type="text" class="input" placeholder="บอท1">
            </div> -->

            <div class="form-group">
                <label>เบอร์โทรศัพท์</label>
                <input id="tg_phone" type="text" class="input" placeholder="+669xxxxxxxx">
            </div>

            <div class="row2">
                <div class="form-group">
                <label>API ID</label>
                <input id="tg_apiId" type="number" class="input" placeholder="123456">
                </div>
                <div class="form-group">
                <label>API Hash</label>
                <input id="tg_apiHash" type="text" class="input" placeholder="API Hash">
                </div>
            </div>

            </div>

            <div class="modal-actions">
            <button id="tgLoginCancel" class="btn dark">ยกเลิก</button>
            <button id="tgLoginNext" class="btn gold">ถัดไป</button>
            </div>

        </div>
    </div>


    <!-- ===================== Modal OTP / Password ===================== -->
    <div id="tgOtpBackdrop" class="modal-backdrop" style="display:none;">
        <div class="modal tg-modal">

            <div class="modal-head">
            <h3 class="title modal-title">ยืนยันรหัส OTP</h3>
            <button id="tgOtpClose" class="modal-close">&times;</button>
            </div>

            <div class="modal-body">

            <div id="otpSection" class="form-group">
                <label>รหัส OTP (5 หลัก)</label>
                <input id="tg_otp" type="text" class="input" placeholder="12345">
            </div>

            <div id="passSection" class="form-group" style="display:none;">
                <label>รหัสผ่าน 2FA</label>
                <input id="tg_password" class="input" type="password" placeholder="Password 2FA">
            </div>

            </div>

            <div class="modal-actions">
            <button id="tgOtpCancel" class="btn dark">ยกเลิก</button>
            <button id="tgOtpSubmit" class="btn gold">ยืนยัน</button>
            </div>

        </div>
    </div>
  </section>
  
  <!-- ========== TAB 2: PULL MEMBERS ========== -->
  <section id="tab-pull" class="tabpane show">
    <!-- PRECHECK WARNING BOX -->
    <div id="precheckBox" 
        style="display:none; margin-bottom:14px; padding:12px; border:1px solid #b86f41; background:#3b2a20; border-radius:8px; color:#ffddb8;">
      <div style="font-weight:600; margin-bottom:4px;">⚠ ไม่สามารถเริ่มงานได้</div>
      <div id="precheckList" style="font-size:13px; line-height:1.45;"></div>
    </div>

    <section class="card" style="padding:18px 18px 22px;">
      <h3 class="title" style="margin-bottom:12px;">ตั้งค่าการดึงสมาชิก</h3>

      <form id="tgPullForm" class="form" onsubmit="return false;">

        <!-- MODE SELECTOR -->
        <div class="form-row" style="margin-bottom:14px;">
          <label>เลือกรูปแบบการเพิ่มสมาชิก</label>

          <div id="pullModeSwitch" class="mode-switch">
            <button type="button" class="mode-btn active" data-mode="group">
              1) ใส่ลิงก์กลุ่ม (ดึงจากกลุ่ม)
            </button>

            <button type="button" class="mode-btn" data-mode="list">
              2) อัปโหลดไฟล์ CSV/TXT (เบอร์ / @username)
            </button>
          </div>

          <div id="listHint" class="muted"
              style="margin-top:8px; font-size:12px; line-height:1.45; display:none;">
            ✅ 1 รายชื่อ = 1 คน • รองรับ <b style="color:#8ec7ff;">+66123456789</b> และ <b style="color:#8ec7ff;">@username</b>
          </div>

          <input type="hidden" id="pullMode" value="group">
          <input type="hidden" id="targetsJson" value="[]">
        </div>

        <!-- ✅ GROUP MODE -->
        <div id="modeGroupFields">
          <!-- 1) กลุ่มเป้าหมาย -->
          <div class="form-row" id="srcRow">
            <label>กลุ่มเป้าหมาย (กลุ่มที่ต้องการดึงสมาชิก)</label>
            <input type="text" id="srcGroup" placeholder="รองรับทั้ง https://t.me/group หรือ t.me/+invitehash หรือ @group" />
          </div>

          <!-- 2) กลุ่มปลายทาง (ย้ายได้ด้วย JS) -->
          <div class="form-row" id="destRow" style="margin-top:14px;">
            <label>กลุ่ม/ช่องปลายทาง (กลุ่ม/ช่องที่ต้องการเพิ่มสมาชิก)</label>
            <input type="text" id="destGroup" placeholder="รองรับทั้ง https://t.me/yourgroup หรือ t.me/+invitehash หรือ @yourgroup" />
          </div>

          <!-- 3) จำนวนสมาชิก -->
          <div class="form-row" id="limitRow" style="margin-top:14px;">
            <label>จำนวนสมาชิกที่ต้องการ</label>
            <input type="number" id="limit" min="1" max="1000" step="1" required placeholder="เช่น 10 สูงสุด 1000 คนต่อ 1 รอบ" />
          </div>
        </div>

        <!-- ✅ LIST MODE -->
        <div id="modeListFields" style="display:none; margin-top:14px;">
          <!-- 1) อัปโหลดไฟล์ -->
          <div class="form-row" id="fileRow">
            <label>อัปโหลดไฟล์รายชื่อ (.csv / .txt)</label>
            <input type="file" id="targetFile" accept=".txt,.csv" style="width:100%;" />

            <div class="muted" style="margin-top:8px; font-size:12px; line-height:1.45;">
              ตัวอย่างในไฟล์: <code style="color:#8ec7ff;">+66123456789</code> หรือ <code style="color:#8ec7ff;">@username</code>
            </div>
          </div>

          <!-- รายชื่อ -->
          <section class="card targets-card" id="targetsCard" style="display:none; margin-top:14px;">

            <!-- TOP (ไม่ต้อง sticky) -->
            <div class="targets-top">
              <div class="targets-title">
                <div class="t-h">รายชื่อที่จะเชิญ</div>
                <div class="t-sub">
                  พบ <b id="tTotal">0</b> รายชื่อ · เลือก <b id="tSelected">0</b>
                  <span id="tInvalidWrap" style="display:none;"> · <b id="tInvalid">0</b> ไม่ถูกต้อง</span>
                </div>
              </div>

              <div class="targets-actions">
                <div class="t-search">
                  <input id="tSearch" type="text" placeholder="ค้นหาเบอร์ / @username..." />
                </div>
                <button type="button" class="btn-mini" id="btnSelectAll">เลือกทั้งหมด</button>
                <button type="button" class="btn-mini danger" id="btnRemoveSelected" disabled>ลบที่เลือก</button>
              </div>
            </div>

            <!-- SCROLL ZONE -->
            <div class="targets-scroll">
              <div class="targets-th">
                <div class="col-check"></div>
                <div class="col-type">ประเภท</div>
                <div class="col-value">เบอร์/Username</div>
                <div class="col-status">สถานะ</div>
                <div class="col-del"></div>
              </div>

              <div id="targetsBody" class="targets-body"></div>
            </div>
          </section>

          <!-- 2) กลุ่มปลายทาง (JS จะย้าย destRow มาเสียบตรงนี้) -->
          <div id="listDestMount" style="margin-top:14px;"></div>
        </div>

        <!-- Cost Preview -->
        <div id="costPreview" style="margin-top:12px; font-size:13px; color:#3fbd0d;">
          เครดิตที่ใช้: 0 เครดิต
        </div>

        <div style="margin-top:20px;">
          <button id="startBtn" class="btn-lux" style="width:100%;">เริ่มการทำงาน</button>
        </div>
      </form>
    </section>
    <!-- ========== HOW TO USE ========== -->
    <section class="card" style="margin-top:22px; padding:20px 20px 26px;">

    <h3 class="title" style="margin-bottom:14px;">วิธีใช้งานแบบละเอียด</h3>

    <ol style="list-style:none; padding-left:0; margin:0;">
        <li style="margin-bottom:16px; display:flex; gap:10px;">
        <div style="
            width:28px; height:28px; background:#2f3238; 
            border-radius:50%; display:flex; 
            align-items:center; justify-content:center;
            color:#9be169; font-weight:600;">
            1
        </div>
        <div id="howtoStep1Text">
          วางลิงก์กลุ่มเป้าหมาย — รองรับทั้ง 
          <code style="color:#8ec7ff;">https://t.me/group</code> 
          หรือ <code style="color:#8ec7ff;">t.me/+invitehash</code>
          หรือ <code style="color:#8ec7ff;">@group</code>
        </div>
        </li>

        <li style="margin-bottom:16px; display:flex; gap:10px;">
        <div style="
            width:28px; height:28px; background:#2f3238; 
            border-radius:50%; display:flex; 
            align-items:center; justify-content:center;
            color:#9be169; font-weight:600;">
            2
        </div>
        <div>
            วางลิงก์กลุ่ม/ช่องปลายทาง — รองรับทั้ง 
            <code style="color:#8ec7ff;">https://t.me/yourgroup</code> 
            หรือ <code style="color:#8ec7ff;">t.me/+invitehash</code>
            หรือ <code style="color:#8ec7ff;">@yourgroup</code>
        </div>
        </li>

        <li style="margin-bottom:16px; display:flex; gap:10px;">
        <div style="
            width:28px; height:28px; background:#2f3238;
            border-radius:50%; display:flex;
            align-items:center; justify-content:center;
            color:#9be169; font-weight:600;">
            3
        </div>
        <div id="howtoStep3Text">
          กรอกจำนวนสมาชิกที่ต้องการเชิญ — ระบบจะคำนวณเครดิตอัตโนมัติ 
          <b style="color:#57d110;">ตอนนี้ใช้ฟรีไม่เสียเงิน</b>
        </div>
        </li>

        <li style="margin-bottom:16px; display:flex; gap:10px;">
        <div style="
            width:28px; height:28px; background:#2f3238;
            border-radius:50%; display:flex;
            align-items:center; justify-content:center;
            color:#9be169; font-weight:600;">
            4
        </div>
        <div>
            กดเริ่มงาน — ถ้า <b style="color:#f78c6c;">ยังไม่มีบัญชีพร้อมใช้งาน</b> ระบบจะแจ้งเตือนอัตโนมัติ
        </div>
        </li>

        <li style="margin-bottom:16px; display:flex; gap:10px;">
        <div style="
            width:28px; height:28px; background:#2f3238;
            border-radius:50%; display:flex;
            align-items:center; justify-content:center;
            color:#9be169; font-weight:600;">
            5
        </div>
        <div>
            ติดตามผลที่หน้า <b style="color:#e3b863;">ประวัติการใช้งาน</b> (อัปเดตแบบเรียลไทม์)
        </div>
        </li>

        <li style="margin-bottom:16px; display:flex; gap:10px;">
        <div style="
            width:28px; height:28px; background:#2f3238;
            border-radius:50%; display:flex;
            align-items:center; justify-content:center;
            color:#9be169; font-weight:600;">
            6
        </div>
        <div>
            จบงานแล้วระบบจะสรุปผลและ 
            <b style="color:#e3b863;">คืนเครดิตอัตโนมัติ</b> สำหรับจำนวนที่เชิญไม่สำเร็จ
        </div>
        </li>

        <li style="margin-bottom:16px; display:flex; gap:10px;">
        <div style="
            width:28px; height:28px; background:#2f3238;
            border-radius:50%; display:flex;
            align-items:center; justify-content:center;
            color:#9be169; font-weight:600;">
            7
        </div>
        <div>
            กลุ่ม/ช่องปลายทางต้องเปิด 
            <b style="color:#e3b863;">สิทธิ์การเชิญเพื่อน (Add Members)</b> ของกลุ่มหรือช่องแล้วเท่านั้น
        </div>
        </li>
    </ol>

    <!-- ───────────── 2 Columns Detail Boxes ───────────── -->
    <div class="detail-boxes">
    
    <!-- ช่องกรอกในฟอร์ม -->
    <div class="box">
        <h4 class="box-title">ช่องกรอกในฟอร์ม</h4>
        <ul>
        <li>ลิงก์กลุ่มเป้าหมาย</li>
        <li>ลิงก์กลุ่มตัวเอง (หรือกลุ่มที่ต้องการเพิ่มสมาชิก)</li>
        <li>จำนวนสมาชิกที่ต้องการ — เช่น <b style="color:#57d110;">5</b>, <b style="color:#57d110;">10</b>, <b style="color:#57d110;">25</b> สูงสุด <b style="color:#d1c410;">1000</b> คนต่อรอบ</li>
        </ul>
    </div>

    <!-- นโยบาย -->
    <div class="box">
        <h4 class="box-title">นโยบายการใช้งาน</h4>
        <ul>
        <li>หักก่อนเริ่มงาน: <b style="color:#e3b863;">2 เครดิต/คน</b></li>
        <li>รีฟันด์ (จำนวนที่ขาด): <b style="color:#e3b863;">คืน 2 เครดิต/คน</b></li>
        <li>สถานะงานในประวัติ: <b style="color:#e3b863;">กำลังทำงาน</b> / <b style="color:#57d110;">สำเร็จ</b> / <b style="color:#d60e0e;">ล้มเหลว</b> / <b style="color:#868686;">จบงาน</b> / <b style="color:#868686;">จบงานอัตโนมัติ</b></li>
        </ul>
    </div>

    <!-- คำแนะนำบัญชี -->
    <div class="box">
        <h4 class="box-title">คำแนะนำบัญชี</h4>
        <ul>
        <li>บัญชีควรมีอายุ: <b style="color:#e3b863;">1 เดือน++ ขึ้่นไป</b></li>
        <li>ไม่ควรใช้บัญชีที่มีอายุต่ำกว่า <b style="color:#e3b863;">1 เดือน</b></li>
        <li>บัญชีควรเป็นบัญชีที่ไม่เคยใช้งานบอทจะปลอดภัยที่สุด</li>
        <li>1 บัญชีจะดึงได้ <b style="color:#e3b863;">50 คนต่อ 1 รอบและจะพักบัญชี (ตามเวลาที่ Telegram สั่งพัก)</b></li>
        </ul>
    </div>

    <!-- การทำงานของระบบ -->
    <div class="box">
      <h4 class="box-title">การทำงานของระบบ</h4>
      <ul>
