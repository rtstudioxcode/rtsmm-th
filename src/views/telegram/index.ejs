/* ======================================================
   HELPERS
====================================================== */
function mapStatus(s) {
  return s === "running"  ? "กำลังทำงาน" :
         s === "pending"  ? "กำลังทำงาน" :
         s === "finished" ? "สำเร็จ" :
         s === "stopped"  ? "จบงาน" :
         s === "auto_stopped" ? "หยุดอัตโนมัติ" :
         s === "failed" ? "ล้มเหลว" :
         s === "error"    ? "ผิดพลาด" :
         (s || "-");
}

// ==============================
// Realtime Log Modal (History) - AUTO UPDATE (SSE + POLL FALLBACK)
// ==============================
let logES = null;
let pollTimer = null;
let modalJobId = null;

const seenLogKey = new Set();

function getLogDom() {
  return {
    modal: document.getElementById("tgLogModal"),
    list: document.getElementById("tgModalContent")
  };
}

function fmtTH(ts) {
  const d = new Date(ts || Date.now());
  return d.toLocaleString("th-TH", {
    year: "2-digit", month: "2-digit", day: "2-digit",
    hour: "2-digit", minute: "2-digit", second: "2-digit"
  });
}

function stopLogStream() {
  try { logES?.close(); } catch (_) {}
  logES = null;
}

function stopLogPoll() {
  if (pollTimer) clearInterval(pollTimer);
  pollTimer = null;
}

function stopLogLive() {
  stopLogStream();
  stopLogPoll();
  modalJobId = null;
}

function appendLogLine(line) {
  const { list } = getLogDom();
  if (!list) return;

  const time = line?.time || line?.createdAt || Date.now();
  const text = line?.text || line?.log || "";
  if (!text) return;

  const key = `${new Date(time).toISOString()}|${text}`;
  if (seenLogKey.has(key)) return;
  seenLogKey.add(key);

  const nearBottom = (list.scrollHeight - list.scrollTop - list.clientHeight) < 80;

  const row = document.createElement("div");
  row.className = "log-row";
  row.textContent = `[${fmtTH(time)}] ${text}`;
  list.appendChild(row);

  if (nearBottom) list.scrollTop = list.scrollHeight;
}

async function fetchAndAppendHistory(jobId) {
  try {
    const r = await fetch(`/telegram/history/${jobId}`);
    const data = await r.json();
    if (!data.ok) return;

    // เติม log ใหม่ (กันซ้ำด้วย seenLogKey)
    (data.logs || []).forEach(l => appendLogLine(l));

    // ถ้างานจบแล้ว หยุด poll/stream ให้เอง (กันกินทรัพยากร)
    const st = String(data.meta?.status || "").toLowerCase();
    if (["finished", "stopped", "error", "auto_stopped", "failed"].includes(st)) {
      stopLogLive();
    }
  } catch (_) {
    // เงียบไว้ ไม่ต้อง spam
  }
}

function startLogPoll(jobId) {
  stopLogPoll();

  // ดึงทันที 1 ครั้งก่อน
  fetchAndAppendHistory(jobId);

  // แล้วค่อยดึงซ้ำทุก 1500ms
  pollTimer = setInterval(() => {
    const { modal } = getLogDom();
    if (!modal || modal.style.display === "none") {
      stopLogPoll();
      return;
    }
    fetchAndAppendHistory(jobId);
  }, 1500);
}

function startLogStream(jobId) {
  stopLogStream();

  logES = new EventSource(`/telegram/jobs/${jobId}/stream`);

  logES.onmessage = (ev) => {
    let data = {};
    try { data = JSON.parse(ev.data || "{}"); } catch (_) {}

    // รองรับได้ทั้งส่งมาเป็น log เดี่ยว หรือส่งมาเป็น array logs
    if (data.log) appendLogLine({ time: data.time || Date.now(), text: data.log });
    if (Array.isArray(data.logs)) data.logs.forEach(l => appendLogLine(l));

    const st = String(data.status || "").toLowerCase();
    if (["finished", "stopped", "error", "auto_stopped", "failed"].includes(st)) {
      stopLogLive();
    }
  };

  logES.onerror = () => {
    // ปล่อยให้มัน reconnect เอง + เรามี poll กันพลาดอยู่แล้ว
  };
}

/**
 * ✅ เปิด modal + เปิด live update ทันที (ไม่ต้องปิด/เปิดใหม่)
 */
function openLogModal(logs = [], meta = {}) {
  const { modal, list } = getLogDom();
  if (!modal || !list) {
    console.log("missing modal dom #tgLogModal/#tgModalContent");
    return;
  }

  const jobId = meta._id || meta.jobId || meta.id;
  if (!jobId) return;

  // reset
  list.innerHTML = "";
  seenLogKey.clear();

  // render ที่มีอยู่ก่อน
  (logs || []).forEach(l => appendLogLine(l));

  // เปิด modal (center ด้วย CSS flex)
  modal.style.display = "flex";
  document.body.style.overflow = "hidden";

  // ✅ เริ่ม live update ทันที (SSE + Poll)
  modalJobId = jobId;
  startLogStream(jobId);
  startLogPoll(jobId);
}

function closeLogModal() {
  const { modal } = getLogDom();
  stopLogLive();
  if (modal) modal.style.display = "none";
  document.body.style.overflow = "";
}

