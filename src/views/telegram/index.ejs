// Update cooldown and status on account
function updateCooldown(account) {
  const now = Date.now();
  const cooldownUntil = new Date(account.cooldownUntil).getTime(); // เวลาเมื่อถึงคูลดาวน์

  if (cooldownUntil > now) {
    const remainingTime = cooldownUntil - now;
    const hours = Math.floor(remainingTime / 3600000);  // ชั่วโมง
    const minutes = Math.floor((remainingTime % 3600000) / 60000);  // นาที
    const seconds = Math.floor((remainingTime % 60000) / 1000);  // วินาที

    // แสดงข้อความเวลา
    const statusText = `จะกลับมาใช้ได้ในอีก ${hours > 0 ? hours + ' ชั่วโมง ' : ''}${minutes} นาที ${seconds} วินาที`;

    const timerElement = document.getElementById(`tg-timer-${account._id}`);  // อัปเดตเฉพาะส่วน timer

    if (timerElement) {
      timerElement.innerHTML = `${hours > 0 ? hours + ' ชั่วโมง ' : ''}${minutes} นาที ${seconds} วินาที`; // แสดงเวลา
    }

    // อัปเดตทุกๆ วินาที
    setTimeout(() => updateCooldown(account), 1000);  // อัปเดตทุกๆ วินาที
  }
}

// เรียกใช้ฟังก์ชันเมื่อโหลดบัญชี
async function loadTgAccounts() {
  try {
    const res = await fetch("/telegram/accounts");
    const data = await res.json();

    if (!data.ok) {
      notify.error("ไม่สามารถโหลดบัญชีได้");
      return;
    }

    const list = data.accounts || [];
    const wrap = document.getElementById("tgAccList");
    const count = document.getElementById("tgAccCount");

    // อัปเดตจำนวนบัญชี
    const ready = list.filter(a => a.status === "READY").length;
    count.textContent = `(พร้อมใช้งาน ${ready} บัญชี)`;  // อัพเดทจำนวนบัญชี

    wrap.innerHTML = "";  // ลบข้อมูลเก่าออก

    list.forEach(acc => {
      const item = document.createElement("div");
      item.className = "tg-acc-item";
      const created = new Date(acc.createdAt).toLocaleString("th-TH");

      let statusClass = "ready";
      let statusText = "พร้อมใช้งาน";

      if (acc.status === "COOLDOWN") {
        statusClass = "cooldown";
        statusText = "พักบัญชี";
        updateCooldown(acc);
      } else if (acc.status === "LOCKED") {
        statusClass = "locked";
        statusText = "พักการใช้งานชั่วคราว";
      }

      item.innerHTML = `
        <div class="tg-acc-left">
          <div><b>${acc.phone} - </b><b class="text-yellow">${acc.name}</b></div>
          <div class="tg-status ${statusClass}" id="tg-status-${acc._id}">${statusText}</div>
          <!-- เพิ่ม div สำหรับเวลานับถอยหลัง (timer) ใต้สถานะ -->
          <div class="tg-cooldown-timer" id="tg-timer-${acc._id}" style="font-size: 12px; color: #e3b863; margin-top: 5px;"></div>
          <div style="font-size:12px; opacity:0.7;">เพิ่มเมื่อ: ${created}</div>
        </div>
        <div class="tg-acc-actions">
          <button class="btn dark small" onclick="removeTgAcc('${acc._id}')">ลบ</button>
        </div>
      `;

      wrap.appendChild(item);  // เพิ่มรายการบัญชีไปที่ UI
    });

  } catch (e) {
    console.error("loadTgAccounts ERR", e);
    notify.error("โหลดบัญชีผิดพลาด");
  }
}

