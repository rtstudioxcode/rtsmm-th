<script>
/* ======================================================
   ELEMENTS
====================================================== */
const tabs = document.querySelectorAll(".tab");
const panes = {
  accounts: document.getElementById("tab-accounts"),
  pull:     document.getElementById("tab-pull"),
  history:  document.getElementById("tab-history")
};

/* ======================================================
   TAB SWITCH
====================================================== */
tabs.forEach(tab => {
  tab.addEventListener("click", () => {

    // active state
    tabs.forEach(t => t.classList.remove("active"));
    tab.classList.add("active");

    // hide all panes
    Object.values(panes).forEach(p => p.classList.remove("show"));

    // show the target pane
    const name = tab.dataset.tab;

    if (name !== "history") stopHistoryLive();

    if (name === "accounts") {
      panes.accounts.classList.add("show");
      loadTgAccounts();
    }
    else if (name === "pull") {
      panes.pull.classList.add("show");
    }
    else if (name === "history") {
      panes.history.classList.add("show");
      loadHistory();
      startHistoryLive(1000);
    }
  });
});


/* ---------- FORM: CALCULATE COST ---------- */
const limitInput = document.getElementById("limit");
const costPreview = document.getElementById("costPreview");
const costPer = 0; // สมมติราคาคนละ 5 เครดิต

limitInput?.addEventListener("input", () => {
    const n = Number(limitInput.value || 0);
    if (n > 0) {
    costPreview.textContent = "เครดิตที่ใช้: " + (n * costPer) + " เครดิต";
    } else {
    costPreview.textContent = "เครดิตที่ใช้: 0"+ " เครดิต";
    }
});

/* ======================================================
   PRECHECK FAIL UI HANDLER
====================================================== */
function showPrecheckErrors(reasons = []) {
  const box = document.getElementById("precheckBox");
  const list = document.getElementById("precheckList");

  if (!reasons.length) {
    box.style.display = "none"; // ถ้าไม่มีข้อผิดพลาดให้ซ่อน
    return;
  }

  list.innerHTML = reasons.map(r => `• ${r}`).join("<br>"); // แสดงรายการเหตุผล
  box.style.display = "block"; // แสดงข้อผิดพลาด

  // ปิดปุ่ม START เมื่อมีข้อผิดพลาด
  const btn = document.getElementById("startBtn");
  btn.disabled = true;
  btn.classList.add("disabled"); // เพิ่มคลาส disabled เพื่อให้ปุ่มไม่สามารถคลิกได้

  // แสดงการแจ้งเตือน
  notify.error("ไม่สามารถเริ่มงานได้<br>" + list.innerHTML);
}

/* ---------- START JOB ---------- */
const startBtn = document.getElementById("startBtn");
const progressBox = document.getElementById("tgProgressBox");
const logBox = document.getElementById("tgLogBox");
const progressBar = document.getElementById("tgProgressBar");
const statusText = document.getElementById("tgStatusText");
const countText = document.getElementById("tgCounts");
document.getElementById("precheckBox").style.display = "none";
document.getElementById("precheckList").innerHTML = "";

window.__TG_TARGETS__ = [];
startBtn.disabled = false;
let currentJob = null;
let orderId = null;
let evtSource = null;
let uiTargets = [];
let parsedInvalid = [];

async function parseTargetsFromFile(file) {
  const fd = new FormData();
  fd.append("file", file);

  const r = await fetch("/telegram/targets/parse", { method: "POST", body: fd });
  const data = await r.json();

  if (!data.ok) throw new Error(data.error || "parse failed");

  targets = Array.isArray(data.targets) ? data.targets : [];   // ✅ ตรงนี้แหละ
  parsedInvalid = Array.isArray(data.invalid) ? data.invalid : [];

  // จะโชว์ preview ก็ทำต่อได้
  console.log("targets:", targets.length, "invalid:", parsedInvalid.length);
}

function syncBackendTargets() {
  const selected = uiTargets
    .filter(t => t.valid && t.checked)
    .map(t => {
      if (t.type === "user") return { kind: "username", value: t.value };
      return { kind: "phone", value: t.value };
    });

  window.__TG_TARGETS__ = selected;
}

startBtn.addEventListener("click", async () => {
  const mode = document.getElementById("pullMode")?.value || "group";

  const srcGroupEl  = document.getElementById("srcGroup");
  const destGroupEl = document.getElementById("destGroup");
  const limitEl     = document.getElementById("limit");

  const srcGroup  = (srcGroupEl?.value || "").trim();
  const destGroup = (destGroupEl?.value || "").trim();
  let limit       = Math.floor(Number(limitEl?.value || 0));

  if (!destGroup) return notify.error("⚠️ กรุณากรอกลิงก์กลุ่มปลายทาง");

  let payload;

  if (mode === "list") {
    const tgTargets = Array.isArray(window.__TG_TARGETS__) ? window.__TG_TARGETS__ : [];
    if (!tgTargets.length) return notify.error("⚠️ โหมดอัปโหลดไฟล์ต้องมีรายชื่อจากไฟล์/รายการ");

    // limit ไม่กรอก/เป็น 0 -> ให้ backend ใช้ targets.length (ตามที่ route ทำไว้แล้ว)
    if (limit <= 0) limit = tgTargets.length;

    payload = {
      mode: "list",
      srcGroup: "__FILE_IMPORT__", // ให้ route ตัดสินเป็น list ชัวร์ๆ
      destGroup,
      limit,
      targets: tgTargets
    };
  } else {
    // group mode
    if (!srcGroup) return notify.error("⚠️ กรุณากรอกลิงก์กลุ่มต้นทาง");
    if (limit <= 0) return notify.error("⚠️ กรุณากรอกจำนวนสมาชิก (มากกว่า 0)");

    payload = {
      mode: "group",
      srcGroup,
      destGroup,
      limit
    };
  }

  const res = await fetch("/telegram/jobs/start", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify(payload)
  });

  const data = await res.json();

  // ✅ handle precheck_fail ให้ตรงกับ backend
  if (!data.ok) {
    if (data.type === "precheck_fail") {
      showPrecheckErrors(data.reasons || []);
      return;
    }
    return notify.error("เกิดข้อผิดพลาด: " + (data.error || data.message || "ไม่ทราบข้อผิดพลาด"));
  }

  currentJob = data.jobId;
  orderId = data.orderId;

  notify.success("เริ่มงาน #" + orderId + " แล้ว");

  showProgressUI();
  attachStream();

  document.querySelector('.tab[data-tab="history"]').click();
  setTimeout(() => loadHistory(), 300);
});

function showProgressUI() {
  progressBox.style.display = "block";
  logBox.innerHTML = "";
  progressBar.style.width = "0%";
  statusText.textContent = "กำลังเริ่มงาน…";
  countText.textContent = "—";
}

/* ---------- SSE STREAM ---------- */
function attachStream() {
  if (evtSource) evtSource.close();

  evtSource = new EventSource(`/telegram/jobs/${currentJob}/stream`);

  const TERMINAL = new Set(["finished", "stopped", "auto_stopped", "failed", "error"]);

  evtSource.onmessage = (ev) => {
    const msg = JSON.parse(ev.data || "{}");

    // log
    if (msg.log) appendLog(msg.log);

    // progress
    if (msg.invited != null && msg.total != null) {
      const pct = msg.total > 0 ? Math.round((msg.invited / msg.total) * 100) : 0;
      progressBar.style.width = pct + "%";
      countText.textContent =
        `เชิญแล้ว ${msg.invited} คน • ล้มเหลว ${msg.failed || 0} คน • ทั้งหมด ${msg.total} คน`;
    }

    // ถ้าอยู่แท็บ history ให้รีเฟรชทันที (realtime)
    if (panes.history.classList.contains("show")) {
      loadHistoryLiveOnce().catch(() => {});
    }

    // PRECHECK FAIL → ปิดงานทันที
    if (msg.type === "precheck_fail") {
      showPrecheckErrors(msg.reasons || []);
      progressBox.style.display = "none";
      try { evtSource.close(); } catch {}
      evtSource = null;
      return;
    }

    // status text (ไทย)
    if (msg.status) {
      const st = String(msg.status).toLowerCase();
      statusText.textContent =
        st === "finished"     ? "สำเร็จ" :
        st === "running"      ? "กำลังทำงาน…" :
        st === "stopped"      ? "หยุดแล้ว" :
        st === "auto_stopped" ? "หยุดอัตโนมัติ" :
        st === "failed"       ? "ล้มเหลว" :
        st === "error"        ? "มีข้อผิดพลาด" : msg.status;
    }

    // จบงานทุกกรณี → ปิดสตรีม + อัปเดต history ทันที
    if (msg.status && TERMINAL.has(String(msg.status).toLowerCase())) {
      loadHistoryLiveOnce().catch(() => {});

      const st = String(msg.status).toLowerCase();
      if (st === "finished") notify.success("งาน #" + orderId + " เสร็จสิ้นแล้ว!");
      else if (st === "stopped") notify.info("งาน #" + orderId + " ถูกหยุดแล้ว");
      else if (st === "auto_stopped") notify.info("งาน #" + orderId + " หยุดอัตโนมัติ");
      else notify.error("งาน #" + orderId + " จบด้วยสถานะ: " + st);

      try { evtSource.close(); } catch {}
      evtSource = null;
    }
  };

  // กันกรณี SSE หลุด (เน็ต/โปรเซสรีสตาร์ท)
  evtSource.onerror = () => {
    // ไม่ต้อง spam notify — แค่ปิด แล้วให้ history auto refresh ทำงานต่อก็พอ
    try { evtSource.close(); } catch {}
    evtSource = null;
  };
}

/* ---------- STOP JOB ---------- */
document.addEventListener("DOMContentLoaded", () => {
  // Dynamically added button handling
  const interval = setInterval(() => {
    const stopBtn = document.getElementById("stopBtn");
    if (stopBtn) {
