   หยุดงานจากประวัติ
====================================================== */
async function stopJobFromHistory(jobId) {
  const ok = await uiConfirm({
    variant: "danger",
    title: "หยุดงานนี้ใช่ไหม?",
    sub: "ระบบจะหยุดทันที และคืนเครดิตตามจำนวนที่ยังไม่ได้เชิญ",
    okText: "หยุดงาน",
    cancelText: "ยกเลิก",
    focus: "cancel"
  });
  if (!ok) return;

  const res = await fetch(`/telegram/jobs/${jobId}/stop`, { method: "POST" });
  const data = await res.json();

  if (!data.ok) {
    notify.error(data.error || "หยุดงานไม่สำเร็จ");
    return;
  }

  notify.info(`⛔ หยุดงานแล้ว • คืน ${data.refund || 0} เครดิต`);
  loadHistoryLiveOnce().catch(()=>{});
}

(function () {
  const el = document.getElementById("limit");
  if (!el) return;

  const MIN = 1;
  const MAX = 1000;

  function clamp() {
    let v = parseInt(el.value, 10);

    // เคสว่าง/ไม่ใช่ตัวเลข: ไม่บังคับ (หรือจะตั้ง MIN ก็ได้)
    if (!Number.isFinite(v)) return;

    if (v > MAX) v = MAX;
    if (v < MIN) v = MIN;

    if (String(v) !== el.value) el.value = String(v);
  }

  // พิมพ์ปุ๊บปรับปั๊บ (รวมกรณี paste)
  el.addEventListener("input", clamp);

  // ตอนออกจากช่องก็เช็คซ้ำ (กันบางเบราว์เซอร์)
  el.addEventListener("blur", clamp);
})();

(() => {
  const PRICE_PER_PERSON = 0;  // เครดิต/คน
  const MAX_TARGETS = 10000;

  const $ = (id) => document.getElementById(id);

  // mode
  const modeSwitch = $("pullModeSwitch");
  const pullMode   = $("pullMode");
  const groupFields = $("modeGroupFields");
  const listFields  = $("modeListFields");
  const listHint = $("listHint");

  // form
  const srcGroup  = $("srcGroup");
  const destGroup = $("destGroup");
  const limitEl   = $("limit");
  const fileEl    = $("targetFile");

  const targetsJson = $("targetsJson");
  const costPreview = $("costPreview");

  // ✅ new UI elements
  const targetsCard = $("targetsCard");
  const targetsBody = $("targetsBody");

  const tTotal = $("tTotal");
  const tSelected = $("tSelected");
  const tInvalidWrap = $("tInvalidWrap");
  const tInvalid = $("tInvalid");

  const tSearch = $("tSearch");
  const btnSelectAll = $("btnSelectAll");
  const btnRemoveSelected = $("btnRemoveSelected");
  const btnClearAll = $("btnClearAll");

  // store
  let targets = []; // { id, value, type:'phone'|'user', valid:boolean, checked:boolean }

  function uid() {
    return Math.random().toString(16).slice(2) + Date.now().toString(16);
  }

  function setActiveButton(mode){
    modeSwitch?.querySelectorAll(".mode-btn").forEach(btn => {
      const is = btn.dataset.mode === mode;
      btn.classList.toggle("active", is);
      btn.style.color = is ? "#ffd78a" : "#b8c1cc";
      btn.style.borderColor = is ? "rgba(255,215,138,.35)" : "rgba(255,255,255,.12)";
      btn.style.boxShadow = is ? "0 0 0 3px rgba(255,215,138,.08) inset" : "none";
    });
  }

  // ✅ รองรับ @username ที่มี . ด้วย (ตามที่คุยไว้)
  function detectType(v){
    v = String(v || "").trim();
    if (!v) return { type:"phone", valid:false, clean:"" };

    // ตัดช่องว่าง/วงเล็บ/ขีด
    v = v.replace(/[()\s-]/g, "");

    // @username
    if (v.startsWith("@")) {
      const u = v.slice(1);
      const ok = /^[a-zA-Z0-9_\.]{3,32}$/.test(u);
      return { type:"user", valid:ok, clean:"@" + u };
    }

    // phone: อนุโลมให้พิมพ์เป็นตัวเลขล้วนได้ -> เติม +
    let p = v;
    if (!p.startsWith("+") && /^\d+$/.test(p)) p = "+" + p;

    if (p.startsWith("+")) {
      const digits = p.slice(1);
      const ok = /^\d{8,15}$/.test(digits);
      return { type:"phone", valid:ok, clean:"+" + digits };
    }

    return { type:"phone", valid:false, clean:v };
  }

  function escapeHtml(s){
    return String(s || "")
      .replaceAll("&","&amp;")
      .replaceAll("<","&lt;")
      .replaceAll(">","&gt;")
      .replaceAll('"',"&quot;")
      .replaceAll("'","&#039;");
  }

  function updateCost(){
    let qty = 0;

    if (pullMode.value === "group") {
      qty = Math.max(0, Number(limitEl.value || 0));
    } else {
      qty = targets.filter(t => t.valid && t.checked).length;
      // ส่ง qty ไป backend ผ่าน limit เหมือนเดิม (ชั่วคราว)
      limitEl.value = String(qty || 0);
    }

    const cost = qty * PRICE_PER_PERSON;
    if (costPreview) costPreview.textContent = `เครดิตที่ใช้: ${cost} เครดิต`;
  }

  function syncTargetsHidden(){
    const selected = targets
      .filter(t => t.valid && t.checked)
      .map(t => t.value);

    if (targetsJson) targetsJson.value = JSON.stringify(selected);

    // ✅ สำคัญ: ส่งขึ้น global ให้ปุ่ม Start เห็น
    window.__TG_TARGETS__ = selected;

    updateCost();
  }

  function updateSelectedCountUI(){
    const sel = targetsBody ? [...targetsBody.querySelectorAll(".t-check")].filter(c => c.checked).length : 0;
    if (tSelected) tSelected.textContent = String(sel);
    if (btnRemoveSelected) btnRemoveSelected.disabled = sel === 0;
  }

  function wireRowEvents(){
    if (!targetsBody) return;

    targetsBody.querySelectorAll(".targets-row").forEach(row => {
      const id = row.dataset.id;
      const chk = row.querySelector(".t-check");
      const inp = row.querySelector(".t-input");
      const del = row.querySelector(".t-del");

      chk?.addEventListener("change", () => {
        const item = targets.find(x => x.id === id);
        if (!item) return;
        item.checked = chk.checked;
        syncTargetsHidden();
        updateSelectedCountUI();
      });

      inp?.addEventListener("input", () => {
        const item = targets.find(x => x.id === id);
        if (!item) return;

        const d = detectType(inp.value);
        item.value = d.clean;
        item.type = d.type;
        item.valid = d.valid;

        // ถ้าแก้จนถูกต้อง ให้ติ๊กอัตโนมัติ
        if (item.valid && item.checked === false) item.checked = true;

        syncTargetsHidden();
        renderTargets(); // รีเฟรช badge/type/status ให้ตรง
      });

      del?.addEventListener("click", () => {
        targets = targets.filter(x => x.id !== id);
        syncTargetsHidden();
        renderTargets();
      });
    });
  }

  function renderTargets(){
    if (!targetsCard || !targetsBody) return;

    const q = String(tSearch?.value || "").trim().toLowerCase();
    const list = !q ? targets : targets.filter(x => String(x.value||"").toLowerCase().includes(q));

    targetsBody.innerHTML = list.map(x => {
      const badge = x.type === "user"
        ? `<span class="t-badge user">@ยูสเซอร์</span>`
        : `<span class="t-badge phone">เบอร์โทรศัพท์</span>`;

      const st = x.valid
        ? `<span class="t-status ok">พร้อม</span>`
        : `<span class="t-status bad">รูปแบบไม่ถูกต้อง</span>`;

      return `
        <div class="targets-row" data-id="${x.id}">
          <div class="col-check"><input class="t-check" type="checkbox" ${x.valid ? "" : "disabled"} ${x.checked ? "checked" : ""} /></div>
          <div class="col-type">${badge}</div>
          <div class="col-value">
            <input class="t-input" value="${escapeHtml(x.value)}" />
          </div>
          <div class="col-status">${st}</div>
          <div class="col-del">
            <button class="t-del" type="button" title="ลบ">🗑️</button>
          </div>
        </div>
      `;
    }).join("");

    // show/hide
    targetsCard.style.display = targets.length ? "block" : "none";

    // stats
    const total = targets.length;
    const invalid = targets.filter(x => !x.valid).length;

    if (tTotal) tTotal.textContent = String(total);
    if (tInvalid) tInvalid.textContent = String(invalid);
    if (tInvalidWrap) tInvalidWrap.style.display = invalid ? "inline" : "none";

    updateSelectedCountUI();
    wireRowEvents();
  }

  function extractTokens(text){
    return String(text || "")
      .split(/[\n,;\t\r]+/g)
      .map(x => x.trim())
      .filter(Boolean);
  }

  async function parseFile(){
    const f = fileEl?.files?.[0];
    if (!f) return;

    const text = await f.text();
    const tokens = extractTokens(text);

    const seen = new Set();
    const out = [];

    for (const raw of tokens) {
      if (out.length >= MAX_TARGETS) break;

      const d = detectType(raw);
      if (!d.clean) continue;

      const key = d.clean.toLowerCase();
      if (seen.has(key)) continue;
      seen.add(key);

      out.push({
        id: uid(),
        value: d.clean,
        type: d.type,
        valid: d.valid,
        checked: !!d.valid
      });
    }

    targets = out;
    syncTargetsHidden();
    renderTargets();
  }

  function setMode(mode){
    pullMode.value = mode;
    setActiveButton(mode);

    const srcRow = $("srcRow");
    const destRow = $("destRow");
    const limitRow = $("limitRow");
    const listDestMount = $("listDestMount");
    const howto1 = $("howtoStep1Text");
    const howto3 = $("howtoStep3Text");

    if (listHint) listHint.style.display = (mode === "list") ? "block" : "none";

    // ✅ สลับ How-to ตามโหมด (เปลี่ยนแค่ข้อ 1 และ 3)
    if (howto1 && howto3) {
      if (mode === "list") {
        howto1.innerHTML = `
          อัปโหลดไฟล์รายชื่อ — รองรับทั้ง 
          <code style="color:#8ec7ff;">.txt</code> และ <code style="color:#8ec7ff;">.csv</code>
          (1 บรรทัด/1 ค่า) เช่น
          <code style="color:#8ec7ff;">+66123456789 | 0123456789</code> หรือ <code style="color:#8ec7ff;">@username | https://t.me/username</code>
        `;

        howto3.innerHTML = `
          ระบบจะคำนวณเครดิตที่ต้องจ่ายให้อัตโนมัติจากรายชื่อในไฟล์ —
          <b style="color:#57d110;">ตอนนี้ใช้ฟรีไม่เสียเงิน</b>
        `;
      } else {
        // mode === "group" (ค่าดั้งเดิม)
        howto1.innerHTML = `
          วางลิงก์กลุ่มเป้าหมาย — รองรับทั้ง 
          <code style="color:#8ec7ff;">https://t.me/group</code> 
          หรือ <code style="color:#8ec7ff;">t.me/+invitehash</code>
          หรือ <code style="color:#8ec7ff;">@group</code>
        `;

        howto3.innerHTML = `
          กรอกจำนวนสมาชิกที่ต้องการเชิญ — ระบบจะคำนวณเครดิตอัตโนมัติ 
          <b style="color:#57d110;">ตอนนี้ใช้ฟรีไม่เสียเงิน</b>
        `;
      }
    }

    if (mode === "group") {
      groupFields.style.display = "block";
      listFields.style.display  = "none";

      // ✅ จัดลำดับ: เป้าหมาย -> ปลายทาง -> จำนวน
      groupFields.appendChild(srcRow);
      groupFields.appendChild(destRow);
      groupFields.appendChild(limitRow);

      // โหมดกลุ่ม ใช้ค่าปกติ
      if (srcGroup.value === "__FILE_IMPORT__") srcGroup.value = "";

    } else {
      groupFields.style.display = "none";
      listFields.style.display  = "block";

      // ✅ จัดลำดับ: อัปโหลดไฟล์ -> ปลายทาง
      listDestMount.appendChild(destRow);

      // srcGroup ไม่ต้องโชว์ แต่ส่งค่าให้ backend รู้ว่าเป็นโหมดไฟล์
      srcGroup.value = "__FILE_IMPORT__";
      if (!limitEl.value) limitEl.value = "0";
    }

    updateCost();
  }

  // ---------- events ----------
  modeSwitch?.addEventListener("click", (e) => {
    const btn = e.target.closest(".mode-btn");
    if (!btn) return;
    setMode(btn.dataset.mode);
  });

  // ✅ อ่านไฟล์ออโต้ทันทีเมื่อเลือกไฟล์
  fileEl?.addEventListener("change", async () => {
    if (pullMode.value !== "list") setMode("list");
    if (!fileEl.files || !fileEl.files[0]) return;
    await parseFile();
  });

  // ค้นหา
  tSearch?.addEventListener("input", renderTargets);

  // เลือกทั้งหมด / ยกเลิกทั้งหมด (toggle)
  btnSelectAll?.addEventListener("click", () => {
    const allValid = targets.filter(t => t.valid);
    const allChecked = allValid.length && allValid.every(t => t.checked);
    allValid.forEach(t => (t.checked = !allChecked));
    syncTargetsHidden();
    renderTargets();
  });

  // ลบที่เลือก
  btnRemoveSelected?.addEventListener("click", () => {
    const removeSet = new Set(
      targetsBody ? [...targetsBody.querySelectorAll(".targets-row")]
        .filter(r => r.querySelector(".t-check")?.checked)
        .map(r => r.dataset.id)
      : []
    );
    targets = targets.filter(t => !removeSet.has(t.id));
    syncTargetsHidden();
    renderTargets();
  });

  // ล้างทั้งหมด
  btnClearAll?.addEventListener("click", () => {
    targets = [];
    syncTargetsHidden();
    renderTargets();
  });

  // อัปเดตราคา realtime (โหมด group)
  limitEl?.addEventListener("input", updateCost);

  // init
  setMode("group");
  renderTargets();
})();
</script>

