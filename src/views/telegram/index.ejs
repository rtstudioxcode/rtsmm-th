/* ======================================================
   REMOVE ACCOUNT
====================================================== */
async function removeTgAcc(id) {
  // เปิด modal uiConfirm
  const ok = await uiConfirm({
    variant: "danger",
    title: "ต้องการลบบัญชี Telegram นี้หรือไม่?",
    sub: "บัญชีจะถูกลบออกจากระบบทันที",
    okText: "ลบเลย",
    cancelText: "ยกเลิก",
    focus: "cancel"
  });

  if (!ok) return;

  try {
    const res = await fetch(`/telegram/accounts/${id}/unlink`, {
      method: "DELETE"
    });

    const data = await res.json();

    if (data.ok) {
      notify.success("ลบสำเร็จ", "บัญชี Telegram ถูกลบออกแล้ว");
      loadTgAccounts(); // โหลดรายการใหม่
    } else {
      notify.error("เกิดข้อผิดพลาด", data.message || "ลบไม่สำเร็จ ");
    }
  } catch (err) {
    console.error("unlink ERR", err);
    notify.error("ลบไม่สำเร็จ", "มีปัญหาในการเชื่อมต่อเซิร์ฟเวอร์");
  }
}


