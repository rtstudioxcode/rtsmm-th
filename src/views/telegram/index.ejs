let historyTimer = null;
let lastHistorySig = "";

function buildHistorySig(list){
  // ทำลายเซ็นกัน rerender ถ้าข้อมูลไม่เปลี่ยน
  return JSON.stringify((list||[]).map(j => ({
    id: j._id,
    st: j.status,
    inv: j.invited,
    lim: j.limit,
    t: j.createdAt
  })));
}

async function loadHistoryLiveOnce() {
  const wrap = document.getElementById("tgHistoryWrap");
  const res = await fetch("/telegram/history/list");
  const data = await res.json();
  if (!data.ok) return;

  const list = data.list || [];
  const sig = buildHistorySig(list);
  if (sig === lastHistorySig) return;      // ไม่เปลี่ยน ไม่ต้องวาดใหม่
  lastHistorySig = sig;

  wrap.innerHTML = list.length ? renderHistoryTable(list)
                               : '<div class="muted">ยังไม่มีประวัติการทำงาน</div>';
}

function startHistoryLive(intervalMs = 2000){
  stopHistoryLive();
  historyTimer = setInterval(() => {
    // อัปเดตเฉพาะตอนอยู่แท็บ history
    if (panes.history.classList.contains("show")) {
      loadHistoryLiveOnce().catch(()=>{});
    }
  }, intervalMs);
}

function stopHistoryLive(){
  if (historyTimer) clearInterval(historyTimer);
  historyTimer = null;
}

