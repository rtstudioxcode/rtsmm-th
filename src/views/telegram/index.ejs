async function loadHistory() {
  const wrap = document.getElementById("tgHistoryWrap");
  wrap.innerHTML = '<div class="muted">กำลังโหลด…</div>';
  
  const res = await fetch("/telegram/history/list");
  const data = await res.json();

  if (!data.ok) {
    wrap.innerHTML = '<div class="muted">โหลดข้อมูลไม่สำเร็จ</div>';
    return;
  }
  
  const list = data.list || [];
  if (list.length === 0) {
    wrap.innerHTML = '<div class="muted">ยังไม่มีประวัติการทำงาน</div>';
    return;
  }
  
  wrap.innerHTML = renderHistoryTable(list);  // ใช้ฟังก์ชันนี้ที่ทำให้ข้อมูลถูกแสดง
}


/* ======================================================
   RENDER HISTORY TABLE
====================================================== */
function renderHistoryTable(list) {
  let html = `<div class="table-wrap" style="overflow-x:auto;">
    <table class="tg-table table">
      <thead>
        <tr>
          <th style="text-align: start;">วันที่</th>
          <th style="text-align: center;">ต้นทาง ➜ ปลายทาง</th>
          <th style="text-align: center;">ผลลัพธ์</th>
          <th style="text-align: end;">สถานะ</th>
        </tr>
      </thead>
      <tbody>`;

  list.forEach(j => {
    const invited = Number(j.invited || 0);
    const limit = Number(j.limit || 0);
    const pct = limit > 0 ? Math.round((invited / limit) * 100) : 0;
    const pill = mapStatus(j.status);
    const logs = j.logs || [];

    html += `<tr data-job-id="${j._id}">
      <td style="text-align:start;">${formatDate(j.createdAt)}</td>

      <td style="text-align:center;">
        <div class="mono">${j.srcGroup || "-"}</div>
        <div class="mono">➜ ${j.destGroup || "-"}</div>
      </td>

      <td style="text-align:center;">
        ${invited}/${limit || "-"} <small class="muted">(${pct}%)</small>
      </td>

      <td style="text-align:end;">
        <span class="pill ${j.status}">${pill}</span>

        ${
          String(j.status).toLowerCase() === "running"
            ? `<button class="icon-btn danger" title="หยุดงาน" onclick="stopJobFromHistory('${j._id}')">
                <img src="/static/assets/emoji/cancel.png" alt="Stop" class="detail-icon">
              </button>`
            : ``
        }

        <button type="button" class="icon-btn logBtn" data-jobid="${j._id}" aria-label="รายละเอียด">
          <img src="/static/assets/emoji/detail.png" alt="Detail" class="detail-icon">
        </button>
      </td>
    </tr>`;
  });

  html += `</tbody></table></div>`;
  return html;
}

document.addEventListener("click", async (e) => {
  const btn = e.target.closest(".logBtn");
  if (!btn) return;

  const jobId = btn.dataset.jobid;
  const r = await fetch(`/telegram/history/${jobId}`);
  const data = await r.json();

