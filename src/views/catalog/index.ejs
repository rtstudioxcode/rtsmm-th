    /* ========= Dark tokens (ครบทุกตัวแปร) ========= */
    html[data-theme="dark"],
    html.dark,
    html[data-bs-theme="dark"]{
      --pv-primary:  var(--theme-primary, #22d3ee);
      --pv-accent:   var(--theme-accent,  #a78bfa);
