/* =============== Helpers =============== */
const $  = (s) => document.querySelector(s);
const $$ = (s, r = document) => Array.from(r.querySelectorAll(s));
const uniq = (a) => [...new Set(a)];
const safe = (s) => String(s ?? '').trim();
const br   = (s) => String(s || '').replace(/\r?\n/g, '<br>');
const linkify = (s) =>
  String(s || '').replace(/https?:\/\/\S+/g, (m) => `<a href="${m}" target="_blank" rel="noopener">${m}</a>`);
const fmt = (n) => Number(n || 0).toLocaleString(undefined, { maximumFractionDigits: 4 });
const enc = (s) => encodeURIComponent(String(s ?? ''));
const dec = (s) => decodeURIComponent(String(s ?? ''));

const debounce = (fn, ms = 250) => {
  let t;
  return (...a) => {
    clearTimeout(t);
    t = setTimeout(() => fn(...a), ms);
  };
};
