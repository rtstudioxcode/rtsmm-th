/* ========= build rows (desktop table + mobile cards) ========= */
function buildTableAndCards(rows){
  const tableHead = `
    <thead>
      <tr>
        <th style="width:90px">ID</th>
        <th>ชื่อบริการ</th>
        <th style="width:140px">เรทราคา</th>
        <th style="width:90px">Min</th>
        <th style="width:90px">Max</th>
        <th style="width:150px"></th>
      </tr>
    </thead>`;

  const tableBody = rows.map(s=>{
    const rate = (s.displayRate ?? s.rate ?? 0);
    const cur  = (s.currency || 'THB');
    const min  = (s.min ?? '');
    const max  = (s.max ?? '');
    const avg  = pickAvg(s);
    const desc = pickDesc(s);
    return `
      <tr>
        <td>${s.providerServiceId||''}</td>
        <td>${s.name||''}</td>
        <td><b>${Number(rate)}</b> ${cur}</td>
        <td>${min}</td>
        <td>${max}</td>
        <td>
          <a class="btn sm" href="/orders/new?type=service&id=${s.providerServiceId}&name=${enc(s.name)}">สั่งซื้อ</a>
          <button class="btn sm ghost btn-desc"
            data-pid="${s.providerServiceId}"
            data-name="${enc(s.name)}"
            data-rate="${rate}" data-cur="${enc(cur)}"
            data-min="${min}" data-max="${max}"
            data-avg="${enc(avg)}"
            data-drip="${s.dripfeed ? 1 : 0}"
            data-refill="${s.refill ? 1 : 0}"
            data-cancel="${s.cancel ? 1 : 0}"
            data-desc="${enc(desc)}">รายละเอียด</button>
        </td>
      </tr>`;
  }).join('');

  const table = `
    <div class="table-wrap">
      <table class="table">
        ${tableHead}
        <tbody>${tableBody}</tbody>
      </table>
    </div>`;

  const cards = `
    <div class="m-cards">
      ${rows.map(s=>{
        const rate = (s.displayRate ?? s.rate ?? 0);
        const cur  = (s.currency || 'THB');
        const min  = (s.min ?? 0);
        const max  = (s.max ?? 0);
        const avg  = pickAvg(s);
        const desc = pickDesc(s);
        return `
          <div class="m-card">
            <div class="left">
              <div class="id">#${s.providerServiceId}</div>
              <div class="title">${s.name||''}</div>
              <div class="meta">
                <div>💵 ${Number(rate)} ${cur}</div>
                <div>ช่วง: ${min}-${max}</div>
              </div>
              <div class="actions">
                <a class="btn sm" href="/orders/new?type=service&id=${s.providerServiceId}&name=${enc(s.name)}">สั่งซื้อ</a>
                <button class="btn sm ghost btn-desc"
                  data-pid="${s.providerServiceId}"
                  data-name="${enc(s.name)}"
                  data-rate="${rate}" data-cur="${enc(cur)}"
                  data-min="${min}" data-max="${max}"
                  data-avg="${enc(avg)}"
                  data-drip="${s.dripfeed ? 1 : 0}"
                  data-refill="${s.refill ? 1 : 0}"
                  data-cancel="${s.cancel ? 1 : 0}"
                  data-desc="${enc(desc)}">รายละเอียด</button>
              </div>
            </div>
          </div>`;
      }).join('')}
    </div>`;

  return table + cards;
}

/* ========= modal ========= */
function openServiceModalFromEl(btn){
  const d = btn.dataset;
  $('#mTitle').textContent = dec(d.name || '') || 'รายละเอียดบริการ';

  const bits = [];
  const avg = dec(d.avg || '');
  const rate = Number(d.rate || 0);
  const cur  = d.cur ? dec(d.cur) : 'THB';
  const min  = d.min ?? '';
  const max  = d.max ?? '';
  if (avg) bits.push(`⏱ เฉลี่ย: ${avg}`);
  if (d.drip === '1')   bits.push('💧 Dripfeed');
  if (d.refill === '1') bits.push('♻️ เติมคืนได้');
  if (d.cancel === '1') bits.push('✖️ ยกเลิกได้');
  bits.push(`💵 เรท: ${fmt(rate)} ${cur}/1,000`);
  if (min !== '' && max !== '') bits.push(`ช่วง: ${min}-${max}`);
  $('#mMeta').innerHTML = bits.map(t=>`<span class="tag">${t}</span>`).join(' ');

  let desc = dec(d.desc || '');
  if (!safe(desc)) {
    const svc = resolveService(d.pid);
    if (svc) desc = pickDesc(svc);
  }
  $('#mBody').innerHTML = safe(desc) ? linkify(br(desc)) : '—';
  $('#svcModal').classList.remove('hidden');
}

/* ========= events (delegation ทีเดียว) ========= */
function wireEvents(){
  // platform switch
  $('#platformGrid').addEventListener('click', e=>{
    const card = e.target.closest('.platform-card'); if (!card) return;
    CURRENT_PLATFORM = card.dataset.platform || null;
    $$('.platform-card').forEach(el=>el.classList.remove('active'));
    card.classList.add('active');
    currentChipId = "";
    renderChips();
    renderServicesList();
  });

  // chips
  $('#chipBar').addEventListener('click', e=>{
    const b = e.target.closest('.chip'); if (!b) return;
    currentChipId = b.dataset.chip;
    renderChips();
    renderServicesList();
  });

  // search (debounced)
  $('#searchAll').addEventListener('input', debounce(e=>{
    SEARCH = (e.target.value || '').trim();
    renderServicesList();
  }, 300));

  // toggle group + lazy render on click
  $('#servicesContainer').addEventListener('click', e=>{
    const head = e.target.closest('.group .head');
    if (head){
      const root = head.parentElement;
      const opened = root.classList.toggle('open');
      head.setAttribute('aria-expanded', opened ? 'true' : 'false');
      if (opened){
        const cat = dec(root.dataset.cat || '');
        renderGroupBody(cat);
      }
      return;
    }
    const b = e.target.closest('.btn-desc');
    if (b) openServiceModalFromEl(b);
  });

  // modal
  $('#mClose').onclick = () => $('#svcModal').classList.add('hidden');
  $('#svcModal').addEventListener('click', e=>{
    if (e.target.dataset.close === '1') $('#svcModal').classList.add('hidden');
  });
  document.addEventListener('keydown', e=>{
    if (e.key === 'Escape') $('#svcModal').classList.add('hidden');
  });
}

/* ========= boot ========= */
(function init(){
  renderPlatforms();
  renderChips();
  renderServicesList();
  wireEvents();
})();
</script>