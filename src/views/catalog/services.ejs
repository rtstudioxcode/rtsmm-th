/* ========= map platform จากชื่อบริการ ========= */
function detectPlatformKeyForService(svc) {
  const text = (
    ' ' +
    safe(svc.providerCategoryName || '') + ' ' +
    safe(svc.categoryName || '') + ' ' +
    safe(svc.name || '') +
    ' '
  ).toLowerCase();

  // วนตามลำดับใน PLATFORM_MAP (premium, thailand มาก่อน)
  for (const m of PLATFORM_MAP) {
    const patterns = (m.match || []).map(p => p.toLowerCase());
    if (!patterns.length) continue;
    if (patterns.some(p => text.includes(p))) {
      return m.key;
    }
  }
  return 'other';
}

function assignPlatformsToServices() {
  if (!Array.isArray(window.__SERVICES__)) return;
  for (const svc of window.__SERVICES__) {
    svc.platformKey = detectPlatformKeyForService(svc);
  }
}

/* ========= รายการ platform แบบ static (กรณีไม่มี data) ========= */
const PLATFORM_STATIC = PLATFORM_MAP
  .filter(m => m.key !== 'other')
  .map(m => m.key);

/* ========= chips ========= */
const CHIP_DEFS = [
  { id: "", label: "ทั้งหมด", kw: [] },
  { id: "views", label: "วิว", kw: ["view", "views", "watch", "play", "ชม", "วิว"] },
  { id: "likes", label: "ไลก์", kw: ["like", "likes", "heart", "react", "reactions", "ถูกใจ", "ไลก์"] },
  { id: "members", label: "สมาชิก/ผู้ติดตาม", kw: ["follow", "follower", "followers", "subscriber", "subscribers", "subs", "ติดตาม", "ผู้ติดตาม", "สมาชิก", "members"] },
  { id: "comments", label: "คอมเมนต์", kw: ["comment", "comments", "คอมเมน"] },
  { id: "shares", label: "แชร์", kw: ["share", "shares", "รีโพสต์", "repost", "retweet", "แชร์"] },
  { id: "traffic", label: "คลิก/ทราฟฟิก", kw: ["link click", "click", "traffic", "คลิก", "ทราฟฟิก"] },
  { id: "shorts_reels", label: "Shorts/Reels/Live", kw: ["short", "shorts", "reel", "reels", "live", "สตรีม", "ไลฟ์"] },
  { id: "general", label: "ทั่วไป", kw: ["general", "รวม", "รวมบริการ", "all-in-one"] }
];

function itemMatchesChip(item, chip) {
  if (!chip || chip.id === "") return true;
  const s = `${item.categoryName || ""} ${item.name || ""}`.toLowerCase();
  return chip.kw.some(k => s.includes(k.toLowerCase()));
}

/* =============== State =============== */
let CURRENT_PLATFORM = null; // จะเก็บเป็น platformKey เช่น 'tiktok', 'facebook'
let SEARCH = '';
let currentChipId = '';
let EVENTS_WIRED = false;

/* lazy group state */
const groupState = new Map();
let allCats = [];
let nextGroupIndex = 0;
let moreIO = null;

const GROUP_BATCH = 6;
const ROW_CHUNK   = 25;

/* ========= service helpers ========= */
const SVC_BY_PID = Object.create(null);
window.__SERVICES__.forEach(it => {
  const pid = it?.providerServiceId;
  if (pid !== undefined && pid !== null) SVC_BY_PID[String(pid)] = it;
});

// เซ็ต platformKey ให้ service ตั้งแต่แรก (กรณี server ฝัง data มาแล้ว)
assignPlatformsToServices();

const pickDesc = svc => (svc?.description || svc?.desc || svc?.details_description || svc?.providerDescription || '');
const pickAvg  = svc => (svc?.average_delivery || svc?.avg_delivery || svc?.averageDelivery || '');
function resolveService(pid) {
  const p = String(pid);
  const direct = SVC_BY_PID[p];
  if (direct && safe(pickDesc(direct))) return direct;
  const hit = window.__SERVICES__.find(x => String(x.providerServiceId) === p && safe(pickDesc(x)));
  return hit || direct || null;
}

/* ========= filter ========= */
function computeFiltered() {
  const chip = CHIP_DEFS.find(c => c.id === currentChipId) || CHIP_DEFS[0];
  let list = window.__SERVICES__;
  if (CURRENT_PLATFORM) list = list.filter(s => s.platformKey === CURRENT_PLATFORM);
  list = list.filter(it => itemMatchesChip(it, chip));
  if (SEARCH) {
    const q = SEARCH.toLowerCase();
    list = list.filter(s =>
      String(s.providerServiceId || '').toLowerCase().includes(q) ||
      safe(s.name).toLowerCase().includes(q) ||
      safe(s.categoryName).toLowerCase().includes(q)
    );
  }
  return list;
}

/* ========= platform grid ========= */
function renderPlatforms() {
  const root = $('#platformGrid');
  const hasData = Array.isArray(window.__SERVICES__) && window.__SERVICES__.length;

  let platforms;
  if (hasData) {
    platforms = uniq(
      window.__SERVICES__
        .map(s => s.platformKey)
        .filter(Boolean)
    );

    // sort ตามลำดับใน PLATFORM_MAP
    platforms.sort((a, b) => {
      const ia = PLATFORM_ORDER_INDEX[a] ?? 999;
      const ib = PLATFORM_ORDER_INDEX[b] ?? 999;
      if (ia !== ib) return ia - ib;
      return String(a).localeCompare(String(b));
    });
  } else {
    platforms = PLATFORM_STATIC.slice();
  }

  const html = [
    `<div class="platform-card${CURRENT_PLATFORM === null ? ' active' : ''}" data-platform="">
      <img src="${pickIconUrl('all')}" alt="All"/>
      <div><div class="name">ทั้งหมด</div><div class="muted">แสดงทุกแพลตฟอร์ม</div></div>
    </div>`
  ].concat(platforms.map(key => {
    const meta = PLATFORM_MAP.find(m => m.key === key);
    const label = meta?.name || key;
    const count = hasData
      ? window.__SERVICES__.filter(s => s.platformKey === key).length
      : null;
    const countLabel = hasData
      ? `${count} บริการ`
      : `พร้อมใช้งาน`;
    return `
      <div class="platform-card${CURRENT_PLATFORM === key ? ' active' : ''}" data-platform="${key}">
        <img src="${pickIconUrl(key)}" alt="${label}"/>
        <div><div class="name">${label}</div><div class="muted">${countLabel}</div></div>
      </div>
    `;
  }));

  root.innerHTML = html.join('');
}

/* ========= chips render ========= */
function computeChipCounts() {
  const base = window.__SERVICES__.filter(s => !CURRENT_PLATFORM || s.platformKey === CURRENT_PLATFORM);
  return CHIP_DEFS.map(ch => {
    if (ch.id === "") return { ...ch, count: base.length };
    return { ...ch, count: base.filter(x => itemMatchesChip(x, ch)).length };
  }).filter(ch => ch.id === "" || ch.count > 0);
}
function renderChips() {
  $('#chipBar').innerHTML = computeChipCounts().map(ch => `
    <button type="button" class="chip ${currentChipId === ch.id ? 'active' : ''}" data-chip="${ch.id}">
      ${ch.label}
    </button>`).join('');
}

/* ========= lazy groups: batch by providerCategory ========= */

function appendNextGroupBatch() {
  const container = $('#servicesContainer');
  if (nextGroupIndex >= allCats.length) return;

  const end = Math.min(allCats.length, nextGroupIndex + GROUP_BATCH);
  const frag = document.createDocumentFragment();

  for (let i = nextGroupIndex; i < end; i++) {
    const cat = allCats[i];
    const rows = groupState.get(cat)?.rows || [];
    const wrap = document.createElement('div');
    wrap.className = 'group';
    wrap.dataset.cat = enc(cat);
    wrap.innerHTML = `
      <div class="head" role="button" tabindex="0" aria-expanded="false">
        <h4>${cat}</h4>
        <div class="meta"><span class="badge">${rows.length} รายการ</span></div>
      </div>
      <div class="body">
        <div class="placeholder muted">แตะเพื่อแสดงรายละเอียดบริการ…</div>
      </div>
    `;
    frag.appendChild(wrap);
  }

  const oldSentinel = container.querySelector('.more-sentinel');
  if (oldSentinel) {
    if (moreIO) moreIO.unobserve(oldSentinel);
    oldSentinel.remove();
  }

  container.appendChild(frag);

  if (end < allCats.length) {
    const sentinel = document.createElement('div');
    sentinel.className = 'more-sentinel';
    sentinel.style.cssText = 'height:1px;opacity:0;';
    container.appendChild(sentinel);
    if (moreIO) moreIO.observe(sentinel);
  }

  nextGroupIndex = end;
}

function onMoreIntersect(entries) {
  for (const en of entries) {
    if (!en.isIntersecting) continue;
    if (moreIO) moreIO.unobserve(en.target);
    appendNextGroupBatch();
  }
}

/* render ทั้ง list แบบ “หัวกลุ่ม + lazy section” */
function renderServicesList() {
  const container = $('#servicesContainer');
  const list = computeFiltered();
  $('#listTitle').textContent = CURRENT_PLATFORM
    ? `บริการทั้งหมดใน ${CURRENT_PLATFORM}`
    : 'บริการทั้งหมด';

  const byProvCat = list.reduce((m, s) => {
    const key = s.providerCategoryName || s.categoryName || 'ทั่วไป';
    (m[key] ??= []).push(s);
    return m;
  }, {});

  groupState.clear();
  allCats = Object.keys(byProvCat).sort();
  allCats.forEach(cat => {
    groupState.set(cat, { rows: byProvCat[cat], rendered: false });
  });

  if (moreIO) moreIO.disconnect();
  container.innerHTML = '';
  nextGroupIndex = 0;

  if (!moreIO && allCats.length > GROUP_BATCH) {
    moreIO = new IntersectionObserver(onMoreIntersect, {
      root: null,
      rootMargin: '0px 0px 400px 0px',
      threshold: 0
    });
  }

  appendNextGroupBatch();

  if (allCats.length > 0) {
    const firstCat = allCats[0];
    const firstGroup =
      container.querySelector(`.group[data-cat="${enc(firstCat)}"]`) ||
      container.querySelector('.group');

    if (firstGroup) {
      firstGroup.classList.add('open');
      const head = firstGroup.querySelector('.head');
      if (head) head.setAttribute('aria-expanded', 'true');
      renderGroupBody(firstCat, firstGroup);
    }
  }
}

/* ========= build rows (desktop table + mobile cards) ========= */
function buildTableAndCards(rows) {
  const tableHead = `
    <thead>
      <tr>
        <th style="width:90px">ID</th>
        <th>ชื่อบริการ</th>
        <th style="width:140px">เรทราคา</th>
        <th style="width:90px">Min</th>
        <th style="width:90px">Max</th>
        <th style="width:150px"></th>
      </tr>
    </thead>`;

  const tableBody = rows.map(s => {
    const rate = (s.displayRate ?? s.rate ?? 0);
    const cur  = (s.currency || 'THB');
    const min  = (s.min ?? '');
    const max  = (s.max ?? '');
    const avg  = pickAvg(s);
    const desc = pickDesc(s);

    const iconHtml = s.icon
      ? `<img class="svc-icon" src="${s.icon}" alt="บริการ ${s.name || ''} SMM ราคาถูก" loading="lazy">`
      : '';

    return `
      <tr>
        <td>${s.providerServiceId || ''}</td>
        <td>${iconHtml}<span class="svc-name">${s.name || ''}</span></td>
        <td><b>${Number(rate)}</b> ${cur}</td>
        <td>${min}</td>
        <td>${max}</td>
        <td>
          <a class="btn sm" href="/orders/new?type=service&id=${s.providerServiceId}&name=${enc(s.name)}">สั่งซื้อ</a>
          <button class="btn sm ghost btn-desc"
            data-pid="${s.providerServiceId}"
            data-name="${enc(s.name)}"
            data-rate="${rate}" data-cur="${enc(cur)}"
            data-min="${min}" data-max="${max}"
            data-avg="${enc(avg)}"
            data-drip="${s.dripfeed ? 1 : 0}"`
            + ` data-refill="${s.refill ? 1 : 0}"
            data-cancel="${s.cancel ? 1 : 0}"
            data-desc="${enc(desc)}">รายละเอียด</button>
        </td>
      </tr>`;
  }).join('');

  const table = `
    <div class="table-wrap">
      <table class="table">
        ${tableHead}
        <tbody>${tableBody}</tbody>
      </table>
    </div>`;

  const cards = `
    <div class="m-cards">
      ${rows.map(s => {
        const rate = (s.displayRate ?? s.rate ?? 0);
        const cur  = (s.currency || 'THB');
        const min  = (s.min ?? 0);
        const max  = (s.max ?? 0);
        const avg  = pickAvg(s);
        const desc = pickDesc(s);

        const iconHtml = s.icon
          ? `<img class="svc-icon" src="${s.icon}" alt="บริการ ${s.name || ''} SMM ราคาถูก" loading="lazy">`
          : '';

        return `
          <div class="m-card">
            <div class="left">
              <div class="id">#${s.providerServiceId}</div>
              <div class="title">
                ${iconHtml}${s.name || ''}
              </div>
              <div class="meta">
                <div>💵 ${Number(rate)} ${cur}</div>
                <div>ช่วง: ${min}-${max}</div>
              </div>
              <div class="actions">
                <a class="btn sm" href="/orders/new?type=service&id=${s.providerServiceId}&name=${enc(s.name)}">สั่งซื้อ</a>
                <button class="btn sm ghost btn-desc"
                  data-pid="${s.providerServiceId}"
                  data-name="${enc(s.name)}"
                  data-rate="${rate}" data-cur="${enc(cur)}"
                  data-min="${min}" data-max="${max}"
                  data-avg="${enc(avg)}"
                  data-drip="${s.dripfeed ? 1 : 0}"
                  data-refill="${s.refill ? 1 : 0}"
                  data-cancel="${s.cancel ? 1 : 0}"
                  data-desc="${enc(desc)}">รายละเอียด</button>
              </div>
            </div>
          </div>`;
      }).join('')}
    </div>`;

  return table + cards;
}

/* ========= render body ของแต่ละ group แบบ lazy ========= */
function renderGroupBody(cat, rootEl) {
  const st = groupState.get(cat);
  if (!st || st.rendered) return;

  const rows = st.rows || [];
  const body = rootEl
    ? rootEl.querySelector('.body')
    : document.querySelector(`.group[data-cat="${enc(cat)}"] .body`);

  if (!body) return;

  body.innerHTML = '';

  let i = 0;
  (function buildChunk() {
    const end = Math.min(i + ROW_CHUNK, rows.length);
    const slice = rows.slice(i, end);

    const wrap = document.createElement('div');
    wrap.innerHTML = buildTableAndCards(slice);
    body.appendChild(wrap);

    i = end;
    if (i < rows.length) {
      schedule(buildChunk);
    } else {
      st.rendered = true;
    }
  })();
}

/* ========= modal ========= */
function openServiceModalFromEl(btn) {
  const d = btn.dataset;
  $('#mTitle').textContent = dec(d.name || '') || 'รายละเอียดบริการ';

  const bits = [];
  const avg  = dec(d.avg || '');
  const rate = Number(d.rate || 0);
  const cur  = d.cur ? dec(d.cur) : 'THB';
  const min  = d.min ?? '';
  const max  = d.max ?? '';

  if (avg) bits.push(`⏱ เฉลี่ย: ${avg}`);
  if (d.drip === '1')   bits.push('💧 Dripfeed');
  if (d.refill === '1') bits.push('♻️ เติมคืนได้');
  if (d.cancel === '1') bits.push('✖️ ยกเลิกได้');
  bits.push(`💵 เรท: ${fmt(rate)} ${cur}/1,000`);
  if (min !== '' && max !== '') bits.push(`ช่วง: ${min}-${max}`);

  $('#mMeta').innerHTML = bits.map(t => `<span class="tag">${t}</span>`).join(' ');

  let desc = dec(d.desc || '');
  if (!safe(desc)) {
    const svc = resolveService(d.pid);
    if (svc) desc = pickDesc(svc);
  }
  $('#mBody').innerHTML = safe(desc) ? linkify(br(desc)) : '—';
  $('#svcModal').classList.remove('hidden');
}

/* ========= events ========= */
function wireEvents() {
  if (EVENTS_WIRED) return;
  EVENTS_WIRED = true;

  // platform switch
  $('#platformGrid').addEventListener('click', e => {
    const card = e.target.closest('.platform-card');
    if (!card) return;
    CURRENT_PLATFORM = card.dataset.platform || null;
    $$('.platform-card').forEach(el => el.classList.remove('active'));
    card.classList.add('active');
    currentChipId = "";
    if (Array.isArray(window.__SERVICES__) && window.__SERVICES__.length) {
      renderChips();
      renderServicesList();
    }
  });

  // chips
  $('#chipBar').addEventListener('click', e => {
    const b = e.target.closest('.chip');
    if (!b) return;
    currentChipId = b.dataset.chip;
    renderChips();
    renderServicesList();
  });

  // search
  $('#searchAll').addEventListener('input', debounce(e => {
    SEARCH = (e.target.value || '').trim();
    renderServicesList();
  }, 300));

  // toggle group + modal
  document.addEventListener('click', e => {
    const head = e.target.closest('.group .head');
    if (head) {
      const root = head.closest('.group');
      if (!root) return;

      const body = root.querySelector('.body');
      const nowOpen = !root.classList.contains('open');

      root.classList.toggle('open', nowOpen);
      head.setAttribute('aria-expanded', nowOpen ? 'true' : 'false');

      if (body) {
        body.style.display = nowOpen ? 'block' : 'none';
      }

      if (nowOpen) {
        const cat = dec(root.dataset.cat || '');
        renderGroupBody(cat, root);
      }
      return;
    }

    const btnDesc = e.target.closest('.btn-desc');
    if (btnDesc) {
      openServiceModalFromEl(btnDesc);
    }
  });

  // modal close
  $('#mClose').onclick = () => $('#svcModal').classList.add('hidden');
  $('#svcModal').addEventListener('click', e => {
    if (e.target.dataset.close === '1') $('#svcModal').classList.add('hidden');
  });
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') $('#svcModal').classList.add('hidden');
  });
}

/* ========= boot ========= */
function bootWithData(){
  // ถ้ามี platformKey=discord ให้ default เข้า discord ไม่งั้นเป็น all
  if (!CURRENT_PLATFORM) {
    const hasDiscord = Array.isArray(window.__SERVICES__)
      && window.__SERVICES__.some(s => s.platformKey === 'discord');
    CURRENT_PLATFORM = hasDiscord ? 'discord' : null;
  }

  renderPlatforms();
  renderChips();
  renderServicesList();
  wireEvents();
}

(async function init(){
  // แสดง platform static ทันที
  renderPlatforms();
  wireEvents();

  if (Array.isArray(window.__SERVICES__) && window.__SERVICES__.length){
    // เผื่อกรณีที่ server ยังไม่ได้ map platformKey มาก่อน
    assignPlatformsToServices();
    bootWithData();
    return;
  }

  const container = document.getElementById('servicesContainer');
  if (container){
    container.innerHTML = `
      <div class="loading-wrap">
        <img src="/static/assets/status/loading.gif" class="loading-gif" alt="loading">
        <span class="muted">กำลังโหลดรายการบริการทั้งหมด</span>
      </div>
    `;
  }

  try {
    const resp = await fetch('/services/data', { headers:{ 'Accept':'application/json' } });
    if (!resp.ok) throw new Error('HTTP ' + resp.status);
    const payload = await resp.json();

    const list = Array.isArray(payload.services) ? payload.services : [];
    window.__SERVICES__ = list;

    // อัปเดต map PID + platformKey
    for (const it of list) {
      const pid = it?.providerServiceId;
      if (pid !== undefined && pid !== null) SVC_BY_PID[String(pid)] = it;
    }
    assignPlatformsToServices();

    CURRENT_PLATFORM = payload.defaultPlatform || CURRENT_PLATFORM || null;

    bootWithData();
  } catch (err){
    console.error('โหลด /services/data ล้มเหลว', err);
    if (container){
      container.innerHTML = '<div class="muted">โหลดรายการบริการไม่สำเร็จ กรุณาลองรีเฟรชหน้าอีกครั้ง</div>';
    }
  }
})();
</script>
