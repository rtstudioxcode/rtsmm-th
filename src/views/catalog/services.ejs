<% const PAGE_TITLE = title || "บริการทั้งหมด"; %>
<section class="page-head">
  <div class="page-title">
    <h1><%= PAGE_TITLE %></h1>
    <small class="muted">หน้าหลัก → <%= PAGE_TITLE %></small>
  </div>
</section>

<!-- ───────────────────────── Platform Selector ───────────────────────── -->
<section class="card">
  <h3 class="title">เลือกแพลตฟอร์ม</h3>
  <div id="platformGrid" class="platform-grid"></div>
</section>

<!-- ───────────────────────── Filters (chips) ───────────────────────── -->
<section class="card" id="filtersBar">
  <div class="row" style="align-items:center; gap:12px;">
    <div class="col grow">
      <input id="searchAll" type="search" placeholder="ค้นหาได้ทั้ง ID / ชื่อบริการ" />
    </div>
  </div>

  <!-- ชิปภาษาไทย -->
  <div id="chipBar" class="chip-bar" style="margin-top:10px;"></div>
</section>

<!-- ───────────────────────── Services List ───────────────────────── -->
<section class="card">
  <h3 class="title" id="listTitle">บริการทั้งหมด</h3>
  <div id="servicesContainer"></div>
</section>

<style>
  /* -------- Platform grid: desktop = แบบการ์ดมีชื่อ, mobile = ไอคอนอย่างเดียว -------- */
  .platform-grid {
    display:grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap:12px;
  }
  .platform-card {
    display:flex; align-items:center; gap:10px;
    background: var(--card, #1c1f24);
    border:1px solid var(--border, #2a2f36);
    border-radius:16px; padding:12px 14px; cursor:pointer;
    transition: transform .12s ease, box-shadow .12s ease, border-color .12s ease;
  }
  .platform-card:hover { transform: translateY(-1px); box-shadow:0 6px 20px rgba(0,0,0,.25); }
  .platform-card.active { border-color: var(--accent, #3bd); box-shadow: 0 0 0 2px rgba(80,200,255,.15) inset; }
  .platform-card img { width:28px; height:28px; border-radius:8px; }
  .platform-card .name { font-weight:600; }

  /* mobile: แสดงแบบไอคอนสี่เหลี่ยมมน (neumorphism เบาๆ) */
  @media (max-width: 720px){
    .platform-grid{ grid-template-columns: repeat(4, 1fr); gap:10px; }
    .platform-card{ flex-direction:column; align-items:center; padding:12px; gap:8px; border-radius:18px; }
    .platform-card img{ width:36px; height:36px; border-radius:10px; }
    .platform-card .name,.platform-card .muted{ display:none; } /* โชว์แต่ไอคอน */
  }

  /* -------- Filters -------- */
  #searchAll { width:100%; padding:10px 12px; border-radius:12px; border:1px solid var(--border,#2a2f36); background:var(--card,#1c1f24); color:var(--text,#fff); }
  .chip-bar { display:flex; flex-wrap:wrap; gap:8px; margin-top:10px; }
  .chip { border:1px solid var(--border,#2a2f36); background:var(--card,#1c1f24);
          border-radius:999px; padding:6px 10px; font-size:13px; cursor:pointer; }
  .chip.active { border-color: var(--accent,#39c); box-shadow:0 0 0 2px rgba(80,200,255,.12) inset; }
  .chip.disabled { opacity:.5; cursor:not-allowed; }

  /* -------- Group container (หมวด provider) -------- */
  .group {
    margin-bottom:16px; border:1px solid var(--border,#2a2f36); border-radius:16px; overflow:hidden;
    background:linear-gradient(180deg, rgba(255,255,255,.02), rgba(255,255,255,0));
  }
  .group .head {
    display:flex; justify-content:space-between; align-items:center; padding:12px 14px; cursor:pointer;
    background:rgba(56, 77, 78, 0.349);
  }
  .group .head h4 { margin:0; font-size:15px; }
  .group .body { padding:10px 10px 12px; display:none; }
  .group.open .body { display:block; }
  .group .meta { font-size:12px; opacity:.8; }

  /* -------- Desktop table (คงไว้สำหรับจอใหญ่) -------- */
  .table { width:100%; border-collapse: collapse; font-size:14px; }
  .table thead th { text-align:left; font-weight:600; padding:10px; border-bottom:1px solid var(--border,#2a2f36);
                    position:sticky; top:0; background:var(--card,#1c1f24); }
  .table tbody td { padding:10px; border-bottom:1px dashed rgba(255,255,255,.07); }

  /* -------- Mobile card list -------- */
  .m-cards{ display:none; gap:10px; }
  .m-card{
    display:flex; justify-content:space-between; align-items:flex-start; gap:8px;
    border:1px dashed rgba(255,255,255,.08); border-radius:12px; padding:10px 12px;
    background:rgba(255,255,255,.02);
  }
  .m-card .title{ font-weight:600; font-size:14px; line-height:1.4; }
  .m-card .meta{ font-size:12px; opacity:.85; display:flex; gap:10px; margin-top:4px; flex-wrap:wrap; }
  .m-card .actions{ display:flex; gap:6px; margin-top:6px; }
  .m-card .id{ font-weight:700; opacity:.9; font-size:12px; }

  /* แปลงเป็น mobile-first: ซ่อน table แล้วใช้ card */
  @media (max-width: 720px){
    .table-wrap{ display:none; }
    .m-cards{ display:grid; }
  }

  /* -------- Modal -------- */
  .modal.hidden { display:none; }
  .modal { position:fixed; inset:0; z-index:60; }
  .modal .overlay{ position:absolute; inset:0; background:rgba(0,0,0,.55); }
  .modal .dialog{ position:relative; margin:6vh auto 0; max-width:760px; width:calc(100% - 24px);
    background:var(--card,#1c1f24); border:1px solid var(--border,#2a2f36);
    border-radius:14px; box-shadow:0 18px 60px rgba(0,0,0,.4); padding:16px 16px 18px; }
  .modal .hdr{ display:flex; justify-content:space-between; align-items:center; gap:8px; }
  .modal .title{ font-weight:700; font-size:16px; }
  .modal .icon.close{ border:0; background:transparent; font-size:22px; color:var(--text,#fff); cursor:pointer; }
  .modal .meta{ font-size:13px; opacity:.85; margin-top:6px; display:flex; flex-wrap:wrap; gap:8px; }
  .modal .meta .tag{ background:rgba(255,255,255,.08); padding:3px 8px; border-radius:999px; }
  .modal .sep{ border:0; border-top:1px solid var(--border,#2a2f36); margin:12px 0; }
  .modal .body{
      font-size:14px; line-height:1.6; word-break:break-word;
      white-space:pre-wrap;            /* เคารพ \n จาก description */
      max-height:60vh; overflow:auto;  /* เลื่อนดูได้ถ้ายาว */
    }
  .modal .body a{ text-decoration:underline; }
</style>

<!-- Modal: รายละเอียดบริการ -->
<div id="svcModal" class="modal hidden">
  <div class="overlay" data-close="1"></div>
  <div class="dialog" role="dialog" aria-modal="true" aria-labelledby="mTitle">
    <div class="hdr">
      <div class="title" id="mTitle">รายละเอียดบริการ</div>
      <button class="icon close" id="mClose" aria-label="ปิด">×</button>
    </div>
    <div class="meta" id="mMeta"></div>
    <hr class="sep">
    <div class="body" id="mBody">—</div>
  </div>
</div>

<script>
/* =============== Data from server =============== */
window.__SERVICES__ = <%- JSON.stringify(servicesFlat || []) %>;

/* =============== Helpers =============== */
const $ = s => document.querySelector(s);
const $$ = (s, r=document) => Array.from(r.querySelectorAll(s));
const uniq = a => [...new Set(a)];
const safe = s => String(s ?? '').trim();
const br = s => String(s||'').replace(/\r?\n/g,'<br>');
const linkify = s => String(s||'').replace(/https?:\/\/\S+/g,m=>`<a href="${m}" target="_blank" rel="noopener">${m}</a>`);
const fmt = n => Number(n||0).toLocaleString(undefined,{maximumFractionDigits:4});
const enc = s => encodeURIComponent(String(s ?? ''));
const dec = s => decodeURIComponent(String(s ?? ''));

/* micro utils */
const debounce = (fn, ms=250) => { let t; return (...a)=>{ clearTimeout(t); t=setTimeout(()=>fn(...a),ms); }; };
const schedule = (cb)=> (window.requestIdleCallback ? requestIdleCallback(cb,{timeout:120}) : requestAnimationFrame(cb));

/* =============== State =============== */
let CURRENT_PLATFORM = null;
let SEARCH = '';
let currentChipId = "";

/* ========= platform icons ========= */
const PLATFORM_ICON_URLS = {
  tiktok:"/static/assets/platform/tiktok.png",
  facebook:"/static/assets/platform/facebook.png",
  youtube:"/static/assets/platform/youtube.png",
  instagram:"/static/assets/platform/ig.png",
  threads:"/static/assets/platform/threads.png",
  twitter:"/static/assets/platform/twitter.png",
  x:"/static/assets/platform/x.png",
  line:"/static/assets/platform/line.png",
  telegram:"/static/assets/platform/telegram.png",
  discord:"/static/assets/platform/discord.png",
  twitch:"/static/assets/platform/twitch.png",
  spotify:"/static/assets/platform/spotify.png",
  kick:"/static/assets/platform/kick.png",
  premium:"/static/assets/platform/premium.png",
  seo:"/static/assets/platform/seo.png",
  traffic:"/static/assets/platform/traffic.png",
  thailand:"/static/assets/platform/thailand.png",
  shopee:"/static/assets/platform/shopee.png"
};
function pickIconUrl(name=''){
  const s = String(name).toLowerCase();
  if (s.includes('tiktok')) return PLATFORM_ICON_URLS.tiktok;
  if (s.includes('facebook')) return PLATFORM_ICON_URLS.facebook;
  if (s.includes('youtube') || s.includes('youtub')) return PLATFORM_ICON_URLS.youtube;
  if (s.includes('instagram') || s.includes('ig')) return PLATFORM_ICON_URLS.instagram;
  if (s.includes('thread')) return PLATFORM_ICON_URLS.threads;
  if (s.includes('twitter') || s === 'x' || s.includes(' x ')) return PLATFORM_ICON_URLS.twitter;
  if (s.includes('line')) return PLATFORM_ICON_URLS.line;
  if (s.includes('telegram')) return PLATFORM_ICON_URLS.telegram;
  if (s.includes('discord')) return PLATFORM_ICON_URLS.discord;
  if (s.includes('twitch')) return PLATFORM_ICON_URLS.twitch;
  if (s.includes('spotify')) return PLATFORM_ICON_URLS.spotify;
  if (s.includes('kick')) return PLATFORM_ICON_URLS.kick;
  if (s.includes('พรีเมีย') || s.includes('premium')) return PLATFORM_ICON_URLS.premium;
  if (s.includes('seo')) return PLATFORM_ICON_URLS.seo;
  if (s.includes('traffic') || s.includes('เพิ่มคนเข้าเว็บ')) return PLATFORM_ICON_URLS.traffic;
  if (s.includes('ไทย') || s.includes('thailand')) return PLATFORM_ICON_URLS.thailand;
  if (s.includes('shopee') || s.includes('ช้อป')) return PLATFORM_ICON_URLS.shopee;
  return PLATFORM_ICON_URLS.seo;
}

/* ========= chips ========= */
const CHIP_DEFS = [
  {id:"",label:"ทั้งหมด",kw:[]},
  {id:"views",label:"วิว",kw:["view","views","watch","play","ชม","วิว"]},
  {id:"likes",label:"ไลก์",kw:["like","likes","heart","react","reactions","ถูกใจ","ไลก์"]},
  {id:"members",label:"สมาชิก/ผู้ติดตาม",kw:["follow","follower","followers","subscriber","subscribers","subs","ติดตาม","ผู้ติดตาม","สมาชิก","members"]},
  {id:"comments",label:"คอมเมนต์",kw:["comment","comments","คอมเมน"]},
  {id:"shares",label:"แชร์",kw:["share","shares","รีโพสต์","repost","retweet","แชร์"]},
  {id:"traffic",label:"คลิก/ทราฟฟิก",kw:["link click","click","traffic","คลิก","ทราฟฟิก"]},
  {id:"shorts_reels",label:"Shorts/Reels/Live",kw:["short","shorts","reel","reels","live","สตรีม","ไลฟ์"]},
  {id:"general",label:"ทั่วไป",kw:["general","รวม","รวมบริการ","all-in-one"]},
];
function itemMatchesChip(item, chip){
  if (!chip || chip.id==="") return true;
  const s = `${item.categoryName||''} ${item.name||''}`.toLowerCase();
  return chip.kw.some(k => s.includes(k.toLowerCase()));
}

/* ========= platform grid ========= */
function renderPlatforms(){
  const root = $('#platformGrid');
  const platforms = uniq(window.__SERVICES__.map(s=>s.platform).filter(Boolean)).sort();
  const html = [
    `<div class="platform-card${CURRENT_PLATFORM===null?' active':''}" data-platform="">
      <img src="${pickIconUrl('All')}" alt="All"/>
      <div><div class="name">ทั้งหมด</div><div class="muted">แสดงทุกแพลตฟอร์ม</div></div>
    </div>`
  ].concat(platforms.map(p => `
    <div class="platform-card${CURRENT_PLATFORM===p?' active':''}" data-platform="${p}">
      <img src="${pickIconUrl(p)}" alt="${p}"/>
      <div><div class="name">${p}</div><div class="muted">${window.__SERVICES__.filter(s=>s.platform===p).length} บริการ</div></div>
    </div>`));
  root.innerHTML = html.join('');
}

/* ========= chips render ========= */
function computeChipCounts(){
  const base = window.__SERVICES__.filter(s=>!CURRENT_PLATFORM || s.platform===CURRENT_PLATFORM);
  return CHIP_DEFS.map(ch=>{
    if (ch.id==="") return {...ch,count:base.length};
    return {...ch,count: base.filter(x=>itemMatchesChip(x,ch)).length};
  }).filter(ch=>ch.id==="" || ch.count>0);
}
function renderChips(){
  $('#chipBar').innerHTML = computeChipCounts().map(ch => `
    <button type="button" class="chip ${currentChipId===ch.id?'active':''}" data-chip="${ch.id}">
      ${ch.label}
    </button>`).join('');
}

/* ========= service helpers ========= */
const SVC_BY_PID = Object.create(null);
window.__SERVICES__.forEach(it=>{
  const pid = it?.providerServiceId;
  if (pid!==undefined && pid!==null) SVC_BY_PID[String(pid)] = it;
});
const pickDesc = svc => (svc?.description || svc?.desc || svc?.details_description || svc?.providerDescription || '');
const pickAvg  = svc => (svc?.average_delivery || svc?.avg_delivery || svc?.averageDelivery || '');
function resolveService(pid){
  const p = String(pid);
  const direct = SVC_BY_PID[p];
  if (direct && safe(pickDesc(direct))) return direct;
  const hit = window.__SERVICES__.find(x => String(x.providerServiceId)===p && safe(pickDesc(x)));
  return hit || direct || null;
}

/* ========= filter ========= */
function computeFiltered(){
  const chip = CHIP_DEFS.find(c=>c.id===currentChipId) || CHIP_DEFS[0];
  let list = window.__SERVICES__;
  if (CURRENT_PLATFORM) list = list.filter(s=>s.platform===CURRENT_PLATFORM);
  list = list.filter(it => itemMatchesChip(it, chip));
  if (SEARCH){
    const q = SEARCH.toLowerCase();
    list = list.filter(s =>
      String(s.providerServiceId||'').toLowerCase().includes(q) ||
      safe(s.name).toLowerCase().includes(q) ||
      safe(s.categoryName).toLowerCase().includes(q)
    );
  }
  return list;
}

/* ========= lazy groups (state + IO) ========= */
const groupState = new Map();               // cat -> { rows, rendered }
let io;                                     // IntersectionObserver
const GROUP_BATCH = 6;     // จำนวนกรุ๊ปที่จะ “สร้างหัวกลุ่ม” ต่อหนึ่งชุด
const PRELOAD_AHEAD = 2;    // สร้างล่วงหน้าอีกกี่ชุดเมื่อใกล้ถึงขอบล่าง
const ROW_CHUNK = 20;       // ขนาดก้อนเรนเดอร์แถวภายในกรุ๊ป (เดิม 60 ก็ได้)
let allCats = [];           // รายการชื่อกรุ๊ปทั้งหมด (เรียงแล้ว)
let nextGroupIndex = 0;     // ชี้ว่ากำลังจะเติมกรุ๊ปจาก index ไหน
let groupIO = null;         // observer สำหรับเปิดกรุ๊ปแล้วเรนเดอร์ข้างใน
let moreIO = null;          // observer สำหรับโหลด batch ถัดไปเมื่อเลื่อนลง

function appendNextGroupBatch(){
  const container = $('#servicesContainer');
  if (nextGroupIndex >= allCats.length) return; // หมดแล้ว

  const end = Math.min(allCats.length, nextGroupIndex + GROUP_BATCH);
  const frag = document.createDocumentFragment();

  for (let i = nextGroupIndex; i < end; i++){
    const cat = allCats[i];
    const rows = groupState.get(cat)?.rows || [];
    const wrap = document.createElement('div');
    wrap.className = 'group';
    wrap.dataset.cat = enc(cat);
    wrap.innerHTML = `
      <div class="head" role="button" tabindex="0">
        <h4>${cat}</h4>
        <div class="meta"><span class="badge">${rows.length} รายการ</span></div>
      </div>
      <div class="body"><div class="placeholder muted">เลื่อนถึงฉันแล้วค่อยโหลด…</div></div>
    `;
    frag.appendChild(wrap);
  }

  // ลบ sentinel เก่าถ้ามี แล้วใส่ batch ใหม่ + sentinel ใหม่
  const oldSentinel = container.querySelector('.more-sentinel');
  if (oldSentinel) oldSentinel.remove();

  container.appendChild(frag);

  // สังเกตทุกกรุ๊ปใหม่ให้เรนเดอร์ภายในเมื่อถึง viewport
  $$('#servicesContainer .group').slice(-GROUP_BATCH).forEach(g => groupIO.observe(g));

  // เพิ่ม sentinel ท้ายสุดเพื่อกระตุ้นโหลด batch ต่อไปตอนเลื่อนใกล้ถึง
  if (end < allCats.length){
    const sentinel = document.createElement('div');
    sentinel.className = 'more-sentinel';
    sentinel.style.cssText = 'height:1px;opacity:0;';
    sentinel.dataset.idx = String(end);   // จำตำแหน่ง batch ล่าสุด
    container.appendChild(sentinel);
    moreIO.observe(sentinel);
  }

  nextGroupIndex = end;
}

function renderServicesList(){
  const container = $('#servicesContainer');
  const list = computeFiltered();
  $('#listTitle').textContent = CURRENT_PLATFORM ? `บริการทั้งหมดใน ${CURRENT_PLATFORM}` : 'บริการทั้งหมด';

  const byProvCat = list.reduce((m,s)=>{
    (m[s.providerCategoryName||s.categoryName||'ทั่วไป'] ??= []).push(s); return m;
  },{});

  // สร้างเฉพาะ “หัวกลุ่ม + placeholder” ให้ปิดไว้ก่อนทุกกลุ่ม
  const frag = document.createDocumentFragment();
  groupState.clear();

  Object.keys(byProvCat).sort().forEach(cat=>{
    groupState.set(cat, { rows: byProvCat[cat], rendered:false });

    const wrap = document.createElement('div');
    wrap.className = 'group';                 // ไม่เพิ่ม .open → ซ่อนไว้
    wrap.dataset.cat = enc(cat);
    wrap.innerHTML = `
      <div class="head" role="button" tabindex="0" aria-expanded="false">
        <h4>${cat}</h4>
        <div class="meta"><span class="badge">${byProvCat[cat].length} รายการ</span></div>
      </div>
      <div class="body"><div class="placeholder muted">กดด้านบนเพื่อแสดงรายการ…</div></div>
    `;
    frag.appendChild(wrap);
  });

  container.innerHTML = '';
  container.appendChild(frag);
}

