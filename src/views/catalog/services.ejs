<% const PAGE_TITLE = title || "บริการทั้งหมด"; %>
<section class="page-head">
  <div class="page-title">
    <h1><%= PAGE_TITLE %></h1>
    <small class="muted">หน้าหลัก → <%= PAGE_TITLE %></small>
  </div>
</section>

<!-- ───────────────────────── Platform Selector ───────────────────────── -->
<section class="card">
  <h3 class="title">เลือกแพลตฟอร์ม</h3>
  <div id="platformGrid" class="platform-grid"></div>
</section>

<!-- ───────────────────────── Filters (chips) ───────────────────────── -->
<section class="card" id="filtersBar">
  <div class="row" style="align-items:center; gap:12px;">
    <div class="col grow">
      <input id="searchAll" type="search" placeholder="ค้นหาได้ทั้ง ID / ชื่อบริการ" />
    </div>
  </div>

  <!-- ชิปภาษาไทย -->
  <div id="chipBar" class="chip-bar" style="margin-top:10px;"></div>
</section>

<!-- ───────────────────────── Services List ───────────────────────── -->
<section class="card">
  <h3 class="title" id="listTitle">บริการทั้งหมด</h3>
  <div id="servicesContainer"></div>
</section>

<style>
  /* -------- Platform grid: desktop = แบบการ์ดมีชื่อ, mobile = ไอคอนอย่างเดียว -------- */
  .platform-grid {
    display:grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap:12px;
  }
  .platform-card {
    display:flex; align-items:center; gap:10px;
    background: var(--card, #1c1f24);
    border:1px solid var(--border, #2a2f36);
    border-radius:16px; padding:12px 14px; cursor:pointer;
    transition: transform .12s ease, box-shadow .12s ease, border-color .12s ease;
  }
  .platform-card:hover { transform: translateY(-1px); box-shadow:0 6px 20px rgba(0,0,0,.25); }
  .platform-card.active { border-color: var(--accent, #3bd); box-shadow: 0 0 0 2px rgba(80,200,255,.15) inset; }
  .platform-card img { width:28px; height:28px; border-radius:8px; }
  .platform-card .name { font-weight:600; }

  /* mobile: แสดงแบบไอคอนสี่เหลี่ยมมน (แถวละ 4 อัน) */
  @media (max-width: 720px){
    .platform-grid{ grid-template-columns: repeat(4, 1fr); gap:10px; }
    .platform-card{ flex-direction:column; align-items:center; padding:12px; gap:8px; border-radius:18px; }
    .platform-card img{ width:36px; height:36px; border-radius:10px; }
    .platform-card .name,.platform-card .muted{ display:none; } /* โชว์แต่ไอคอน */
  }

  /* -------- Filters -------- */
  #searchAll { width:100%; padding:10px 12px; border-radius:12px; border:1px solid var(--border,#2a2f36); background:var(--card,#1c1f24); color:var(--text,#fff); }
  .chip-bar { display:flex; flex-wrap:wrap; gap:8px; margin-top:10px; }
  .chip { border:1px solid var(--border,#2a2f36); background:var(--card,#1c1f24);
          border-radius:999px; padding:6px 10px; font-size:13px; cursor:pointer; }
  .chip.active { border-color: var(--accent,#39c); box-shadow:0 0 0 2px rgba(80,200,255,.12) inset; }
  .chip.disabled { opacity:.5; cursor:not-allowed; }

  /* -------- Group container (หมวด provider) -------- */
  .group {
    margin-bottom:16px; border:1px solid var(--border,#2a2f36); border-radius:16px; overflow:hidden;
    background:linear-gradient(180deg, rgba(255,255,255,.02), rgba(255,255,255,0));
  }
  .group .head {
    display:flex; justify-content:space-between; align-items:center; padding:12px 14px; cursor:pointer;
    background:rgba(56, 77, 78, 0.349);
  }
  .group .head h4 { margin:0; font-size:15px; }
  .group .body {
    padding:10px 10px 12px;
    display:none !important;
  }
  .group.open .body {
    display:block !important;
  }
  .group .meta { font-size:12px; opacity:.8; }

  /* -------- Desktop table (คงไว้สำหรับจอใหญ่) -------- */
  .table { width:100%; border-collapse: collapse; font-size:14px; }
  .table thead th { text-align:left; font-weight:600; padding:10px; border-bottom:1px solid var(--border,#2a2f36);
                    position:sticky; top:0; background:var(--card,#1c1f24); }
  .table tbody td { padding:10px; border-bottom:1px dashed rgba(255,255,255,.07); }

  /* -------- Mobile card list -------- */
  .m-cards{ display:none; gap:10px; }
  .m-card{
    display:flex; justify-content:space-between; align-items:flex-start; gap:8px;
    border:1px dashed rgba(255,255,255,.08); border-radius:12px; padding:10px 12px;
    background:rgba(255,255,255,.02);
  }
  .m-card .title{ font-weight:600; font-size:14px; line-height:1.4; }
  .m-card .meta{ font-size:12px; opacity:.85; display:flex; gap:10px; margin-top:4px; flex-wrap:wrap; }
  .m-card .actions{ display:flex; gap:6px; margin-top:6px; }
  .m-card .id{ font-weight:700; opacity:.9; font-size:12px; }

  /* แปลงเป็น mobile-first: ซ่อน table แล้วใช้ card */
  @media (max-width: 720px){
    .table-wrap{ display:none; }
    .m-cards{ display:grid; }
  }

  /* -------- Modal -------- */
  .modal.hidden { display:none; }
  .modal { position:fixed; inset:0; z-index:60; }
  .modal .overlay{ position:absolute; inset:0; background:rgba(0,0,0,.55); }
  .modal .dialog{ position:relative; margin:6vh auto 0; max-width:760px; width:calc(100% - 24px);
    background:var(--card,#1c1f24); border:1px solid var(--border,#2a2f36);
    border-radius:14px; box-shadow:0 18px 60px rgba(0,0,0,.4); padding:16px 16px 18px; }
  .modal .hdr{ display:flex; justify-content:space-between; align-items:center; gap:8px; }
  .modal .title{ font-weight:700; font-size:16px; }
  .modal .icon.close{ border:0; background:transparent; font-size:22px; color:var(--text,#fff); cursor:pointer; }
  .modal .meta{ font-size:13px; opacity:.85; margin-top:6px; display:flex; flex-wrap:wrap; gap:8px; }
  .modal .meta .tag{ background:rgba(255,255,255,.08); padding:3px 8px; border-radius:999px; }
  .modal .sep{ border:0; border-top:1px solid var(--border,#2a2f36); margin:12px 0; }
  .modal .body{
      font-size:14px; line-height:1.6; word-break:break-word;
      white-space:pre-wrap;            /* เคารพ \n จาก description */
      max-height:60vh; overflow:auto;  /* เลื่อนดูได้ถ้ายาว */
    }
  .modal .body a{ text-decoration:underline; }
  .svc-icon{
    width:22px;
    height:22px;
    border-radius:6px;
    object-fit:cover;
    margin-right:6px;
    vertical-align:middle;
  }
  .svc-name{
    vertical-align:middle;
  }
  .loading-wrap {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 16px;
  }

  .loading-gif {
    width: 24px;
    height: 24px;
  }

  .group .head {
    display:flex;
    align-items:center;
    gap:10px;
    padding:14px 16px;
    cursor:pointer;
  }

  .group-ico {
    width: 22px;
    height: 22px;
    object-fit: contain;
    vertical-align: middle;
    margin-right: 6px;
  }
</style>

<!-- Modal: รายละเอียดบริการ -->
<div id="svcModal" class="modal hidden">
  <div class="overlay" data-close="1"></div>
  <div class="dialog" role="dialog" aria-modal="true" aria-labelledby="mTitle">
    <div class="hdr">
      <div class="title" id="mTitle">รายละเอียดบริการ</div>
      <button class="icon close" id="mClose" aria-label="ปิด">×</button>
    </div>
    <div class="meta" id="mMeta"></div>
    <hr class="sep">
    <div class="body" id="mBody">—</div>
  </div>
</div>

