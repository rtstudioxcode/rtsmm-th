/* ========= map platform จากชื่อบริการ ========= */
function detectPlatformKeyForService(svc) {
  const text = (
    ' ' +
    safe(svc.providerCategoryName || '') + ' ' +
    safe(svc.categoryName || '') + ' ' +
    safe(svc.name || '') +
    ' '
  ).toLowerCase();

  // วนตามลำดับใน PLATFORM_MAP (premium, thailand มาก่อน)
  for (const m of PLATFORM_MAP) {
    const patterns = (m.match || []).map(p => p.toLowerCase());
    if (!patterns.length) continue;
    if (patterns.some(p => text.includes(p))) {
      return m.key;
    }
  }
  return 'other';
}

function assignPlatformsToServices() {
  if (!Array.isArray(window.__SERVICES__)) return;
  for (const svc of window.__SERVICES__) {
    svc.platformKey = detectPlatformKeyForService(svc);
  }
}

