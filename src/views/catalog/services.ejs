function onGroupIntersect(entries){
  for (const en of entries){
    if (!en.isIntersecting) continue;
    const cat = dec(en.target.dataset.cat || '');
    // เปิดกรุ๊ปอัตโนมัติเมื่อถึง viewport และเรนเดอร์ภายในแบบ chunk
    en.target.classList.add('open');
    renderGroupBody(cat);
    groupIO.unobserve(en.target); // เรนเดอร์ครั้งเดียวพอ
  }
}

function onMoreIntersect(entries){
  for (const en of entries){
    if (!en.isIntersecting) continue;
    // ถึง sentinel แล้ว → เติมกรุ๊ป batch ถัดไป และเลิกดู sentinel เก่า
    moreIO.unobserve(en.target);
    appendNextGroupBatch();
  }
}

function renderGroupBody(cat){
  const st = groupState.get(cat);
  if (!st || st.rendered) return;

  const rows = st.rows;
  const body = $(`.group[data-cat="${enc(cat)}"] .body`);
  if (!body) return;
  body.innerHTML = ''; // clear placeholder

  let i = 0;
  (function build(){
    const end = Math.min(i + ROW_CHUNK, rows.length);
    const slice = rows.slice(i, end);

    const wrap = document.createElement('div');
    wrap.innerHTML = buildTableAndCards(slice);
    body.appendChild(wrap);

    i = end;
    if (i < rows.length) {
      schedule(build); // requestIdleCallback / rAF
    } else {
      st.rendered = true;
    }
  })();
}

