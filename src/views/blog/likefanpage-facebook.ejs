<%
  const pageTitle = `${article.title} | หาเงินจาก Facebook แบบยั่งยืนในปี 2025 | RTSMM-TH`;
  const pageDesc  = article.excerpt 
    || 'สรุปแผนหาเงินจาก Facebook แบบมืออาชีพ ตั้งแต่การเลือกใช้โปรไฟล์หรือเพจ การวางแผนคอนเทนต์ การเติบโตแบบ Organic ไปจนถึงการสร้างรายได้จากสปอนเซอร์ คอร์ส และโฆษณา.';
  const canonicalPath = `/blog/${article.slug || article._id || ''}`;

  // ส่งค่าให้ layout.ejs ใช้ใน <head>
  title       = pageTitle;
  description = pageDesc;
  ogTitle     = pageTitle;
  ogDesc      = pageDesc;
  ogImage     = article.image;
%>

<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": article.title,
  "description": pageDesc,
  "image": article.image,
  "author": {
    "@type": "Person",
    "name": article.author
  },
  "datePublished": article.dateISO || article.date,
  "dateModified": article.updatedAt || article.dateISO || article.date,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://rtsmm-th.com" + canonicalPath
  },
  "publisher": {
    "@type": "Organization",
    "name": "RTSSM-TH.COM",
    "logo": {
      "@type": "ImageObject",
      "url": "https://rtsmm-th.com/static/logo/icon-logo.png"
    }
  }
}, null, 2) %>
</script>

<section class="page blog-detail container" style="max-width:980px; margin:0 auto; padding:24px 16px;">
