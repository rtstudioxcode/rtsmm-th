  const pageTitle = `${article.title} | คู่มือปั๊มวิว YouTube/TikTok แบบยั่งยืน | RTSMM-TH`;
  const pageDesc  = article.excerpt 
    || 'สอนปั๊มวิวให้โตอย่างยั่งยืนบน YouTube และ TikTok ด้วยการเข้าใจอัลกอริทึม Retention, CTR, Thumbnail, Title และตารางโพสต์ที่ช่วยให้คอนเทนต์ขึ้นจริงในหน้าแนะนำ.';
  const canonicalPath = `/blog/${article.slug || article._id || ''}`;

  // ส่งให้ layout.ejs ใช้เซ็ต <title>, meta description, OG, Twitter
  title       = pageTitle;
  description = pageDesc;
  ogTitle     = pageTitle;
  ogDesc      = pageDesc;
  ogImage     = article.image;
%>

<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": article.title,
  "description": pageDesc,
  "image": article.image,
  "author": {
    "@type": "Person",
    "name": article.author
  },
  "datePublished": article.dateISO || article.date,
  "dateModified": article.updatedAt || article.dateISO || article.date,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://rtsmm-th.com" + canonicalPath
